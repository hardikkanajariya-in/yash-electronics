---
import MetaTags from '../components/seo/MetaTags.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { getCategories, getSettings } from '../services/cms';
import { translateObject, getLocalizedPath } from '../lib/translations';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  hideHeaderFooter?: boolean;
}

const { title, description, canonicalUrl, ogImage, noindex, hideHeaderFooter = false } = Astro.props;
const locale = Astro.currentLocale || 'gu';

const [rawSettings, rawCategories] = await Promise.all([getSettings(), getCategories()]);
const settings = translateObject(rawSettings, locale);
const categories = translateObject(rawCategories, locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <MetaTags
      title={title}
      description={description}
      canonicalUrl={canonicalUrl ? getLocalizedPath(canonicalUrl, locale) : undefined}
      ogImage={ogImage}
      noindex={noindex}
    />
    <OrganizationSchema settings={settings} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#171717" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then(reg => console.log('ServiceWorker registered:', reg))
            .catch(err => console.error('ServiceWorker registration failed:', err));
        });
      }
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    {!hideHeaderFooter && <Header settings={settings} categories={categories} />}
    <main class="flex-1">
      <slot />
    </main>
    {!hideHeaderFooter && <Footer settings={settings} categories={categories} />}

    {!hideHeaderFooter && (
      <a
        href={`https://wa.me/${settings.whatsapp}`}
        target="_blank"
        rel="noopener noreferrer"
        class="fixed bottom-4 right-4 z-40 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg transition-transform hover:scale-105"
        aria-label="Chat on WhatsApp"
      >
        <svg class="h-8 w-8 fill-current" viewBox="0 0 24 24">
          <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.394 9.806-9.799.002-2.618-1.01-5.078-2.856-6.927C16.378 2.03 13.932.997 12.002.997c-5.408 0-9.813 4.394-9.816 9.801-.001 1.87.526 3.69 1.523 5.253L2.7 20.8l4.037-1.059.043-.027-.133-.56zm11.233-5.062c-.295-.148-1.746-.862-2.019-.962-.272-.1-.471-.148-.669.148-.198.295-.767.962-.94 1.16-.173.199-.347.223-.642.074-.295-.148-1.246-.459-2.373-1.464-.877-.782-1.47-1.747-1.642-2.043-.173-.295-.018-.454.13-.601.134-.133.295-.347.444-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.74-.71 1.988-1.396.248-.687.248-1.277.173-1.396-.074-.12-.272-.198-.57-.347z"/>
        </svg>
      </a>
    )}

    <!-- Custom Toast Container -->
    <div id="custom-toast-container" class="fixed bottom-5 right-5 z-[100] flex flex-col gap-2 pointer-events-none"></div>

    <!-- Custom Confirmation Modal -->
    <div id="custom-confirm-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200">
      <div class="bg-white border border-neutral-200 rounded-lg max-w-sm w-full mx-4 p-5 shadow-xl scale-95 transition-transform duration-200" id="custom-confirm-content">
        <h3 class="text-base font-bold text-neutral-900 animate-fade-in" id="custom-confirm-title">Confirm Action</h3>
        <p class="text-xs text-neutral-500 mt-2 leading-relaxed" id="custom-confirm-message">Are you sure you want to proceed?</p>
        <div class="flex justify-end gap-2 mt-5">
          <button type="button" id="custom-confirm-cancel" class="rounded border border-neutral-300 px-3 py-1.5 text-xs font-semibold text-neutral-600 hover:bg-neutral-50 transition-colors focus:outline-none cursor-pointer">Cancel</button>
          <button type="button" id="custom-confirm-submit" class="rounded bg-red-600 px-4 py-1.5 text-xs font-semibold text-white hover:bg-red-700 transition-colors focus:outline-none cursor-pointer">Delete</button>
        </div>
      </div>
    </div>

    <script is:inline>
      // Premium Custom Toast Notification
      window.showToast = function (message, type = 'success') {
        const container = document.getElementById('custom-toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.className = 'flex items-center gap-2.5 px-4 py-3 rounded-lg border shadow-lg text-xs font-bold bg-white/95 backdrop-blur-md translate-y-3 opacity-0 transition-all duration-300 pointer-events-auto max-w-xs';
        
        if (type === 'success') {
          toast.className += ' border-green-200 text-green-700 bg-green-50/80';
          toast.innerHTML = `<span class="text-sm font-semibold">✓</span> <span>${message}</span>`;
        } else {
          toast.className += ' border-red-200 text-red-700 bg-red-50/80';
          toast.innerHTML = `<span class="text-sm font-semibold">⚠</span> <span>${message}</span>`;
        }

        container.appendChild(toast);

        // Animate in
        setTimeout(() => {
          toast.classList.remove('translate-y-3', 'opacity-0');
        }, 10);

        // Auto dismiss
        setTimeout(() => {
          toast.classList.add('opacity-0', 'translate-y-1');
          setTimeout(() => {
            toast.remove();
          }, 300);
        }, 3200);
      };

      // Premium Custom Confirmation Modal
      let activeConfirmCallback = null;
      window.showConfirm = function (title, message, onConfirm, submitLabel = 'Delete') {
        const modal = document.getElementById('custom-confirm-modal');
        const content = document.getElementById('custom-confirm-content');
        const titleEl = document.getElementById('custom-confirm-title');
        const msgEl = document.getElementById('custom-confirm-message');
        const submitBtn = document.getElementById('custom-confirm-submit');

        if (!modal || !content) return;

        titleEl.textContent = title;
        msgEl.textContent = message;
        submitBtn.textContent = submitLabel;
        activeConfirmCallback = onConfirm;

        // Show Modal
        modal.classList.remove('pointer-events-none');
        modal.classList.add('opacity-100');
        content.classList.remove('scale-95');
        content.classList.add('scale-100');
      };

      window.hideConfirm = function () {
        const modal = document.getElementById('custom-confirm-modal');
        const content = document.getElementById('custom-confirm-content');
        if (!modal || !content) return;

        modal.classList.add('pointer-events-none');
        modal.classList.remove('opacity-100');
        content.classList.add('scale-95');
        content.classList.remove('scale-100');
        activeConfirmCallback = null;
      };

      // Helper function to submit delete form programmatically
      window.confirmDelete = function (buttonEl, title, message) {
        const form = buttonEl.closest('form');
        if (!form) return;
        window.showConfirm(title, message, function () {
          form.submit();
        }, 'Delete');
      };

      // Bind Cancel & Submit
      document.getElementById('custom-confirm-cancel')?.addEventListener('click', window.hideConfirm);
      document.getElementById('custom-confirm-submit')?.addEventListener('click', function () {
        if (typeof activeConfirmCallback === 'function') {
          activeConfirmCallback();
        }
        window.hideConfirm();
      });

      if (!window.addToCart) {
        window.addToCart = function (product, redirect) {
          try {
            const CART_KEY = 'ye_cart';
            let cart = JSON.parse(localStorage.getItem(CART_KEY) || '[]');
            const existing = cart.find(item => item.id === product.id);
            if (existing) {
              existing.quantity += 1;
            } else {
              cart.push({
                id: product.id,
                name: product.name,
                price: product.price,
                image: product.image,
                quantity: 1
              });
            }
            localStorage.setItem(CART_KEY, JSON.stringify(cart));
            window.dispatchEvent(new CustomEvent('cart-updated'));
            
            const isEn = window.location.pathname.startsWith('/en/') || window.location.pathname === '/en';
            if (redirect) {
              window.location.href = isEn ? '/en/cart' : '/cart';
            } else {
              window.showToast(isEn ? 'Product added to cart successfully!' : 'પ્રોડક્ટ કાર્ટમાં ઉમેરવામાં આવી છે!');
            }
          } catch (e) {
            console.error('Failed to add to cart:', e);
          }
        };

        // Attach event delegation for all Add/Buy clicks
        document.addEventListener('click', function (event) {
          const btn = event.target.closest('[data-action="add-to-cart"], [data-action="buy-now"]');
          if (!btn) return;

          event.preventDefault();
          event.stopPropagation();

          const product = {
            id: btn.getAttribute('data-product-id') || '',
            name: btn.getAttribute('data-product-name') || '',
            price: Number(btn.getAttribute('data-product-price') || '0'),
            image: btn.getAttribute('data-product-image') || '',
          };

          const redirect = btn.getAttribute('data-action') === 'buy-now';
          window.addToCart(product, redirect);
        });
      }
    </script>

    <!-- PWA Install Banner (Site-wide) -->
    <div
      id="pwa-install-banner"
      class="fixed bottom-6 right-4 left-4 md:left-auto md:w-96 bg-neutral-900 border border-neutral-800 text-white rounded-xl p-4 shadow-2xl z-[100] transform translate-y-full opacity-0 transition-all duration-300 hidden"
    >
      <div class="flex items-start gap-3">
        <div class="h-12 w-12 rounded-lg bg-neutral-800 flex items-center justify-center text-white font-bold shrink-0">
          <img src="/icon-192.png" alt="App Icon" class="h-full w-full object-cover rounded-lg" />
        </div>
        <div class="flex-1">
          <h4 class="text-xs font-bold text-white">Install {settings.businessName} App</h4>
          <p class="text-[10px] text-neutral-400 mt-1 leading-relaxed">
            {locale === 'gu' 
              ? 'ઝડપી ઍક્સેસ અને બહેતર અનુભવ માટે તમારા ઉપકરણ પર અમારી એપ ઇન્સ્ટોલ કરો.'
              : 'Install our app on your device for quick access and a better mobile experience.'}
          </p>
          <div class="flex gap-2 mt-3 justify-end items-center">
            <button
              id="pwa-dismiss-never-btn"
              type="button"
              class="px-2.5 py-1.5 rounded bg-transparent hover:bg-neutral-800 text-neutral-400 hover:text-white text-[10px] font-semibold transition-all cursor-pointer mr-auto"
            >
              {locale === 'gu' ? 'ફરીથી ના પૂછશો' : "Don't ask again"}
            </button>
            <button
              id="pwa-dismiss-btn"
              type="button"
              class="px-3 py-1.5 rounded bg-neutral-800 hover:bg-neutral-700 text-neutral-300 hover:text-white text-[10px] font-bold transition-all cursor-pointer"
            >
              {locale === 'gu' ? 'પછીથી' : 'Later'}
            </button>
            <button
              id="pwa-install-btn"
              type="button"
              class="px-4 py-1.5 rounded bg-primary hover:bg-primary/95 text-white text-[10px] font-bold transition-all cursor-pointer"
            >
              {locale === 'gu' ? 'ઇન્સ્ટોલ' : 'Install'}
            </button>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        let deferredPrompt = null;
        const pwaBanner = document.getElementById('pwa-install-banner');
        const pwaInstallBtn = document.getElementById('pwa-install-btn');
        const pwaDismissBtn = document.getElementById('pwa-dismiss-btn');
        const pwaDismissNeverBtn = document.getElementById('pwa-dismiss-never-btn');
        const pwaHeaderBtn = document.getElementById('pwa-install-header-btn');
        const pwaMobileBtn = document.getElementById('pwa-install-mobile-btn');

        // Check standalone mode
        const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;
        if (isStandalone) {
          return;
        }

        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;

          // 1. Show the header top bar button (desktop only)
          if (pwaHeaderBtn) {
            pwaHeaderBtn.classList.remove('hidden');
            pwaHeaderBtn.classList.add('md:inline-flex');
          }

          // 2. Show the mobile drawer button (mobile only)
          if (pwaMobileBtn) {
            pwaMobileBtn.classList.remove('hidden');
            pwaMobileBtn.classList.add('flex');
          }

          // 3. Show the pop-up banner unless dismissed permanently
          const dismissedNever = localStorage.getItem('pwa-install-dismissed-never') === 'true';
          const dismissedSession = sessionStorage.getItem('pwa-install-dismissed-session') === 'true';

          if (!dismissedNever && !dismissedSession && pwaBanner) {
            pwaBanner.classList.remove('hidden');
            setTimeout(() => {
              pwaBanner.classList.remove('translate-y-full', 'opacity-0');
            }, 150);
          }
        });

        const triggerInstall = async () => {
          if (deferredPrompt) {
            deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            console.log('PWA installation outcome:', outcome);
            deferredPrompt = null;
          }
          hidePwaBanner();
          if (pwaHeaderBtn) {
            pwaHeaderBtn.classList.add('hidden');
            pwaHeaderBtn.classList.remove('md:inline-flex');
          }
          if (pwaMobileBtn) {
            pwaMobileBtn.classList.add('hidden');
            pwaMobileBtn.classList.remove('flex');
          }
        };

        pwaInstallBtn?.addEventListener('click', triggerInstall);
        pwaHeaderBtn?.addEventListener('click', triggerInstall);
        pwaMobileBtn?.addEventListener('click', triggerInstall);

        pwaDismissBtn?.addEventListener('click', () => {
          sessionStorage.setItem('pwa-install-dismissed-session', 'true');
          hidePwaBanner();
        });

        pwaDismissNeverBtn?.addEventListener('click', () => {
          localStorage.setItem('pwa-install-dismissed-never', 'true');
          hidePwaBanner();
        });

        function hidePwaBanner() {
          if (pwaBanner) {
            pwaBanner.classList.add('translate-y-full', 'opacity-0');
            setTimeout(() => {
              pwaBanner.classList.add('hidden');
            }, 300);
          }
        }

        window.addEventListener('appinstalled', () => {
          deferredPrompt = null;
          hidePwaBanner();
          if (pwaHeaderBtn) {
            pwaHeaderBtn.classList.add('hidden');
            pwaHeaderBtn.classList.remove('md:inline-flex');
          }
          if (pwaMobileBtn) {
            pwaMobileBtn.classList.add('hidden');
            pwaMobileBtn.classList.remove('flex');
          }
        });
      });
    </script>
  </body>
</html>
