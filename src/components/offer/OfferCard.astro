---
import type { Offer, SiteSettings } from '../../types';
import CloudinaryImage from '../common/CloudinaryImage.astro';
import { buildWhatsAppUrl, generateOfferInquiryMessage } from '../../features/whatsapp/generateMessage';
import { t } from '../../lib/translations';

interface Props {
  offer: Offer;
  settings: SiteSettings;
}

const { offer, settings } = Astro.props;
const locale = Astro.currentLocale || 'gu';

const whatsappUrl = buildWhatsAppUrl(
  settings.whatsapp,
  generateOfferInquiryMessage(offer.title, settings, locale),
);

const offerTypeLabels: Record<string, string> = {
  combo: locale === 'gu' ? 'કોમ્બો ઓફર્સ' : 'Combo Offers',
  bundle: locale === 'gu' ? 'બંડલ ઓફર્સ' : 'Build Your Bundle',
  weekly: locale === 'gu' ? 'સાપ્તાહિક ઓફર્સ' : 'Offer Of The Week',
  festival: locale === 'gu' ? 'તહેવારની ઓફરો' : 'Festival Offers',
};
---

<article class="retail-card flex flex-col overflow-hidden">
  <div class="relative aspect-[16/9] overflow-hidden bg-white">
    <!-- Blurred Background for varying aspect ratios -->
    {offer.image && (
      <div class="absolute inset-0 scale-110 blur-xl opacity-20 pointer-events-none">
        <CloudinaryImage
          publicId={offer.image}
          alt=""
          width={100}
          height={56}
          crop="fill"
          class="h-full w-full object-cover"
        />
      </div>
    )}
    <!-- Foreground Contain Image -->
    <div class="relative h-full w-full flex items-center justify-center">
      <CloudinaryImage
      publicId={offer.image}
      alt={offer.title}
      width={500}
      height={375}
      crop="fill"
      class="
        h-full
        w-full
        object-cover
        transition-transform
        duration-700
        group-hover:scale-110
      "
    />
    </div>
    <span class="absolute left-2 top-2 rounded bg-secondary px-2 py-0.5 text-xs font-semibold text-white">
      {offerTypeLabels[offer.type]}
    </span>
  </div>
  <div class="flex flex-1 flex-col p-4">
    <h3 class="font-semibold text-neutral-900">{offer.title}</h3>
    <p class="mt-1 line-clamp-2 text-sm text-neutral-600">{offer.description}</p>
    <p class="mt-2 text-sm font-bold text-accent">{offer.discountText}</p>
    <p class="mt-1 text-xs text-neutral-500">{t('offers.validUntil', locale).replace('{date}', offer.validUntil)}</p>
    <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp mt-3 w-full text-sm">
      {locale === 'gu' ? 'હમણાં પૂછપરછ કરો' : 'Enquire Now'}
    </a>
  </div>
</article>
