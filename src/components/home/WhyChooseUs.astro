---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { t } from '../../lib/translations';

const locale = Astro.currentLocale || 'gu';

const localizedTrustPoints = [
  {
    title: t('why.point1.title', locale),
    description: t('why.point1.desc', locale),
    icon: 'shield',
  },
  {
    title: t('why.point2.title', locale),
    description: t('why.point2.desc', locale),
    icon: 'badge',
  },
  {
    title: t('why.point3.title', locale),
    description: t('why.point3.desc', locale),
    icon: 'location',
  },
  {
    title: t('why.point4.title', locale),
    description: t('why.point4.desc', locale),
    icon: 'tag',
  },
  {
    title: t('why.point5.title', locale),
    description: t('why.point5.desc', locale),
    icon: 'chat',
  },
];

const icons: Record<string, string> = {
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  badge: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  location: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z',
  tag: 'M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82zM7 7h.01',
  chat: 'M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z',
};
---

<section class="section-padding bg-primary text-white">
  <Container>
    <SectionHeading
      title={t('why.title', locale)}
      subtitle={t('why.subtitle', locale)}
      align="center"
      class="[&_h2]:text-white [&_p]:text-primary-100"
    />
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {localizedTrustPoints.map((point) => (
        <div class="rounded-lg border border-primary-400/30 bg-primary-700/50 p-4 text-center">
          <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-full bg-secondary">
            <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d={icons[point.icon]} />
            </svg>
          </div>
          <h3 class="mt-3 font-semibold text-white">{point.title}</h3>
          <p class="mt-1 text-sm text-primary-100">{point.description}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
