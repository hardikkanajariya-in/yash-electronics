---
import type { Category } from '../../types';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import CategoryCard from '../category/CategoryCard.astro';
import { t } from '../../lib/translations';

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
const locale = Astro.currentLocale || 'gu';
---

<section class="section-padding bg-neutral-50">
  <Container>
    <SectionHeading
      title={locale === 'gu' ? 'કેટેગરી પ્રમાણે ખરીદો' : 'Shop By Category'}
      subtitle={locale === 'gu' ? 'કેટેગરી પ્રમાણે ઇલેક્ટ્રોનિક્સ અને ઘર વપરાશના ઉપકરણો જુઓ' : 'Browse electronics and home appliances by category'}
    />
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {categories.map((category) => (
        <CategoryCard category={category} />
      ))}
    </div>
  </Container>
</section>
