---
import type { SiteSettings } from '../../types';
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import CloudinaryImage from '../common/CloudinaryImage.astro';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
---

<section class="bg-white">
  <Container>
    <div class="grid items-center gap-6 py-8 md:grid-cols-2 md:py-10">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-secondary">Electronics & Home Appliances</p>
        <h1 class="mt-2 text-2xl font-bold leading-tight text-neutral-900 md:text-3xl lg:text-4xl">
          {settings.heroTitle}
        </h1>
        <p class="mt-3 text-base text-neutral-600 md:text-lg">
          {settings.heroSubtitle}
        </p>
        <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm text-neutral-700">
          <li class="flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            Genuine Products
          </li>
          <li class="flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            Trusted Brands
          </li>
          <li class="flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            Local Service
          </li>
        </ul>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={settings.heroCtaLink} text={settings.heroCtaText} variant="primary" />
          <Button href={`https://wa.me/${settings.whatsapp}`} text="WhatsApp Us" variant="whatsapp" external />
        </div>
      </div>
      <div class="overflow-hidden rounded-lg border border-neutral-200 shadow-card">
        <CloudinaryImage
          publicId={settings.heroImage}
          alt="Electronics and home appliances at Yash Electronics"
          width={640}
          height={480}
          class="aspect-[4/3] w-full"
          priority
          sizes="(max-width: 768px) 100vw, 50vw"
        />
      </div>
    </div>
  </Container>
</section>
