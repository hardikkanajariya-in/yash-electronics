---
import type { Offer, SiteSettings } from '../../types';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import OfferCard from '../offer/OfferCard.astro';
import Button from '../ui/Button.astro';

interface Props {
  offers: Offer[];
  settings: SiteSettings;
}

const { offers, settings } = Astro.props;
---

<section class="section-padding bg-white">
  <Container>
    <div class="flex items-end justify-between gap-4">
      <SectionHeading
        title="Special Offer Zone"
        subtitle="Combo deals, bundles and festival offers — updated regularly"
      />
      <Button href="/offers" text="All Offers" variant="outline" class="hidden shrink-0 sm:inline-flex" />
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {offers.map((offer) => (
        <OfferCard offer={offer} settings={settings} />
      ))}
    </div>
  </Container>
</section>
