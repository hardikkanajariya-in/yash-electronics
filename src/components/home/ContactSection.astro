---
import type { SiteSettings } from '../../types';
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { buildWhatsAppUrl, generateGeneralInquiryMessage } from '../../features/whatsapp/generateMessage';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const whatsappUrl = buildWhatsAppUrl(
  settings.whatsapp,
  generateGeneralInquiryMessage(settings),
);
---

<section class="section-padding bg-neutral-50">
  <Container>
    <div class="rounded-lg border border-neutral-200 bg-white p-6 md:p-8">
      <div class="grid gap-6 md:grid-cols-2">
        <div>
          <h2 class="text-xl font-bold text-neutral-900 md:text-2xl">Visit Our Store or Enquire Online</h2>
          <p class="mt-2 text-neutral-600">
            Have questions about a product, price or availability? Our team is ready to help on phone or WhatsApp.
          </p>
          <dl class="mt-4 space-y-3 text-sm">
            <div>
              <dt class="font-semibold text-neutral-800">Address</dt>
              <dd class="text-neutral-600">
                {settings.address}, {settings.city}, {settings.state} - {settings.pincode}
              </dd>
            </div>
            <div>
              <dt class="font-semibold text-neutral-800">Phone</dt>
              <dd>
                <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="text-primary hover:underline">
                  {settings.phone}
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-semibold text-neutral-800">Email</dt>
              <dd>
                <a href={`mailto:${settings.email}`} class="text-primary hover:underline">
                  {settings.email}
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-semibold text-neutral-800">Working Hours</dt>
              <dd class="text-neutral-600">{settings.workingHours}</dd>
            </div>
          </dl>
        </div>
        <div class="flex flex-col justify-center gap-4">
          <Button href={whatsappUrl} text="Chat on WhatsApp" variant="whatsapp" external class="w-full text-base py-3" />
          <Button href={`tel:${settings.phone.replace(/\s/g, '')}`} text="Call Now" variant="primary" class="w-full text-base py-3" />
          {settings.googleMapsUrl && (
            <Button href={settings.googleMapsUrl} text="Get Directions" variant="outline" external class="w-full" />
          )}
        </div>
      </div>
    </div>
  </Container>
</section>
