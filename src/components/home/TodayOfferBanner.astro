---
import type { Offer, SiteSettings } from '../../types';
import CloudinaryImage from '../common/CloudinaryImage.astro';
import { buildWhatsAppUrl, generateOfferInquiryMessage } from '../../features/whatsapp/generateMessage';
import { t } from '../../lib/translations';

interface Props {
  offer: Offer;
  settings: SiteSettings;
}

const { offer, settings } = Astro.props;
if (!offer) return null;

const locale = Astro.currentLocale || 'gu';

const whatsappUrl = buildWhatsAppUrl(
  settings.whatsapp,
  generateOfferInquiryMessage(offer.title, settings, locale),
);
---

<section class="w-full bg-neutral-900 text-white relative overflow-hidden py-8 sm:py-12 border-b border-neutral-800 shadow-md">
  <!-- Glowing background elements for rich aesthetics -->
  <div class="absolute top-0 right-0 w-80 h-80 bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-accent/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid md:grid-cols-12 gap-8 items-center">
      <!-- Info Left -->
      <div class="md:col-span-7 space-y-4">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-accent/25 border border-accent/40 px-3 py-1 text-xs font-bold text-accent tracking-wider uppercase animate-pulse">
          <span class="h-2 w-2 rounded-full bg-accent"></span>
          {locale === 'gu' ? "આજની ખાસ ધમાકેદાર ઓફર" : "TODAY'S SPECIAL OFFER"}
        </div>
        
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white tracking-tight leading-tight">
          {offer.title}
        </h1>

        <p class="text-lg sm:text-xl font-bold text-accent">
          {offer.discountText}
        </p>

        <p class="text-sm text-neutral-300 leading-relaxed max-w-xl">
          {offer.description}
        </p>

        <div class="flex items-center gap-2 text-xs text-neutral-400 font-medium">
          <span>📅</span>
          <span>{t('offers.validUntil', locale).replace('{date}', offer.validUntil)}</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <button
            class="view-offer-btn w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl bg-white text-neutral-950 px-6 py-3 text-sm font-extrabold hover:bg-neutral-100 transition-transform active:scale-95 shadow-lg cursor-pointer"
            data-title={offer.title}
            data-description={offer.description}
            data-detail-description={offer.detailDescription || offer.description}
            data-image={offer.image}
            data-detail-image={offer.detailImage || offer.image}
            data-discount={offer.discountText}
            data-valid={t('offers.validUntil', locale).replace('{date}', offer.validUntil)}
            data-whatsapp={whatsappUrl}
          >
            <span>👁️</span>
            <span>{locale === 'gu' ? 'ઓફર જુઓ' : 'View Offer'}</span>
          </button>
          
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp w-full sm:w-auto py-3 px-6 flex items-center justify-center gap-2 font-bold shadow-lg"
          >
            <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.394 9.806-9.799.002-2.618-1.01-5.078-2.856-6.927C16.378 2.03 13.932.997 12.002.997c-5.408 0-9.813 4.394-9.816 9.801-.001 1.87.526 3.69 1.523 5.253L2.7 20.8l4.037-1.059.043-.027-.133-.56zm11.233-5.062c-.295-.148-1.746-.862-2.019-.962-.272-.1-.471-.148-.669.148-.198.295-.767.962-.94 1.16-.173.199-.347.223-.642.074-.295-.148-1.246-.459-2.373-1.464-.877-.782-1.47-1.747-1.642-2.043-.173-.295-.018-.454.13-.601.134-.133.295-.347.444-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.74-.71 1.988-1.396.248-.687.248-1.277.173-1.396-.074-.12-.272-.198-.57-.347z"/>
            </svg>
            <span>{locale === 'gu' ? 'વોટ્સએપ પૂછપરછ' : 'Enquire Now'}</span>
          </a>
        </div>
      </div>

      <!-- Image Right -->
      <div class="md:col-span-5 relative group">
        <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-accent to-primary opacity-25 group-hover:opacity-40 blur transition duration-500"></div>
        <div class="relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950 aspect-[16/10] shadow-card">
          <CloudinaryImage
            publicId={offer.image}
            alt={offer.title}
            width={640}
            height={400}
            crop="fill"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            priority
          />
        </div>
      </div>
    </div>
  </div>
</section>
