---
import type { Category, SiteSettings } from '../../types';
import Container from '../ui/Container.astro';
import { t, getLocalizedPath, getAlternateLocalePath } from '../../lib/translations';

interface Props {
  settings: SiteSettings;
  categories: Category[];
}

const { settings, categories } = Astro.props;
const locale = Astro.currentLocale || 'gu';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white shadow-sm">
  <div class="bg-primary text-white">
    <Container>
      <div class="flex items-center justify-between py-1.5 text-xs md:text-sm">
        <p class="truncate">{settings.workingHours}</p>
        <div class="flex items-center gap-4">
          <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="hidden hover:underline sm:inline">
            {settings.phone}
          </a>
          <a
            href={`https://wa.me/${settings.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium hover:underline"
          >
            {t('contact.chatWhatsApp', locale)}
          </a>
          <div class="flex items-center gap-1.5 border-l border-white/20 pl-3">
            <a
              href={getAlternateLocalePath(currentPath, 'gu')}
              class:list={['hover:underline transition-colors', locale === 'gu' ? 'font-semibold text-yellow-300' : 'opacity-80']}
            >
              ગુજરાતી
            </a>
            <span class="opacity-30">|</span>
            <a
              href={getAlternateLocalePath(currentPath, 'en')}
              class:list={['hover:underline transition-colors', locale === 'en' ? 'font-semibold text-yellow-300' : 'opacity-80']}
            >
              EN
            </a>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <Container>
    <div class="flex items-center justify-between gap-4 py-3">
      <a href={getLocalizedPath('/', locale)} class="flex shrink-0 items-center gap-3">
        {settings.logoUrl ? (
          <img src={settings.logoUrl} alt={settings.businessName} class="h-11 w-11 rounded-md object-contain" />
        ) : (
          <div class="flex h-11 w-11 items-center justify-center rounded-md bg-gradient-to-br from-primary to-primary-700 text-lg font-bold text-white shadow-sm">
            YE
          </div>
        )}
        <div>
          <p class="font-display text-lg font-extrabold leading-tight tracking-tight text-primary sm:text-xl">YASH ELECTRONICS</p>
          <p class="hidden text-[11px] text-neutral-500 sm:block">{settings.tagline}</p>
        </div>
      </a>

      <form action={getLocalizedPath('/products', locale)} method="get" class="hidden flex-1 max-w-md md:block">
        <div class="relative">
          <input
            type="search"
            name="search"
            placeholder={t('search.placeholder', locale)}
            class="w-full rounded-md border border-neutral-300 py-2 pl-4 pr-10 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
          <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-neutral-400 hover:text-primary" aria-label="Search">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </div>
      </form>

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
        <a href={getLocalizedPath('/', locale)} class:list={['rounded px-3 py-2 text-sm font-medium transition-colors', currentPath === getLocalizedPath('/', locale) ? 'text-primary' : 'text-neutral-700 hover:text-primary']}>
          {t('nav.home', locale)}
        </a>
        <a href={getLocalizedPath('/products', locale)} class:list={['rounded px-3 py-2 text-sm font-medium transition-colors', currentPath.startsWith(getLocalizedPath('/products', locale)) ? 'text-primary' : 'text-neutral-700 hover:text-primary']}>
          {t('nav.products', locale)}
        </a>
        <a href={getLocalizedPath('/services', locale)} class:list={['rounded px-3 py-2 text-sm font-medium transition-colors', currentPath.startsWith(getLocalizedPath('/services', locale)) ? 'text-primary' : 'text-neutral-700 hover:text-primary']}>
          {t('nav.services', locale)}
        </a>
        <a href={getLocalizedPath('/about', locale)} class:list={['rounded px-3 py-2 text-sm font-medium transition-colors', currentPath.startsWith(getLocalizedPath('/about', locale)) ? 'text-primary' : 'text-neutral-700 hover:text-primary']}>
          {t('nav.about', locale)}
        </a>
        <a href={getLocalizedPath('/contact', locale)} class:list={['rounded px-3 py-2 text-sm font-medium transition-colors', currentPath === getLocalizedPath('/contact', locale) ? 'text-primary' : 'text-neutral-700 hover:text-primary']}>
          {t('nav.contact', locale)}
        </a>
        <a data-astro-prefetch="false" href={getLocalizedPath('/cart', locale)} class:list={['relative rounded px-3 py-2 text-sm font-medium transition-colors flex items-center gap-1', currentPath === getLocalizedPath('/cart', locale) ? 'text-primary' : 'text-neutral-700 hover:text-primary']}>
          <span>🛒</span>
          <span>{t('nav.cart', locale)}</span>
          <span id="cart-badge-count" class="hidden absolute -top-0.5 -right-0.5 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[9px] font-bold text-white">0</span>
        </a>
        <a data-astro-prefetch="false" href={getLocalizedPath('/account', locale)} class:list={['rounded px-3 py-2 text-sm font-medium transition-colors flex items-center gap-1', currentPath.startsWith(getLocalizedPath('/account', locale)) ? 'text-primary' : 'text-neutral-700 hover:text-primary']}>
          <span>👤</span>
          <span>{t('nav.account', locale)}</span>
        </a>
      </nav>

      <button
        type="button"
        id="mobile-menu-btn"
        class="rounded p-2 text-neutral-700 hover:bg-neutral-100 lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </Container>

  <div class="hidden border-t border-neutral-200 bg-neutral-50 lg:block">
    <Container>
      <nav class="flex gap-1 overflow-x-auto py-2" aria-label="Categories">
        {categories.slice(0, 8).map((cat) => (
          <a
            href={getLocalizedPath(`/category/${cat.slug}`, locale)}
            class="shrink-0 rounded px-3 py-1.5 text-xs font-medium text-neutral-700 transition-colors hover:bg-white hover:text-primary"
          >
            {cat.name}
          </a>
        ))}
        <a href={getLocalizedPath('/products', locale)} class="shrink-0 rounded px-3 py-1.5 text-xs font-medium text-secondary hover:underline">
          {t('nav.viewAll', locale)} →
        </a>
      </nav>
    </Container>
  </div>

  <div id="mobile-menu" class="hidden border-t border-neutral-200 bg-white lg:hidden">
    <Container>
      <form action={getLocalizedPath('/products', locale)} method="get" class="py-3">
        <input
          type="search"
          name="search"
          placeholder={t('search.shortPlaceholder', locale)}
          class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm"
        />
      </form>
      <nav class="flex flex-col border-t border-neutral-100 py-2">
        <a href={getLocalizedPath('/', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800">{t('nav.home', locale)}</a>
        <a href={getLocalizedPath('/products', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800">{t('nav.products', locale)}</a>
        <a href={getLocalizedPath('/services', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800">{t('nav.services', locale)}</a>
        <a href={getLocalizedPath('/about', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800">{t('nav.about', locale)}</a>
        <a href={getLocalizedPath('/team', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800">{t('nav.team', locale)}</a>
        <a href={getLocalizedPath('/offers', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800">{t('nav.offers', locale)}</a>
        <a href={getLocalizedPath('/contact', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800">{t('nav.contact', locale)}</a>
        <a data-astro-prefetch="false" href={getLocalizedPath('/cart', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800 flex items-center justify-between">
          <span class="flex items-center gap-2">🛒 {t('nav.cart', locale)}</span>
          <span id="mobile-cart-badge-count" class="hidden flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white">0</span>
        </a>
        <a data-astro-prefetch="false" href={getLocalizedPath('/account', locale)} class="px-2 py-2.5 text-sm font-medium text-neutral-800 flex items-center gap-2">
          <span>👤 {t('nav.account', locale)}</span>
        </a>
      </nav>
      <div class="border-t border-neutral-100 py-3">
        <p class="mb-2 text-xs font-semibold uppercase text-neutral-500">{t('filter.category', locale)}</p>
        <div class="grid grid-cols-2 gap-1">
          {categories.map((cat) => (
            <a href={getLocalizedPath(`/category/${cat.slug}`, locale)} class="rounded px-2 py-1.5 text-sm text-neutral-700 hover:bg-neutral-50">
              {cat.name}
            </a>
          ))}
        </div>
      </div>
    </Container>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  function updateCartBadge() {
    try {
      const cart = JSON.parse(localStorage.getItem('ye_cart') || '[]');
      const totalItems = cart.reduce((sum: number, item: any) => sum + item.quantity, 0);
      const badges = ['cart-badge-count', 'mobile-cart-badge-count'];
      badges.forEach(id => {
        const badge = document.getElementById(id);
        if (badge) {
          if (totalItems > 0) {
            badge.textContent = String(totalItems);
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        }
      });
    } catch (e) {
      // Ignore
    }
  }

  // Update badge immediately
  updateCartBadge();

  // Listen for dynamic updates
  window.addEventListener('cart-updated', updateCartBadge);
  document.addEventListener('astro:page-load', updateCartBadge);
</script>
