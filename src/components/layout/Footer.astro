---
import type { Category, SiteSettings } from '../../types';
import Container from '../ui/Container.astro';

interface Props {
  settings: SiteSettings;
  categories: Category[];
}

const { settings, categories } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 bg-neutral-900 text-neutral-300">
  <Container>
    <div class="grid gap-8 py-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <p class="font-display text-lg font-bold text-white">{settings.businessName}</p>
        <p class="mt-2 text-sm">{settings.tagline}</p>
        <p class="mt-3 text-sm leading-relaxed">
          {settings.address}<br />
          {settings.city}, {settings.state} - {settings.pincode}
        </p>
      </div>

      <div>
        <p class="font-semibold text-white">Quick Links</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/products" class="hover:text-white">All Products</a></li>
          <li><a href="/offers" class="hover:text-white">Special Offers</a></li>
          <li><a href="/contact" class="hover:text-white">Contact Us</a></li>
        </ul>
      </div>

      <div>
        <p class="font-semibold text-white">Categories</p>
        <ul class="mt-3 space-y-2 text-sm">
          {categories.slice(0, 6).map((cat) => (
            <li>
              <a href={`/category/${cat.slug}`} class="hover:text-white">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="font-semibold text-white">Contact</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="hover:text-white">{settings.phone}</a>
          </li>
          <li>
            <a href={`mailto:${settings.email}`} class="hover:text-white">{settings.email}</a>
          </li>
          <li>{settings.workingHours}</li>
        </ul>
        <div class="mt-4 flex gap-3">
          {settings.facebookUrl && (
            <a href={settings.facebookUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white" aria-label="Facebook">FB</a>
          )}
          {settings.instagramUrl && (
            <a href={settings.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white" aria-label="Instagram">IG</a>
          )}
          {settings.youtubeUrl && (
            <a href={settings.youtubeUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white" aria-label="YouTube">YT</a>
          )}
        </div>
      </div>
    </div>

    <div class="border-t border-neutral-800 py-4 text-center text-xs text-neutral-500">
      <p>© {year} {settings.businessName}. All rights reserved. Genuine products. Local support.</p>
    </div>
  </Container>
</footer>
