---
import type { Category, SiteSettings } from '../../types';
import Container from '../ui/Container.astro';
import { t, getLocalizedPath } from '../../lib/translations';
import { buildCloudinaryUrl } from '../../lib/cloudinary';

interface Props {
  settings: SiteSettings;
  categories: Category[];
}

const { settings, categories } = Astro.props;
const locale = Astro.currentLocale || 'gu';
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 bg-neutral-900 text-neutral-300">
  <Container>
    <div class="grid gap-8 py-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="flex items-center gap-2 mb-3">
          {settings.logoUrl ? (
            <img src={buildCloudinaryUrl(settings.logoUrl, { width: 72, height: 72 })} alt={settings.businessName} class="h-9 w-9 rounded-md object-contain bg-white p-0.5" />
          ) : (
            <div class="flex h-9 w-9 items-center justify-center rounded-md bg-gradient-to-br from-primary to-primary-700 text-sm font-bold text-white">
              {settings.businessName.split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase()}
            </div>
          )}
          <p class="font-display text-lg font-bold text-white">{settings.businessName.toUpperCase()}</p>
        </div>
        <p class="text-sm text-neutral-400">{settings.tagline}</p>
        <p class="mt-3 text-sm leading-relaxed">
          {settings.address}<br />
          {settings.city}, {settings.state} - {settings.pincode}
        </p>
        <div class="mt-4 overflow-hidden rounded-lg border border-neutral-800 shadow-sm h-32 w-full bg-neutral-800 relative group">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2909.917727789059!2d69.6535241!3d22.2054469!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3956fd744aa61b5f%3A0x43393887f7fc9b14!2sYash%20Electronics%20-%20Samsung%2520Exclusive!5e1!3m2!1sen!2sin!4v1782389161261!5m2!1sen!2sin" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="strict-origin-when-cross-origin" 
            class="w-full h-full opacity-70 group-hover:opacity-100 transition-opacity duration-300"
          ></iframe>
          {settings.googleMapsUrl && (
            <a 
              href={settings.googleMapsUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="absolute bottom-2 right-2 bg-neutral-900/85 hover:bg-primary text-white text-[10px] font-bold px-2 py-1 rounded transition-colors flex items-center gap-1 backdrop-blur-sm shadow-sm select-none"
            >
              <span>{locale === 'gu' ? 'નકશો જુઓ' : 'View Map'}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
            </a>
          )}
        </div>
      </div>

      <div>
        <p class="font-semibold text-white">{t('nav.quickLinks', locale) || 'Quick Links'}</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href={getLocalizedPath('/products', locale)} class="hover:text-white transition-colors">{t('nav.viewAllProducts', locale)}</a></li>
          <li><a href={getLocalizedPath('/services', locale)} class="hover:text-white transition-colors">{t('nav.services', locale)}</a></li>
          <li><a href={getLocalizedPath('/about', locale)} class="hover:text-white transition-colors">{t('nav.about', locale)}</a></li>
          <li><a href={getLocalizedPath('/bank-details', locale)} class="hover:text-white transition-colors">{t('nav.bankDetails', locale)}</a></li>
          <li><a href={getLocalizedPath('/service-request', locale)} class="hover:text-white transition-colors">{t('nav.serviceRequest', locale)}</a></li>
          <li><a href={getLocalizedPath('/offers', locale)} class="hover:text-white transition-colors">{t('offers.specialOffers', locale) || 'Special Offers'}</a></li>
          <li><a href={getLocalizedPath('/contact', locale)} class="hover:text-white transition-colors">{t('contact.contactUs', locale) || 'Contact Us'}</a></li>
        </ul>
      </div>

      <div>
        <p class="font-semibold text-white">{t('filter.category', locale)}</p>
        <ul class="mt-3 space-y-2 text-sm">
          {categories.slice(0, 8).map((cat) => (
            <li>
              <a href={getLocalizedPath(`/category/${cat.slug}`, locale)} class="hover:text-white transition-colors">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="font-semibold text-white">{t('nav.contact', locale)}</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="h-4 w-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              {settings.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${settings.email}`} class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="h-4 w-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              {settings.email}
            </a>
          </li>
          <li class="flex items-start gap-2 pt-1">
            <svg class="h-4 w-4 text-secondary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <div class="text-xs leading-relaxed">
              <p class="font-medium text-neutral-200">{t('hours.title', locale)}</p>
              {settings.workingHours.split('|').map((h, i) => (
                <p class={i === 0 ? "mt-1" : ""}>{h.trim()}</p>
              ))}
            </div>
          </li>
        </ul>
        <div class="mt-4 flex gap-3">
          {settings.facebookUrl && (
            <a href={settings.facebookUrl} target="_blank" rel="noopener noreferrer" class="flex h-8 w-8 items-center justify-center rounded-full bg-neutral-800 text-neutral-400 hover:bg-primary hover:text-white transition-colors" aria-label="Facebook">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {settings.instagramUrl && (
            <a href={settings.instagramUrl} target="_blank" rel="noopener noreferrer" class="flex h-8 w-8 items-center justify-center rounded-full bg-neutral-800 text-neutral-400 hover:bg-gradient-to-br hover:from-purple-500 hover:to-pink-500 hover:text-white transition-colors" aria-label="Instagram">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
          {settings.youtubeUrl && (
            <a href={settings.youtubeUrl} target="_blank" rel="noopener noreferrer" class="flex h-8 w-8 items-center justify-center rounded-full bg-neutral-800 text-neutral-400 hover:bg-red-600 hover:text-white transition-colors" aria-label="YouTube">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
        </div>
        <div class="mt-5">
          <button
            id="footer-pwa-install-btn"
            class="inline-flex items-center gap-2 rounded-md bg-neutral-800 hover:bg-neutral-700 text-neutral-300 hover:text-white px-3 py-1.5 text-xs font-semibold border border-neutral-700 transition-colors cursor-pointer focus:outline-none"
          >
            📱 {locale === 'gu' ? 'એપ ઇન્સ્ટોલ કરો' : 'Install App'}
          </button>
        </div>
      </div>
    </div>


    <div class="border-t border-neutral-800 py-4 text-center text-xs text-neutral-500 space-y-1">
      <p>{locale === 'gu' ? `© ${year} ${settings.businessName}. સર્વાધિકાર સુરક્ષિત. અસલી પ્રોડક્ટ્સ. સ્થાનિક સપોર્ટ.` : `© ${year} ${settings.businessName}. All rights reserved. Genuine products. Local support.`}</p>
      <p>
        {locale === 'gu' ? 'બનાવનાર: ' : 'Made by '}
        <a href="https://hardikkanajariya.in" target="_blank" rel="noopener noreferrer" class="underline hover:text-neutral-400 transition-colors font-medium">
          hardikkanajariya.in
        </a>
      </p>
    </div>
  </Container>
</footer>

<script is:inline>
  (function() {
    let footerDeferredPrompt = null;

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      footerDeferredPrompt = e;
    });

    const footerInstallBtn = document.getElementById('footer-pwa-install-btn');
    footerInstallBtn?.addEventListener('click', async () => {
      if (footerDeferredPrompt) {
        footerDeferredPrompt.prompt();
        const { outcome } = await footerDeferredPrompt.userChoice;
        console.log('Footer PWA installation outcome:', outcome);
        footerDeferredPrompt = null;
      } else {
        const isGu = document.documentElement.lang === 'gu';
        alert(
          isGu
            ? 'એપ ઇન્સ્ટોલ કરવા માટે:\n૧. તમારા બ્રાઉઝરના મેનૂ (⋮ અથવા શેર બટન) પર ક્લિક કરો.\n૨. "હોમ સ્ક્રીન પર ઉમેરો" અથવા "એપ ઇન્સ્ટોલ કરો" પસંદ કરો.'
            : 'To install the app:\n1. Click your browser\'s menu (⋮ or share button).\n2. Select "Add to Home Screen" or "Install App".'
        );
      }
    });
  })();
</script>
