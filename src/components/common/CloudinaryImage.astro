---
interface Props {
  /** Cloudinary public ID or local image path */
  publicId?: string;
  /** Alias for publicId */
  src?: string;
  alt: string;
  width?: number;
  height?: number;
  crop?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  sizes?: string;
  priority?: boolean;
}

import { buildCloudinaryUrl, buildSrcSet, isLocalImage } from '../../lib/cloudinary';

const {
  publicId: publicIdProp,
  src,
  alt,
  width = 400,
  height,
  crop,
  class: className = '',
  loading = 'lazy',
  sizes = '100vw',
  priority = false,
} = Astro.props;

const publicId = publicIdProp ?? src ?? '';
const imgSrc = buildCloudinaryUrl(publicId, { width, height, crop });
const srcSet = isLocalImage(publicId) ? undefined : buildSrcSet(publicId, [320, 480, 640, 768, 1024]);
const imgLoading = priority ? 'eager' : loading;
const hasObjectFit = className.includes('object-');
const defaultFitClass = hasObjectFit ? '' : 'object-cover';
---

<img
  src={imgSrc}
  {...(srcSet ? { srcset: srcSet } : {})}
  sizes={sizes}
  alt={alt}
  width={width}
  height={height}
  loading={imgLoading}
  decoding="async"
  class:list={[defaultFitClass, className]}
/>
