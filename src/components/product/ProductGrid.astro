---
import type { Product } from '../../types';
import ProductCard from './ProductCard.astro';

interface Props {
  products: Product[];
  columns?: 2 | 3 | 4;
}

const { products, columns = 4 } = Astro.props;

const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4',
}[columns];
---

{products.length > 0 ? (
  <div class:list={['grid gap-3 md:gap-4', gridCols]}>
    {products.map((product) => (
      <ProductCard product={product} />
    ))}
  </div>
) : (
  <div class="rounded-lg border border-neutral-200 bg-white p-8 text-center">
    <p class="text-neutral-600">No products found matching your criteria.</p>
    <a href="/products" class="mt-3 inline-block text-sm font-semibold text-primary hover:underline">
      View all products
    </a>
  </div>
)}
