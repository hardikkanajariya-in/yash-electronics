---
import type { Brand, Category } from '../../types';
import { SORT_OPTIONS } from '../../lib/constants';

interface Props {
  categories: Category[];
  brands: Brand[];
  currentFilters: {
    search?: string;
    category?: string;
    brand?: string;
    minPrice?: number;
    maxPrice?: number;
    sort?: string;
  };
  priceRange: { min: number; max: number };
}

const { categories, brands, currentFilters, priceRange } = Astro.props;
const baseUrl = Astro.url.pathname;
---

<aside class="rounded-lg border border-neutral-200 bg-white p-4">
  <h2 class="font-semibold text-neutral-900">Filters</h2>

  <form method="get" action={baseUrl} class="mt-4 space-y-5">
    {currentFilters.search && (
      <input type="hidden" name="search" value={currentFilters.search} />
    )}

    <div>
      <label for="category" class="block text-sm font-medium text-neutral-700">Category</label>
      <select
        id="category"
        name="category"
        class="mt-1 w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
      >
        <option value="">All Categories</option>
        {categories.map((cat) => (
          <option value={cat.slug} selected={currentFilters.category === cat.slug}>
            {cat.name}
          </option>
        ))}
      </select>
    </div>

    <div>
      <label for="brand" class="block text-sm font-medium text-neutral-700">Brand</label>
      <select
        id="brand"
        name="brand"
        class="mt-1 w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
      >
        <option value="">All Brands</option>
        {brands.map((brand) => (
          <option value={brand.slug} selected={currentFilters.brand === brand.slug}>
            {brand.name}
          </option>
        ))}
      </select>
    </div>

    <div class="grid grid-cols-2 gap-2">
      <div>
        <label for="minPrice" class="block text-sm font-medium text-neutral-700">Min Price</label>
        <input
          type="number"
          id="minPrice"
          name="minPrice"
          min={priceRange.min}
          max={priceRange.max}
          value={currentFilters.minPrice ?? ''}
          placeholder={String(priceRange.min)}
          class="mt-1 w-full rounded-md border border-neutral-300 px-3 py-2 text-sm"
        />
      </div>
      <div>
        <label for="maxPrice" class="block text-sm font-medium text-neutral-700">Max Price</label>
        <input
          type="number"
          id="maxPrice"
          name="maxPrice"
          min={priceRange.min}
          max={priceRange.max}
          value={currentFilters.maxPrice ?? ''}
          placeholder={String(priceRange.max)}
          class="mt-1 w-full rounded-md border border-neutral-300 px-3 py-2 text-sm"
        />
      </div>
    </div>

    <div>
      <label for="sort" class="block text-sm font-medium text-neutral-700">Sort By</label>
      <select
        id="sort"
        name="sort"
        class="mt-1 w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
      >
        {SORT_OPTIONS.map((opt) => (
          <option value={opt.value} selected={currentFilters.sort === opt.value}>
            {opt.label}
          </option>
        ))}
      </select>
    </div>

    <div class="flex gap-2">
      <button type="submit" class="btn-primary flex-1 text-sm">Apply</button>
      <a href={baseUrl} class="btn-outline flex-1 text-center text-sm">Clear</a>
    </div>
  </form>
</aside>
