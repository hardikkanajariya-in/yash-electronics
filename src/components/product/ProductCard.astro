---
import type { Product } from '../../types';
import CloudinaryImage from '../common/CloudinaryImage.astro';
import { formatPrice, calculateSavings, calculateDiscountPercent } from '../../lib/format';
import { getLocalizedPath, t } from '../../lib/translations';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const locale = Astro.currentLocale || 'gu';
const savings = calculateSavings(product.mrp, product.offerPrice);
const discount = calculateDiscountPercent(product.mrp, product.offerPrice);
const primaryImage = product.images[0] || '';
---

<a href={getLocalizedPath(`/products/${product.slug}`, locale)} class="retail-card group flex flex-col overflow-hidden">
  <div class="relative aspect-square overflow-hidden bg-neutral-100">
    {primaryImage && (
      <CloudinaryImage
        publicId={primaryImage}
        alt={product.name}
        width={280}
        height={280}
        class="h-full w-full transition-transform duration-200 group-hover:scale-105"
        sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
      />
    )}
    {discount > 0 && (
      <span class="absolute left-2 top-2 rounded bg-accent px-2 py-0.5 text-xs font-semibold text-white">
        {t('product.off', locale).replace('{percent}', String(discount))}
      </span>
    )}
  </div>
  <div class="flex flex-1 flex-col p-3">
    <p class="text-xs font-medium uppercase tracking-wide text-neutral-500">{product.brand}</p>
    <h3 class="mt-1 line-clamp-2 text-sm font-semibold leading-snug text-neutral-900 group-hover:text-primary">
      {product.name}
    </h3>
    <p class="mt-0.5 text-xs text-neutral-500">{t('product.model', locale)}: {product.modelNumber}</p>
    <div class="mt-auto pt-2">
      <div class="flex items-baseline gap-2">
        <span class="text-base font-bold text-primary">{formatPrice(product.offerPrice)}</span>
        {product.mrp > product.offerPrice && (
          <span class="text-xs text-neutral-400 line-through">{formatPrice(product.mrp)}</span>
        )}
      </div>
      {savings > 0 && (
        <p class="mt-0.5 text-xs font-medium text-accent">{t('product.save', locale).replace('{amount}', formatPrice(savings))}</p>
      )}
    </div>
  </div>
</a>
