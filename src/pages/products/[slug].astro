---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import ProductGallery from '../../components/product/ProductGallery.astro';
import Button from '../../components/ui/Button.astro';
import ProductSchema from '../../components/seo/ProductSchema.astro';
import { getSettings, getProductBySlug, clearCmsCache } from '../../services/cms';
import {
  formatPrice,
  calculateSavings,
  calculateDiscountPercent,
  parseSpecifications,
} from '../../lib/format';
import { buildCloudinaryUrl } from '../../lib/cloudinary';
import {
  buildWhatsAppUrl,
  generateProductInquiryMessage,
} from '../../features/whatsapp/generateMessage';
import { translateObject, t, getLocalizedPath } from '../../lib/translations';
import { db } from '../../db';
import { reviews } from '../../db/schema';
import { desc, eq } from 'drizzle-orm';
import { getSessionUser } from '../../lib/auth';

export const prerender = false;

const locale = Astro.currentLocale || 'gu';

if (Astro.request.method === 'GET') {
  Astro.response.headers.set(
    'Cache-Control',
    'public, max-age=0, s-maxage=600, stale-while-revalidate=600'
  );
}

const { slug } = Astro.params;
const rawProduct = slug ? await getProductBySlug(slug) : null;

if (!rawProduct) {
  return new Response(null, {
    status: 404,
    statusText: 'Not Found',
  });
}

const product = translateObject(rawProduct, locale);

const rawSettings = await getSettings();
const settings = translateObject(rawSettings, locale);

const siteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.url.origin;
const savings = calculateSavings(product.mrp, product.offerPrice);
const discount = calculateDiscountPercent(product.mrp, product.offerPrice);
const specs = parseSpecifications(product.specifications);
const ogImage = product.images[0]
  ? buildCloudinaryUrl(product.images[0], { width: 1200 })
  : undefined;

const whatsappUrl = buildWhatsAppUrl(
  settings.whatsapp,
  generateProductInquiryMessage(
    {
      name: product.name,
      brand: product.brand,
      modelNumber: product.modelNumber,
      offerPrice: product.offerPrice,
      url: `${siteUrl}${getLocalizedPath(`/products/${product.slug}`, locale)}`,
    },
    settings,
    locale,
  ),
);

const currentUser = await getSessionUser(Astro.cookies);

// Fetch reviews directly from DB to prevent caching
let productReviews: any[] = [];
try {
  productReviews = await db.select()
    .from(reviews)
    .where(eq(reviews.productId, rawProduct.id))
    .orderBy(desc(reviews.createdAt));
} catch (e) {
  console.error('[Product Details] Failed to fetch reviews:', e);
}

// Calculate rating aggregates
const totalReviews = productReviews.length;
const averageRating = totalReviews > 0
  ? Number((productReviews.reduce((sum, r) => sum + r.rating, 0) / totalReviews).toFixed(1))
  : 0;

// Breakdowns
const breakdownCounts = { 5: 0, 4: 0, 3: 0, 2: 0, 1: 0 };
productReviews.forEach(r => {
  const ratingKey = r.rating as 5 | 4 | 3 | 2 | 1;
  if (breakdownCounts[ratingKey] !== undefined) {
    breakdownCounts[ratingKey]++;
  }
});
const breakdownPercentages = {
  5: totalReviews > 0 ? Math.round((breakdownCounts[5] / totalReviews) * 100) : 0,
  4: totalReviews > 0 ? Math.round((breakdownCounts[4] / totalReviews) * 100) : 0,
  3: totalReviews > 0 ? Math.round((breakdownCounts[3] / totalReviews) * 100) : 0,
  2: totalReviews > 0 ? Math.round((breakdownCounts[2] / totalReviews) * 100) : 0,
  1: totalReviews > 0 ? Math.round((breakdownCounts[1] / totalReviews) * 100) : 0,
};

let reviewSuccess = '';
let reviewError = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('formAction')?.toString();
    
    if (formAction === 'submit-review') {
      if (!currentUser) {
        throw new Error(locale === 'en' ? 'You must be logged in to submit a review.' : 'રિવ્યુ આપવા માટે તમારે લોગ ઇન કરવું પડશે.');
      }
      
      const rating = Number(formData.get('rating'));
      const comment = formData.get('comment')?.toString().trim();
      const purchaseSource = formData.get('purchaseSource')?.toString() || 'online';
      
      if (!rating || rating < 1 || rating > 5) {
        throw new Error(locale === 'en' ? 'Please select a star rating (1-5).' : 'કૃપા કરીને રેટિંગ (૧-૫) પસંદ કરો.');
      }
      if (!comment) {
        throw new Error(locale === 'en' ? 'Please enter your comment.' : 'કૃપા કરીને તમારી ટિપ્પણી લખો.');
      }
      
      const { generateId } = await import('../../lib/auth');
      const newReviewId = `rev-${generateId()}`;
      
      await db.insert(reviews).values({
        id: newReviewId,
        productId: rawProduct.id,
        userId: currentUser.id,
        userName: currentUser.name,
        rating,
        comment,
        purchaseSource: purchaseSource as 'online' | 'instore',
        createdAt: new Date().toISOString().split('T')[0],
      });
      
      reviewSuccess = locale === 'en' ? 'Thank you! Your review has been submitted.' : 'આભાર! તમારો રિવ્યુ સબમિટ થઈ ગયો છે.';
      
      // Fetch updated reviews
      productReviews = await db.select()
        .from(reviews)
        .where(eq(reviews.productId, rawProduct.id))
        .orderBy(desc(reviews.createdAt));
        
      // Re-calculate rating aggregates
      const updatedTotal = productReviews.length;
      const updatedAverage = updatedTotal > 0
        ? Number((productReviews.reduce((sum, r) => sum + r.rating, 0) / updatedTotal).toFixed(1))
        : 0;
      
      // Trigger redirect to clear form state and prevent duplicate submissions on page refresh
      return Astro.redirect(`${Astro.url.pathname}?successReview=true#reviews-section`);
    }
  } catch (e: any) {
    reviewError = e.message || 'An error occurred while submitting your review.';
  }
}

// Check success flag in query params
if (Astro.url.searchParams.get('successReview') === 'true') {
  reviewSuccess = locale === 'en' ? 'Thank you! Your review has been submitted.' : 'આભાર! તમારો રિવ્યુ સબમિટ થઈ ગયો છે.';
}

// Helper to parse description into structured HTML blocks
const parseDescription = (descText: string | null | undefined) => {
  if (!descText) return [];

  const lines = descText.split(/\r?\n/);
  const blocks: Array<{ type: 'paragraph' | 'list'; content: string | string[] }> = [];
  let currentListItems: string[] = [];

  const parseInline = (text: string) => {
    return text
      .trim()
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<strong>$1</strong>');
  };

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) {
      if (currentListItems.length > 0) {
        blocks.push({ type: 'list', content: currentListItems });
        currentListItems = [];
      }
      continue;
    }

    // Check if line starts with bullet like - or * or •
    const listMatch = trimmed.match(/^([•\-\*])\s*(.*)/);
    if (listMatch) {
      currentListItems.push(parseInline(listMatch[2]));
      continue;
    }

    // Check if the line has inline • characters
    if (trimmed.includes('•')) {
      if (currentListItems.length > 0) {
        blocks.push({ type: 'list', content: currentListItems });
        currentListItems = [];
      }

      const parts = trimmed.split('•');
      const intro = parts[0].trim();
      if (intro) {
        blocks.push({ type: 'paragraph', content: parseInline(intro) });
      }

      const items = parts.slice(1).map(p => parseInline(p)).filter(Boolean);
      if (items.length > 0) {
        blocks.push({ type: 'list', content: items });
      }
      continue;
    }

    // If it's a regular line
    if (currentListItems.length > 0) {
      blocks.push({ type: 'list', content: currentListItems });
      currentListItems = [];
    }

    blocks.push({ type: 'paragraph', content: parseInline(trimmed) });
  }

  if (currentListItems.length > 0) {
    blocks.push({ type: 'list', content: currentListItems });
  }

  return blocks;
};

const descriptionBlocks = parseDescription(product.description);
---

<BaseLayout
  title={product.name}
  description={product.description}
  canonicalUrl={`/products/${product.slug}`}
  ogImage={ogImage}
>
  <ProductSchema product={product} settings={settings} />
  <Container class="py-6">
    <nav class="mb-4 text-sm text-neutral-500" aria-label="Breadcrumb">
      <a href={getLocalizedPath('/', locale)} class="hover:text-primary">{t('nav.home', locale)}</a>
      <span class="mx-1">/</span>
      <a href={getLocalizedPath('/products', locale)} class="hover:text-primary">{t('nav.products', locale)}</a>
      <span class="mx-1">/</span>
      <a href={getLocalizedPath(`/category/${product.categorySlug}`, locale)} class="hover:text-primary">{product.category}</a>
      <span class="mx-1">/</span>
      <span class="text-neutral-800">{product.name}</span>
    </nav>

    <div class="grid gap-8 lg:grid-cols-2">
      <ProductGallery images={product.images} productName={product.name} />

      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-neutral-500">{product.brand}</p>
        <h1 class="mt-1 text-xl font-bold text-neutral-900 md:text-2xl">{product.name}</h1>
        <p class="mt-1 text-sm text-neutral-500">{t('product.model', locale)}: {product.modelNumber}</p>

        {totalReviews > 0 && (
          <div class="mt-2 flex items-center gap-2">
            <div class="flex items-center gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class={`w-4 h-4 ${i < Math.round(averageRating) ? 'text-amber-400' : 'text-neutral-300'} fill-current`}
                  viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-neutral-800">{averageRating}</span>
            <span class="text-xs text-neutral-400">|</span>
            <a href="#reviews-section" class="text-xs font-semibold text-primary hover:underline">
              {totalReviews} {locale === 'en' ? 'reviews' : 'રિવ્યુઝ'}
            </a>
          </div>
        )}

        <div class="mt-4 rounded-lg border border-neutral-200 bg-neutral-50 p-4">
          <div class="flex flex-wrap items-baseline gap-3">
            <span class="text-2xl font-bold text-primary">{formatPrice(product.offerPrice)}</span>
            {product.mrp > product.offerPrice && (
              <>
                <span class="text-base text-neutral-400 line-through">{formatPrice(product.mrp)}</span>
                <span class="rounded bg-accent px-2 py-0.5 text-xs font-semibold text-white">
                  {t('product.off', locale).replace('{percent}', String(discount))}
                </span>
              </>
            )}
          </div>
          {savings > 0 && (
            <p class="mt-1 text-sm font-medium text-accent">{t('product.save', locale).replace('{amount}', formatPrice(savings))}</p>
          )}
          <p class="mt-2 text-xs text-neutral-500">{t('product.mrpNote', locale)}</p>
        </div>

        {/* Purchase Actions */}
        <div class="mt-6 grid grid-cols-2 gap-3">
          <button
            type="button"
            data-action="add-to-cart"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.offerPrice > 0 ? product.offerPrice : product.mrp}
            data-product-image={product.images[0] || ''}
            class="flex items-center justify-center rounded border-2 border-primary px-4 py-2.5 text-xs sm:text-sm font-bold text-primary hover:bg-primary/5 transition-colors focus:outline-none cursor-pointer"
          >
            🛒 {locale === 'en' ? 'Add to Cart' : 'કાર્ટમાં ઉમેરો'}
          </button>
          <button
            type="button"
            data-action="buy-now"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.offerPrice > 0 ? product.offerPrice : product.mrp}
            data-product-image={product.images[0] || ''}
            class="flex items-center justify-center rounded bg-secondary px-4 py-2.5 text-xs sm:text-sm font-bold text-white hover:bg-secondary/95 transition-colors focus:outline-none cursor-pointer"
          >
            ⚡ {locale === 'en' ? 'Buy Now' : 'હમણાં ખરીદો'}
          </button>
        </div>

        {/* Query Actions */}
        <div class="mt-3 flex flex-col gap-3 sm:flex-row">
          <Button href={whatsappUrl} text={t('product.enquireWhatsApp', locale)} variant="whatsapp" external class="flex-1 py-2.5 text-sm" />
          <Button href={`tel:${settings.phone.replace(/\s/g, '')}`} text={t('product.callStore', locale)} variant="outline" class="flex-1 py-2.5 text-sm" />
        </div>

        {descriptionBlocks.length > 0 && (
          <div class="mt-6">
            <h2 class="font-semibold text-neutral-900">{t('product.description', locale)}</h2>
            <div class="mt-2 space-y-3">
              {descriptionBlocks.map((block) => {
                if (block.type === 'list') {
                  return (
                    <ul class="list-disc list-inside space-y-1.5 pl-2 text-sm leading-relaxed text-neutral-600">
                      {(block.content as string[]).map((item) => (
                        <li set:html={item} />
                      ))}
                    </ul>
                  );
                } else {
                  return (
                    <p class="text-sm leading-relaxed text-neutral-600" set:html={block.content} />
                  );
                }
              })}
            </div>
          </div>
        )}

        {Object.keys(specs).length > 0 && (
          <div class="mt-6">
            <h2 class="font-semibold text-neutral-900">{t('product.specifications', locale)}</h2>
            <table class="mt-2 w-full text-sm">
              <tbody>
                {Object.entries(specs).map(([key, value]) => (
                  <tr class="border-b border-neutral-100">
                    <td class="py-2 pr-4 font-medium text-neutral-700">{key}</td>
                    <td class="py-2 text-neutral-600">{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        <dl class="mt-6 grid grid-cols-2 gap-3 text-sm">
          <div class="rounded border border-neutral-200 p-3">
            <dt class="text-neutral-500">{t('filter.brand', locale)}</dt>
            <dd class="font-medium text-neutral-900">
              <a href={getLocalizedPath(`/products?brand=${product.brandSlug}`, locale)} class="text-primary hover:underline">
                {product.brand}
              </a>
            </dd>
          </div>
          <div class="rounded border border-neutral-200 p-3">
            <dt class="text-neutral-500">{t('filter.category', locale)}</dt>
            <dd class="font-medium text-neutral-900">
              <a href={getLocalizedPath(`/category/${product.categorySlug}`, locale)} class="text-primary hover:underline">
                {product.category}
              </a>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    {/* Ratings and Reviews Section */}
    <div id="reviews-section" class="mt-12 pt-8 border-t border-neutral-200">
      <h2 class="text-xl font-bold text-neutral-900 mb-6">{t('reviews.title', locale)}</h2>
      
      <div class="grid gap-8 lg:grid-cols-3">
        {/* Left Column: Summary Card & Submission form */}
        <div class="space-y-6">
          <div class="rounded-xl border border-neutral-200 bg-neutral-50/50 p-6 shadow-sm">
            <h3 class="text-xs font-bold uppercase tracking-wider text-neutral-500 mb-4">{t('reviews.average', locale)}</h3>
            <div class="flex items-baseline gap-2">
              <span class="text-5xl font-black text-neutral-900">{averageRating || '0.0'}</span>
              <span class="text-sm font-semibold text-neutral-400">/ 5</span>
            </div>
            
            <div class="flex items-center gap-1 mt-2">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class={`w-5 h-5 ${i < Math.round(averageRating) ? 'text-amber-400' : 'text-neutral-300'} fill-current`}
                  viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-xs text-neutral-500 mt-2">
              {totalReviews} {totalReviews === 1 ? (locale === 'en' ? 'customer review' : 'ગ્રાહક રિવ્યુ') : (locale === 'en' ? 'customer reviews' : 'ગ્રાહકોના રિવ્યુઝ')}
            </p>
            
            {/* Progress Bars */}
            <div class="mt-6 space-y-2">
              {[5, 4, 3, 2, 1].map((stars) => {
                const count = breakdownCounts[stars as 5|4|3|2|1] || 0;
                const percentage = breakdownPercentages[stars as 5|4|3|2|1] || 0;
                return (
                  <div class="flex items-center gap-3 text-xs">
                    <span class="w-12 text-neutral-600 font-bold">{stars} Star</span>
                    <div class="flex-1 h-2 bg-neutral-200 rounded overflow-hidden">
                      <div class="h-full bg-amber-400 rounded-r transition-all duration-300" style={`width: ${percentage}%`}></div>
                    </div>
                    <span class="w-8 text-right text-neutral-500 font-semibold">{percentage}%</span>
                  </div>
                );
              })}
            </div>
          </div>
          
          {/* Write a Review Block */}
          <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm">
            <h3 class="font-bold text-neutral-900 mb-3">{t('reviews.writeReview', locale)}</h3>
            
            {currentUser ? (
              <form method="POST" class="space-y-4">
                <input type="hidden" name="formAction" value="submit-review" />
                
                {reviewSuccess && (
                  <div class="p-3 bg-green-50 border border-green-200 text-green-700 text-xs rounded-lg font-semibold">
                    {reviewSuccess}
                  </div>
                )}
                {reviewError && (
                  <div class="p-3 bg-red-50 border border-red-200 text-red-700 text-xs rounded-lg font-semibold">
                    {reviewError}
                  </div>
                )}
                
                {/* Interactive Star Selection */}
                <div>
                  <label class="block text-xs font-bold text-neutral-600 mb-1.5 uppercase tracking-wide">{t('reviews.rating', locale)} *</label>
                  <div class="flex items-center gap-1 text-neutral-300" id="star-selector">
                    {[1, 2, 3, 4, 5].map((star) => (
                      <button
                        type="button"
                        data-value={star}
                        class="p-0.5 hover:scale-110 active:scale-95 transition-transform focus:outline-none cursor-pointer text-neutral-300 hover:text-amber-400"
                      >
                        <svg class="w-8 h-8 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      </button>
                    ))}
                  </div>
                  <input type="hidden" name="rating" id="rating-value" required />
                </div>
                
                {/* Purchase Source Selection */}
                <div>
                  <label class="block text-xs font-bold text-neutral-600 mb-1.5 uppercase tracking-wide">{t('reviews.source', locale)} *</label>
                  <div class="grid grid-cols-2 gap-2">
                    <label class="flex items-center justify-center gap-1.5 rounded-lg border border-neutral-300 p-2 text-center text-xs font-semibold select-none ring-primary/20 has-[:checked]:border-primary has-[:checked]:bg-primary/5 has-[:checked]:text-primary has-[:checked]:ring-2 cursor-pointer">
                      <input type="radio" name="purchaseSource" value="online" checked class="sr-only" />
                      <span>{t('reviews.online', locale)}</span>
                    </label>
                    <label class="flex items-center justify-center gap-1.5 rounded-lg border border-neutral-300 p-2 text-center text-xs font-semibold select-none ring-primary/20 has-[:checked]:border-primary has-[:checked]:bg-primary/5 has-[:checked]:text-primary has-[:checked]:ring-2 cursor-pointer">
                      <input type="radio" name="purchaseSource" value="instore" class="sr-only" />
                      <span>{t('reviews.instore', locale)}</span>
                    </label>
                  </div>
                </div>
                
                {/* Comments Textarea */}
                <div>
                  <label for="comment" class="block text-xs font-bold text-neutral-600 mb-1.5 uppercase tracking-wide">{t('reviews.comment', locale)} *</label>
                  <textarea
                    id="comment"
                    name="comment"
                    rows="3"
                    required
                    placeholder={locale === 'en' ? "Share your experience with this product..." : "આ પ્રોડક્ટ વિશે તમારો અનુભવ લખો..."}
                    class="w-full rounded-lg border border-neutral-300 p-3 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
                  ></textarea>
                </div>
                
                <button
                  type="submit"
                  class="w-full rounded-lg bg-primary py-2.5 text-xs font-bold text-white hover:bg-primary/95 transition-colors cursor-pointer text-center flex items-center justify-center shadow-sm"
                >
                  {t('reviews.submit', locale)}
                </button>
              </form>
            ) : (
              <div class="text-center py-4 bg-neutral-50/70 border border-dashed border-neutral-300 rounded-xl px-4">
                <p class="text-sm text-neutral-600 mb-4 leading-relaxed">{t('reviews.loginRequired', locale)}</p>
                <a
                  href={getLocalizedPath(`/account/login?redirectTo=${encodeURIComponent(Astro.url.pathname + '#reviews-section')}`, locale)}
                  class="inline-block bg-primary text-white text-xs font-bold px-6 py-2 rounded-lg hover:bg-primary/95 transition-colors shadow-sm"
                >
                  {t('reviews.loginBtn', locale)}
                </a>
              </div>
            )}
          </div>
        </div>
        
        {/* Right Column: Reviews List */}
        <div class="lg:col-span-2 space-y-4">
          {productReviews.length > 0 ? (
            productReviews.map((rev) => {
              const initials = rev.userName
                ? rev.userName.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase()
                : 'C';
              const colors = [
                'bg-rose-100 text-rose-700',
                'bg-blue-100 text-blue-700',
                'bg-emerald-100 text-emerald-700',
                'bg-indigo-100 text-indigo-700',
                'bg-amber-100 text-amber-700',
                'bg-purple-100 text-purple-700'
              ];
              const hash = (rev.userName || '').split('').reduce((acc: number, char: string) => acc + char.charCodeAt(0), 0);
              const colorClass = colors[hash % colors.length];
              
              return (
                <div class="rounded-xl border border-neutral-100 bg-white p-5 shadow-sm space-y-3">
                  <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                      <div class={`w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold shadow-sm ${colorClass}`}>
                        {initials}
                      </div>
                      <div>
                        <h4 class="text-sm font-bold text-neutral-900">{rev.userName}</h4>
                        <div class="flex items-center gap-1.5 mt-0.5">
                          <div class="flex items-center">
                            {Array.from({ length: 5 }).map((_, i) => (
                              <svg
                                class={`w-3.5 h-3.5 ${i < rev.rating ? 'text-amber-400' : 'text-neutral-200'} fill-current`}
                                viewBox="0 0 20 20"
                                xmlns="http://www.w3.org/2000/svg"
                              >
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                              </svg>
                            ))}
                          </div>
                          <span class="text-[10px] text-neutral-400 font-semibold">•</span>
                          <span class="text-[10px] text-neutral-400 font-semibold">{rev.createdAt}</span>
                        </div>
                      </div>
                    </div>
                    
                    <div>
                      {rev.purchaseSource === 'online' && (
                        <span class="inline-flex items-center gap-1 rounded bg-green-50 px-2 py-1 text-[10px] font-bold text-green-700 border border-green-100">
                          ✓ {t('reviews.verified', locale)}
                        </span>
                      )}
                      {rev.purchaseSource === 'instore' && (
                        <span class="inline-flex items-center gap-1 rounded bg-blue-50 px-2 py-1 text-[10px] font-bold text-blue-700 border border-blue-100">
                          🏬 {t('reviews.instoreBadge', locale)}
                        </span>
                      )}
                      {rev.purchaseSource === 'seeded' && (
                        <span class="inline-flex items-center gap-1 rounded bg-neutral-100 px-2 py-1 text-[10px] font-bold text-neutral-600 border border-neutral-200">
                          ★ {t('reviews.seededBadge', locale)}
                        </span>
                      )}
                    </div>
                  </div>
                  
                  <p class="text-sm text-neutral-700 leading-relaxed sm:pl-[3.25rem]">{rev.comment}</p>
                </div>
              );
            })
          ) : (
            <div class="text-center py-12 bg-neutral-50/50 border border-neutral-200 rounded-xl">
              <p class="text-neutral-500 text-sm">{t('reviews.noReviews', locale)}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>

<script is:inline>
  function initStarSelector() {
    const starSelector = document.getElementById('star-selector');
    if (starSelector) {
      const buttons = starSelector.querySelectorAll('button');
      const ratingInput = document.getElementById('rating-value');
      
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          const val = parseInt(button.getAttribute('data-value') || '0', 10);
          ratingInput.value = val;
          
          // Color all stars up to val
          buttons.forEach(btn => {
            const btnVal = parseInt(btn.getAttribute('data-value') || '0', 10);
            if (btnVal <= val) {
              btn.classList.remove('text-neutral-300');
              btn.classList.add('text-amber-400');
            } else {
              btn.classList.remove('text-amber-400');
              btn.classList.add('text-neutral-300');
            }
          });
        });
        
        button.addEventListener('mouseenter', () => {
          const val = parseInt(button.getAttribute('data-value') || '0', 10);
          buttons.forEach(btn => {
            const btnVal = parseInt(btn.getAttribute('data-value') || '0', 10);
            if (btnVal <= val) {
              btn.classList.add('text-amber-400');
              btn.classList.remove('text-neutral-300');
            } else {
              btn.classList.remove('text-amber-400');
              btn.classList.add('text-neutral-300');
            }
          });
        });
      });
      
      starSelector.addEventListener('mouseleave', () => {
        const val = parseInt(ratingInput.value || '0', 10);
        buttons.forEach(btn => {
          const btnVal = parseInt(btn.getAttribute('data-value') || '0', 10);
          if (btnVal <= val) {
            btn.classList.remove('text-neutral-300');
            btn.classList.add('text-amber-400');
          } else {
            btn.classList.remove('text-amber-400');
            btn.classList.add('text-neutral-300');
          }
        });
      });
    }
  }

  // Support standard page loads and Astro View Transitions
  document.addEventListener('DOMContentLoaded', initStarSelector);
  document.addEventListener('astro:page-load', initStarSelector);
</script>

