---
import AdminLayout from '../../layouts/AdminLayout.astro';
import CropModal from '../../components/admin/CropModal.astro';
import { db } from '../../db';
import { promoVideos } from '../../db/schema';
import { getSessionUser, generateId } from '../../lib/auth';
import { eq, asc } from 'drizzle-orm';
import { deleteCloudinaryAsset } from '../../lib/cloudinary-server';
import { buildCloudinaryUrl } from '../../lib/cloudinary';

export const prerender = false;
export const isr = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

let message = Astro.url.searchParams.get('message') || '';
let error = Astro.url.searchParams.get('error') || '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('_action')?.toString();

    if (formAction === 'delete') {
      const deleteId = formData.get('id')?.toString();
      if (deleteId) {
        // Fetch existing first to delete from Cloudinary
        const [existing] = await db.select().from(promoVideos).where(eq(promoVideos.id, deleteId));
        if (existing) {
          if (existing.videoUrl) {
            await deleteCloudinaryAsset(existing.videoUrl, 'video');
          }
          if (existing.thumbnailUrl) {
            await deleteCloudinaryAsset(existing.thumbnailUrl, 'image');
          }
        }
        await db.delete(promoVideos).where(eq(promoVideos.id, deleteId));
        return Astro.redirect('/admin/promo-videos?message=' + encodeURIComponent('Promo video deleted.'));
      }
    } else if (formAction === 'save') {
      const id = formData.get('id')?.toString();
      const title = formData.get('title')?.toString().trim() || '';
      const titleGu = formData.get('titleGu')?.toString().trim() || null;
      const videoUrl = formData.get('videoUrl')?.toString().trim() || '';
      const thumbnailUrl = formData.get('thumbnailUrl')?.toString().trim() || null;
      const description = formData.get('description')?.toString().trim() || null;
      const descriptionGu = formData.get('descriptionGu')?.toString().trim() || null;
      const sortOrder = Number(formData.get('sortOrder') || '0');
      const isActive = formData.get('isActive') !== 'false';

      if (!title) {
        error = 'Title is required.';
      } else if (!videoUrl) {
        error = 'Video file or URL is required.';
      } else if (id) {
        // Fetch existing to delete replaced files from Cloudinary
        const [existing] = await db.select().from(promoVideos).where(eq(promoVideos.id, id));
        if (existing) {
          if (existing.videoUrl && existing.videoUrl !== videoUrl) {
            await deleteCloudinaryAsset(existing.videoUrl, 'video');
          }
          if (existing.thumbnailUrl && existing.thumbnailUrl !== thumbnailUrl) {
            await deleteCloudinaryAsset(existing.thumbnailUrl, 'image');
          }
        }

        await db.update(promoVideos).set({
          title,
          titleGu,
          videoUrl,
          thumbnailUrl,
          description,
          descriptionGu,
          sortOrder,
          isActive
        }).where(eq(promoVideos.id, id));
        return Astro.redirect('/admin/promo-videos?message=' + encodeURIComponent('Promo video updated.'));
      } else {
        await db.insert(promoVideos).values({
          id: generateId(),
          title,
          titleGu,
          videoUrl,
          thumbnailUrl,
          description,
          descriptionGu,
          sortOrder,
          isActive,
          createdAt: new Date().toISOString()
        });
        return Astro.redirect('/admin/promo-videos?message=' + encodeURIComponent('Promo video added.'));
      }
    }
  } catch (e: any) {
    error = 'Operation failed: ' + (e.message || 'Unknown error');
  }
}

let allVideos: any[] = [];
try {
  allVideos = await db.select().from(promoVideos).orderBy(asc(promoVideos.sortOrder));
} catch (e) {
  console.error('[Admin Promo Videos] Load failed:', e);
}

const editId = Astro.url.searchParams.get('edit');
const isAdding = Astro.url.searchParams.get('action') === 'add';
const editVideo = editId ? allVideos.find(v => v.id === editId) : null;
const showForm = isAdding || editVideo;
const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
---

<AdminLayout title="Promo Videos" activeTab="promo-videos" subtitle={`${allVideos.length} promo videos configured`}>
  {message && <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">{message}</div>}
  {error && <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">{error}</div>}

  {showForm && (
    <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm mb-6">
      <h2 class="text-base font-bold text-neutral-900 mb-4">{editVideo ? 'Edit Promo Video' : 'Add Promo Video'}</h2>
      <form id="promo-form" method="post" data-deferred-upload-form class="grid gap-4 sm:grid-cols-2">
        <input type="hidden" name="_action" value="save" />
        {editVideo && <input type="hidden" name="id" value={editVideo.id} />}

        <div>
          <label class="block text-xs font-semibold text-neutral-700 mb-1">Title (English) *</label>
          <input type="text" name="title" required value={editVideo?.title || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" placeholder="e.g. Luminous Inverter Promo" />
        </div>

        <div>
          <label class="block text-xs font-semibold text-neutral-700 mb-1">Title (Gujarati)</label>
          <input type="text" name="titleGu" value={editVideo?.titleGu || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" placeholder="દા.ત. લ્યુમિનસ ઇન્વર્ટર પ્રોમો" />
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-neutral-700 mb-1">Description (English)</label>
          <textarea name="description" rows="2" class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" placeholder="Short description of the video ad...">{editVideo?.description || ''}</textarea>
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-neutral-700 mb-1">Description (Gujarati)</label>
          <textarea name="descriptionGu" rows="2" class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" placeholder="વિડીયો વિશે ટૂંકી માહિતી...">{editVideo?.descriptionGu || ''}</textarea>
        </div>

        <div>
          <label class="block text-xs font-semibold text-neutral-700 mb-1">Sort Order</label>
          <input type="number" name="sortOrder" value={editVideo?.sortOrder ?? 0} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>

        <div>
          <label class="block text-xs font-semibold text-neutral-700 mb-1">Status</label>
          <select name="isActive" class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none">
            <option value="true" selected={editVideo?.isActive !== false}>Active</option>
            <option value="false" selected={editVideo?.isActive === false}>Inactive</option>
          </select>
        </div>

        <!-- Video Upload / URL -->
        <div class="sm:col-span-2 border-t border-neutral-100 pt-3">
          <label class="block text-xs font-bold text-neutral-800 mb-2">1. Promo Video File (Vertical 9:16 recommended) *</label>
          <input type="text" id="videoUrl" name="videoUrl" required value={editVideo?.videoUrl || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none mb-2" placeholder="Video URL or Upload below" />
          
          <div id="video-preview" class="mb-3 hidden max-w-xs"></div>

          <div class="relative border border-dashed border-neutral-300 rounded-lg p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer text-center" id="video-upload-zone">
            <input type="file" id="video-file-picker" accept="video/*"
                   data-deferred-upload-picker
                   data-hidden-input="videoUrl"
                   data-previews-container="video-preview"
                   data-folder="yash-electronics/promo-videos"
                   data-aspect-ratio="NaN"
                   data-video-supported="true"
                   data-progress-bar="video-progress-bar"
                   data-progress-container="video-progress"
                   data-progress-percent="video-percent"
                   class="absolute inset-0 opacity-0 cursor-pointer" />
            <div class="space-y-1">
              <p class="text-xs font-semibold text-neutral-600">🎥 Click or drag to upload Reel Video</p>
              <p class="text-[10px] text-neutral-400">Supports MP4, WebM up to 50MB</p>
            </div>
          </div>

          <div id="video-progress" class="hidden mt-2 space-y-1">
            <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
              <span>Uploading video...</span>
              <span id="video-percent">0%</span>
            </div>
            <div class="w-full bg-neutral-200 rounded-full h-1.5 overflow-hidden">
              <div id="video-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
            </div>
          </div>
        </div>

        <!-- Thumbnail Upload / URL -->
        <div class="sm:col-span-2 border-t border-neutral-100 pt-3">
          <label class="block text-xs font-bold text-neutral-800 mb-2">2. Cover Thumbnail Image</label>
          <input type="text" id="thumbnailUrl" name="thumbnailUrl" value={editVideo?.thumbnailUrl || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none mb-2" placeholder="Image URL or Upload below" />
          
          <div id="thumbnail-preview" class="mb-3 hidden"></div>

          <div class="relative border border-dashed border-neutral-300 rounded-lg p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer text-center" id="thumbnail-upload-zone">
            <input type="file" id="thumbnail-file-picker" accept="image/*"
                   data-deferred-upload-picker
                   data-hidden-input="thumbnailUrl"
                   data-previews-container="thumbnail-preview"
                   data-folder="yash-electronics/promo-videos"
                   data-aspect-ratio="0.5625"
                   data-progress-bar="thumbnail-progress-bar"
                   data-progress-container="thumbnail-progress"
                   data-progress-percent="thumbnail-percent"
                   class="absolute inset-0 opacity-0 cursor-pointer" />
            <div class="space-y-1">
              <p class="text-xs font-semibold text-neutral-600">🖼️ Click or drag to upload Cover Image</p>
              <p class="text-[10px] text-neutral-400">Supports PNG, JPG, WebP</p>
            </div>
          </div>

          <div id="thumbnail-progress" class="hidden mt-2 space-y-1">
            <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
              <span>Uploading thumbnail...</span>
              <span id="thumbnail-percent">0%</span>
            </div>
            <div class="w-full bg-neutral-200 rounded-full h-1.5 overflow-hidden">
              <div id="thumbnail-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
            </div>
          </div>
        </div>

        <div class="sm:col-span-2 flex gap-2 border-t border-neutral-100 pt-4 mt-2">
          <button type="submit" class="btn-primary text-xs">{editVideo ? 'Update' : 'Add Video'}</button>
          <a href="/admin/promo-videos" class="btn-outline text-xs flex items-center justify-center">Cancel</a>
        </div>
      </form>
      <CropModal />
    </div>
  )}

  {!showForm && (
    <div class="flex justify-end mb-4 w-full">
      <a href="/admin/promo-videos?action=add" class="w-full sm:w-auto text-center btn-primary text-xs">+ Add Promo Video</a>
    </div>
  )}

  {/* Desktop Table View */}
  <div class="hidden md:block bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-neutral-50 border-b border-neutral-200">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold text-neutral-500 uppercase">Video Title</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-neutral-500 uppercase">Sort Order</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-neutral-500 uppercase">Status</th>
          <th class="text-right px-4 py-3 text-xs font-semibold text-neutral-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-neutral-100">
        {allVideos.map(video => (
          <tr class="hover:bg-neutral-50 transition-colors">
            <td class="px-4 py-3">
              <div class="flex items-center gap-3">
                {video.thumbnailUrl ? (
                  <img src={buildCloudinaryUrl(video.thumbnailUrl, { width: 100, height: 100 })} class="h-10 w-10 object-cover rounded-md border border-neutral-200" />
                ) : (
                  <div class="h-10 w-10 flex items-center justify-center bg-neutral-100 text-lg rounded-md border border-neutral-200">🎥</div>
                )}
                <div>
                  <p class="font-medium text-neutral-900">{video.title}</p>
                  {video.titleGu && <p class="text-xs text-neutral-500">{video.titleGu}</p>}
                </div>
              </div>
            </td>
            <td class="px-4 py-3 text-neutral-600">{video.sortOrder}</td>
            <td class="px-4 py-3">
              <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-semibold border ${video.isActive ? 'bg-green-50 text-green-700 border-green-200' : 'bg-neutral-50 text-neutral-600 border-neutral-200'}`}>
                {video.isActive ? 'Active' : 'Inactive'}
              </span>
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <a href={`/admin/promo-videos?edit=${video.id}`} class="text-xs font-semibold text-primary hover:underline">Edit</a>
                <form method="post" class="inline">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={video.id} />
                  <button type="button" onclick="confirmDelete(this, 'Delete Promo Video', 'Are you sure you want to delete this promo video?')" class="text-xs font-semibold text-red-500 hover:underline cursor-pointer">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        ))}
        {allVideos.length === 0 && (
          <tr>
            <td colspan="4" class="px-4 py-8 text-center text-neutral-500">No promo videos configured yet.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>

  {/* Mobile View */}
  <div class="md:hidden space-y-4">
    {allVideos.map(video => (
      <div class="bg-white border border-neutral-200 rounded-lg p-4 shadow-sm relative pr-20">
        <div class="flex items-center gap-3">
          {video.thumbnailUrl ? (
            <img src={buildCloudinaryUrl(video.thumbnailUrl, { width: 100, height: 100 })} class="h-12 w-12 object-cover rounded-md border border-neutral-200" />
          ) : (
            <div class="h-12 w-12 flex items-center justify-center bg-neutral-100 text-xl rounded-md border border-neutral-200">🎥</div>
          )}
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-sm text-neutral-900 truncate">{video.title}</h3>
            {video.titleGu && <p class="text-xs text-neutral-450 truncate">{video.titleGu}</p>}
            <span class={`inline-block rounded mt-1.5 px-1.5 py-0.5 text-[9px] font-bold border ${video.isActive ? 'bg-green-50 text-green-700 border-green-200' : 'bg-neutral-50 text-neutral-600 border-neutral-200'}`}>
              {video.isActive ? 'Active' : 'Inactive'}
            </span>
          </div>
        </div>

        <div class="absolute top-4 right-4 flex items-center gap-2">
          <a href={`/admin/promo-videos?edit=${video.id}`} class="w-8 h-8 rounded-full border border-neutral-200 flex items-center justify-center text-xs text-neutral-600 hover:text-primary transition-colors cursor-pointer" title="Edit">
            ✏️
          </a>
          <form method="post" class="inline m-0">
            <input type="hidden" name="_action" value="delete" />
            <input type="hidden" name="id" value={video.id} />
            <button type="button" onclick="confirmDelete(this, 'Delete Promo Video', 'Are you sure?')" class="w-8 h-8 rounded-full border border-red-100 bg-red-50 hover:bg-red-100 flex items-center justify-center text-xs text-red-655 transition-colors cursor-pointer" title="Delete">
              🗑️
            </button>
          </form>
        </div>
      </div>
    ))}
    {allVideos.length === 0 && (
      <div class="bg-white border border-neutral-200 rounded-lg p-8 text-center text-neutral-500 text-sm">
        No promo videos configured yet.
      </div>
    )}
  </div>
</AdminLayout>

<script is:inline>
  function confirmDelete(button, title, text) {
    if (confirm(text || 'Are you sure?')) {
      button.closest('form').submit();
    }
  }
</script>
