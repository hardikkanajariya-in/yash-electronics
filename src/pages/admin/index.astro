---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { db } from '../../db';
import { products, offers, orders, contactQueries, teamMembers, services } from '../../db/schema';
import { getSessionUser, clearSessionUser } from '../../lib/auth';
import { sql } from 'drizzle-orm';

export const prerender = false;

// Authenticate
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/admin/login');
}

// Handle Logout
if (Astro.url.searchParams.get('action') === 'logout') {
  clearSessionUser(Astro.cookies, Astro.url);
  return Astro.redirect('/admin/login');
}

// Fetch stats
let stats = {
  productsCount: 0,
  offersCount: 0,
  ordersCount: 0,
  queriesCount: 0,
  totalSales: 0,
  teamCount: 0,
  servicesCount: 0,
};

try {
  const [pCount] = await db.select({ count: sql`count(*)` }).from(products);
  const [oCount] = await db.select({ count: sql`count(*)` }).from(offers);
  const [ordCount] = await db.select({ count: sql`count(*)`, sales: sql`sum(total_amount)` }).from(orders);
  const [qCount] = await db.select({ count: sql`count(*)` }).from(contactQueries);
  
  let tCount = { count: 0 };
  let sCount = { count: 0 };
  try {
    [tCount] = await db.select({ count: sql`count(*)` }).from(teamMembers) as any[];
    [sCount] = await db.select({ count: sql`count(*)` }).from(services) as any[];
  } catch (e) { /* tables may not exist yet */ }

  stats = {
    productsCount: Number(pCount?.count || 0),
    offersCount: Number(oCount?.count || 0),
    ordersCount: Number(ordCount?.count || 0),
    queriesCount: Number(qCount?.count || 0),
    totalSales: Number((ordCount as any)?.sales || 0),
    teamCount: Number(tCount?.count || 0),
    servicesCount: Number(sCount?.count || 0),
  };
} catch (e) {
  console.error('[Admin Dashboard] Failed to fetch stats:', e);
}
---

<BaseLayout title="Admin Dashboard" noindex={true}>
  <Container class="py-6">
    <div class="flex items-center justify-between border-b border-neutral-200 pb-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold text-neutral-900">Admin Dashboard</h1>
        <p class="text-xs text-neutral-500">Welcome, {currentUser.name}</p>
      </div>
      <a href="/admin?action=logout" class="text-xs font-semibold text-red-600 border border-red-200 bg-red-50 hover:bg-red-100 rounded-md px-3 py-1.5 transition-colors">
        Sign Out
      </a>
    </div>

    <!-- Navigation Tabs -->
    <nav class="flex flex-wrap border-b border-neutral-200 gap-x-4 gap-y-1 mb-6 text-sm font-medium">
      <a data-astro-prefetch="false" href="/admin" class="border-b-2 border-primary text-primary px-1 pb-3">Overview</a>
      <a data-astro-prefetch="false" href="/admin/products" class="text-neutral-600 hover:text-primary px-1 pb-3">Products</a>
      <a data-astro-prefetch="false" href="/admin/offers" class="text-neutral-600 hover:text-primary px-1 pb-3">Offers</a>
      <a data-astro-prefetch="false" href="/admin/orders" class="text-neutral-600 hover:text-primary px-1 pb-3">Orders ({stats.ordersCount})</a>
      <a data-astro-prefetch="false" href="/admin/queries" class="text-neutral-600 hover:text-primary px-1 pb-3">Queries ({stats.queriesCount})</a>
      <a data-astro-prefetch="false" href="/admin/team" class="text-neutral-600 hover:text-primary px-1 pb-3">Team</a>
      <a data-astro-prefetch="false" href="/admin/services" class="text-neutral-600 hover:text-primary px-1 pb-3">Services</a>
      <a data-astro-prefetch="false" href="/admin/about" class="text-neutral-600 hover:text-primary px-1 pb-3">About</a>
      <a data-astro-prefetch="false" href="/admin/bank-details" class="text-neutral-600 hover:text-primary px-1 pb-3">Bank</a>
      <a data-astro-prefetch="false" href="/admin/business-hours" class="text-neutral-600 hover:text-primary px-1 pb-3">Hours</a>
    </nav>

    <!-- Stats Grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-8">
      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm">
        <p class="text-xs font-medium text-neutral-500 uppercase">Total Sales</p>
        <p class="text-2xl font-bold text-primary mt-1">₹{stats.totalSales.toLocaleString('en-IN')}</p>
        <span class="text-neutral-400 text-[10px]">From completed & pending orders</span>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm">
        <p class="text-xs font-medium text-neutral-500 uppercase">Total Orders</p>
        <p class="text-2xl font-bold text-neutral-900 mt-1">{stats.ordersCount}</p>
        <a href="/admin/orders" class="text-xs text-primary font-medium hover:underline mt-1 inline-block">Manage Orders →</a>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm">
        <p class="text-xs font-medium text-neutral-500 uppercase">Store Products</p>
        <p class="text-2xl font-bold text-neutral-900 mt-1">{stats.productsCount}</p>
        <a href="/admin/products" class="text-xs text-primary font-medium hover:underline mt-1 inline-block">Manage Catalog →</a>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm">
        <p class="text-xs font-medium text-neutral-500 uppercase">Customer Inquiries</p>
        <p class="text-2xl font-bold text-neutral-900 mt-1">{stats.queriesCount}</p>
        <a href="/admin/queries" class="text-xs text-primary font-medium hover:underline mt-1 inline-block">View Queries →</a>
      </div>
    </div>

    <!-- Quick Links Grid -->
    <div class="bg-white border border-neutral-200 rounded-lg p-6 shadow-sm">
      <h2 class="text-lg font-bold text-neutral-900 mb-4">Quick Management Actions</h2>
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-4">
        <a href="/admin/products?action=add" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-primary/10 text-primary mb-2 text-lg font-bold">+</span>
          <span class="text-sm font-semibold text-neutral-800">Add Product</span>
          <span class="text-xs text-neutral-400 mt-0.5">Upload new catalog item</span>
        </a>

        <a href="/admin/team" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-accent/10 text-accent mb-2 text-sm font-bold">👥</span>
          <span class="text-sm font-semibold text-neutral-800">Manage Team</span>
          <span class="text-xs text-neutral-400 mt-0.5">{stats.teamCount} members</span>
        </a>

        <a href="/admin/services" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-secondary/10 text-secondary mb-2 text-sm font-bold">🔧</span>
          <span class="text-sm font-semibold text-neutral-800">Manage Services</span>
          <span class="text-xs text-neutral-400 mt-0.5">{stats.servicesCount} services</span>
        </a>

        <a href="/admin/about" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-primary/10 text-primary mb-2 text-sm font-bold">📝</span>
          <span class="text-sm font-semibold text-neutral-800">About / Leadership</span>
          <span class="text-xs text-neutral-400 mt-0.5">Founder, Owner, Next Gen</span>
        </a>

        <a href="/admin/bank-details" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-green-100 text-green-700 mb-2 text-sm font-bold">🏦</span>
          <span class="text-sm font-semibold text-neutral-800">Bank Details</span>
          <span class="text-xs text-neutral-400 mt-0.5">Payment info & QR codes</span>
        </a>

        <a href="/admin/business-hours" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-blue-100 text-blue-700 mb-2 text-sm font-bold">🕐</span>
          <span class="text-sm font-semibold text-neutral-800">Business Hours</span>
          <span class="text-xs text-neutral-400 mt-0.5">Opening times per day</span>
        </a>

        <a href="/admin/orders" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-accent/10 text-accent mb-2 text-sm font-bold">📦</span>
          <span class="text-sm font-semibold text-neutral-800">View Orders</span>
          <span class="text-xs text-neutral-400 mt-0.5">Approve, deliver or cancel</span>
        </a>

        <a href="/admin/queries" class="flex flex-col items-center justify-center p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors">
          <span class="h-8 w-8 flex items-center justify-center rounded-full bg-green-100 text-green-700 mb-2 text-sm font-bold">💬</span>
          <span class="text-sm font-semibold text-neutral-800">Read Messages</span>
          <span class="text-xs text-neutral-400 mt-0.5">Reply to support requests</span>
        </a>
      </div>
    </div>
  </Container>
</BaseLayout>
