---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db } from "../../db";
import {
  products,
  offers,
  orders,
  contactQueries,
  teamMembers,
  services,
  serviceRequests,
  users,
} from "../../db/schema";
import { getSessionUser, clearSessionUser } from "../../lib/auth";
import { sql, eq } from "drizzle-orm";

export const prerender = false;

// Authenticate
Astro.response.headers.set(
  "Cache-Control",
  "no-cache, no-store, must-revalidate",
);
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== "admin") {
  return Astro.redirect(
    "/account/login?redirect=" + encodeURIComponent(Astro.url.pathname),
  );
}

// Handle Logout
if (Astro.url.searchParams.get("action") === "logout") {
  clearSessionUser(Astro.cookies, Astro.url);
  return Astro.redirect(
    "/account/login?redirect=" + encodeURIComponent(Astro.url.pathname),
  );
}

// Fetch stats
let stats = {
  productsCount: 0,
  offersCount: 0,
  ordersCount: 0,
  queriesCount: 0,
  totalSales: 0,
  teamCount: 0,
  servicesCount: 0,
  srsCount: 0,
  customersCount: 0,
};

try {
  const [pCount] = await db.select({ count: sql`count(*)` }).from(products);
  const [oCount] = await db.select({ count: sql`count(*)` }).from(offers);
  const [ordCount] = await db
    .select({ count: sql`count(*)`, sales: sql`sum(total_amount)` })
    .from(orders);
  const [qCount] = await db
    .select({ count: sql`count(*)` })
    .from(contactQueries);
  const [srsCount] = await db
    .select({ count: sql`count(*)` })
    .from(serviceRequests);
  const [cCount] = await db
    .select({ count: sql`count(*)` })
    .from(users)
    .where(eq(users.role, "customer"));

  let tCount = { count: 0 };
  let sCount = { count: 0 };
  try {
    [tCount] = (await db
      .select({ count: sql`count(*)` })
      .from(teamMembers)) as any[];
    [sCount] = (await db
      .select({ count: sql`count(*)` })
      .from(services)) as any[];
  } catch (e) {
    /* tables may not exist yet */
  }

  stats = {
    productsCount: Number(pCount?.count || 0),
    offersCount: Number(oCount?.count || 0),
    ordersCount: Number(ordCount?.count || 0),
    queriesCount: Number(qCount?.count || 0),
    totalSales: Number((ordCount as any)?.sales || 0),
    teamCount: Number(tCount?.count || 0),
    servicesCount: Number(sCount?.count || 0),
    srsCount: Number(srsCount?.count || 0),
    customersCount: Number(cCount?.count || 0),
  };
} catch (e) {
  console.error("[Admin Dashboard] Failed to fetch stats:", e);
}
---

<AdminLayout
  title="Admin Dashboard"
  activeTab="overview"
  subtitle={`Welcome back, ${currentUser.name}`}
>
  <!-- Stats Grid -->
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-2 lg:grid-cols-5 mb-8">
    <div
      class="col-span-2 sm:col-span-1 bg-white border border-neutral-200 rounded-lg p-4 sm:p-5 shadow-sm"
    >
      <p class="text-xs font-medium text-neutral-500 uppercase">Total Sales</p>
      <p class="text-xl sm:text-2xl font-bold text-primary mt-1">
        ₹{stats.totalSales.toLocaleString("en-IN")}
      </p>
      <span class="text-neutral-400 text-[10px]"
        >From completed & pending orders</span
      >
    </div>

    <div
      class="bg-white border border-neutral-200 rounded-lg p-4 sm:p-5 shadow-sm"
    >
      <p class="text-xs font-medium text-neutral-500 uppercase">Total Orders</p>
      <p class="text-xl sm:text-2xl font-bold text-neutral-900 mt-1">
        {stats.ordersCount}
      </p>
      <a
        href="/admin/orders"
        class="text-xs text-primary font-medium hover:underline mt-1 inline-block"
        >Manage Orders →</a
      >
    </div>

    <div
      class="bg-white border border-neutral-200 rounded-lg p-4 sm:p-5 shadow-sm"
    >
      <p class="text-xs font-medium text-neutral-500 uppercase">Customers</p>
      <p class="text-xl sm:text-2xl font-bold text-neutral-900 mt-1">
        {stats.customersCount}
      </p>
      <a
        href="/admin/customers"
        class="text-xs text-primary font-medium hover:underline mt-1 inline-block"
        >Manage Users →</a
      >
    </div>

    <div
      class="bg-white border border-neutral-200 rounded-lg p-4 sm:p-5 shadow-sm"
    >
      <p class="text-xs font-medium text-neutral-500 uppercase">
        Store Products
      </p>
      <p class="text-xl sm:text-2xl font-bold text-neutral-900 mt-1">
        {stats.productsCount}
      </p>
      <a
        href="/admin/products"
        class="text-xs text-primary font-medium hover:underline mt-1 inline-block"
        >Manage Catalog →</a
      >
    </div>

    <div
      class="bg-white border border-neutral-200 rounded-lg p-4 sm:p-5 shadow-sm"
    >
      <p class="text-xs font-medium text-neutral-500 uppercase">Inquiries</p>
      <p class="text-xl sm:text-2xl font-bold text-neutral-900 mt-1">
        {stats.queriesCount}
      </p>
      <a
        href="/admin/queries"
        class="text-xs text-primary font-medium hover:underline mt-1 inline-block"
        >View Queries →</a
      >
    </div>
  </div>

  <!-- Quick Links Grid -->
  <div
    class="bg-white border border-neutral-200 rounded-lg p-4 sm:p-6 shadow-sm"
  >
    <h2 class="text-base sm:text-lg font-bold text-neutral-900 mb-4">
      Quick Management Actions
    </h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-2 md:grid-cols-4">
      <a
        href="/admin/products?action=add"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-primary/10 text-primary mb-2 text-sm sm:text-lg font-bold"
          >+</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Add Product</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >Upload new catalog item</span
        >
      </a>

      <a
        href="/admin/customers"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-blue-100 text-blue-700 mb-2 text-sm font-bold"
          >👤</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Manage Customers</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >{stats.customersCount} registered users</span
        >
      </a>

      <a
        href="/admin/team"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-accent/10 text-accent mb-2 text-sm font-bold"
          >👥</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Manage Team</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >{stats.teamCount} members</span
        >
      </a>

      <a
        href="/admin/services"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-secondary/10 text-secondary mb-2 text-sm font-bold"
          >🔧</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Manage Services</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >{stats.servicesCount} services</span
        >
      </a>

      <a
        href="/admin/about"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-primary/10 text-primary mb-2 text-sm font-bold"
          >📝</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >About Info</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >Founder, Owner, Next Gen</span
        >
      </a>

      <a
        href="/admin/bank-details"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-green-100 text-green-700 mb-2 text-sm font-bold"
          >🏦</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Bank Details</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >Payment info & QR codes</span
        >
      </a>

      <a
        href="/admin/business-hours"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-blue-100 text-blue-700 mb-2 text-sm font-bold"
          >🕐</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Business Hours</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >Opening times per day</span
        >
      </a>

      <a
        href="/admin/orders"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-accent/10 text-accent mb-2 text-sm font-bold"
          >📦</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >View Orders</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >Approve, deliver or cancel</span
        >
      </a>

      <a
        href="/admin/queries"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-green-100 text-green-700 mb-2 text-sm font-bold"
          >💬</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Read Messages</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >Reply to support requests</span
        >
      </a>

      <a
        href="/admin/service-requests"
        class="flex flex-col items-center justify-center p-3 sm:p-4 border border-dashed border-neutral-300 rounded-lg hover:border-primary hover:bg-neutral-50 text-center transition-colors"
      >
        <span
          class="h-8 w-8 flex items-center justify-center rounded-full bg-amber-100 text-amber-700 mb-2 text-sm font-bold"
          >🔧</span
        >
        <span class="text-xs sm:text-sm font-semibold text-neutral-800"
          >Service Requests</span
        >
        <span
          class="text-[10px] sm:text-xs text-neutral-400 mt-0.5 leading-tight"
          >Process complaints ({stats.srsCount})</span
        >
      </a>
    </div>
  </div>
</AdminLayout>
