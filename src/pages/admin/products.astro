                    if (!res.ok) {
                      throw new Error(`Server returned status ${res.status}`);
                    }
                    
                    const data = await res.json();
                    if (data.success) {
                      updateGalleryDom(productId, data.images);
                    } else {
                      alert('Failed to save uploaded image: ' + data.error);
                    }
                  }
                } catch (err) {
                  alert(`Upload failed for "${fileToUpload.name}": ` + err);
                }

                if (uploadedCount === totalCount) {
                  statusEls.forEach(statusEl => {
                    statusEl.classList.add('hidden');
                  });
                  input.value = '';
                }
              });
            });
          });
        </script>
