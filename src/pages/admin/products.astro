---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { db } from '../../db';
import { products, categories, brands } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { getSessionUser, generateId } from '../../lib/auth';

export const prerender = false;

// Authenticate
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/admin/login');
}

const action = Astro.url.searchParams.get('action') || 'list';
const productId = Astro.url.searchParams.get('id') || '';

let error = '';
let success = '';

// Fetch categories and brands for the dropdowns
const [allCategories, allBrands] = await Promise.all([
  db.select().from(categories),
  db.select().from(brands),
]);

// Handle POST actions (Create, Update, Delete)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('formAction')?.toString() || '';

    if (formAction === 'delete') {
      const idToDelete = formData.get('id')?.toString() || '';
      await db.delete(products).where(eq(products.id, idToDelete));
      success = 'Product deleted successfully!';
    } else if (formAction === 'save') {
      const name = formData.get('name')?.toString() || '';
      const slug = formData.get('slug')?.toString() || '';
      const brandId = formData.get('brandId')?.toString() || null;
      const categoryId = formData.get('categoryId')?.toString() || null;
      const modelNumber = formData.get('modelNumber')?.toString() || '';
      const description = formData.get('description')?.toString() || '';
      const specifications = formData.get('specifications')?.toString() || '{}';
      const mrp = Number(formData.get('mrp') || 0);
      const offerPrice = Number(formData.get('offerPrice') || 0);
      const isFeatured = formData.get('isFeatured') === 'on';
      const isActive = formData.get('isActive') === 'on';
      const imagesString = formData.get('images')?.toString() || '';
      const imagesArray = imagesString.split(',').map(s => s.trim()).filter(Boolean);

      if (productId) {
        // Edit existing product
        await db.update(products).set({
          name,
          slug,
          brandId,
          categoryId,
          modelNumber,
          description,
          specifications,
          mrp,
          offerPrice,
          images: imagesArray,
          isFeatured,
          isActive,
          updatedAt: new Date().toISOString(),
        }).where(eq(products.id, productId));
        success = 'Product updated successfully!';
      } else {
        // Create new product
        const newId = generateId();
        await db.insert(products).values({
          id: newId,
          name,
          slug,
          brandId,
          categoryId,
          modelNumber,
          description,
          specifications,
          mrp,
          offerPrice,
          images: imagesArray,
          isFeatured,
          isActive,
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString(),
        });
        success = 'Product added successfully!';
      }
    }
  } catch (e: any) {
    error = e.message || 'Failed to save product. Ensure slug is unique.';
  }
}

// Fetch single product if in edit mode
let editProduct: any = null;
if (action === 'edit' && productId) {
  const [found] = await db.select().from(products).where(eq(products.id, productId));
  editProduct = found;
}

// Fetch all products for list view
const allProducts = await db.select().from(products);
const emptySpecifications = '{}';
---

<BaseLayout title="Manage Products" noindex={true}>
  <Container class="py-6">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-neutral-200 pb-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold text-neutral-900">Manage Catalog</h1>
        <p class="text-xs text-neutral-500">Add, edit, or delete store products</p>
      </div>
      <div class="flex gap-2">
        <a href="/admin" class="text-xs font-semibold text-neutral-600 border border-neutral-300 rounded-md px-3 py-1.5 hover:bg-neutral-50 transition-colors">
          ← Dashboard
        </a>
        {action === 'list' && (
          <a href="/admin/products?action=add" class="text-xs font-semibold text-white bg-primary hover:bg-primary/95 rounded-md px-3 py-1.5 transition-colors">
            + Add Product
          </a>
        )}
      </div>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    <!-- LIST VIEW -->
    {action === 'list' && (
      <div class="bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm text-neutral-700 border-collapse">
            <thead>
              <tr class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900">
                <th class="p-3">Product Name</th>
                <th class="p-3">Model</th>
                <th class="p-3">Offer Price</th>
                <th class="p-3">MRP</th>
                <th class="p-3">Status</th>
                <th class="p-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              {allProducts.map((prod) => (
                <tr class="border-b border-neutral-100 hover:bg-neutral-50/50">
                  <td class="p-3 font-medium text-neutral-900">{prod.name}</td>
                  <td class="p-3 text-xs text-neutral-500">{prod.modelNumber || '-'}</td>
                  <td class="p-3 font-semibold text-primary">
                    ₹{prod.offerPrice.toLocaleString('en-IN')}
                  </td>
                  <td class="p-3 text-neutral-400 line-through">
                    ₹{prod.mrp.toLocaleString('en-IN')}
                  </td>
                  <td class="p-3">
                    <span class={prod.isActive ? "inline-block rounded px-2 py-0.5 text-xs font-medium bg-green-50 text-green-700 border border-green-200" : "inline-block rounded px-2 py-0.5 text-xs font-medium bg-red-50 text-red-700 border border-red-200"}>
                      {prod.isActive ? 'Active' : 'Inactive'}
                    </span>
                    {prod.isFeatured && <span class="inline-block rounded bg-yellow-50 text-yellow-700 border border-yellow-200 px-2 py-0.5 text-xs font-medium ml-1">Featured</span>}
                  </td>
                  <td class="p-3 text-right flex justify-end gap-2">
                    <a href={"/admin/products?action=edit&id=" + prod.id} class="text-xs font-semibold text-primary hover:underline">
                      Edit
                    </a>
                    <form method="post" class="inline">
                      <input type="hidden" name="formAction" value="delete" />
                      <input type="hidden" name="id" value={prod.id} />
                      <button 
                        type="button" 
                        onclick="window.confirmDelete(this, 'Delete Product', 'Are you sure you want to delete this product?')"
                        class="text-xs font-semibold text-red-600 hover:underline bg-none border-none cursor-pointer focus:outline-none"
                      >
                        Delete
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
              {allProducts.length === 0 && (
                <tr>
                  <td colspan="6" class="p-8 text-center text-neutral-500">No products found. Add some to get started.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <!-- ADD/EDIT FORM VIEW -->
    {(action === 'add' || action === 'edit') && (
      <div class="bg-white border border-neutral-200 rounded-lg p-6 shadow-sm max-w-2xl mx-auto">
        <h2 class="text-lg font-bold text-neutral-900 mb-6">{action === 'edit' ? 'Edit Product' : 'Add New Product'}</h2>
        
        <form method="post" class="space-y-4">
          <input type="hidden" name="formAction" value="save" />

          <div>
            <label for="name" class="block text-sm font-semibold text-neutral-700 mb-1">Product Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={editProduct?.name || ''}
              placeholder="e.g. Sony Bravia 55"
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            />
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="slug" class="block text-sm font-semibold text-neutral-700 mb-1">Slug (URL parameter) *</label>
              <input
                type="text"
                id="slug"
                name="slug"
                required
                value={editProduct?.slug || ''}
                placeholder="e.g. sony-bravia-55"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </div>
            <div>
              <label for="modelNumber" class="block text-sm font-semibold text-neutral-700 mb-1">Model Number</label>
              <input
                type="text"
                id="modelNumber"
                name="modelNumber"
                value={editProduct?.modelNumber || ''}
                placeholder="e.g. KD-55X75L"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="brandId" class="block text-sm font-semibold text-neutral-700 mb-1">Brand</label>
              <select
                id="brandId"
                name="brandId"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >
                <option value="">Select Brand</option>
                {allBrands.map(b => (
                  <option value={b.id} selected={editProduct?.brandId === b.id}>{b.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="categoryId" class="block text-sm font-semibold text-neutral-700 mb-1">Category</label>
              <select
                id="categoryId"
                name="categoryId"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >
                <option value="">Select Category</option>
                {allCategories.map(c => (
                  <option value={c.id} selected={editProduct?.categoryId === c.id}>{c.name}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="mrp" class="block text-sm font-semibold text-neutral-700 mb-1">MRP (Original Price) *</label>
              <input
                type="number"
                id="mrp"
                name="mrp"
                required
                value={editProduct?.mrp || ''}
                placeholder="e.g. 89990"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary"
              />
            </div>
            <div>
              <label for="offerPrice" class="block text-sm font-semibold text-neutral-700 mb-1">Offer Price *</label>
              <input
                type="number"
                id="offerPrice"
                name="offerPrice"
                required
                value={editProduct?.offerPrice || ''}
                placeholder="e.g. 74990"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-neutral-700 mb-2">Product Images</label>
            <input type="hidden" id="images" name="images" value={editProduct?.images?.join(',') || ''} />
            
            <div id="image-previews" class="flex flex-wrap gap-3 mb-3"></div>

            <div class="relative border-2 border-dashed border-neutral-300 rounded-lg p-6 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer group text-center" id="upload-dropzone">
              <input type="file" id="file-picker" multiple accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
              <div class="space-y-1">
                <span class="text-2xl text-neutral-400 group-hover:text-primary transition-colors">📷</span>
                <p class="text-xs font-semibold text-neutral-600">Click to upload or drag & drop</p>
                <p class="text-[10px] text-neutral-400">Supports JPG, PNG, WEBP</p>
              </div>
            </div>

            <div id="upload-progress-container" class="hidden mt-3 space-y-1.5">
              <div class="flex justify-between text-[11px] font-semibold text-neutral-500">
                <span id="upload-status">Uploading...</span>
                <span id="upload-percent">0%</span>
              </div>
              <div class="w-full bg-neutral-200 rounded-full h-1.5 overflow-hidden">
                <div id="upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
              </div>
            </div>
          </div>

          <div>
            <label for="description" class="block text-sm font-semibold text-neutral-700 mb-1">Product Description</label>
            <textarea
              id="description"
              name="description"
              rows="3"
              placeholder="Enter product details..."
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
            >{editProduct?.description || ''}</textarea>
          </div>

          <div>
            <label class="block text-sm font-semibold text-neutral-700 mb-2">Specifications</label>
            <input type="hidden" id="specifications" name="specifications" value={editProduct?.specifications || emptySpecifications} />
            
            <div id="specs-list" class="space-y-2 mb-3"></div>
            
            <button
              type="button"
              id="add-spec-btn"
              class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:text-primary-700 transition-colors bg-primary/10 px-3 py-1.5 rounded"
            >
              + Add Specification
            </button>
          </div>

          <div class="flex items-center gap-6 py-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="isFeatured" checked={editProduct ? editProduct.isFeatured : false} class="rounded border-neutral-300 text-primary focus:ring-primary" />
              <span class="text-sm font-semibold text-neutral-700">Featured Product</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="isActive" checked={editProduct ? editProduct.isActive : true} class="rounded border-neutral-300 text-primary focus:ring-primary" />
              <span class="text-sm font-semibold text-neutral-700">Product Active</span>
            </label>
          </div>

          <div class="flex justify-end gap-3 pt-4 border-t border-neutral-200">
            <a href="/admin/products" class="btn-outline px-4 py-2 text-sm">
              Cancel
            </a>
            <button type="submit" class="btn-primary px-6 py-2 text-sm font-medium">
              Save Product
            </button>
          </div>
         </form>

        <script>
          // Specifications Editor
          const specsInput = document.getElementById('specifications') as HTMLInputElement;
          const specsList = document.getElementById('specs-list');
          const addSpecBtn = document.getElementById('add-spec-btn');

          function getSpecsData() {
            try {
              return JSON.parse(specsInput.value || '{}');
            } catch(e) {
              return {};
            }
          }

          function saveSpecsData() {
            const data: Record<string, string> = {};
            const rows = specsList?.querySelectorAll('.spec-row');
            rows?.forEach(row => {
              const keyInput = row.querySelector('.spec-key') as HTMLInputElement;
              const valInput = row.querySelector('.spec-val') as HTMLInputElement;
              if (keyInput && valInput && keyInput.value.trim()) {
                data[keyInput.value.trim()] = valInput.value.trim();
              }
            });
            specsInput.value = JSON.stringify(data);
          }

          function createSpecRow(key = '', val = '') {
            const div = document.createElement('div');
            div.className = 'spec-row flex gap-2 items-center';
            div.innerHTML = `
              <input type="text" placeholder="Specification Name (e.g. Screen Size)" value="${key}" class="spec-key flex-1 rounded-md border border-neutral-300 px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-primary" />
              <input type="text" placeholder="Value (e.g. 55 inch)" value="${val}" class="spec-val flex-1 rounded-md border border-neutral-300 px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-primary" />
              <button type="button" class="remove-spec-btn text-red-500 hover:text-red-700 p-1.5 rounded transition-colors text-sm">✕</button>
            `;
            
            div.querySelector('.spec-key')?.addEventListener('input', saveSpecsData);
            div.querySelector('.spec-val')?.addEventListener('input', saveSpecsData);
            div.querySelector('.remove-spec-btn')?.addEventListener('click', () => {
              div.remove();
              saveSpecsData();
            });

            specsList?.appendChild(div);
          }

          // File Uploader
          const imagesInput = document.getElementById('images') as HTMLInputElement;
          const previewsContainer = document.getElementById('image-previews');
          const filePicker = document.getElementById('file-picker') as HTMLInputElement;
          const progressContainer = document.getElementById('upload-progress-container');
          const progressBar = document.getElementById('upload-progress-bar');
          const progressPercent = document.getElementById('upload-percent');
          const progressStatus = document.getElementById('upload-status');

          const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dyjsrdrxa';

          function getImages() {
            return imagesInput.value.split(',').map(s => s.trim()).filter(Boolean);
          }

          function saveImages(arr: string[]) {
            imagesInput.value = arr.join(',');
          }

          function renderPreviews() {
            if (!previewsContainer) return;
            previewsContainer.innerHTML = '';
            const images = getImages();
            images.forEach(img => {
              let displayUrl = img;
              if (!img.startsWith('http') && !img.startsWith('/')) {
                displayUrl = `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/w_200,h_200,c_fill,f_auto,q_auto/${img}`;
              }
              
              const div = document.createElement('div');
              div.className = 'relative group w-20 h-20 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
              div.innerHTML = `
                <img src="${displayUrl}" class="w-full h-full object-cover" />
                <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
              `;
              
              div.querySelector('button')?.addEventListener('click', () => {
                const remaining = getImages().filter(x => x !== img);
                saveImages(remaining);
                renderPreviews();
              });
              
              previewsContainer.appendChild(div);
            });
          }

          filePicker?.addEventListener('change', async () => {
            const files = filePicker.files;
            if (!files || files.length === 0) return;

            progressContainer?.classList.remove('hidden');
            const imagesList = getImages();

            for (let i = 0; i < files.length; i++) {
              const file = files[i];
              progressStatus!.textContent = `Uploading file ${i + 1} of ${files.length}...`;
              
              try {
                const publicId = await uploadFileWithProgress(file, (percent) => {
                  progressBar!.style.width = `${percent}%`;
                  progressPercent!.textContent = `${percent}%`;
                });
                
                if (publicId) {
                  imagesList.push(publicId);
                  saveImages(imagesList);
                  renderPreviews();
                }
              } catch (err) {
                alert('Upload failed: ' + err);
              }
            }

            progressContainer?.classList.add('hidden');
            filePicker.value = '';
          });

          function uploadFileWithProgress(file: File, onProgress: (pct: number) => void): Promise<string> {
            return new Promise((resolve, reject) => {
              const xhr = new XMLHttpRequest();
              xhr.open('POST', '/api/upload', true);
              
              xhr.upload.onprogress = (e) => {
                if (e.lengthComputable) {
                  const pct = Math.round((e.loaded / e.total) * 100);
                  onProgress(pct);
                }
              };

              xhr.onload = () => {
                if (xhr.status === 200) {
                  try {
                    const res = JSON.parse(xhr.responseText);
                    resolve(res.public_id || res.url);
                  } catch(e) {
                    reject('Invalid response');
                  }
                } else {
                  reject('Server returned status ' + xhr.status);
                }
              };

              xhr.onerror = () => reject('Network error');

              const formData = new FormData();
              formData.append('file', file);
              xhr.send(formData);
            });
          }

          // Initialize
          const initialSpecs = getSpecsData();
          Object.entries(initialSpecs).forEach(([key, val]) => {
            createSpecRow(key, val as string);
          });

          addSpecBtn?.addEventListener('click', () => {
            createSpecRow();
          });

          renderPreviews();
        </script>
      </div>
    )}  
  </Container>
</BaseLayout>
