---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db, pool } from '../../db';
import { products, categories, brands } from '../../db/schema';
import { eq, and, or, ilike, sql, asc, desc } from 'drizzle-orm';
import { getSessionUser, generateId } from '../../lib/auth';
import { importProductsFromCsv, exportProductsToCsv } from '../../lib/csv';
import { clearCmsCache } from '../../services/cms';
import { seedReviewsForProduct } from '../../lib/review-seeder';

export const prerender = false;

const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dyjsrdrxa';
function getProductImageUrl(img: string | undefined | null) {
  if (!img) return '/images/placeholder-product.svg';
  if (img.startsWith('http') || img.startsWith('/')) return img;
  const isVideo = img.endsWith('.mp4') || img.endsWith('.webm') || img.endsWith('.ogg') || img.endsWith('.mov');
  if (isVideo) {
    const publicIdWithJpg = img.substring(0, img.lastIndexOf('.')) + '.jpg';
    return `https://res.cloudinary.com/${CLOUD_NAME}/video/upload/w_100,h_100,c_fill,q_auto/${publicIdWithJpg}`;
  }
  return `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/w_100,h_100,c_fill,f_auto,q_auto/${img}`;
}

// Authenticate
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

const action = Astro.url.searchParams.get('action') || 'list';
const productId = Astro.url.searchParams.get('id') || '';

let error = Astro.url.searchParams.get('error') || '';
let success = Astro.url.searchParams.get('success') || '';

// Handle CSV Export and Template Downloads
if (action === 'export') {
  try {
    const csvContent = await exportProductsToCsv();
    return new Response('\uFEFF' + csvContent, {
      headers: {
        'Content-Type': 'text/csv; charset=utf-8',
        'Content-Disposition': 'attachment; filename="yash_electronics_products.csv"',
      }
    });
  } catch (e: any) {
    error = 'Failed to export CSV: ' + e.message;
  }
}

if (action === 'template') {
  const headers = [
    'Name',
    'Slug',
    'Brand',
    'Category',
    'Model Number',
    'MRP',
    'Offer Price',
    'Featured',
    'Eligible for Bundle',
    'Active',
    'Specifications',
    'Description',
    'Name (Gujarati)',
    'Brand (Gujarati)',
    'Category (Gujarati)',
    'Specifications (Gujarati)',
    'Description (Gujarati)'
  ];
  const sampleRow = [
    'Luminous Zelio+ 1100 Inverter',
    'luminous-zelio-1100',
    'Luminous',
    'Home Inverters',
    'Zelio+ 1100',
    '9500',
    '7999',
    'true',
    'true',
    'true',
    'Capacity: 900 VA; Output Waveform: Pure Sine Wave; Warranty: 2 Years',
    'India\'s most intelligent home UPS with LED display for backup status.',
    'લ્યુમિનસ ઝેલિયો+ ૧૧૦૦ હોમ યુપીએસ',
    'Luminous',
    'Home Inverters',
    'Capacity: 900 VA; Output Waveform: Pure Sine Wave; Warranty: 2 Years',
    'એલઇડી ડિસ્પ્લે સાથે ભારતનું સૌથી બુદ્ધિશાળી હોમ યુપીએસ.'
  ];
  
  return new Response(
    '\uFEFF' + headers.join(',') + '\r\n' + sampleRow.map(v => '"' + v.replace(/"/g, '""') + '"').join(','),
    {
      headers: {
        'Content-Type': 'text/csv; charset=utf-8',
        'Content-Disposition': 'attachment; filename="products_csv_template.csv"',
      }
    }
  );
}

// Fetch categories and brands for the dropdowns
const [allCategories, allBrands] = await Promise.all([
  db.select().from(categories),
  db.select().from(brands),
]);

let redirectUrl = '';

// Handle POST actions (Create, Update, Delete, Import)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('formAction')?.toString() || '';

    if (formAction === 'import_csv') {
      const file = formData.get('csvFile') as File;
      if (file && file.name) {
        const csvText = await file.text();
        const importResult = await importProductsFromCsv(csvText);
        if (importResult.errors.length > 0) {
          error = `Imported ${importResult.success} products. Errors:\n` + importResult.errors.slice(0, 5).join('\n') + (importResult.errors.length > 5 ? `\n...and ${importResult.errors.length - 5} more errors.` : '');
        }
        if (importResult.success > 0) {
          clearCmsCache();
          redirectUrl = '/admin/products?success=' + encodeURIComponent(`Successfully imported/updated ${importResult.success} products!`);
        }
      } else {
        error = 'Please select a valid CSV file.';
      }
    } else if (formAction === 'delete') {
      const idToDelete = formData.get('id')?.toString() || '';
      await db.delete(products).where(eq(products.id, idToDelete));
      clearCmsCache();
      redirectUrl = '/admin/products?success=' + encodeURIComponent('Product deleted successfully!');
    } else if (formAction === 'save') {
      const name = formData.get('name')?.toString() || '';
      const nameGu = formData.get('nameGu')?.toString() || '';
      const slug = (formData.get('slug')?.toString() || '').trim();

      const slugRegex = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
      if (!slugRegex.test(slug)) {
        throw new Error('Slug must only contain lowercase alphanumeric characters and hyphens, and cannot start or end with a hyphen.');
      }
      const brandId = formData.get('brandId')?.toString() || null;
      const categoryId = formData.get('categoryId')?.toString() || null;
      const modelNumber = formData.get('modelNumber')?.toString() || '';
      const description = formData.get('description')?.toString() || '';
      const descriptionGu = formData.get('descriptionGu')?.toString() || '';
      const specifications = formData.get('specifications')?.toString() || '{}';
      const specificationsGu = formData.get('specificationsGu')?.toString() || '{}';
      const mrp = Number(formData.get('mrp') || 0);
      const offerPrice = Number(formData.get('offerPrice') || 0);
      const isFeatured = formData.get('isFeatured') === 'on';
      const eligibleForBundle = formData.get('eligibleForBundle') === 'on';
      const isActive = formData.get('isActive') === 'on';
      const imagesString = formData.get('images')?.toString() || '';
      const imagesArray = imagesString.split(',').map(s => s.trim()).filter(Boolean);

      // Check if a product with the same slug already exists
      const existingProduct = await db.select({ id: products.id }).from(products).where(eq(products.slug, slug));
      if (existingProduct.length > 0 && (!productId || existingProduct[0].id !== productId)) {
        throw new Error(`A product with the slug "${slug}" already exists. Please choose a different, unique slug.`);
      }

      if (productId) {
        // Edit existing product
        await db.update(products).set({
          name,
          nameGu: nameGu || null,
          slug,
          brandId,
          categoryId,
          modelNumber,
          description,
          descriptionGu: descriptionGu || null,
          specifications,
          specificationsGu: specificationsGu || null,
          mrp,
          offerPrice,
          images: imagesArray,
          isFeatured,
          eligibleForBundle,
          isActive,
          updatedAt: new Date().toISOString(),
        }).where(eq(products.id, productId));
        clearCmsCache();
        redirectUrl = '/admin/products?success=' + encodeURIComponent('Product updated successfully!');
      } else {
        // Create new product
        const newId = generateId();
        await db.insert(products).values({
          id: newId,
          name,
          nameGu: nameGu || null,
          slug,
          brandId,
          categoryId,
          modelNumber,
          description,
          descriptionGu: descriptionGu || null,
          specifications,
          specificationsGu: specificationsGu || null,
          mrp,
          offerPrice,
          images: imagesArray,
          isFeatured,
          eligibleForBundle,
          isActive,
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString(),
        });
        
        // Seed 3 to 10 reviews
        const categorySlug = allCategories.find(c => c.id === categoryId)?.slug || null;
        await seedReviewsForProduct(pool, newId, categorySlug);

        clearCmsCache();
        redirectUrl = '/admin/products?success=' + encodeURIComponent('Product added successfully!');
      }
    } else if (formAction === 'toggle_bundle') {
      const idToToggle = formData.get('id')?.toString() || '';
      const currentValue = formData.get('currentValue')?.toString() === 'true';
      await db.update(products).set({
        eligibleForBundle: !currentValue,
        updatedAt: new Date().toISOString()
      }).where(eq(products.id, idToToggle));
      clearCmsCache();
      redirectUrl = '/admin/products?success=' + encodeURIComponent('Bundle eligibility updated successfully!');
    }
  } catch (e: any) {
    const errMsg = e.message || '';
    if (errMsg.includes('unique constraint') || errMsg.includes('products_slug_unique') || errMsg.includes('duplicate key')) {
      error = 'A product with this slug already exists. Please choose a different, unique slug.';
    } else {
      error = errMsg || 'Failed to save product.';
    }
  }
}

if (redirectUrl) {
  return Astro.redirect(redirectUrl);
}

// Fetch single product if in edit mode
let editProduct: any = null;
if (action === 'edit' && productId) {
  const [found] = await db.select().from(products).where(eq(products.id, productId));
  editProduct = found;
}


const search = Astro.url.searchParams.get('search')?.trim() || '';
const brandFilter = Astro.url.searchParams.get('brand') || '';
const categoryFilter = Astro.url.searchParams.get('category') || '';
const statusFilter = Astro.url.searchParams.get('status') || 'all'; // all, active, inactive
const sort = Astro.url.searchParams.get('sort') || 'latest';
const page = Number(Astro.url.searchParams.get('page') || '1');
const limit = 10;
const offset = (page - 1) * limit;

const conditions = [];

if (statusFilter === 'active') {
  conditions.push(eq(products.isActive, true));
} else if (statusFilter === 'inactive') {
  conditions.push(eq(products.isActive, false));
}

if (brandFilter) {
  conditions.push(eq(products.brandId, brandFilter));
}

if (categoryFilter) {
  conditions.push(eq(products.categoryId, categoryFilter));
}

if (search) {
  conditions.push(
    or(
      ilike(products.name, `%${search}%`),
      ilike(products.nameGu, `%${search}%`),
      ilike(products.modelNumber, `%${search}%`),
      ilike(products.slug, `%${search}%`),
      ilike(products.description, `%${search}%`),
      ilike(products.descriptionGu, `%${search}%`)
    )
  );
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

let orderByClause = [asc(products.name)];
if (sort === 'name-desc') {
  orderByClause = [desc(products.name)];
} else if (sort === 'price-asc') {
  orderByClause = [asc(products.offerPrice)];
} else if (sort === 'price-desc') {
  orderByClause = [desc(products.offerPrice)];
} else if (sort === 'latest') {
  orderByClause = [desc(products.createdAt)];
}

// Fetch paginated products for list view
let allProducts: any[] = [];
let totalCount = 0;

try {
  allProducts = await db.query.products.findMany({
    where: whereClause,
    orderBy: orderByClause,
    limit,
    offset,
    with: {
      category: true,
    }
  });

  const [countRes] = await db
    .select({ count: sql`count(*)` })
    .from(products)
    .where(whereClause);
  totalCount = Number(countRes?.count || 0);
} catch (e) {
  console.error('[Admin Products] Failed to fetch products:', e);
}

const totalPages = Math.ceil(totalCount / limit);
const emptySpecifications = '{}';

// Fetch products with brand/category details for bulk images view
let bulkProducts: any[] = [];
if (action === 'bulk-images') {
  bulkProducts = await db.query.products.findMany({
    with: {
      brand: true,
      category: true,
    },
    orderBy: (products: any, { desc }: any) => [desc(products.createdAt)],
  });
}
---

<AdminLayout title="Manage Products" activeTab="products" subtitle="Add, edit, or delete store products">
    {action === 'list' && (
      <div class="grid grid-cols-2 sm:flex sm:flex-wrap items-center justify-end gap-2 mb-6 bg-white border border-neutral-200 rounded-lg p-3 shadow-sm">
        <a href="/admin/products?action=export" class="text-xs font-semibold text-neutral-700 border border-neutral-300 bg-white hover:bg-neutral-50 rounded-md px-3 py-1.5 transition-colors flex items-center justify-center gap-1">
          📤 Export CSV
        </a>

        <form method="post" enctype="multipart/form-data" class="m-0 w-full sm:w-auto">
          <input type="hidden" name="formAction" value="import_csv" />
          <label class="text-xs font-semibold text-neutral-700 border border-neutral-300 bg-white hover:bg-neutral-50 rounded-md px-3 py-1.5 transition-colors cursor-pointer flex items-center justify-center gap-1 w-full">
            📥 Import CSV
            <input type="file" name="csvFile" accept=".csv" class="hidden" onchange="this.form.submit()" />
          </label>
        </form>

        <a href="/admin/products?action=bulk-images" class="col-span-2 sm:col-span-1 text-xs font-semibold text-neutral-700 border border-neutral-300 bg-white hover:bg-neutral-50 rounded-md px-3 py-1.5 transition-colors flex items-center justify-center gap-1">
          🖼️ Bulk Manage Images
        </a>

        <a href="/admin/products?action=add" class="col-span-2 sm:col-span-1 text-xs font-bold text-white bg-primary hover:bg-primary/95 rounded-md px-4 py-1.5 transition-colors text-center flex items-center justify-center">
          + Add Product
        </a>
      </div>
    )}

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    <!-- LIST VIEW -->
    {action === 'list' && (
      <div class="space-y-4">
        {/* Search, Sort, Filter Controls */}
        <div class="bg-white border border-neutral-200 rounded-lg p-4 shadow-sm">
          <form method="get" class="grid grid-cols-2 gap-3 sm:flex sm:flex-wrap sm:items-center sm:gap-3 w-full">
            <div class="relative col-span-2 sm:flex-1 sm:min-w-[200px]">
              <input
                type="text"
                name="search"
                value={search}
                placeholder="Search products..."
                class="w-full rounded border border-neutral-300 pl-8 pr-3 py-1.5 text-xs focus:border-primary focus:outline-none"
              />
              <span class="absolute left-2.5 top-2.5 text-neutral-400 text-xs">🔍</span>
            </div>
            
            <select name="brand" class="col-span-1 rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer w-full sm:w-auto">
              <option value="">All Brands</option>
              {allBrands.map(b => (
                <option value={b.id} selected={brandFilter === b.id}>{b.name}</option>
              ))}
            </select>

            <select name="category" class="col-span-1 rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer w-full sm:w-auto">
              <option value="">All Categories</option>
              {allCategories.map(c => (
                <option value={c.id} selected={categoryFilter === c.id}>{c.name}</option>
              ))}
            </select>

            <select name="status" class="col-span-1 rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer w-full sm:w-auto">
              <option value="all" selected={statusFilter === 'all'}>All Status</option>
              <option value="active" selected={statusFilter === 'active'}>Active Only</option>
              <option value="inactive" selected={statusFilter === 'inactive'}>Inactive Only</option>
            </select>

            <select name="sort" class="col-span-1 rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer w-full sm:w-auto">
              <option value="name-asc" selected={sort === 'name-asc'}>Name (A-Z)</option>
              <option value="name-desc" selected={sort === 'name-desc'}>Name (Z-A)</option>
              <option value="price-asc" selected={sort === 'price-asc'}>Price (Low to High)</option>
              <option value="price-desc" selected={sort === 'price-desc'}>Price (High to Low)</option>
              <option value="latest" selected={sort === 'latest'}>Newest First</option>
            </select>

            <div class="col-span-2 sm:col-span-1 flex gap-2 w-full sm:w-auto">
              <button type="submit" class="flex-1 sm:flex-initial bg-neutral-800 text-white rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-900 transition-colors cursor-pointer text-center">
                Filter
              </button>

              {(search || brandFilter || categoryFilter || statusFilter !== 'all' || sort !== 'name-asc') && (
                <a href="/admin/products" class="flex-1 sm:flex-initial bg-neutral-100 text-neutral-700 rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-200 transition-colors text-center flex items-center justify-center">
                  Clear
                </a>
              )}
            </div>
          </form>
        </div>

        {/* Desktop View Table */}
        <div class="hidden md:block bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
          <table class="w-full text-left text-sm text-neutral-700 border-collapse">
            <thead>
              <tr class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900">
                <th class="p-3 w-16">Image</th>
                <th class="p-3">Product Name</th>
                <th class="p-3">Model</th>
                <th class="p-3">Category</th>
                <th class="p-3">Offer Price</th>
                <th class="p-3">MRP</th>
                <th class="p-3">Status</th>
                <th class="p-3">Bundle</th>
                <th class="p-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              {allProducts.map((prod) => (
                <tr class="border-b border-neutral-100 hover:bg-neutral-50/50">
                  <td class="p-3">
                    <div class="relative w-10 h-10">
                      <img src={getProductImageUrl(prod.images?.[0])} class="w-10 h-10 object-cover rounded border border-neutral-200 shadow-sm bg-neutral-50" alt={prod.name} />
                      {prod.images?.[0] && (prod.images[0].endsWith('.mp4') || prod.images[0].endsWith('.webm') || prod.images[0].endsWith('.ogg') || prod.images[0].endsWith('.mov')) && (
                        <div class="absolute inset-0 flex items-center justify-center bg-black/35 rounded">
                          <span class="text-white text-[9px]">▶</span>
                        </div>
                      )}
                    </div>
                  </td>
                  <td class="p-3 font-medium text-neutral-900">{prod.name}</td>
                  <td class="p-3 text-xs text-neutral-500">{prod.modelNumber || '-'}</td>
                  <td class="p-3 text-xs text-neutral-600">{prod.category?.name || '—'}</td>
                  <td class="p-3 font-semibold text-primary">
                    ₹{prod.offerPrice.toLocaleString('en-IN')}
                  </td>
                  <td class="p-3 text-neutral-400 line-through">
                    ₹{prod.mrp.toLocaleString('en-IN')}
                  </td>
                  <td class="p-3">
                    <div class="flex items-center gap-1.5">
                      <span class={`w-2 h-2 rounded-full ${prod.isActive ? 'bg-green-500' : 'bg-red-500'}`} title={prod.isActive ? 'Active' : 'Inactive'}></span>
                      {prod.isFeatured && <span class="w-2 h-2 rounded-full bg-yellow-500" title="Featured"></span>}
                    </div>
                  </td>
                  <td class="p-3">
                    <form method="post" class="inline m-0">
                      <input type="hidden" name="formAction" value="toggle_bundle" />
                      <input type="hidden" name="id" value={prod.id} />
                      <input type="hidden" name="currentValue" value={prod.eligibleForBundle ? 'true' : 'false'} />
                      <button
                        type="submit"
                        class={`relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none ${
                          prod.eligibleForBundle ? 'bg-secondary animate-pulse-subtle' : 'bg-neutral-200'
                        }`}
                        title={prod.eligibleForBundle ? 'Eligible for Bundle (Click to disable)' : 'Not Eligible for Bundle (Click to enable)'}
                      >
                        <span
                          class={`pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out ${
                            prod.eligibleForBundle ? 'translate-x-4' : 'translate-x-0'
                          }`}
                        />
                      </button>
                    </form>
                  </td>
                  <td class="p-3 text-right flex justify-end gap-2 items-center h-12">
                    <a href={"/admin/products?action=edit&id=" + prod.id} class="text-xs font-semibold text-primary hover:underline">
                      Edit
                    </a>
                    <form method="post" class="inline m-0">
                      <input type="hidden" name="formAction" value="delete" />
                      <input type="hidden" name="id" value={prod.id} />
                      <button 
                        type="button" 
                        onclick="window.confirmDelete(this, 'Delete Product', 'Are you sure you want to delete this product?')"
                        class="text-xs font-semibold text-red-600 hover:underline bg-none border-none cursor-pointer focus:outline-none"
                      >
                        Delete
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
              {allProducts.length === 0 && (
                <tr>
                  <td colspan="9" class="p-8 text-center text-neutral-500">No products found. Add some to get started.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>

        {/* Mobile View Native List (flat items with divider lines) */}
        <div class="md:hidden bg-white border border-neutral-200 rounded-lg shadow-sm divide-y divide-neutral-100">
          {allProducts.map((prod) => (
            <div class="p-4 flex gap-3 items-center relative pr-20 min-h-[5.5rem]">
              <!-- Thumbnail -->
              <div class="relative w-16 h-16 shrink-0">
                <img 
                  src={getProductImageUrl(prod.images?.[0])} 
                  class="w-16 h-16 object-cover rounded border border-neutral-200 shadow-sm bg-neutral-50" 
                  alt={prod.name} 
                />
                {prod.images?.[0] && (prod.images[0].endsWith('.mp4') || prod.images[0].endsWith('.webm') || prod.images[0].endsWith('.ogg') || prod.images[0].endsWith('.mov')) && (
                  <div class="absolute inset-0 flex items-center justify-center bg-black/35 rounded">
                    <span class="text-white text-xs">▶</span>
                  </div>
                )}
              </div>
              
              <div class="flex-1 min-w-0">
                <div class="font-bold text-sm text-neutral-900 truncate pr-2">{prod.name}</div>
                
                <div class="flex items-center gap-2 mt-0.5">
                  <span class="text-xs font-semibold text-primary">₹{prod.offerPrice.toLocaleString('en-IN')}</span>
                  {prod.mrp > prod.offerPrice && (
                    <span class="text-xs text-neutral-400 line-through">₹{prod.mrp.toLocaleString('en-IN')}</span>
                  )}
                </div>

                <div class="text-[10px] text-neutral-500 mt-1 flex flex-wrap gap-x-2 gap-y-0.5 items-center">
                  <span>Model: {prod.modelNumber || '—'}</span>
                  <span>•</span>
                  <span>Cat: {prod.category?.name || '—'}</span>
                  <span>•</span>
                  <div class="flex items-center gap-1.5">
                    <span class={`w-2 h-2 rounded-full ${prod.isActive ? 'bg-green-500' : 'bg-red-500'}`} title={prod.isActive ? 'Active' : 'Inactive'}></span>
                    {prod.isFeatured && <span class="w-2 h-2 rounded-full bg-yellow-500" title="Featured"></span>}
                  </div>
                </div>
                
                <div class="flex items-center gap-2 mt-1.5 pt-1.5 border-t border-neutral-100">
                  <span class="text-[10px] text-neutral-400 font-bold uppercase">Bundle Eligibility:</span>
                  <form method="post" class="inline m-0">
                    <input type="hidden" name="formAction" value="toggle_bundle" />
                    <input type="hidden" name="id" value={prod.id} />
                    <input type="hidden" name="currentValue" value={prod.eligibleForBundle ? 'true' : 'false'} />
                    <button
                      type="submit"
                      class={`relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none ${
                        prod.eligibleForBundle ? 'bg-secondary' : 'bg-neutral-200'
                      }`}
                      title={prod.eligibleForBundle ? 'Eligible for Bundle (Click to disable)' : 'Not Eligible for Bundle (Click to enable)'}
                    >
                      <span
                        class={`pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out ${
                          prod.eligibleForBundle ? 'translate-x-4' : 'translate-x-0'
                        }`}
                      />
                    </button>
                  </form>
                </div>
              </div>

              <!-- Corner Actions -->
              <div class="absolute top-4 right-4 flex items-center gap-2">
                <a 
                  href={"/admin/products?action=edit&id=" + prod.id} 
                  class="w-8 h-8 rounded-full border border-neutral-200 hover:border-primary/30 hover:bg-primary/5 flex items-center justify-center text-xs text-neutral-600 hover:text-primary transition-colors cursor-pointer"
                  title="Edit"
                >
                  ✏️
                </a>
                <form method="post" class="inline m-0">
                  <input type="hidden" name="formAction" value="delete" />
                  <input type="hidden" name="id" value={prod.id} />
                  <button 
                    type="button" 
                    onclick="window.confirmDelete(this, 'Delete Product', 'Are you sure you want to delete this product?')"
                    class="w-8 h-8 rounded-full border border-red-100 bg-red-50 hover:bg-red-100 flex items-center justify-center text-xs text-red-600 transition-colors cursor-pointer"
                    title="Delete"
                  >
                    🗑️
                  </button>
                </form>
              </div>
            </div>
          ))}
          {allProducts.length === 0 && (
            <div class="p-8 text-center text-neutral-500 text-sm">No products found.</div>
          )}
        </div>

        {/* Pagination Controls */}
        {totalPages > 1 && (
          <div class="flex items-center justify-between border-t border-neutral-200 bg-white px-4 py-3 sm:px-6 rounded-lg shadow-sm">
            <div class="flex flex-1 justify-between sm:hidden">
              <a
                href={page > 1 ? `?page=${page - 1}&search=${search}&brand=${brandFilter}&category=${categoryFilter}&status=${statusFilter}&sort=${sort}` : '#'}
                class={`relative inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
              >
                Previous
              </a>
              <a
                href={page < totalPages ? `?page=${page + 1}&search=${search}&brand=${brandFilter}&category=${categoryFilter}&status=${statusFilter}&sort=${sort}` : '#'}
                class={`relative ml-3 inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
              >
                Next
              </a>
            </div>
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
              <div>
                <p class="text-xs text-neutral-700">
                  Showing
                  <span class="font-semibold">{Math.min(offset + 1, totalCount)}</span>
                  to
                  <span class="font-semibold">{Math.min(offset + limit, totalCount)}</span>
                  of
                  <span class="font-semibold">{totalCount}</span>
                  results
                </p>
              </div>
              <div>
                <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                  <a
                    href={page > 1 ? `?page=${page - 1}&search=${search}&brand=${brandFilter}&category=${categoryFilter}&status=${statusFilter}&sort=${sort}` : '#'}
                    class={`relative inline-flex items-center rounded-l-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
                  >
                    <span class="sr-only">Previous</span>
                    <span>◀</span>
                  </a>
                  {Array.from({ length: totalPages }).map((_, idx) => {
                    const pNum = idx + 1;
                    const isCurrent = pNum === page;
                    return (
                      <a
                        href={`?page=${pNum}&search=${search}&brand=${brandFilter}&category=${categoryFilter}&status=${statusFilter}&sort=${sort}`}
                        aria-current={isCurrent ? "page" : undefined}
                        class={`relative inline-flex items-center px-3 py-2 text-xs font-semibold ${isCurrent ? 'z-10 bg-primary text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary' : 'text-neutral-900 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0'}`}
                      >
                        {pNum}
                      </a>
                    );
                  })}
                  <a
                    href={page < totalPages ? `?page=${page + 1}&search=${search}&brand=${brandFilter}&category=${categoryFilter}&status=${statusFilter}&sort=${sort}` : '#'}
                    class={`relative inline-flex items-center rounded-r-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
                  >
                    <span class="sr-only">Next</span>
                    <span>▶</span>
                  </a>
                </nav>
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- ADD/EDIT FORM VIEW -->
    {(action === 'add' || action === 'edit') && (
      <div class="bg-white border border-neutral-200 rounded-lg p-6 shadow-sm max-w-2xl mx-auto">
        <h2 class="text-lg font-bold text-neutral-900 mb-6">{action === 'edit' ? 'Edit Product' : 'Add New Product'}</h2>
        
        <form method="post" class="space-y-4">
          <input type="hidden" name="formAction" value="save" />

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-sm font-semibold text-neutral-700 mb-1">Product Name (English) *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                value={editProduct?.name || ''}
                placeholder="e.g. Sony Bravia 55"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </div>
            <div>
              <label for="nameGu" class="block text-sm font-semibold text-neutral-700 mb-1">Product Name (Gujarati)</label>
              <input
                type="text"
                id="nameGu"
                name="nameGu"
                value={editProduct?.nameGu || ''}
                placeholder="દા.ત. સોની બ્રાવિયા ૫૫"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="slug" class="block text-sm font-semibold text-neutral-700 mb-1">Slug (URL parameter) *</label>
              <input
                type="text"
                id="slug"
                name="slug"
                required
                pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$"
                title="Slug must only contain lowercase letters, numbers, and hyphens, and cannot start or end with a hyphen."
                value={editProduct?.slug || ''}
                placeholder="e.g. sony-bravia-55"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </div>
            <div>
              <label for="modelNumber" class="block text-sm font-semibold text-neutral-700 mb-1">Model Number</label>
              <input
                type="text"
                id="modelNumber"
                name="modelNumber"
                value={editProduct?.modelNumber || ''}
                placeholder="e.g. KD-55X75L"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-sm font-semibold text-neutral-700 mb-1">Brand</label>
              <div class="relative searchable-dropdown" id="brand-dropdown">
                <input
                  type="text"
                  placeholder="Search & Select Brand..."
                  class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none pr-8 dropdown-input"
                  value={allBrands.find(b => b.id === editProduct?.brandId)?.name || ''}
                />
                <span class="absolute right-2.5 top-2.5 text-neutral-400 pointer-events-none text-[10px]">▼</span>
                <input type="hidden" name="brandId" id="brandId" class="dropdown-value" value={editProduct?.brandId || ''} />
                <div class="absolute z-50 left-0 right-0 mt-1 max-h-60 overflow-y-auto bg-white border border-neutral-200 rounded-md shadow-lg hidden dropdown-menu">
                  <div class="py-1 px-3 text-xs text-neutral-400 hover:bg-neutral-50 cursor-pointer dropdown-option" data-value="">None (Select Brand)</div>
                  {allBrands.map(b => (
                    <div class="py-1.5 px-3 text-sm hover:bg-neutral-100 cursor-pointer dropdown-option" data-value={b.id} data-search={b.name.toLowerCase()}>{b.name}</div>
                  ))}
                </div>
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold text-neutral-700 mb-1">Category</label>
              <div class="relative searchable-dropdown" id="category-dropdown">
                <input
                  type="text"
                  placeholder="Search & Select Category..."
                  class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none pr-8 dropdown-input"
                  value={allCategories.find(c => c.id === editProduct?.categoryId)?.name || ''}
                />
                <span class="absolute right-2.5 top-2.5 text-neutral-400 pointer-events-none text-[10px]">▼</span>
                <input type="hidden" name="categoryId" id="categoryId" class="dropdown-value" value={editProduct?.categoryId || ''} />
                <div class="absolute z-50 left-0 right-0 mt-1 max-h-60 overflow-y-auto bg-white border border-neutral-200 rounded-md shadow-lg hidden dropdown-menu">
                  <div class="py-1 px-3 text-xs text-neutral-400 hover:bg-neutral-50 cursor-pointer dropdown-option" data-value="">None (Select Category)</div>
                  {allCategories.map(c => (
                    <div class="py-1.5 px-3 text-sm hover:bg-neutral-100 cursor-pointer dropdown-option" data-value={c.id} data-search={c.name.toLowerCase()}>{c.name}</div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="mrp" class="block text-sm font-semibold text-neutral-700 mb-1">MRP (Original Price) *</label>
              <input
                type="number"
                id="mrp"
                name="mrp"
                required
                value={editProduct?.mrp || ''}
                placeholder="e.g. 89990"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary"
              />
            </div>
            <div>
              <label for="offerPrice" class="block text-sm font-semibold text-neutral-700 mb-1">Offer Price *</label>
              <input
                type="number"
                id="offerPrice"
                name="offerPrice"
                required
                value={editProduct?.offerPrice || ''}
                placeholder="e.g. 74990"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-neutral-700 mb-2">Product Images</label>
            <input type="hidden" id="images" name="images" value={editProduct?.images?.join(',') || ''} />
            
            <div id="image-previews" class="flex flex-wrap gap-3 mb-3"></div>

            <div class="relative border-2 border-dashed border-neutral-300 rounded-lg p-6 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer group text-center" id="upload-dropzone">
              <input type="file" id="file-picker" multiple accept="image/*,video/*" class="absolute inset-0 opacity-0 cursor-pointer" />
              <div class="space-y-1">
                <span class="text-2xl text-neutral-400 group-hover:text-primary transition-colors">🎥</span>
                <p class="text-xs font-semibold text-neutral-600">Click to upload or drag & drop</p>
                <p class="text-[10px] text-neutral-400">Supports JPG, PNG, WEBP, MP4, WEBM</p>
              </div>
            </div>

            <div id="upload-progress-container" class="hidden mt-3 space-y-1.5">
              <div class="flex justify-between text-[11px] font-semibold text-neutral-500">
                <span id="upload-status">Uploading...</span>
                <span id="upload-percent">0%</span>
              </div>
              <div class="w-full bg-neutral-200 rounded-full h-1.5 overflow-hidden">
                <div id="upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
              </div>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="description" class="block text-sm font-semibold text-neutral-700 mb-1">Product Description (English)</label>
              <textarea
                id="description"
                name="description"
                rows="3"
                placeholder="Enter product details..."
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >{editProduct?.description || ''}</textarea>
            </div>
            <div>
              <label for="descriptionGu" class="block text-sm font-semibold text-neutral-700 mb-1">Product Description (Gujarati)</label>
              <textarea
                id="descriptionGu"
                name="descriptionGu"
                rows="3"
                placeholder="ગુજરાતીમાં વિગતો દાખલ કરો..."
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >{editProduct?.descriptionGu || ''}</textarea>
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-neutral-700 mb-2">Specifications</label>
            <input type="hidden" id="specifications" name="specifications" value={editProduct?.specifications || emptySpecifications} />
            <input type="hidden" id="specificationsGu" name="specificationsGu" value={editProduct?.specificationsGu || emptySpecifications} />
            
            <div id="specs-list" class="space-y-3 mb-3"></div>
            
            <button
              type="button"
              id="add-spec-btn"
              class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:text-primary-700 transition-colors bg-primary/10 px-3 py-1.5 rounded"
            >
              + Add Specification
            </button>
          </div>

          <div class="flex items-center gap-6 py-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="isFeatured" checked={editProduct ? editProduct.isFeatured : false} class="rounded border-neutral-300 text-primary focus:ring-primary" />
              <span class="text-sm font-semibold text-neutral-700">Featured Product</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="eligibleForBundle" checked={editProduct ? editProduct.eligibleForBundle : true} class="rounded border-neutral-300 text-primary focus:ring-primary" />
              <span class="text-sm font-semibold text-neutral-700">Eligible for Bundle</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="isActive" checked={editProduct ? editProduct.isActive : true} class="rounded border-neutral-300 text-primary focus:ring-primary" />
              <span class="text-sm font-semibold text-neutral-700">Product Active</span>
            </label>
          </div>

          <div class="flex justify-end gap-3 pt-4 border-t border-neutral-200">
            <a href="/admin/products" class="btn-outline px-4 py-2 text-sm">
              Cancel
            </a>
            <button type="submit" class="btn-primary px-6 py-2 text-sm font-medium">
              Save Product
            </button>
          </div>
         </form>

        <script>
          // Slug Input Restrictor
          const slugInput = document.getElementById('slug') as HTMLInputElement;
          if (slugInput) {
            slugInput.addEventListener('input', () => {
              let val = slugInput.value;
              val = val.replace(/[\s_]+/g, '-');
              val = val.toLowerCase().replace(/[^a-z0-9-]/g, '');
              val = val.replace(/-+/g, '-');
              slugInput.value = val;
            });
          }

          // Specifications Editor
          const specsInput = document.getElementById('specifications') as HTMLInputElement;
          const specsGuInput = document.getElementById('specificationsGu') as HTMLInputElement;
          const specsList = document.getElementById('specs-list');
          const addSpecBtn = document.getElementById('add-spec-btn');

          function getSpecsData() {
            try {
              return JSON.parse(specsInput.value || '{}');
            } catch(e) {
              return {};
            }
          }

          function getSpecsGuData() {
            try {
              return JSON.parse(specsGuInput.value || '{}');
            } catch(e) {
              return {};
            }
          }

          function saveSpecsData() {
            const data: Record<string, string> = {};
            const dataGu: Record<string, string> = {};
            const rows = specsList?.querySelectorAll('.spec-row');
            rows?.forEach(row => {
              const keyInput = row.querySelector('.spec-key') as HTMLInputElement;
              const valInput = row.querySelector('.spec-val') as HTMLInputElement;
              const keyGuInput = row.querySelector('.spec-key-gu') as HTMLInputElement;
              const valGuInput = row.querySelector('.spec-val-gu') as HTMLInputElement;
              
              if (keyInput && valInput && keyInput.value.trim()) {
                const k = keyInput.value.trim();
                const v = valInput.value.trim();
                data[k] = v;
                
                const kGu = keyGuInput?.value.trim() || k;
                const vGu = valGuInput?.value.trim() || v;
                dataGu[kGu] = vGu;
              }
            });
            specsInput.value = JSON.stringify(data);
            specsGuInput.value = JSON.stringify(dataGu);
          }

          function createSpecRow(key = '', val = '', keyGu = '', valGu = '') {
            const div = document.createElement('div');
            div.className = 'spec-row border border-neutral-200 rounded-md p-3 bg-neutral-50/50 space-y-3 relative';
            div.innerHTML = `
              <div class="flex items-center justify-between border-b border-neutral-200/60 pb-2">
                <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wider">Specification Item</span>
                <button type="button" class="remove-spec-btn text-red-500 hover:text-red-700 transition-colors text-xs font-semibold focus:outline-none cursor-pointer">
                  ✕ Remove
                </button>
              </div>
              <div class="space-y-3">
                <!-- English spec inputs -->
                <div class="flex flex-col sm:flex-row gap-2 sm:items-center">
                  <div class="w-8 shrink-0">
                    <span class="text-[9px] font-black text-neutral-500 bg-neutral-200/80 px-1.5 py-0.5 rounded uppercase">EN</span>
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 flex-1">
                    <input type="text" placeholder="Spec Name (e.g. Screen Size)" value="${key}" class="spec-key w-full rounded-md border border-neutral-300 px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-primary" />
                    <input type="text" placeholder="Value (e.g. 55 inch)" value="${val}" class="spec-val w-full rounded-md border border-neutral-300 px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-primary" />
                  </div>
                </div>
                <!-- Gujarati spec inputs -->
                <div class="flex flex-col sm:flex-row gap-2 sm:items-center">
                  <div class="w-8 shrink-0">
                    <span class="text-[9px] font-black text-neutral-500 bg-neutral-200/80 px-1.5 py-0.5 rounded uppercase">GU</span>
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 flex-1">
                    <input type="text" placeholder="ગુજરાતી નામ (વૈકલ્પિક)" value="${keyGu}" class="spec-key-gu w-full rounded-md border border-neutral-300 px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-primary" />
                    <input type="text" placeholder="ગુજરાતી કિંમત (વૈકલ્પિક)" value="${valGu}" class="spec-val-gu w-full rounded-md border border-neutral-300 px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-primary" />
                  </div>
                </div>
              </div>
            `;
            
            div.querySelector('.spec-key')?.addEventListener('input', saveSpecsData);
            div.querySelector('.spec-val')?.addEventListener('input', saveSpecsData);
            div.querySelector('.spec-key-gu')?.addEventListener('input', saveSpecsData);
            div.querySelector('.spec-val-gu')?.addEventListener('input', saveSpecsData);
            div.querySelector('.remove-spec-btn')?.addEventListener('click', () => {
              div.remove();
              saveSpecsData();
            });

            specsList?.appendChild(div);
          }

          // File Uploader
          const imagesInput = document.getElementById('images') as HTMLInputElement;
          const previewsContainer = document.getElementById('image-previews');
          const filePicker = document.getElementById('file-picker') as HTMLInputElement;
          const progressContainer = document.getElementById('upload-progress-container');
          const progressBar = document.getElementById('upload-progress-bar');
          const progressPercent = document.getElementById('upload-percent');
          const progressStatus = document.getElementById('upload-status');

          const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dyjsrdrxa';

          function getImages() {
            return imagesInput.value.split(',').map(s => s.trim()).filter(Boolean);
          }

          function saveImages(arr: string[]) {
            imagesInput.value = arr.join(',');
          }

          function renderPreviews() {
            if (!previewsContainer) return;
            previewsContainer.innerHTML = '';
            const images = getImages();
            images.forEach(img => {
              const isVideo = img.endsWith('.mp4') || img.endsWith('.webm') || img.endsWith('.ogg') || img.endsWith('.mov');
              let mediaHtml = '';
              
              if (isVideo) {
                let videoUrl = img;
                if (!img.startsWith('http') && !img.startsWith('/')) {
                  videoUrl = `https://res.cloudinary.com/${CLOUD_NAME}/video/upload/w_200,h_200,c_fill/${img}`;
                }
                mediaHtml = `
                  <video src="${videoUrl}" class="w-full h-full object-cover" muted playsinline></video>
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none bg-black/20">
                    <span class="text-white text-xs">▶</span>
                  </div>
                `;
              } else {
                let displayUrl = img;
                if (!img.startsWith('http') && !img.startsWith('/')) {
                  displayUrl = `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/w_200,h_200,c_fill,f_auto,q_auto/${img}`;
                }
                mediaHtml = `<img src="${displayUrl}" class="w-full h-full object-cover" />`;
              }
              
              const fullMediaUrl = (img.startsWith('http') || img.startsWith('/')) ? img : `https://res.cloudinary.com/${CLOUD_NAME}/${isVideo ? 'video' : 'image'}/upload/${img}`;
              const div = document.createElement('div');
              div.className = 'relative group w-20 h-20 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
              div.innerHTML = `
                ${mediaHtml}
                <div class="absolute inset-0 bg-black/45 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-1.5 z-10">
                  <button type="button" class="preview-trigger-btn w-7 h-7 rounded-full bg-white/90 hover:bg-white text-neutral-800 flex items-center justify-center text-xs shadow-sm transition-transform hover:scale-110" data-preview-src="${fullMediaUrl}" data-preview-type="${isVideo ? 'video' : 'image'}" title="Preview">👁️</button>
                  <button type="button" class="remove-btn-direct w-7 h-7 rounded-full bg-red-500 hover:bg-red-600 text-white flex items-center justify-center text-xs shadow-sm transition-transform hover:scale-110" title="Remove">🗑️</button>
                </div>
              `;
              
              div.querySelector('.remove-btn-direct')?.addEventListener('click', () => {
                const remaining = getImages().filter(x => x !== img);
                saveImages(remaining);
                renderPreviews();
              });
              
              previewsContainer.appendChild(div);
            });
          }


          async function uploadFiles(files: FileList | null, pickerElement: HTMLInputElement) {
            if (!files || files.length === 0) return;

            const filesArray = Array.from(files);
            let uploadedCount = 0;
            const totalCount = filesArray.length;

            progressContainer?.classList.remove('hidden');
            progressStatus!.textContent = `Preparing files...`;
            progressBar!.style.width = `0%`;
            progressPercent!.textContent = `0%`;

            const imagesList = getImages();

            (window as any).processAndUploadFiles(filesArray, async (fileToUpload: File) => {
              uploadedCount++;
              progressStatus!.textContent = `Uploading file ${uploadedCount} of ${totalCount}...`;
              
              try {
                const publicId = await uploadFileWithProgress(fileToUpload, (percent) => {
                  progressBar!.style.width = `${percent}%`;
                  progressPercent!.textContent = `${percent}%`;
                });
                
                if (publicId) {
                  imagesList.push(publicId);
                  saveImages(imagesList);
                  renderPreviews();
                }
              } catch (err) {
                alert('Upload failed for ' + fileToUpload.name + ': ' + err);
              }

              if (uploadedCount === totalCount) {
                progressContainer?.classList.add('hidden');
                pickerElement.value = '';
              }
            });
          }

          filePicker?.addEventListener('change', () => {
            uploadFiles(filePicker.files, filePicker);
          });


          function uploadFileWithProgress(file: File, onProgress: (pct: number) => void): Promise<string> {
            return new Promise((resolve, reject) => {
              const xhr = new XMLHttpRequest();
              xhr.open('POST', '/api/upload', true);
              
              xhr.upload.onprogress = (e) => {
                if (e.lengthComputable) {
                  const pct = Math.round((e.loaded / e.total) * 100);
                  onProgress(pct);
                }
              };

              xhr.onload = () => {
                if (xhr.status === 200) {
                  try {
                    const res = JSON.parse(xhr.responseText);
                    resolve(res.public_id || res.url);
                  } catch(e) {
                    reject('Invalid response');
                  }
                } else {
                  reject('Server returned status ' + xhr.status);
                }
              };

              xhr.onerror = () => reject('Network error');

              const formData = new FormData();
              formData.append('file', file);
              xhr.send(formData);
            });
          }

          // Initialize
          const initialSpecs = getSpecsData();
          const initialSpecsGu = getSpecsGuData();
          const keysEn = Object.keys(initialSpecs);
          const keysGu = Object.keys(initialSpecsGu);

          keysEn.forEach((key, index) => {
            const val = initialSpecs[key];
            const keyGu = keysGu[index] || '';
            const valGu = initialSpecsGu[keyGu] || '';
            createSpecRow(key, val, keyGu, valGu);
          });

          addSpecBtn?.addEventListener('click', () => {
            createSpecRow();
          });

          // Searchable Dropdowns JS Logic
          document.querySelectorAll('.searchable-dropdown').forEach(dropdown => {
            const input = dropdown.querySelector('.dropdown-input') as HTMLInputElement;
            const hidden = dropdown.querySelector('.dropdown-value') as HTMLInputElement;
            const menu = dropdown.querySelector('.dropdown-menu') as HTMLDivElement;
            const options = dropdown.querySelectorAll('.dropdown-option');

            input.addEventListener('focus', () => {
              // Close all other dropdowns first
              document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));
              menu.classList.remove('hidden');
            });

            input.addEventListener('input', () => {
              const query = input.value.toLowerCase().trim();
              options.forEach(opt => {
                const searchVal = opt.getAttribute('data-search') || '';
                const val = opt.getAttribute('data-value') || '';
                if (!val || searchVal.includes(query)) {
                  (opt as HTMLDivElement).style.display = 'block';
                } else {
                  (opt as HTMLDivElement).style.display = 'none';
                }
              });
            });

            options.forEach(opt => {
              opt.addEventListener('click', (e) => {
                e.stopPropagation();
                const val = opt.getAttribute('data-value') || '';
                const label = opt.textContent || '';
                hidden.value = val;
                input.value = val ? label : '';
                menu.classList.add('hidden');
                hidden.dispatchEvent(new Event('change', { bubbles: true }));
              });
            });

            // Close on click outside
            document.addEventListener('click', (e) => {
              if (!dropdown.contains(e.target as Node)) {
                menu.classList.add('hidden');
                // Restore label if empty or invalid input
                const currentVal = hidden.value;
                const match = Array.from(options).find(o => o.getAttribute('data-value') === currentVal);
                input.value = match && currentVal ? match.textContent || '' : '';
              }
            });
          });

          renderPreviews();
        </script>
      </div>
    )}  

