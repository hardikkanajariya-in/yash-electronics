              const res = await fetch('/api/bulk-image', {
                method: 'POST',
                body: new URLSearchParams({
                  formAction: 'bulk_remove_image',
                  productId: productId,
                  imageUrl: imageUrl
                })
              });
              
              if (!res.ok) {
                throw new Error(`Server returned status ${res.status}`);
