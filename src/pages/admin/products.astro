              if (productId && imageUrl) {
                handleRemoveImage(productId, imageUrl);
              }
            }
          });

          // Upload helper
          function uploadFileWithProgress(file: File, onProgress: (pct: number) => void): Promise<string> {
            return new Promise((resolve, reject) => {
              const xhr = new XMLHttpRequest();
              xhr.open('POST', '/api/upload', true);
              
              xhr.upload.onprogress = (e) => {
                if (e.lengthComputable) {
                  const pct = Math.round((e.loaded / e.total) * 100);
                  onProgress(pct);
                }
              };

              xhr.onload = () => {
                if (xhr.status === 200) {
                  try {
                    const res = JSON.parse(xhr.responseText);
                    resolve(res.public_id || res.url);
                  } catch(e) {
                    reject('Invalid response');
                  }
                } else {
                  reject('Server returned status ' + xhr.status);
                }
              };

              xhr.onerror = () => reject('Network error');

              const formData = new FormData();
              formData.append('file', file);
              xhr.send(formData);
            });
          }

          // Setup file upload event delegation or listeners
          const filePickers = document.querySelectorAll('.bulk-file-picker');
          filePickers.forEach(picker => {
            picker.addEventListener('change', async (e) => {
              const input = e.target as HTMLInputElement;
              const productId = input.getAttribute('data-product-id');
              if (!productId) return;
              
              const files = input.files;
              if (!files || files.length === 0) return;
              
              const statusEls = [
                document.getElementById(`status-${productId}`),
                document.getElementById(`status-mobile-${productId}`)
              ].filter(Boolean) as HTMLElement[];
              
              statusEls.forEach(statusEl => {
                statusEl.classList.remove('hidden');
              });

              const filesArray = Array.from(files);
              let uploadedCount = 0;
              const totalCount = filesArray.length;
              
              (window as any).processAndUploadFiles(filesArray, async (fileToUpload: File) => {
                uploadedCount++;
                statusEls.forEach(statusEl => {
                  statusEl.childNodes[0].textContent = `Uploading ${uploadedCount}/${totalCount}... `;
                });
                
                try {
                  const publicId = await uploadFileWithProgress(fileToUpload, (pct) => {
                    statusEls.forEach(statusEl => {
                      const percentEl = statusEl.querySelector('.upload-percent') as HTMLElement;
                      if (percentEl) percentEl.textContent = `${pct}%`;
                    });
                  });
                  
                  if (publicId) {
                    const res = await fetch('/api/bulk-image', {
                      method: 'POST',
                      body: new URLSearchParams({
                        formAction: 'bulk_add_image',
                        productId: productId,
                        imageUrl: publicId
                      })
