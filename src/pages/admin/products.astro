              const data = await res.json();
              if (data.success) {
                updateGalleryDom(productId, data.images);
              } else {
                alert('Failed to remove image: ' + data.error);
              }
            } catch (err) {
              alert('Error removing image: ' + err);
            }
          }

           // Update product gallery in DOM dynamically
          function updateGalleryDom(productId: string, images: string[]) {
            const galleries = [
              document.getElementById(`gallery-${productId}`),
              document.getElementById(`gallery-mobile-${productId}`)
            ].filter(Boolean);
            
