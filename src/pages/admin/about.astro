---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { aboutInfo } from '../../db/schema';
import { getSessionUser, generateId } from '../../lib/auth';
import { eq } from 'drizzle-orm';
import { deleteCloudinaryAsset } from '../../lib/cloudinary-server';
import { buildCloudinaryUrl } from '../../lib/cloudinary';

import { clearCmsCache } from '../../services/cms';

export const prerender = false;

Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));

let message = Astro.url.searchParams.get('message') || '';
let error = Astro.url.searchParams.get('error') || '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('_action')?.toString();

    if (formAction === 'delete') {
      const deleteId = formData.get('id')?.toString();
      if (deleteId) {
        const [existing] = await db.select().from(aboutInfo).where(eq(aboutInfo.id, deleteId));
        if (existing?.photo) {
          await deleteCloudinaryAsset(existing.photo);
        }
        await db.delete(aboutInfo).where(eq(aboutInfo.id, deleteId));
        clearCmsCache();
        return Astro.redirect('/admin/about?message=' + encodeURIComponent('Entry deleted.'));
      }
    } else if (formAction === 'save') {
      const id = formData.get('id')?.toString();
      const name = formData.get('name')?.toString().trim() || '';
      const role = formData.get('role')?.toString() as any || 'founder';
      const photo = formData.get('photo')?.toString().trim() || null;
      const description = formData.get('description')?.toString().trim() || null;
      const sortOrder = Number(formData.get('sortOrder') || '0');

      if (!name) {
        error = 'Name is required.';
      } else if (id) {
        const [existing] = await db.select().from(aboutInfo).where(eq(aboutInfo.id, id));
        if (existing?.photo && existing.photo !== photo) {
          await deleteCloudinaryAsset(existing.photo);
        }
        await db.update(aboutInfo).set({ name, role, photo, description, sortOrder }).where(eq(aboutInfo.id, id));
        clearCmsCache();
        return Astro.redirect('/admin/about?message=' + encodeURIComponent('Entry updated.'));
      } else {
        await db.insert(aboutInfo).values({ id: generateId(), name, role, photo, description, sortOrder });
        clearCmsCache();
        return Astro.redirect('/admin/about?message=' + encodeURIComponent('Entry added.'));
      }
    }
  } catch (e: any) {
    error = 'Operation failed: ' + (e.message || 'Unknown error');
  }
}

let allEntries: any[] = [];
try { allEntries = await db.select().from(aboutInfo).orderBy(aboutInfo.sortOrder); } catch (e) { }

const editId = Astro.url.searchParams.get('edit');
const isAdding = Astro.url.searchParams.get('action') === 'add';
const editEntry = editId ? allEntries.find(e => e.id === editId) : null;
const showForm = isAdding || editEntry;

const roleLabels: Record<string, string> = { founder: 'Founder', owner: 'Owner', next_gen: 'Next Generation' };
---

<AdminLayout title="About Store Info" activeTab="about" subtitle="Manage Founder, Owner & Next Gen info">

    {message && <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">{message}</div>}
    {error && <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">{error}</div>}

    {showForm && (
      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm mb-6">
        <h2 class="text-base font-bold text-neutral-900 mb-4">{editEntry ? 'Edit Entry' : 'Add Entry'}</h2>
        <form id="about-form" method="post" class="grid gap-4 sm:grid-cols-2">
          <input type="hidden" name="_action" value="save" />
          {editEntry && <input type="hidden" name="id" value={editEntry.id} />}
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Name *</label>
            <input type="text" name="name" required value={editEntry?.name || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Role *</label>
            <select name="role" class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none">
              <option value="founder" selected={editEntry?.role === 'founder'}>Founder</option>
              <option value="owner" selected={editEntry?.role === 'owner'}>Owner</option>
              <option value="next_gen" selected={editEntry?.role === 'next_gen'}>Next Generation</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Photo</label>
            <input type="hidden" id="photo" name="photo" value={editEntry?.photo || ''} />
            
            <div id="photo-preview" class="mb-2"></div>
            
            <div class="relative border border-dashed border-neutral-300 rounded p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer group text-center" id="upload-dropzone">
              <input type="file" id="file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
              <div class="space-y-1">
                <p class="text-xs font-semibold text-neutral-600">Choose Photo</p>
              </div>
            </div>

            <div id="upload-progress-container" class="hidden mt-2 space-y-1">
              <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
                <span id="upload-status">Uploading...</span>
                <span id="upload-percent">0%</span>
              </div>
              <div class="w-full bg-neutral-200 rounded-full h-1 overflow-hidden">
                <div id="upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
              </div>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Sort Order</label>
            <input type="number" name="sortOrder" value={editEntry?.sortOrder ?? 0} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Description</label>
            <textarea name="description" rows="3" class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none">{editEntry?.description || ''}</textarea>
          </div>
          <div class="sm:col-span-2 flex gap-2">
            <button type="submit" class="btn-primary text-xs">{editEntry ? 'Update' : 'Add Entry'}</button>
            <a href="/admin/about" class="btn-outline text-xs">Cancel</a>
          </div>
        </form>

        <script>
          import { fileManager } from '../../lib/file-manager';
          import { buildCloudinaryUrl } from '../../lib/cloudinary';

          const aboutForm = document.getElementById('about-form') as HTMLFormElement;
          const photoInput = document.getElementById('photo') as HTMLInputElement;
          const previewContainer = document.getElementById('photo-preview');
          const filePicker = document.getElementById('file-picker') as HTMLInputElement;
          const progressContainer = document.getElementById('upload-progress-container');
          const progressBar = document.getElementById('upload-progress-bar');
          const progressPercent = document.getElementById('upload-percent');
          const progressStatus = document.getElementById('upload-status');

          let selectedFile: File | null = null;
          let removedPublicIds: string[] = [];

          function renderPreview() {
            if (!previewContainer) return;
            previewContainer.innerHTML = '';
            
            let displayUrl = '';
            if (selectedFile) {
              displayUrl = URL.createObjectURL(selectedFile);
            } else {
              const imgVal = photoInput.value.trim();
              if (!imgVal) return;
              displayUrl = buildCloudinaryUrl(imgVal, { width: 200, height: 200 });
            }

            const div = document.createElement('div');
            div.className = 'relative group w-24 h-24 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
            div.innerHTML = `
              <img src="${displayUrl}" class="w-full h-full object-cover" />
              <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
            `;

            div.querySelector('button')?.addEventListener('click', () => {
              if (selectedFile) {
                selectedFile = null;
                filePicker.value = '';
              } else {
                const oldVal = photoInput.value.trim();
                if (oldVal) {
                  removedPublicIds.push(oldVal);
                }
                photoInput.value = '';
              }
              renderPreview();
            });

            previewContainer.appendChild(div);
          }

          filePicker?.addEventListener('change', async () => {
            const files = filePicker.files;
            if (!files || files.length === 0) return;

            let file = files[0];
            if (file.type.startsWith('image/')) {
              const cropped = await (window as any).cropImage(file, { aspectRatio: 1, title: 'Crop Leader Photo' });
              if (cropped === null) {
                filePicker.value = '';
                return;
              }
              file = cropped;
            }

            selectedFile = file;
            renderPreview();
          });

          aboutForm?.addEventListener('submit', async (e) => {
            if (!selectedFile && removedPublicIds.length === 0) {
              return; // Normal submit
            }

            e.preventDefault();

            if (progressContainer) {
              progressContainer.classList.remove('hidden');
              if (progressStatus) progressStatus.textContent = 'Saving entry...';
              if (progressBar) progressBar.style.width = '20%';
              if (progressPercent) progressPercent.textContent = '20%';
            }

            try {
              // 1. Upload new photo if selected
              if (selectedFile) {
                if (progressStatus) progressStatus.textContent = 'Uploading photo...';
                if (progressBar) progressBar.style.width = '50%';
                if (progressPercent) progressPercent.textContent = '50%';
                
                const uploadedId = await fileManager.upload(selectedFile, 'yash-electronics/about');
                photoInput.value = uploadedId;
              }

              // 2. Delete removed photos
              if (removedPublicIds.length > 0) {
                if (progressStatus) progressStatus.textContent = 'Removing old photo...';
                if (progressBar) progressBar.style.width = '80%';
                if (progressPercent) progressPercent.textContent = '80%';
                
                await Promise.all(removedPublicIds.map(id => fileManager.remove(id)));
                removedPublicIds = [];
              }

              if (progressBar) progressBar.style.width = '100%';
              if (progressPercent) progressPercent.textContent = '100%';

              // Submit form
              aboutForm.submit();
            } catch (err: any) {
              alert('Error saving leader photo: ' + err.message);
              if (progressContainer) progressContainer.classList.add('hidden');
            }
          });

          renderPreview();
        </script>
      </div>
    )}

    {!showForm && <div class="flex justify-end mb-4"><a href="/admin/about?action=add" class="btn-primary text-xs">+ Add Entry</a></div>}

    <div class="grid gap-4 sm:grid-cols-3">
      {allEntries.map(entry => (
        <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm flex flex-col justify-between">
          <div>
            <div class="flex justify-between items-start gap-3 mb-3">
              <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-semibold uppercase border ${
                entry.role === 'founder' ? 'bg-primary-50 text-primary border-primary-200' :
                entry.role === 'owner' ? 'bg-secondary-50 text-secondary border-secondary-200' :
                'bg-accent-50 text-accent border-accent-200'
              }`}>{roleLabels[entry.role] || entry.role}</span>
              
              {entry.photo && (
                <div class="h-12 w-12 rounded border border-neutral-200 overflow-hidden bg-neutral-50 flex-shrink-0">
                  <img src={buildCloudinaryUrl(entry.photo, { width: 100, height: 100 })} 
                    class="w-full h-full object-cover" />
                </div>
              )}
            </div>
            <h3 class="font-bold text-neutral-900 text-lg">{entry.name}</h3>
            {entry.description && <p class="text-xs text-neutral-500 mt-1 line-clamp-2">{entry.description}</p>}
          </div>
          <div class="mt-3 flex items-center gap-3">
            <a href={`/admin/about?edit=${entry.id}`} class="text-xs font-semibold text-primary hover:underline">Edit</a>
            <form method="post" class="inline-flex items-center m-0">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={entry.id} />
              <button type="button" onclick="confirmDelete(this, 'Delete Entry', 'Are you sure?')" class="text-xs font-semibold text-red-500 hover:underline cursor-pointer bg-transparent border-none p-0">Delete</button>
            </form>
          </div>
        </div>
      ))}
      {allEntries.length === 0 && <div class="sm:col-span-3 text-center py-8 text-neutral-500">No entries yet. Add Founder, Owner, and Next Gen leadership info.</div>}
    </div>
</AdminLayout>
