---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { settings } from '../../db/schema';
import { getSessionUser } from '../../lib/auth';
import { eq } from 'drizzle-orm';
import { clearCmsCache } from '../../services/cms';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

let message = Astro.url.searchParams.get('message') || '';
let error = Astro.url.searchParams.get('error') || '';

// Load current settings from database
let dbSettingsList = await db.select().from(settings);
const currentSettings: Record<string, string> = {};
dbSettingsList.forEach(s => {
  currentSettings[s.key] = s.value;
});

// Handle form submission
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const updatedSettings: Record<string, string> = {};

    const keys = [
      'businessName', 'businessName_gu',
      'tagline', 'tagline_gu',
      'logoUrl',
      'phone', 'whatsapp', 'email',
      'address', 'address_gu',
      'city', 'city_gu',
      'state', 'state_gu',
      'pincode', 'googleMapsUrl',
      'workingHours', 'workingHours_gu',
      'signup_bonus_points', 'referrer_bonus_points',
      'facebookUrl', 'instagramUrl', 'youtubeUrl'
    ];

    for (const key of keys) {
      updatedSettings[key] = formData.get(key)?.toString().trim() || '';
    }

    // Save/Update keys
    for (const [key, value] of Object.entries(updatedSettings)) {
      const [existing] = await db.select().from(settings).where(eq(settings.key, key));
      if (existing) {
        await db.update(settings).set({ value }).where(eq(settings.key, key));
      } else {
        await db.insert(settings).values({ key, value });
      }
    }

    // Reload settings
    dbSettingsList = await db.select().from(settings);
    dbSettingsList.forEach(s => {
      currentSettings[s.key] = s.value;
    });

    clearCmsCache();
    return Astro.redirect('/admin/settings?message=' + encodeURIComponent('System settings updated successfully!'));
  } catch (e: any) {
    error = 'Failed to update settings: ' + (e.message || 'Unknown error');
  }
}
---

<AdminLayout title="System Settings" activeTab="settings" subtitle="Manage store details, contact info, social links & global configurations">

  {message && <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-6">{message}</div>}
  {error && <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-6">{error}</div>}

  <form method="post" class="space-y-6 max-w-4xl mx-auto pb-12">
    <!-- Group 1: Store Branding -->
    <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm space-y-4">
      <h3 class="text-sm font-bold text-neutral-800 border-b border-neutral-100 pb-2 flex items-center gap-2">
        <span>🏪</span> Store Branding
      </h3>
      
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="businessName" class="block text-xs font-semibold text-neutral-700 mb-1">Store Name (English) *</label>
          <input type="text" id="businessName" name="businessName" required value={currentSettings.businessName || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="businessName_gu" class="block text-xs font-semibold text-neutral-700 mb-1">Store Name (Gujarati) *</label>
          <input type="text" id="businessName_gu" name="businessName_gu" required value={currentSettings.businessName_gu || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="tagline" class="block text-xs font-semibold text-neutral-700 mb-1">Tagline (English)</label>
          <input type="text" id="tagline" name="tagline" value={currentSettings.tagline || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="tagline_gu" class="block text-xs font-semibold text-neutral-700 mb-1">Tagline (Gujarati)</label>
          <input type="text" id="tagline_gu" name="tagline_gu" value={currentSettings.tagline_gu || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-neutral-700 mb-1">Store Logo</label>
        <input type="hidden" id="logoUrl" name="logoUrl" value={currentSettings.logoUrl || ''} />
        <div id="logo-preview" class="mb-2"></div>
        <div class="relative border border-dashed border-neutral-300 rounded p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer text-center" id="logo-dropzone">
          <input type="file" id="logo-file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
          <p class="text-xs font-semibold text-neutral-600">Choose Logo</p>
        </div>
        <div id="logo-upload-progress" class="hidden mt-2 space-y-1">
          <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
            <span>Uploading...</span>
            <span id="logo-upload-percent">0%</span>
          </div>
          <div class="w-full bg-neutral-200 rounded-full h-1 overflow-hidden">
            <div id="logo-upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Group 2: Contact Information -->
    <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm space-y-4">
      <h3 class="text-sm font-bold text-neutral-800 border-b border-neutral-100 pb-2 flex items-center gap-2">
        <span>📞</span> Contact Information
      </h3>

      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <label for="phone" class="block text-xs font-semibold text-neutral-700 mb-1">Phone Number</label>
          <input type="text" id="phone" name="phone" value={currentSettings.phone || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="whatsapp" class="block text-xs font-semibold text-neutral-700 mb-1">WhatsApp Number (inc. country code)</label>
          <input type="text" id="whatsapp" name="whatsapp" value={currentSettings.whatsapp || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="email" class="block text-xs font-semibold text-neutral-700 mb-1">Email Address</label>
          <input type="email" id="email" name="email" value={currentSettings.email || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="address" class="block text-xs font-semibold text-neutral-700 mb-1">Address (English)</label>
          <input type="text" id="address" name="address" value={currentSettings.address || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="address_gu" class="block text-xs font-semibold text-neutral-700 mb-1">Address (Gujarati)</label>
          <input type="text" id="address_gu" name="address_gu" value={currentSettings.address_gu || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-4">
        <div>
          <label for="city" class="block text-xs font-semibold text-neutral-700 mb-1">City (English)</label>
          <input type="text" id="city" name="city" value={currentSettings.city || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="city_gu" class="block text-xs font-semibold text-neutral-700 mb-1">City (Gujarati)</label>
          <input type="text" id="city_gu" name="city_gu" value={currentSettings.city_gu || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="state" class="block text-xs font-semibold text-neutral-700 mb-1">State (English)</label>
          <input type="text" id="state" name="state" value={currentSettings.state || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="pincode" class="block text-xs font-semibold text-neutral-700 mb-1">Pincode</label>
          <input type="text" id="pincode" name="pincode" value={currentSettings.pincode || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>

      <div>
        <label for="googleMapsUrl" class="block text-xs font-semibold text-neutral-700 mb-1">Google Maps Location Link</label>
        <input type="url" id="googleMapsUrl" name="googleMapsUrl" value={currentSettings.googleMapsUrl || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
      </div>
    </div>



    <!-- Group 4: Operating Hours & System Constants -->
    <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm space-y-4">
      <h3 class="text-sm font-bold text-neutral-800 border-b border-neutral-100 pb-2 flex items-center gap-2">
        <span>⏰</span> System Configurations
      </h3>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="workingHours" class="block text-xs font-semibold text-neutral-700 mb-1">Working Hours (English)</label>
          <input type="text" id="workingHours" name="workingHours" value={currentSettings.workingHours || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="workingHours_gu" class="block text-xs font-semibold text-neutral-700 mb-1">Working Hours (Gujarati)</label>
          <input type="text" id="workingHours_gu" name="workingHours_gu" value={currentSettings.workingHours_gu || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="signup_bonus_points" class="block text-xs font-semibold text-neutral-700 mb-1">Signup Reward (Credits/Points)</label>
          <input type="number" id="signup_bonus_points" name="signup_bonus_points" value={currentSettings.signup_bonus_points || '0'} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="referrer_bonus_points" class="block text-xs font-semibold text-neutral-700 mb-1">Referral Reward (Credits/Points)</label>
          <input type="number" id="referrer_bonus_points" name="referrer_bonus_points" value={currentSettings.referrer_bonus_points || '0'} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>
    </div>

    <!-- Group 5: Social Media Links -->
    <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm space-y-4">
      <h3 class="text-sm font-bold text-neutral-800 border-b border-neutral-100 pb-2 flex items-center gap-2">
        <span>🌐</span> Social Media Links
      </h3>

      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <label for="facebookUrl" class="block text-xs font-semibold text-neutral-700 mb-1">Facebook URL</label>
          <input type="url" id="facebookUrl" name="facebookUrl" value={currentSettings.facebookUrl || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="instagramUrl" class="block text-xs font-semibold text-neutral-700 mb-1">Instagram URL</label>
          <input type="url" id="instagramUrl" name="instagramUrl" value={currentSettings.instagramUrl || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
        <div>
          <label for="youtubeUrl" class="block text-xs font-semibold text-neutral-700 mb-1">YouTube URL</label>
          <input type="url" id="youtubeUrl" name="youtubeUrl" value={currentSettings.youtubeUrl || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
        </div>
      </div>
    </div>

    <div class="flex justify-end gap-3 pt-4 border-t border-neutral-200">
      <button type="submit" class="btn-primary px-8 py-2 text-sm font-semibold">
        Save Configurations
      </button>
    </div>
  </form>

  <script>
    const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dyjsrdrxa';

    function setupUploader(inputId: string, filePickerId: string, previewId: string, progressContainerId: string, progressBarId: string, percentId: string) {
      const input = document.getElementById(inputId) as HTMLInputElement;
      const preview = document.getElementById(previewId);
      const picker = document.getElementById(filePickerId) as HTMLInputElement;
      const progressContainer = document.getElementById(progressContainerId);
      const progressBar = document.getElementById(progressBarId);
      const percent = document.getElementById(percentId);

      function render() {
        if (!preview) return;
        preview.innerHTML = '';
        const val = input.value.trim();
        if (!val) return;

        let displayUrl = val;
        if (!val.startsWith('http') && !val.startsWith('/')) {
          displayUrl = `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/w_200,h_200,c_fill,f_auto,q_auto/${val}`;
        }

        const div = document.createElement('div');
        div.className = 'relative group w-24 h-24 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
        div.innerHTML = `
          <img src="${displayUrl}" class="w-full h-full object-cover" />
          <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
        `;

        div.querySelector('button')?.addEventListener('click', () => {
          input.value = '';
          render();
        });

        preview.appendChild(div);
      }

      picker?.addEventListener('change', async () => {
        const files = picker.files;
        if (!files || files.length === 0) return;

        const file = files[0];
        progressContainer?.classList.remove('hidden');

        try {
          const resVal = await new Promise<string>((resolve, reject) => {
            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/api/upload', true);
            
            xhr.upload.onprogress = (e) => {
              if (e.lengthComputable) {
                const pct = Math.round((e.loaded / e.total) * 100);
                progressBar!.style.width = `${pct}%`;
                percent!.textContent = `${pct}%`;
              }
            };

            xhr.onload = () => {
              if (xhr.status === 200) {
                try {
                  const res = JSON.parse(xhr.responseText);
                  resolve(res.public_id || res.url);
                } catch(e) {
                  reject('Invalid response');
                }
              } else {
                reject('Server returned status ' + xhr.status);
              }
            };

            xhr.onerror = () => reject('Network error');

            const formData = new FormData();
            formData.append('file', file);
            xhr.send(formData);
          });

          if (resVal) {
            input.value = resVal;
            render();
          }
        } catch (err) {
          alert('Upload failed: ' + err);
        } finally {
          progressContainer?.classList.add('hidden');
          picker.value = '';
        }
      });

      render();
    }

    // Setup uploader for Logo & Hero image
    setupUploader('logoUrl', 'logo-file-picker', 'logo-preview', 'logo-upload-progress', 'logo-upload-progress-bar', 'logo-upload-percent');
  </script>
</AdminLayout>
