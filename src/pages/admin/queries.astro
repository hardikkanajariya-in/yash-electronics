---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db } from "../../db";
import { contactQueries } from "../../db/schema";
import { eq, and, or, ilike, desc, asc, sql } from "drizzle-orm";
import { getSessionUser } from "../../lib/auth";

export const prerender = false;

// Authenticate Admin
Astro.response.headers.set(
  "Cache-Control",
  "no-cache, no-store, must-revalidate",
);
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== "admin") {
  return Astro.redirect(
    "/account/login?redirect=" + encodeURIComponent(Astro.url.pathname),
  );
}

let error = Astro.url.searchParams.get("error") || "";
let success = Astro.url.searchParams.get("success") || "";

// Handle status updates or deletions
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("formAction")?.toString() || "";
    const queryId = formData.get("queryId")?.toString() || "";

    if (action === "update_status" && queryId) {
      const newStatus = formData.get("status")?.toString() as any;
      if (["unread", "read", "resolved"].includes(newStatus)) {
        await db
          .update(contactQueries)
          .set({ status: newStatus })
          .where(eq(contactQueries.id, queryId));
        return Astro.redirect(
          "/admin/queries?success=" +
            encodeURIComponent("Query status updated successfully!"),
        );
      }
    } else if (action === "delete" && queryId) {
      await db.delete(contactQueries).where(eq(contactQueries.id, queryId));
      return Astro.redirect(
        "/admin/queries?success=" +
          encodeURIComponent("Query deleted successfully!"),
      );
    }
  } catch (e: any) {
    error = e.message || "Failed to update query.";
  }
}

// Fetch queries parameters
const search = Astro.url.searchParams.get("search")?.trim() || "";
const statusFilter = Astro.url.searchParams.get("status") || "all"; // all, unread, read, resolved
const sort = Astro.url.searchParams.get("sort") || "created-desc";
const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 10;
const offset = (page - 1) * limit;

const conditions = [];

if (statusFilter !== "all") {
  conditions.push(eq(contactQueries.status, statusFilter as any));
}

if (search) {
  conditions.push(
    or(
      ilike(contactQueries.name, `%${search}%`),
      ilike(contactQueries.phone, `%${search}%`),
      ilike(contactQueries.email, `%${search}%`),
      ilike(contactQueries.message, `%${search}%`),
    ),
  );
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

let orderByClause = [desc(contactQueries.createdAt)];
if (sort === "created-asc") {
  orderByClause = [asc(contactQueries.createdAt)];
}

let allQueries: any[] = [];
let totalCount = 0;

try {
  allQueries = await db
    .select()
    .from(contactQueries)
    .where(whereClause)
    .orderBy(...orderByClause)
    .limit(limit)
    .offset(offset);

  const [countRes] = await db
    .select({ count: sql`count(*)` })
    .from(contactQueries)
    .where(whereClause);
  totalCount = Number(countRes?.count || 0);
} catch (e) {
  console.error("[Admin Queries] Failed to fetch queries:", e);
}

const totalPages = Math.ceil(totalCount / limit);

// Counts for filters
let allCount = 0;
let unreadCount = 0;
let readCount = 0;
let resolvedCount = 0;

try {
  const [allRes] = await db
    .select({ count: sql`count(*)` })
    .from(contactQueries);
  allCount = Number(allRes?.count || 0);

  const [unreadRes] = await db
    .select({ count: sql`count(*)` })
    .from(contactQueries)
    .where(eq(contactQueries.status, "unread"));
  unreadCount = Number(unreadRes?.count || 0);

  const [readRes] = await db
    .select({ count: sql`count(*)` })
    .from(contactQueries)
    .where(eq(contactQueries.status, "read"));
  readCount = Number(readRes?.count || 0);

  const [resolvedRes] = await db
    .select({ count: sql`count(*)` })
    .from(contactQueries)
    .where(eq(contactQueries.status, "resolved"));
  resolvedCount = Number(resolvedRes?.count || 0);
} catch (e) {
  console.error("[Admin Queries] Failed to fetch counts:", e);
}
---

<AdminLayout
  title="Customer Queries"
  activeTab="queries"
  subtitle="Respond to customer questions and messages"
>
  {
    error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )
  }
  {
    success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )
  }

  <!-- Navigation Tabs / Filters -->
  <div
    class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6"
  >
    <nav
      class="flex border-b border-neutral-200 gap-2 overflow-x-auto text-xs font-medium pb-1 select-none whitespace-nowrap no-scrollbar w-full md:w-auto"
    >
      <a
        href={`?status=all&search=${search}&sort=${sort}`}
        class={`px-3 py-2 font-semibold border-b-2 ${statusFilter === "all" ? "border-primary text-primary font-bold" : "text-neutral-600 hover:text-primary border-transparent"}`}
      >
        All ({allCount})
      </a>
      <a
        href={`?status=unread&search=${search}&sort=${sort}`}
        class={`px-3 py-2 font-semibold border-b-2 ${statusFilter === "unread" ? "border-primary text-primary font-bold" : "text-neutral-600 hover:text-primary border-transparent"}`}
      >
        Unread ({unreadCount})
      </a>
      <a
        href={`?status=read&search=${search}&sort=${sort}`}
        class={`px-3 py-2 font-semibold border-b-2 ${statusFilter === "read" ? "border-primary text-primary font-bold" : "text-neutral-600 hover:text-primary border-transparent"}`}
      >
        Read ({readCount})
      </a>
      <a
        href={`?status=resolved&search=${search}&sort=${sort}`}
        class={`px-3 py-2 font-semibold border-b-2 ${statusFilter === "resolved" ? "border-primary text-primary font-bold" : "text-neutral-600 hover:text-primary border-transparent"}`}
      >
        Resolved ({resolvedCount})
      </a>
    </nav>

    {/* Search, Sort, Filter Controls */}
    <form
      method="get"
      class="flex flex-col sm:flex-row flex-wrap gap-3 items-stretch sm:items-center w-full md:w-auto"
    >
      <input type="hidden" name="status" value={statusFilter} />
      <div class="relative w-full sm:w-64">
        <input
          type="text"
          name="search"
          value={search}
          placeholder="Search inquiries..."
          class="w-full rounded border border-neutral-300 pl-8 pr-3 py-1.5 text-xs focus:border-primary focus:outline-none"
        />
        <span class="absolute left-2.5 top-2.5 text-neutral-400 text-xs"
          >🔍</span
        >
      </div>

      <select
        name="sort"
        class="w-full sm:w-auto rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer"
      >
        <option value="created-desc" selected={sort === "created-desc"}
          >Date Created (Newest)</option
        >
        <option value="created-asc" selected={sort === "created-asc"}
          >Date Created (Oldest)</option
        >
      </select>

      <div class="flex items-center gap-2 w-full sm:w-auto">
        <button
          type="submit"
          class="flex-1 sm:flex-initial bg-neutral-800 text-white rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-900 transition-colors cursor-pointer text-center"
        >
          Filter
        </button>

        {
          (search || sort !== "created-desc") && (
            <a
              href={`?status=${statusFilter}`}
              class="flex-1 sm:flex-initial bg-neutral-100 text-neutral-700 rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-200 transition-colors text-center justify-center flex items-center"
            >
              Clear
            </a>
          )
        }
      </div>
    </form>
  </div>

  <!-- Queries List -->
  <div class="space-y-4">
    {/* Desktop Table View */}
    <div
      class="hidden md:block bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden"
    >
      <div class="overflow-x-auto">
        <table
          class="w-full text-left text-sm text-neutral-700 border-collapse"
        >
          <thead>
            <tr
              class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900"
            >
              <th class="p-3 w-1/6">Customer</th>
              <th class="p-3 w-1/5">Contact</th>
              <th class="p-3">Message</th>
              <th class="p-3 w-1/6">Date</th>
              <th class="p-3 w-1/12">Status</th>
              <th class="p-3 text-right w-1/6">Actions</th>
            </tr>
          </thead>
          <tbody>
            {
              allQueries.map((query) => {
                const dateStr = new Date(query.createdAt).toLocaleDateString(
                  "en-IN",
                  {
                    day: "2-digit",
                    month: "short",
                    year: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                  },
                );
                return (
                  <tr class="border-b border-neutral-100 hover:bg-neutral-50/50">
                    <td class="p-3 font-semibold text-neutral-900">
                      {query.name}
                    </td>
                    <td class="p-3 text-xs">
                      <div>
                        📞{" "}
                        <a
                          href={`tel:${query.phone}`}
                          class="text-primary hover:underline font-medium"
                        >
                          {query.phone}
                        </a>
                      </div>
                      {query.email && (
                        <div class="mt-0.5 text-neutral-500 font-mono">
                          ✉️ {query.email}
                        </div>
                      )}
                    </td>
                    <td
                      class="p-3 text-xs max-w-md break-words whitespace-pre-wrap"
                      title={query.message}
                    >
                      {query.message}
                    </td>
                    <td class="p-3 text-xs text-neutral-400">{dateStr}</td>
                    <td class="p-3">
                      <span
                        class={`inline-block rounded px-2 py-0.5 text-[10px] font-semibold uppercase border ${
                          query.status === "unread"
                            ? "bg-red-50 text-red-700 border-red-200 font-bold"
                            : query.status === "read"
                              ? "bg-blue-50 text-blue-700 border-blue-200"
                              : "bg-green-50 text-green-700 border-green-200"
                        }`}
                      >
                        {query.status}
                      </span>
                    </td>
                    <td class="p-3 text-right flex justify-end gap-3 items-center min-h-[4rem]">
                      <form method="post" class="flex items-center gap-1">
                        <input
                          type="hidden"
                          name="formAction"
                          value="update_status"
                        />
                        <input type="hidden" name="queryId" value={query.id} />
                        <select
                          name="status"
                          class="rounded border border-neutral-300 px-1 py-0.5 text-[10px] focus:border-primary focus:outline-none cursor-pointer"
                          onchange="this.form.submit()"
                        >
                          <option
                            value="unread"
                            selected={query.status === "unread"}
                          >
                            Unread
                          </option>
                          <option
                            value="read"
                            selected={query.status === "read"}
                          >
                            Read
                          </option>
                          <option
                            value="resolved"
                            selected={query.status === "resolved"}
                          >
                            Resolved
                          </option>
                        </select>
                      </form>

                      <form method="post" class="inline m-0">
                        <input type="hidden" name="formAction" value="delete" />
                        <input type="hidden" name="queryId" value={query.id} />
                        <button
                          type="button"
                          onclick="window.confirmDelete(this, 'Delete Inquiry', 'Are you sure you want to delete this inquiry?')"
                          class="text-xs font-semibold text-red-600 hover:underline bg-none border-none cursor-pointer focus:outline-none"
                        >
                          Delete
                        </button>
                      </form>
                    </td>
                  </tr>
                );
              })
            }
            {
              allQueries.length === 0 && (
                <tr>
                  <td colspan="6" class="p-8 text-center text-neutral-500">
                    No inquiries found.
                  </td>
                </tr>
              )
            }
          </tbody>
        </table>
      </div>
    </div>

    {/* Mobile Flat List View */}
    <div
      class="md:hidden bg-white border border-neutral-200 rounded-lg shadow-sm divide-y divide-neutral-100"
    >
      {
        allQueries.map((query) => {
          const dateStr = new Date(query.createdAt).toLocaleDateString(
            "en-IN",
            {
              day: "2-digit",
              month: "short",
              year: "numeric",
              hour: "2-digit",
              minute: "2-digit",
            },
          );
          return (
            <div class="p-4 space-y-3">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="font-bold text-sm text-neutral-900 truncate">
                    {query.name}
                  </div>
                  <div class="text-[10px] text-neutral-400 mt-0.5">
                    {dateStr}
                  </div>
                </div>
                <div class="shrink-0">
                  <span
                    class={`inline-block rounded px-2 py-0.5 text-[9px] font-bold uppercase border ${
                      query.status === "unread"
                        ? "bg-red-50 text-red-700 border-red-200"
                        : query.status === "read"
                          ? "bg-blue-50 text-blue-700 border-blue-200"
                          : "bg-green-50 text-green-700 border-green-200"
                    }`}
                  >
                    {query.status}
                  </span>
                </div>
              </div>

              <div class="text-xs text-neutral-600 space-y-0.5">
                <div>
                  Phone:{" "}
                  <a
                    href={`tel:${query.phone}`}
                    class="text-primary hover:underline font-medium font-mono"
                  >
                    {query.phone}
                  </a>
                </div>
                {query.email && (
                  <div>
                    Email:{" "}
                    <a
                      href={`mailto:${query.email}`}
                      class="text-primary hover:underline font-mono"
                    >
                      {query.email}
                    </a>
                  </div>
                )}
              </div>

              <div class="bg-neutral-50 rounded p-2 text-xs text-neutral-700 border border-neutral-100 whitespace-pre-wrap leading-relaxed">
                {query.message}
              </div>

              <div class="flex items-center justify-between pt-1">
                <form method="post" class="flex items-center gap-1.5">
                  <input
                    type="hidden"
                    name="formAction"
                    value="update_status"
                  />
                  <input type="hidden" name="queryId" value={query.id} />
                  <span class="text-[10px] text-neutral-400">Mark:</span>
                  <select
                    name="status"
                    class="rounded border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none"
                    onchange="this.form.submit()"
                  >
                    <option value="unread" selected={query.status === "unread"}>
                      Unread
                    </option>
                    <option value="read" selected={query.status === "read"}>
                      Read
                    </option>
                    <option
                      value="resolved"
                      selected={query.status === "resolved"}
                    >
                      Resolved
                    </option>
                  </select>
                </form>

                <form method="post" class="inline m-0">
                  <input type="hidden" name="formAction" value="delete" />
                  <input type="hidden" name="queryId" value={query.id} />
                  <button
                    type="button"
                    onclick="window.confirmDelete(this, 'Delete Inquiry', 'Are you sure you want to delete this inquiry?')"
                    class="text-xs font-bold text-red-600 bg-red-50 px-2.5 py-1.5 rounded hover:bg-red-100 cursor-pointer"
                  >
                    Delete
                  </button>
                </form>
              </div>
            </div>
          );
        })
      }
      {
        allQueries.length === 0 && (
          <div class="p-8 text-center text-neutral-500 text-sm">
            No inquiries found.
          </div>
        )
      }
    </div>

    {/* Pagination Controls */}
    {
      totalPages > 1 && (
        <div class="flex items-center justify-between border-t border-neutral-200 bg-white px-4 py-3 sm:px-6 rounded-lg shadow-sm">
          <div class="flex flex-1 justify-between sm:hidden">
            <a
              href={
                page > 1
                  ? `?page=${page - 1}&search=${search}&status=${statusFilter}&sort=${sort}`
                  : "#"
              }
              class={`relative inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page <= 1 ? "pointer-events-none opacity-50" : ""}`}
            >
              Previous
            </a>
            <a
              href={
                page < totalPages
                  ? `?page=${page + 1}&search=${search}&status=${statusFilter}&sort=${sort}`
                  : "#"
              }
              class={`relative ml-3 inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page >= totalPages ? "pointer-events-none opacity-50" : ""}`}
            >
              Next
            </a>
          </div>
          <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
              <p class="text-xs text-neutral-700">
                Showing
                <span class="font-semibold">
                  {Math.min(offset + 1, totalCount)}
                </span>
                to
                <span class="font-semibold">
                  {Math.min(offset + limit, totalCount)}
                </span>
                of
                <span class="font-semibold">{totalCount}</span>
                results
              </p>
            </div>
            <div>
              <nav
                class="isolate inline-flex -space-x-px rounded-md shadow-sm"
                aria-label="Pagination"
              >
                <a
                  href={
                    page > 1
                      ? `?page=${page - 1}&search=${search}&status=${statusFilter}&sort=${sort}`
                      : "#"
                  }
                  class={`relative inline-flex items-center rounded-l-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page <= 1 ? "pointer-events-none opacity-50" : ""}`}
                >
                  <span class="sr-only">Previous</span>
                  <span>◀</span>
                </a>
                {Array.from({ length: totalPages }).map((_, idx) => {
                  const pNum = idx + 1;
                  const isCurrent = pNum === page;
                  return (
                    <a
                      href={`?page=${pNum}&search=${search}&status=${statusFilter}&sort=${sort}`}
                      aria-current={isCurrent ? "page" : undefined}
                      class={`relative inline-flex items-center px-3 py-2 text-xs font-semibold ${isCurrent ? "z-10 bg-primary text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" : "text-neutral-900 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0"}`}
                    >
                      {pNum}
                    </a>
                  );
                })}
                <a
                  href={
                    page < totalPages
                      ? `?page=${page + 1}&search=${search}&status=${statusFilter}&sort=${sort}`
                      : "#"
                  }
                  class={`relative inline-flex items-center rounded-r-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page >= totalPages ? "pointer-events-none opacity-50" : ""}`}
                >
                  <span class="sr-only">Next</span>
                  <span>▶</span>
                </a>
              </nav>
            </div>
          </div>
        </div>
      )
    }
  </div>
</AdminLayout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>
