---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { db } from '../../db';
import { contactQueries } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getSessionUser } from '../../lib/auth';

export const prerender = false;

// Authenticate Admin
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/admin/login');
}

let error = '';
let success = '';

// Handle status updates or deletions
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('formAction')?.toString() || '';
    const queryId = formData.get('queryId')?.toString() || '';

    if (action === 'update_status' && queryId) {
      const newStatus = formData.get('status')?.toString() as any;
      if (['unread', 'read', 'resolved'].includes(newStatus)) {
        await db.update(contactQueries).set({ status: newStatus }).where(eq(contactQueries.id, queryId));
        success = 'Query status updated successfully!';
      }
    } else if (action === 'delete' && queryId) {
      await db.delete(contactQueries).where(eq(contactQueries.id, queryId));
      success = 'Query deleted successfully!';
    }
  } catch (e: any) {
    error = e.message || 'Failed to update query.';
  }
}

// Fetch contact queries
let allQueries: any[] = [];
try {
  allQueries = await db.select().from(contactQueries).orderBy(desc(contactQueries.createdAt));
} catch (e) {
  console.error('[Admin Queries] Failed to fetch queries:', e);
}

// Counts for filters
const counts = {
  all: allQueries.length,
  unread: allQueries.filter(q => q.status === 'unread').length,
  read: allQueries.filter(q => q.status === 'read').length,
  resolved: allQueries.filter(q => q.status === 'resolved').length,
};
---

<BaseLayout title="Contact Queries" noindex={true}>
  <Container class="py-6">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-neutral-200 pb-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold text-neutral-900">Contact Inquiries</h1>
        <p class="text-xs text-neutral-500">Respond to customer questions and messages</p>
      </div>
      <a href="/admin" class="text-xs font-semibold text-neutral-600 border border-neutral-300 rounded-md px-3 py-1.5 hover:bg-neutral-50 transition-colors">
        ← Dashboard
      </a>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    <!-- Navigation Tabs / Filters -->
    <nav class="flex border-b border-neutral-200 gap-2 mb-6 overflow-x-auto text-xs font-medium pb-2 select-none whitespace-nowrap">
      <button onclick="filterQueries('all')" id="tab-all" class="border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none">
        All ({counts.all})
      </button>
      <button onclick="filterQueries('unread')" id="tab-unread" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Unread ({counts.unread})
      </button>
      <button onclick="filterQueries('read')" id="tab-read" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Read ({counts.read})
      </button>
      <button onclick="filterQueries('resolved')" id="tab-resolved" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Resolved ({counts.resolved})
      </button>
    </nav>

    <!-- Queries List -->
    <div class="space-y-4" id="queries-container">
      {allQueries.map((query) => {
        const dateStr = new Date(query.createdAt).toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });

        return (
          <div data-status={query.status} class="query-card bg-white border border-neutral-200 rounded-lg shadow-sm p-4 sm:p-5 hover:shadow-md transition-shadow">
            <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-100 pb-3 mb-3">
              <div>
                <h3 class="text-sm font-bold text-neutral-800">{query.name}</h3>
                <span class="text-[10px] text-neutral-400">{dateStr}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class={`inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase border ${
                  query.status === 'unread' ? 'bg-red-50 text-red-700 border-red-200 font-bold' :
                  query.status === 'read' ? 'bg-blue-50 text-blue-700 border-blue-200' :
                  'bg-green-50 text-green-700 border-green-200'
                }`}>
                  {query.status}
                </span>
              </div>
            </div>

            <div class="space-y-3">
              {/* Contact metadata */}
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-neutral-600">
                <span>
                  📞 <a href={`tel:${query.phone}`} class="text-primary hover:underline font-medium">{query.phone}</a>
                </span>
                {query.email && (
                  <span>
                    ✉️ <a href={`mailto:${query.email}`} class="text-primary hover:underline">{query.email}</a>
                  </span>
                )}
              </div>

              {/* Message */}
              <div class="bg-neutral-50 rounded-md p-3 border border-neutral-100 text-sm text-neutral-700 whitespace-pre-wrap leading-relaxed">
                {query.message}
              </div>

              {/* Actions */}
              <div class="flex items-center justify-between border-t border-neutral-100 pt-3 mt-3">
                <form method="post" class="inline">
                  <input type="hidden" name="formAction" value="delete" />
                  <input type="hidden" name="queryId" value={query.id} />
                  <button 
                    type="button" 
                    onclick="window.confirmDelete(this, 'Delete Inquiry', 'Are you sure you want to delete this inquiry?')"
                    class="text-xs text-red-600 font-semibold hover:underline bg-none border-none cursor-pointer focus:outline-none"
                  >
                    Delete Inquiry
                  </button>
                </form>

                <form method="post" class="flex items-center gap-2">
                  <input type="hidden" name="formAction" value="update_status" />
                  <input type="hidden" name="queryId" value={query.id} />
                  <span class="text-[11px] text-neutral-400">Mark:</span>
                  <select
                    name="status"
                    class="rounded border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none"
                    onchange="this.form.submit()"
                  >
                    <option value="unread" selected={query.status === 'unread'}>Unread</option>
                    <option value="read" selected={query.status === 'read'}>Read</option>
                    <option value="resolved" selected={query.status === 'resolved'}>Resolved</option>
                  </select>
                </form>
              </div>
            </div>
          </div>
        );
      })}

      {allQueries.length === 0 && (
        <div class="bg-white border border-neutral-200 rounded-lg p-12 text-center text-neutral-500 shadow-sm">
          No customer inquiries found.
        </div>
      )}
    </div>
  </Container>
</BaseLayout>

<script is:inline>
  function filterQueries(status) {
    const tabs = ['all', 'unread', 'read', 'resolved'];
    tabs.forEach(t => {
      const el = document.getElementById(`tab-${t}`);
      if (el) {
        if (t === status) {
          el.className = "border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none";
        } else {
          el.className = "text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none";
        }
      }
    });

    const cards = document.querySelectorAll('.query-card');
    cards.forEach(card => {
      const cardStatus = card.getAttribute('data-status');
      if (status === 'all' || cardStatus === status) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>
