---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db } from "../../db";
import { users, orders, settings } from "../../db/schema";
import { eq, and, or, ilike, desc, asc, gt, sql } from "drizzle-orm";
import { getSessionUser } from "../../lib/auth";

export const prerender = false;

// Authenticate Admin
Astro.response.headers.set(
  "Cache-Control",
  "no-cache, no-store, must-revalidate",
);
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== "admin") {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

let error = Astro.url.searchParams.get("error") || "";
let success = Astro.url.searchParams.get("success") || "";

const action = Astro.url.searchParams.get("action") || "list";
const customerId = Astro.url.searchParams.get("id") || "";

// Handle POST actions (credit adjustment, deletion, settings update)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get("formAction")?.toString();
    const targetId = formData.get("customerId")?.toString() || "";

    if (formAction === "adjust_credits" && targetId) {
      const newCredits = parseInt(
        formData.get("credits")?.toString() || "0",
        10,
      );
      if (isNaN(newCredits) || newCredits < 0) {
        error = "Credits must be a valid positive integer.";
      } else {
        await db
          .update(users)
          .set({ credits: newCredits })
          .where(eq(users.id, targetId));
        return Astro.redirect(
          `/admin/customers?action=view&id=${targetId}&success=` +
            encodeURIComponent("Customer credits updated successfully!"),
        );
      }
    } else if (formAction === "delete" && targetId) {
      await db.delete(users).where(eq(users.id, targetId));
      return Astro.redirect(
        "/admin/customers?success=" +
          encodeURIComponent("Customer deleted successfully!"),
      );
    }
  } catch (e: any) {
    error = e.message || "Failed to perform action.";
  }
}

// Fetch global referral reward settings
let signupBonusPointsSetting = 50;
let referrerBonusPointsSetting = 100;
try {
  const [signupSetting] = await db
    .select()
    .from(settings)
    .where(eq(settings.key, "signup_bonus_points"));
  if (signupSetting)
    signupBonusPointsSetting = parseInt(signupSetting.value, 10);

  const [referrerSetting] = await db
    .select()
    .from(settings)
    .where(eq(settings.key, "referrer_bonus_points"));
  if (referrerSetting)
    referrerBonusPointsSetting = parseInt(referrerSetting.value, 10);
} catch (e) {
  console.error("[Admin Customers] Failed to fetch settings:", e);
}

// Page variables
let customer: any = null;
let referralsMade: any[] = [];
let ledger: any[] = [];
let customersList: any[] = [];
let search = Astro.url.searchParams.get("search")?.trim() || "";
let referrerName = "None";

const sort = Astro.url.searchParams.get("sort") || "created-desc";
const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 10;
const offset = (page - 1) * limit;
let totalCount = 0;

if (action === "view" && customerId) {
  const [foundCustomer] = await db
    .select()
    .from(users)
    .where(and(eq(users.id, customerId), eq(users.role, "customer")));
  if (!foundCustomer) {
    return Astro.redirect("/admin/customers?error=Customer+not+found");
  }
  customer = foundCustomer;

  // Fetch referrals made by this customer (U.referredById = customer.id)
  referralsMade = await db
    .select()
    .from(users)
    .where(eq(users.referredById, customer.id))
    .orderBy(desc(users.createdAt));

  // Determine referrer details
  if (customer.referredById) {
    const [ref] = await db
      .select()
      .from(users)
      .where(eq(users.id, customer.referredById));
    if (ref) {
      referrerName = `${ref.name} (${ref.phone})`;
    }
  }

  // Build points transaction ledger
  // 1. Signup Bonus (+50 points)
  if (customer.referredById) {
    const [referrerUser] = await db
      .select()
      .from(users)
      .where(eq(users.id, customer.referredById));
    ledger.push({
      date: customer.createdAt,
      type: "signup_bonus",
      points: signupBonusPointsSetting,
      description: referrerUser
        ? `Signup bonus for registering with code of ${referrerUser.name} (${referrerUser.phone})`
        : `Signup bonus for registering`,
    });
  }

  // 2. Referral Earnings (+100 points per referred user)
  for (const ref of referralsMade) {
    ledger.push({
      date: ref.createdAt,
      type: "referral_bonus",
      points: referrerBonusPointsSetting,
      description: `Referral bonus for inviting ${ref.name} (${ref.phone})`,
    });
  }

  // 3. Order Redeemed Credits (deductions)
  const orderDeductions = await db
    .select()
    .from(orders)
    .where(and(eq(orders.userId, customer.id), gt(orders.creditsUsed, 0)))
    .orderBy(desc(orders.createdAt));

  for (const order of orderDeductions) {
    ledger.push({
      date: order.createdAt,
      type: "redemption",
      points: -order.creditsUsed,
      description: `Redeemed points on order #${order.id.slice(0, 8)}`,
      link: `/admin/orders`,
    });
  }

  // Sort chronological ledger newest first
  ledger.sort(
    (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
  );
} else {
  // List view
  const conditions: any[] = [eq(users.role, "customer")];

  if (search) {
    conditions.push(
      or(
        ilike(users.name, `%${search}%`),
        ilike(users.phone, `%${search}%`),
        ilike(users.email, `%${search}%`)
      )
    );
  }

  const whereClause = and(...conditions);

  let orderByClause = [desc(users.createdAt)];
  if (sort === 'created-asc') {
    orderByClause = [asc(users.createdAt)];
  } else if (sort === 'name-asc') {
    orderByClause = [asc(users.name)];
  } else if (sort === 'name-desc') {
    orderByClause = [desc(users.name)];
  } else if (sort === 'points-desc') {
    orderByClause = [desc(users.credits)];
  }

  try {
    customersList = await db
      .select()
      .from(users)
      .where(whereClause)
      .orderBy(...orderByClause)
      .limit(limit)
      .offset(offset);

    const [countRes] = await db
      .select({ count: sql`count(*)` })
      .from(users)
      .where(whereClause);
    totalCount = Number(countRes?.count || 0);
  } catch (e) {
    console.error("[Admin Customers] Failed to fetch customer list:", e);
  }
}

const totalPages = Math.ceil(totalCount / limit);

// Fetch stats for overview
let totalCustomers = 0;
try {
  const [custCount] = await db
    .select({ count: sql`count(*)` })
    .from(users)
    .where(eq(users.role, "customer"));
  totalCustomers = Number(custCount?.count || 0);
} catch (e) {
  console.error("[Admin Customers] Failed to fetch total customer count:", e);
}

const formatDate = (dateStr: string) => {
  if (!dateStr) return "N/A";
  try {
    return new Date(dateStr).toLocaleDateString("en-IN", {
      day: "2-digit",
      month: "short",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    });
  } catch (e) {
    return dateStr;
  }
};
---

<AdminLayout
  title={action === "view" && customer
    ? "Customer Profile"
    : "Manage Customers"}
  activeTab="customers"
  subtitle={action === "view" && customer
    ? `View details, referral statistics, and loyalty credit history.`
    : `${totalCustomers} registered customers in database.`}
>
  {
    error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )
  }
  {
    success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )
  }

  {/* LIST VIEW */}
  {
    action === "list" && (
      <div class="space-y-4">
        {/* Search, Sort, Filter Controls */}
        <div class="flex flex-wrap items-center justify-between gap-4 bg-white border border-neutral-200 rounded-lg p-4 shadow-sm">
          <form method="get" class="flex flex-wrap gap-3 items-center w-full sm:w-auto">
            <div class="relative w-80">
              <input
                type="text"
                name="search"
                value={search}
                placeholder="Search by name, phone, or email..."
                class="w-full rounded border border-neutral-300 pl-8 pr-3 py-1.5 text-xs focus:border-primary focus:outline-none"
              />
              <span class="absolute left-2.5 top-2.5 text-neutral-400 text-xs">🔍</span>
            </div>

            <select name="sort" class="rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer">
              <option value="created-desc" selected={sort === 'created-desc'}>Joined Date (Newest)</option>
              <option value="created-asc" selected={sort === 'created-asc'}>Joined Date (Oldest)</option>
              <option value="name-asc" selected={sort === 'name-asc'}>Name (A-Z)</option>
              <option value="name-desc" selected={sort === 'name-desc'}>Name (Z-A)</option>
              <option value="points-desc" selected={sort === 'points-desc'}>Points (High to Low)</option>
            </select>

            <button type="submit" class="bg-neutral-800 text-white rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-900 transition-colors cursor-pointer">
              Filter
            </button>

            {(search || sort !== 'created-desc') && (
              <a href="/admin/customers" class="bg-neutral-100 text-neutral-700 rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-200 transition-colors text-center flex items-center">
                Clear
              </a>
            )}
          </form>
        </div>

        {/* Desktop Table View */}
        <div class="hidden md:block bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm text-neutral-700 border-collapse">
              <thead>
                <tr class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900">
                  <th class="px-4 py-3">Customer Name</th>
                  <th class="px-4 py-3">Phone</th>
                  <th class="px-4 py-3">Email</th>
                  <th class="px-4 py-3 text-center">Referral Code</th>
                  <th class="px-4 py-3 text-right">Points / Credits</th>
                  <th class="px-4 py-3">Joined Date</th>
                  <th class="px-4 py-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100">
                {customersList.map((cust) => (
                  <tr class="hover:bg-neutral-50/50 transition-colors">
                    <td class="px-4 py-3">
                      <div class="font-semibold text-neutral-950">
                        {cust.name}
                      </div>
                      <span class="inline-block bg-neutral-100 text-neutral-600 px-1.5 py-0.5 rounded text-[10px] uppercase font-bold mt-0.5">
                        Customer
                      </span>
                    </td>
                    <td class="px-4 py-3">
                      <a
                        href={`tel:${cust.phone}`}
                        class="text-primary hover:underline font-medium"
                      >
                        {cust.phone}
                      </a>
                    </td>
                    <td class="px-4 py-3 text-neutral-500 font-mono text-xs">
                      {cust.email || (
                        <span class="text-neutral-400 italic">None</span>
                      )}
                    </td>
                    <td class="px-4 py-3 text-center font-mono font-bold text-neutral-800">
                      {cust.referralCode}
                    </td>
                    <td class="px-4 py-3 text-right font-bold text-green-600 font-mono">
                      {cust.credits} Pts
                    </td>
                    <td class="px-4 py-3 text-xs text-neutral-400">
                      {formatDate(cust.createdAt)}
                    </td>
                    <td class="px-4 py-3 text-right whitespace-nowrap space-x-3">
                      <a
                        href={`/admin/customers?action=view&id=${cust.id}`}
                        class="text-xs font-semibold text-primary hover:underline"
                      >
                        View Details
                      </a>
                      <form
                        method="post"
                        onsubmit="return confirm('Are you sure you want to delete this customer? This action is permanent and will delete all associated orders, service requests, and referral history.')"
                        class="inline"
                      >
                        <input type="hidden" name="formAction" value="delete" />
                        <input
                          type="hidden"
                          name="customerId"
                          value={cust.id}
                        />
                        <button
                          type="submit"
                          class="text-xs font-semibold text-red-600 hover:text-red-700 hover:underline"
                        >
                          Delete
                        </button>
                      </form>
                    </td>
                  </tr>
                ))}

                {customersList.length === 0 && (
                  <tr>
                    <td
                      colspan="7"
                      class="px-4 py-12 text-center text-neutral-400"
                    >
                      {search
                        ? "No customers match your search criteria."
                        : "No registered customers found."}
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

        {/* Mobile Flat List View */}
        <div class="md:hidden bg-white border border-neutral-200 rounded-lg shadow-sm divide-y divide-neutral-100">
          {customersList.map((cust) => (
            <div class="p-4 space-y-2">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="font-bold text-sm text-neutral-900 truncate">{cust.name}</div>
                  <div class="text-[10px] text-neutral-500 font-mono mt-0.5">{cust.email || 'No email'}</div>
                </div>
                <div class="shrink-0 text-right">
                  <span class="text-xs font-extrabold text-green-600 font-mono">{cust.credits} Pts</span>
                </div>
              </div>

              <div class="flex flex-wrap items-center justify-between text-[11px] text-neutral-600 pt-1 border-t border-neutral-50/50">
                <div class="space-y-0.5">
                  <div>Phone: <a href={`tel:${cust.phone}`} class="text-primary hover:underline font-medium font-mono">{cust.phone}</a></div>
                  <div>Referral Code: <span class="font-mono font-bold text-neutral-800">{cust.referralCode}</span></div>
                </div>
                <div class="text-[10px] text-neutral-400 self-end">
                  Joined: {formatDate(cust.createdAt)}
                </div>
              </div>

              <div class="flex items-center justify-end gap-3 pt-2">
                <a
                  href={`/admin/customers?action=view&id=${cust.id}`}
                  class="text-xs font-bold text-primary bg-primary/10 px-3 py-1.5 rounded hover:bg-primary/20"
                >
                  View Details
                </a>
                <form
                  method="post"
                  onsubmit="return confirm('Are you sure you want to delete this customer? This action is permanent and will delete all associated orders, service requests, and referral history.')"
                  class="inline m-0"
                >
                  <input type="hidden" name="formAction" value="delete" />
                  <input type="hidden" name="customerId" value={cust.id} />
                  <button
                    type="submit"
                    class="text-xs font-bold text-red-600 bg-red-50 px-3 py-1.5 rounded hover:bg-red-100 cursor-pointer"
                  >
                    Delete
                  </button>
                </form>
              </div>
            </div>
          ))}

          {customersList.length === 0 && (
            <div class="p-8 text-center text-neutral-500 text-sm">
              {search ? "No customers match your search." : "No registered customers found."}
            </div>
          )}
        </div>

        {/* Pagination Controls */}
        {totalPages > 1 && (
          <div class="flex items-center justify-between border-t border-neutral-200 bg-white px-4 py-3 sm:px-6 rounded-lg shadow-sm">
            <div class="flex flex-1 justify-between sm:hidden">
              <a
                href={page > 1 ? `?page=${page - 1}&search=${search}&sort=${sort}` : '#'}
                class={`relative inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
              >
                Previous
              </a>
              <a
                href={page < totalPages ? `?page=${page + 1}&search=${search}&sort=${sort}` : '#'}
                class={`relative ml-3 inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
              >
                Next
              </a>
            </div>
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
              <div>
                <p class="text-xs text-neutral-700">
                  Showing
                  <span class="font-semibold">{Math.min(offset + 1, totalCount)}</span>
                  to
                  <span class="font-semibold">{Math.min(offset + limit, totalCount)}</span>
                  of
                  <span class="font-semibold">{totalCount}</span>
                  results
                </p>
              </div>
              <div>
                <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                  <a
                    href={page > 1 ? `?page=${page - 1}&search=${search}&sort=${sort}` : '#'}
                    class={`relative inline-flex items-center rounded-l-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
                  >
                    <span class="sr-only">Previous</span>
                    <span>◀</span>
                  </a>
                  {Array.from({ length: totalPages }).map((_, idx) => {
                    const pNum = idx + 1;
                    const isCurrent = pNum === page;
                    return (
                      <a
                        href={`?page=${pNum}&search=${search}&sort=${sort}`}
                        aria-current={isCurrent ? "page" : undefined}
                        class={`relative inline-flex items-center px-3 py-2 text-xs font-semibold ${isCurrent ? 'z-10 bg-primary text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary' : 'text-neutral-900 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0'}`}
                      >
                        {pNum}
                      </a>
                    );
                  })}
                  <a
                    href={page < totalPages ? `?page=${page + 1}&search=${search}&sort=${sort}` : '#'}
                    class={`relative inline-flex items-center rounded-r-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
                  >
                    <span class="sr-only">Next</span>
                    <span>▶</span>
                  </a>
                </nav>
              </div>
            </div>
          </div>
        )}
      </div>
    )
  }

  {/* CUSTOMER DETAILS VIEW */}
  {
    action === "view" && customer && (
      <div class="space-y-6">


        {/* Profile Header banner */}
        <div class="bg-gradient-to-r from-primary/10 via-primary/5 to-transparent border border-neutral-200 rounded-lg p-5 shadow-sm flex flex-col sm:flex-row items-center gap-4">
          <div class="w-16 h-16 rounded-full bg-primary text-white flex items-center justify-center text-2xl font-black shadow-md shrink-0 uppercase">
            {customer.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
          </div>
          <div class="text-center sm:text-left min-w-0 flex-1">
            <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2">
              <h2 class="text-lg font-bold text-neutral-900 leading-tight">{customer.name}</h2>
              <span class={`inline-block rounded-full px-2.5 py-0.5 text-[9px] font-bold uppercase border ${
                customer.credits >= 500 ? 'bg-amber-50 text-amber-700 border-amber-200' :
                customer.credits >= 100 ? 'bg-blue-50 text-blue-700 border-blue-200' :
                'bg-neutral-50 text-neutral-700 border-neutral-200'
              }`}>
                {customer.credits >= 500 ? '👑 VIP Member' : customer.credits >= 100 ? '⭐ Star Member' : 'Member'}
              </span>
            </div>
            <p class="text-xs text-neutral-500 mt-1 font-mono">{customer.phone}</p>
            <p class="text-[10px] text-neutral-400 mt-0.5">Customer since {formatDate(customer.createdAt)}</p>
          </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {/* Profile Details Card */}
          <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm space-y-4 lg:col-span-2">
            <h3 class="text-xs font-bold text-neutral-800 uppercase tracking-wider border-b border-neutral-100 pb-2 flex items-center gap-1.5">
              👤 Personal Information
            </h3>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="p-3 bg-neutral-50 rounded-lg space-y-0.5">
                <span class="text-[9px] font-bold text-neutral-400 uppercase">Full Name</span>
                <p class="font-bold text-neutral-900 text-sm">{customer.name}</p>
              </div>
              <div class="p-3 bg-neutral-50 rounded-lg space-y-0.5">
                <span class="text-[9px] font-bold text-neutral-400 uppercase">Referral Code</span>
                <div class="flex items-center justify-between">
                  <p class="font-mono font-bold text-primary text-sm">{customer.referralCode}</p>
                  <button 
                    onclick={`navigator.clipboard.writeText('${customer.referralCode}'); window.showToast('Copied Code!')`}
                    class="text-[10px] text-primary hover:underline font-sans cursor-pointer focus:outline-none"
                  >
                    Copy
                  </button>
                </div>
              </div>
              <div class="p-3 bg-neutral-50 rounded-lg space-y-0.5">
                <span class="text-[9px] font-bold text-neutral-400 uppercase">Phone Number</span>
                <p class="font-bold text-neutral-900 text-sm">
                  <a href={`tel:${customer.phone}`} class="text-primary hover:underline">{customer.phone}</a>
                </p>
              </div>
              <div class="p-3 bg-neutral-50 rounded-lg space-y-0.5">
                <span class="text-[9px] font-bold text-neutral-400 uppercase">Email Address</span>
                <p class="font-semibold text-neutral-800 truncate text-sm">
                  {customer.email || <span class="text-neutral-400 italic font-normal">Not Provided</span>}
                </p>
              </div>
              <div class="p-3 bg-neutral-50 rounded-lg space-y-0.5">
                <span class="text-[9px] font-bold text-neutral-400 uppercase">Registration Date</span>
                <p class="font-semibold text-neutral-850 text-sm">{formatDate(customer.createdAt)}</p>
              </div>
              <div class="p-3 bg-neutral-50 rounded-lg space-y-0.5">
                <span class="text-[9px] font-bold text-neutral-400 uppercase">Referred By</span>
                <p class="font-semibold text-neutral-850 text-sm truncate">{referrerName}</p>
              </div>
            </div>
          </div>

          {/* Credits Balance Card */}
          <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm flex flex-col justify-between">
            <div class="space-y-4">
              <h3 class="text-xs font-bold text-neutral-800 uppercase tracking-wider border-b border-neutral-100 pb-2 flex items-center gap-1.5">
                💎 Credits Wallet
              </h3>
              <div class="bg-gradient-to-br from-green-600 to-emerald-700 rounded-xl p-4 text-white shadow-sm flex flex-col justify-between min-h-[7rem]">
                <div class="flex justify-between items-start">
                  <span class="text-[10px] uppercase font-semibold text-green-150 tracking-wider">Wallet Balance</span>
                  <span class="text-lg">💳</span>
                </div>
                <div class="mt-2">
                  <span class="text-3xl font-black font-mono">{customer.credits}</span>
                  <span class="text-xs font-semibold ml-1 text-green-150">Points</span>
                </div>
              </div>
            </div>

            <form method="post" class="space-y-4 mt-6">
              <input type="hidden" name="formAction" value="adjust_credits" />
              <input type="hidden" name="customerId" value={customer.id} />

              <div>
                <label for="credits-input" class="block text-[10px] font-bold text-neutral-500 uppercase mb-1.5">
                  Adjust Credits Balance
                </label>
                <div class="flex gap-2">
                  <button 
                    type="button" 
                    onclick="document.getElementById('credits-input').stepDown(50)"
                    class="bg-neutral-100 hover:bg-neutral-200 border border-neutral-300 rounded px-2.5 text-xs font-bold cursor-pointer select-none"
                  >
                    -50
                  </button>
                  <input
                    type="number"
                    id="credits-input"
                    name="credits"
                    required
                    min="0"
                    value={customer.credits}
                    class="w-full text-center rounded border border-neutral-300 px-3 py-1.5 text-sm font-mono font-bold focus:border-primary focus:outline-none"
                  />
                  <button 
                    type="button" 
                    onclick="document.getElementById('credits-input').stepUp(50)"
                    class="bg-neutral-100 hover:bg-neutral-200 border border-neutral-300 rounded px-2.5 text-xs font-bold cursor-pointer select-none"
                  >
                    +50
                  </button>
                </div>
                <p class="text-[10px] text-neutral-400 mt-1.5 leading-normal">
                  Update customer's total loyalty credit point balance.
                </p>
              </div>

              <button
                type="submit"
                class="w-full bg-primary text-white text-xs font-bold rounded px-4 py-2 hover:bg-primary/95 transition-colors cursor-pointer"
              >
                Save New Balance
              </button>
            </form>
          </div>
        </div>

        {/* Referrals Card */}
        <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm space-y-4">
          <h3 class="text-xs font-bold text-neutral-800 uppercase tracking-wider border-b border-neutral-100 pb-2 flex items-center gap-1.5">
            👥 Referrals Made ({referralsMade.length})
          </h3>
          
          {/* Desktop Table */}
          <div class="hidden sm:block overflow-x-auto">
            <table class="w-full text-left text-sm text-neutral-700 border-collapse">
              <thead>
                <tr class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900">
                  <th class="px-4 py-2">Referred Customer</th>
                  <th class="px-4 py-2">Phone</th>
                  <th class="px-4 py-2">Joined Date</th>
                  <th class="px-4 py-2 text-right">Referral Reward</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100">
                {referralsMade.map((ref) => (
                  <tr class="hover:bg-neutral-50/50 transition-colors">
                    <td class="px-4 py-2.5 font-semibold text-neutral-950">
                      {ref.name}
                    </td>
                    <td class="px-4 py-2.5 font-mono">
                      <a href={`tel:${ref.phone}`} class="text-primary hover:underline">{ref.phone}</a>
                    </td>
                    <td class="px-4 py-2.5 text-xs text-neutral-400">
                      {formatDate(ref.createdAt)}
                    </td>
                    <td class="px-4 py-2.5 text-right font-bold text-green-600 font-mono">
                      +{referrerBonusPointsSetting} Pts
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {/* Mobile Grid */}
          <div class="sm:hidden space-y-3">
            {referralsMade.map((ref) => (
              <div class="bg-neutral-50/50 border border-neutral-150 rounded-lg p-3 flex justify-between items-center gap-3">
                <div class="min-w-0">
                  <h4 class="font-bold text-xs text-neutral-900 truncate">{ref.name}</h4>
                  <p class="text-[10px] text-neutral-500 font-mono mt-0.5">
                    <a href={`tel:${ref.phone}`} class="text-primary hover:underline">{ref.phone}</a>
                  </p>
                  <p class="text-[9px] text-neutral-400 mt-0.5">{formatDate(ref.createdAt)}</p>
                </div>
                <span class="text-xs font-bold text-green-600 font-mono whitespace-nowrap bg-green-50 px-2 py-0.5 rounded border border-green-100">
                  +{referrerBonusPointsSetting} Pts
                </span>
              </div>
            ))}
          </div>

          {referralsMade.length === 0 && (
            <p class="text-center text-neutral-400 text-xs py-4">
              No referrals registered under this customer's code yet.
            </p>
          )}
        </div>

        {/* Ledger Transaction History Card */}
        <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm space-y-4">
          <h3 class="text-xs font-bold text-neutral-800 uppercase tracking-wider border-b border-neutral-100 pb-2 flex items-center gap-1.5">
            📜 Transaction History
          </h3>

          <div class="relative pl-6 border-l-2 border-neutral-150 space-y-6 ml-2 py-2">
            {ledger.map((item) => {
              const isPositive = item.points > 0;
              return (
                <div class="relative">
                  {/* Timeline bullet dot */}
                  <span class={`absolute -left-[31px] top-1.5 w-4 h-4 rounded-full border-2 border-white shadow-sm flex items-center justify-center text-[8px] ${
                    item.type === "signup_bonus" ? "bg-blue-500 text-white" :
                    item.type === "referral_bonus" ? "bg-green-500 text-white" :
                    "bg-red-500 text-white"
                  }`}>
                    {item.type === "signup_bonus" ? "👤" :
                     item.type === "referral_bonus" ? "🤝" :
                     "🛍️"}
                  </span>

                  <div class="bg-neutral-50/50 hover:bg-neutral-50 border border-neutral-100 rounded-lg p-3 flex flex-col sm:flex-row sm:items-center justify-between gap-3 transition-colors">
                    <div class="space-y-1">
                      <div class="flex flex-wrap items-center gap-2">
                        <span class={`inline-block rounded px-1.5 py-0.5 text-[9px] font-bold uppercase border ${
                          item.type === "signup_bonus" ? "bg-blue-50 text-blue-700 border-blue-100" :
                          item.type === "referral_bonus" ? "bg-green-50 text-green-700 border-green-100" :
                          "bg-red-50 text-red-700 border-red-100"
                        }`}>
                          {item.type.replace("_", " ")}
                        </span>
                        <span class="text-[10px] text-neutral-450 font-medium">{formatDate(item.date)}</span>
                      </div>
                      <p class="text-xs text-neutral-700 leading-normal">{item.description}</p>
                    </div>

                    <div class="text-right self-start sm:self-center shrink-0">
                      <span class={`font-mono font-black text-sm ${isPositive ? "text-green-600" : "text-red-600"}`}>
                        {isPositive ? `+${item.points}` : `${item.points}`} Pts
                      </span>
                    </div>
                  </div>
                </div>
              );
            })}

            {ledger.length === 0 && (
              <div class="relative">
                <span class="absolute -left-[31px] top-1 w-4 h-4 rounded-full bg-neutral-300 border-2 border-white"></span>
                <p class="text-neutral-400 text-xs py-2 pl-2">No points transactions recorded yet.</p>
              </div>
            )}
          </div>
        </div>
      </div>
    )
  }
</AdminLayout>
