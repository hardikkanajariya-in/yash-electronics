---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { orders } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getSessionUser } from '../../lib/auth';

export const prerender = false;

// Authenticate Admin
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

let error = Astro.url.searchParams.get('error') || '';
let success = Astro.url.searchParams.get('success') || '';

// Handle Order Actions (Status & Payment update)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('formAction')?.toString() || '';
    const orderId = formData.get('orderId')?.toString() || '';

    if (action === 'update_status' && orderId) {
      const newStatus = formData.get('status')?.toString() as any;
      if (['pending', 'processing', 'shipped', 'delivered', 'cancelled', 'returned'].includes(newStatus)) {
        await db.update(orders).set({ status: newStatus }).where(eq(orders.id, orderId));
        return Astro.redirect('/admin/orders?success=' + encodeURIComponent(`Order status updated to ${newStatus} successfully!`));
      } else {
        error = 'Invalid status value.';
      }
    }

    if (action === 'update_payment_status' && orderId) {
      const newPaymentStatus = formData.get('paymentStatus')?.toString() as any;
      if (['pending', 'received'].includes(newPaymentStatus)) {
        await db.update(orders).set({ paymentStatus: newPaymentStatus }).where(eq(orders.id, orderId));
        return Astro.redirect('/admin/orders?success=' + encodeURIComponent(`Payment status updated to ${newPaymentStatus} successfully!`));
      } else {
        error = 'Invalid payment status value.';
      }
    }
  } catch (e: any) {
    error = e.message || 'Failed to update order details.';
  }
}

// Fetch all orders with items and product details
let allOrders: any[] = [];
try {
  allOrders = await db.query.orders.findMany({
    orderBy: [desc(orders.createdAt)],
    with: {
      items: {
        with: {
          product: true,
        },
      },
    },
  });
} catch (e) {
  console.error('[Admin Orders] Failed to fetch orders:', e);
}

// Stats for status tabs/filter counts
const counts = {
  all: allOrders.length,
  pending: allOrders.filter(o => o.status === 'pending').length,
  processing: allOrders.filter(o => o.status === 'processing').length,
  shipped: allOrders.filter(o => o.status === 'shipped').length,
  delivered: allOrders.filter(o => o.status === 'delivered').length,
  cancelled: allOrders.filter(o => o.status === 'cancelled').length,
  returned: allOrders.filter(o => o.status === 'returned').length,
};
---

<AdminLayout title="Manage Orders" activeTab="orders" subtitle="Track and fulfill customer orders">


    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    <!-- Navigation Tabs / Filters -->
    <nav class="flex border-b border-neutral-200 gap-2 mb-6 overflow-x-auto text-xs font-medium pb-2 select-none whitespace-nowrap no-scrollbar">
      <button onclick="filterOrders('all')" id="tab-all" class="border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none">
        All ({counts.all})
      </button>
      <button onclick="filterOrders('pending')" id="tab-pending" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Pending ({counts.pending})
      </button>
      <button onclick="filterOrders('processing')" id="tab-processing" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Processing ({counts.processing})
      </button>
      <button onclick="filterOrders('shipped')" id="tab-shipped" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Shipped ({counts.shipped})
      </button>
      <button onclick="filterOrders('delivered')" id="tab-delivered" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Delivered ({counts.delivered})
      </button>
      <button onclick="filterOrders('cancelled')" id="tab-cancelled" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Cancelled ({counts.cancelled})
      </button>
      <button onclick="filterOrders('returned')" id="tab-returned" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Returned ({counts.returned})
      </button>
    </nav>
 
    <!-- Orders List/Grid -->
    <div class="space-y-4" id="orders-container">
      {allOrders.map((order) => {
        const dateStr = new Date(order.createdAt).toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
        
        return (
          <div data-status={order.status} class="order-card bg-white border border-neutral-200 rounded-lg shadow-sm hover:shadow-md transition-shadow p-4 sm:p-5">
            {/* Top row */}
            <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-100 pb-3 mb-4">
              <div>
                <span class="text-xs font-bold text-neutral-500 uppercase">Order ID</span>
                <h3 class="text-sm font-mono font-bold text-neutral-800 flex items-center gap-1.5">
                  #{order.id.slice(0, 8)}...
                  <button 
                    onclick={`navigator.clipboard.writeText('${order.id}'); window.showToast('Copied ID!')`} 
                    class="text-[10px] text-primary hover:underline font-sans cursor-pointer focus:outline-none"
                    title="Copy full ID"
                  >
                    Copy
                  </button>
                </h3>
                <span class="text-[11px] text-neutral-400">{dateStr}</span>
              </div>
              
              <div class="flex items-center gap-2">
                <!-- Payment Status Badge -->
                <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold uppercase border ${
                  order.paymentStatus === 'received' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-rose-50 text-rose-700 border-rose-200'
                }`}>
                  💳 {order.paymentStatus === 'received' ? 'Paid' : 'Unpaid'}
                </span>

                <!-- Order Status Badge -->
                <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold uppercase border ${
                  order.status === 'pending' ? 'bg-amber-50 text-amber-700 border-amber-200' :
                  order.status === 'processing' ? 'bg-sky-50 text-sky-700 border-sky-200' :
                  order.status === 'shipped' ? 'bg-indigo-50 text-indigo-700 border-indigo-200' :
                  order.status === 'delivered' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
                  order.status === 'cancelled' ? 'bg-rose-50 text-rose-700 border-rose-200' :
                  'bg-neutral-50 text-neutral-700 border-neutral-200'
                }`}>
                  📦 {order.status}
                </span>
              </div>
            </div>
 
            {/* Content Row: Grid */}
            <div class="grid gap-4 sm:gap-6 md:grid-cols-3">
              {/* Customer Info */}
              <div class="space-y-2 text-sm">
                <h4 class="text-xs font-bold uppercase text-neutral-400">Customer Details</h4>
                <p class="font-bold text-neutral-900">{order.customerName}</p>
                <p>
                  <a href={`tel:${order.customerPhone}`} class="text-primary hover:underline inline-flex items-center gap-1">
                    📞 {order.customerPhone}
                  </a>
                </p>
                <p class="text-neutral-600 text-xs mt-1 leading-relaxed">
                  <span class="font-semibold">Address:</span><br/>
                  {order.shippingAddress}
                </p>
              </div>

              {/* Items List */}
              <div class="space-y-2 text-sm md:col-span-2">
                <h4 class="text-xs font-bold uppercase text-neutral-400">Items Ordered</h4>
                <div class="border border-neutral-100 rounded-md divide-y divide-neutral-100 max-h-48 overflow-y-auto bg-neutral-50/50 p-2">
                  {order.items?.map((item: any) => (
                    <div class="py-2 flex justify-between items-center text-xs gap-4">
                      <div class="flex-1">
                        <p class="font-semibold text-neutral-800">{item.product?.name || 'Unknown Product'}</p>
                        {item.product?.modelNumber && (
                          <p class="text-[10px] text-neutral-400">Model: {item.product.modelNumber}</p>
                        )}
                      </div>
                      <div class="text-right shrink-0">
                        <span class="text-neutral-500">₹{item.price.toLocaleString('en-IN')} x {item.quantity}</span>
                        <p class="font-bold text-neutral-800">₹{(item.price * item.quantity).toLocaleString('en-IN')}</p>
                      </div>
                    </div>
                  ))}
                </div>

                {/* Totals */}
                <div class="flex flex-col items-end border-t border-neutral-100 pt-3 gap-1">
                  {order.discountApplied > 0 && (
                    <span class="text-xs text-green-600 font-medium">
                      Coupon Discount ({order.couponCode || 'Promo'}): -₹{order.discountApplied.toLocaleString('en-IN')}
                    </span>
                  )}
                  {order.bundleDiscountApplied > 0 && (
                    <span class="text-xs text-secondary font-bold">
                      Bundle Discount: -₹{order.bundleDiscountApplied.toLocaleString('en-IN')}
                    </span>
                  )}
                  {order.bundleRewardGiven && (
                    <span class="text-xs text-purple-700 bg-purple-50 border border-purple-200 rounded-md px-2 py-1 font-bold">
                      🎁 Bundle Reward: {order.bundleRewardGiven}
                    </span>
                  )}
                  {order.creditsUsed > 0 && (
                    <span class="text-xs text-green-600 font-medium">
                      In-store Credits Discount: -₹{order.creditsUsed.toLocaleString('en-IN')}
                    </span>
                  )}
                  <span class="text-sm font-semibold text-neutral-800">
                    Total Amount: <span class="text-lg font-bold text-primary">₹{order.totalAmount.toLocaleString('en-IN')}</span>
                  </span>
                </div>
              </div>
            </div>

            {/* Tracking Trail/Timeline */}
            <div class="border-t border-neutral-100 pt-4 mt-4 relative z-0">
              <h4 class="text-xs font-bold uppercase text-neutral-400 mb-3">Order Tracking Trail</h4>
              <div class="flex items-center w-full justify-between text-xs text-neutral-500 font-medium relative select-none">
                <!-- Line background -->
                <div class="absolute top-[9px] left-0 right-0 h-0.5 bg-neutral-200 -z-10"></div>
                <!-- Shipped status progress highlight -->
                <div class={`absolute top-[9px] left-0 h-0.5 bg-primary -z-10 transition-all duration-300 ${
                  order.status === 'pending' ? 'w-0' :
                  order.status === 'processing' ? 'w-1/3' :
                  order.status === 'shipped' ? 'w-2/3' :
                  'w-full'
                }`}></div>

                <!-- Step 1: Placed -->
                <div class="flex flex-col items-center">
                  <div class="w-[20px] h-[20px] rounded-full bg-primary text-white flex items-center justify-center text-[10px] font-bold shadow-sm">
                    ✓
                  </div>
                  <span class="mt-1 text-[10px] sm:text-xs font-bold text-neutral-800">Placed</span>
                </div>

                <!-- Step 2: Processing -->
                <div class="flex flex-col items-center">
                  <div class={`w-[20px] h-[20px] rounded-full flex items-center justify-center text-[10px] font-bold shadow-sm ${
                    ['processing', 'shipped', 'delivered'].includes(order.status)
                      ? 'bg-primary text-white'
                      : 'bg-neutral-200 text-neutral-400'
                  }`}>
                    {['processing', 'shipped', 'delivered'].includes(order.status) ? '✓' : '2'}
                  </div>
                  <span class={`mt-1 text-[10px] sm:text-xs ${
                    ['processing', 'shipped', 'delivered'].includes(order.status) ? 'font-bold text-neutral-800' : 'text-neutral-450'
                  }`}>Processing</span>
                </div>

                <!-- Step 3: Shipped -->
                <div class="flex flex-col items-center">
                  <div class={`w-[20px] h-[20px] rounded-full flex items-center justify-center text-[10px] font-bold shadow-sm ${
                    ['shipped', 'delivered'].includes(order.status)
                      ? 'bg-primary text-white'
                      : 'bg-neutral-200 text-neutral-400'
                  }`}>
                    {['shipped', 'delivered'].includes(order.status) ? '✓' : '3'}
                  </div>
                  <span class={`mt-1 text-[10px] sm:text-xs ${
                    ['shipped', 'delivered'].includes(order.status) ? 'font-bold text-neutral-800' : 'text-neutral-450'
                  }`}>Shipped</span>
                </div>

                <!-- Step 4: Delivered / Cancelled / Returned -->
                <div class="flex flex-col items-center">
                  {order.status === 'cancelled' ? (
                    <>
                      <div class="w-[20px] h-[20px] rounded-full bg-rose-500 text-white flex items-center justify-center text-[10px] font-bold shadow-sm">
                        ✕
                      </div>
                      <span class="mt-1 text-[10px] sm:text-xs font-bold text-rose-600">Cancelled</span>
                    </>
                  ) : order.status === 'returned' ? (
                    <>
                      <div class="w-[20px] h-[20px] rounded-full bg-amber-500 text-white flex items-center justify-center text-[10px] font-bold shadow-sm">
                        ⟲
                      </div>
                      <span class="mt-1 text-[10px] sm:text-xs font-bold text-amber-600">Returned</span>
                    </>
                  ) : (
                    <>
                      <div class={`w-[20px] h-[20px] rounded-full flex items-center justify-center text-[10px] font-bold shadow-sm ${
                        order.status === 'delivered'
                          ? 'bg-primary text-white'
                          : 'bg-neutral-200 text-neutral-400'
                      }`}>
                        {order.status === 'delivered' ? '✓' : '4'}
                      </div>
                      <span class={`mt-1 text-[10px] sm:text-xs ${
                        order.status === 'delivered' ? 'font-bold text-neutral-800' : 'text-neutral-450'
                      }`}>Delivered</span>
                    </>
                  )}
                </div>
              </div>
            </div>

            {/* Actions Footer */}
            <div class="flex flex-wrap items-center justify-between border-t border-neutral-100 pt-3 mt-4 gap-4">
              <div class="flex items-center gap-1.5 text-xs text-neutral-500">
                <span>⚙️</span> Fulfill Actions:
              </div>
              
              <div class="flex flex-wrap gap-3">
                <!-- Change Payment Status form -->
                <form method="post" class="flex items-center gap-1">
                  <input type="hidden" name="formAction" value="update_payment_status" />
                  <input type="hidden" name="orderId" value={order.id} />
                  <label class="text-[10px] text-neutral-400 font-bold uppercase mr-1">Payment:</label>
                  <select
                    name="paymentStatus"
                    class="rounded border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none bg-white cursor-pointer"
                    onchange="this.form.submit()"
                  >
                    <option value="pending" selected={order.paymentStatus === 'pending'}>Unpaid</option>
                    <option value="received" selected={order.paymentStatus === 'received'}>Paid</option>
                  </select>
                </form>

                <!-- Change Order Status form -->
                <form method="post" class="flex items-center gap-1">
                  <input type="hidden" name="formAction" value="update_status" />
                  <input type="hidden" name="orderId" value={order.id} />
                  <label class="text-[10px] text-neutral-400 font-bold uppercase mr-1">Tracking:</label>
                  <select
                    name="status"
                    class="rounded border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none bg-white cursor-pointer"
                    onchange="this.form.submit()"
                  >
                    <option value="pending" selected={order.status === 'pending'}>Pending</option>
                    <option value="processing" selected={order.status === 'processing'}>Processing</option>
                    <option value="shipped" selected={order.status === 'shipped'}>Shipped</option>
                    <option value="delivered" selected={order.status === 'delivered'}>Delivered</option>
                    <option value="cancelled" selected={order.status === 'cancelled'}>Cancelled</option>
                    <option value="returned" selected={order.status === 'returned'}>Returned</option>
                  </select>
                </form>
              </div>
            </div>
          </div>
        );
      })}

      {allOrders.length === 0 && (
        <div class="bg-white border border-neutral-200 rounded-lg p-12 text-center text-neutral-500 shadow-sm">
          No orders found.
        </div>
      )}
    </div>
</AdminLayout>

<script is:inline>
  function filterOrders(status) {
    // Select correct tab styling
    const tabs = ['all', 'pending', 'processing', 'shipped', 'delivered', 'cancelled', 'returned'];
    tabs.forEach(t => {
      const el = document.getElementById(`tab-${t}`);
      if (el) {
        if (t === status) {
          el.className = "border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none";
        } else {
          el.className = "text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none";
        }
      }
    });

    // Toggle card visibility
    const cards = document.querySelectorAll('.order-card');
    cards.forEach(card => {
      const cardStatus = card.getAttribute('data-status');
      if (status === 'all' || cardStatus === status) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
