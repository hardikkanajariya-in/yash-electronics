---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { orders } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getSessionUser } from '../../lib/auth';

export const prerender = false;

// Authenticate Admin
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/admin/login');
}

let error = Astro.url.searchParams.get('error') || '';
let success = Astro.url.searchParams.get('success') || '';

// Handle Order Actions (Status update)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('formAction')?.toString() || '';
    const orderId = formData.get('orderId')?.toString() || '';

    if (action === 'update_status' && orderId) {
      const newStatus = formData.get('status')?.toString() as any;
      if (['pending', 'processing', 'delivered', 'cancelled'].includes(newStatus)) {
        await db.update(orders).set({ status: newStatus }).where(eq(orders.id, orderId));
        return Astro.redirect('/admin/orders?success=' + encodeURIComponent(`Order status updated to ${newStatus} successfully!`));
      } else {
        error = 'Invalid status value.';
      }
    }
  } catch (e: any) {
    error = e.message || 'Failed to update order status.';
  }
}

// Fetch all orders with items and product details
let allOrders: any[] = [];
try {
  allOrders = await db.query.orders.findMany({
    orderBy: [desc(orders.createdAt)],
    with: {
      items: {
        with: {
          product: true,
        },
      },
    },
  });
} catch (e) {
  console.error('[Admin Orders] Failed to fetch orders:', e);
}

// Stats for status tabs/filter counts
const counts = {
  all: allOrders.length,
  pending: allOrders.filter(o => o.status === 'pending').length,
  processing: allOrders.filter(o => o.status === 'processing').length,
  delivered: allOrders.filter(o => o.status === 'delivered').length,
  cancelled: allOrders.filter(o => o.status === 'cancelled').length,
};
---

<AdminLayout title="Manage Orders" activeTab="orders" subtitle="Track and fulfill customer orders">


    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    <!-- Navigation Tabs / Filters -->
    <nav class="flex border-b border-neutral-200 gap-2 mb-6 overflow-x-auto text-xs font-medium pb-2 select-none whitespace-nowrap">
      <button onclick="filterOrders('all')" id="tab-all" class="border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none">
        All ({counts.all})
      </button>
      <button onclick="filterOrders('pending')" id="tab-pending" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Pending ({counts.pending})
      </button>
      <button onclick="filterOrders('processing')" id="tab-processing" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Processing ({counts.processing})
      </button>
      <button onclick="filterOrders('delivered')" id="tab-delivered" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Delivered ({counts.delivered})
      </button>
      <button onclick="filterOrders('cancelled')" id="tab-cancelled" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Cancelled ({counts.cancelled})
      </button>
    </nav>

    <!-- Orders List/Grid -->
    <div class="space-y-4" id="orders-container">
      {allOrders.map((order) => {
        const dateStr = new Date(order.createdAt).toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
        
        return (
          <div data-status={order.status} class="order-card bg-white border border-neutral-200 rounded-lg shadow-sm hover:shadow-md transition-shadow p-4 sm:p-5">
            {/* Top row */}
            <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-100 pb-3 mb-4">
              <div>
                <span class="text-xs font-bold text-neutral-500 uppercase">Order ID</span>
                <h3 class="text-sm font-mono font-bold text-neutral-800 flex items-center gap-1.5">
                  #{order.id.slice(0, 8)}...
                  <button 
                    onclick={`navigator.clipboard.writeText('${order.id}'); window.showToast('Copied ID!')`} 
                    class="text-[10px] text-primary hover:underline font-sans cursor-pointer focus:outline-none"
                    title="Copy full ID"
                  >
                    Copy
                  </button>
                </h3>
                <span class="text-[11px] text-neutral-400">{dateStr}</span>
              </div>
              
              <div class="flex items-center gap-2">
                <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold uppercase border ${
                  order.status === 'pending' ? 'bg-amber-50 text-amber-700 border-amber-200' :
                  order.status === 'processing' ? 'bg-blue-50 text-blue-700 border-blue-200' :
                  order.status === 'delivered' ? 'bg-green-50 text-green-700 border-green-200' :
                  'bg-neutral-50 text-neutral-700 border-neutral-200'
                }`}>
                  {order.status}
                </span>
              </div>
            </div>

            {/* Content Row: Grid */}
            <div class="grid gap-6 md:grid-cols-3">
              {/* Customer Info */}
              <div class="space-y-2 text-sm">
                <h4 class="text-xs font-bold uppercase text-neutral-400">Customer Details</h4>
                <p class="font-bold text-neutral-900">{order.customerName}</p>
                <p>
                  <a href={`tel:${order.customerPhone}`} class="text-primary hover:underline inline-flex items-center gap-1">
                    📞 {order.customerPhone}
                  </a>
                </p>
                <p class="text-neutral-600 text-xs mt-1 leading-relaxed">
                  <span class="font-semibold">Address:</span><br/>
                  {order.shippingAddress}
                </p>
              </div>

              {/* Items List */}
              <div class="space-y-2 text-sm md:col-span-2">
                <h4 class="text-xs font-bold uppercase text-neutral-400">Items Ordered</h4>
                <div class="border border-neutral-100 rounded-md divide-y divide-neutral-100 max-h-48 overflow-y-auto bg-neutral-50/50 p-2">
                  {order.items?.map((item: any) => (
                    <div class="py-2 flex justify-between items-center text-xs gap-4">
                      <div class="flex-1">
                        <p class="font-semibold text-neutral-800">{item.product?.name || 'Unknown Product'}</p>
                        {item.product?.modelNumber && (
                          <p class="text-[10px] text-neutral-400">Model: {item.product.modelNumber}</p>
                        )}
                      </div>
                      <div class="text-right shrink-0">
                        <span class="text-neutral-500">₹{item.price.toLocaleString('en-IN')} x {item.quantity}</span>
                        <p class="font-bold text-neutral-800">₹{(item.price * item.quantity).toLocaleString('en-IN')}</p>
                      </div>
                    </div>
                  ))}
                </div>

                {/* Totals */}
                <div class="flex flex-col items-end border-t border-neutral-100 pt-3 gap-1">
                  {order.creditsUsed > 0 && (
                    <span class="text-xs text-green-600 font-medium">
                      In-store Credits Discount: -₹{order.creditsUsed.toLocaleString('en-IN')}
                    </span>
                  )}
                  <span class="text-sm font-semibold text-neutral-800">
                    Total Amount: <span class="text-lg font-bold text-primary">₹{order.totalAmount.toLocaleString('en-IN')}</span>
                  </span>
                </div>
              </div>
            </div>

            {/* Actions Footer */}
            <div class="flex items-center justify-between border-t border-neutral-100 pt-3 mt-4 gap-4">
              <span class="text-xs text-neutral-400">
                Change Status:
              </span>
              
              <form method="post" class="flex gap-2">
                <input type="hidden" name="formAction" value="update_status" />
                <input type="hidden" name="orderId" value={order.id} />
                <select
                  name="status"
                  class="rounded-md border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none"
                  onchange="this.form.submit()"
                >
                  <option value="pending" selected={order.status === 'pending'}>Pending</option>
                  <option value="processing" selected={order.status === 'processing'}>Processing</option>
                  <option value="delivered" selected={order.status === 'delivered'}>Delivered</option>
                  <option value="cancelled" selected={order.status === 'cancelled'}>Cancelled</option>
                </select>
              </form>
            </div>
          </div>
        );
      })}

      {allOrders.length === 0 && (
        <div class="bg-white border border-neutral-200 rounded-lg p-12 text-center text-neutral-500 shadow-sm">
          No orders found.
        </div>
      )}
    </div>
</AdminLayout>

<script is:inline>
  function filterOrders(status) {
    // Select correct tab styling
    const tabs = ['all', 'pending', 'processing', 'delivered', 'cancelled'];
    tabs.forEach(t => {
      const el = document.getElementById(`tab-${t}`);
      if (el) {
        if (t === status) {
          el.className = "border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none";
        } else {
          el.className = "text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none";
        }
      }
    });

    // Toggle card visibility
    const cards = document.querySelectorAll('.order-card');
    cards.forEach(card => {
      const cardStatus = card.getAttribute('data-status');
      if (status === 'all' || cardStatus === status) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>
