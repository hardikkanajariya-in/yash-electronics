---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { bankDetails } from '../../db/schema';
import { getSessionUser, generateId } from '../../lib/auth';
import { eq } from 'drizzle-orm';
import { deleteCloudinaryAsset } from '../../lib/cloudinary-server';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));

let message = Astro.url.searchParams.get('message') || '';
let error = Astro.url.searchParams.get('error') || '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('_action')?.toString();

    if (formAction === 'delete') {
      const deleteId = formData.get('id')?.toString();
      if (deleteId) {
        const [existing] = await db.select().from(bankDetails).where(eq(bankDetails.id, deleteId));
        if (existing) {
          if (existing.upiQrCode) await deleteCloudinaryAsset(existing.upiQrCode);
          if (existing.bankQrCode) await deleteCloudinaryAsset(existing.bankQrCode);
        }
        await db.delete(bankDetails).where(eq(bankDetails.id, deleteId));
        return Astro.redirect('/admin/bank-details?message=' + encodeURIComponent('Bank detail deleted.'));
      }
    } else if (formAction === 'save') {
      const id = formData.get('id')?.toString();
      const bankName = formData.get('bankName')?.toString().trim() || '';
      const accountHolderName = formData.get('accountHolderName')?.toString().trim() || '';
      const accountNumber = formData.get('accountNumber')?.toString().trim() || '';
      const ifscCode = formData.get('ifscCode')?.toString().trim() || '';
      const branchName = formData.get('branchName')?.toString().trim() || '';
      const upiQrCode = formData.get('upiQrCode')?.toString().trim() || null;
      const bankQrCode = formData.get('bankQrCode')?.toString().trim() || null;

      if (!bankName || !accountHolderName || !accountNumber || !ifscCode || !branchName) {
        error = 'All bank fields are required.';
      } else if (id) {
        const [existing] = await db.select().from(bankDetails).where(eq(bankDetails.id, id));
        if (existing) {
          if (existing.upiQrCode && existing.upiQrCode !== upiQrCode) await deleteCloudinaryAsset(existing.upiQrCode);
          if (existing.bankQrCode && existing.bankQrCode !== bankQrCode) await deleteCloudinaryAsset(existing.bankQrCode);
        }
        await db.update(bankDetails).set({ bankName, accountHolderName, accountNumber, ifscCode, branchName, upiQrCode, bankQrCode }).where(eq(bankDetails.id, id));
        return Astro.redirect('/admin/bank-details?message=' + encodeURIComponent('Bank details updated.'));
      } else {
        await db.insert(bankDetails).values({ id: generateId(), bankName, accountHolderName, accountNumber, ifscCode, branchName, upiQrCode, bankQrCode, isActive: true });
        return Astro.redirect('/admin/bank-details?message=' + encodeURIComponent('Bank details added.'));
      }
    }
  } catch (e: any) {
    error = 'Operation failed: ' + (e.message || 'Unknown error');
  }
}

let allBankDetails: any[] = [];
try { allBankDetails = await db.select().from(bankDetails); } catch (e) { }

const editId = Astro.url.searchParams.get('edit');
const isAdding = Astro.url.searchParams.get('action') === 'add';
const editBank = editId ? allBankDetails.find(b => b.id === editId) : null;
const showForm = isAdding || editBank;
---

<AdminLayout title="Bank Details" activeTab="bank" subtitle="Manage payment information shown to customers">

    {message && <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">{message}</div>}
    {error && <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">{error}</div>}

    {showForm && (
      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm mb-6">
        <h2 class="text-base font-bold text-neutral-900 mb-4">{editBank ? 'Edit Bank Details' : 'Add Bank Details'}</h2>
        <form method="post" class="grid gap-4 sm:grid-cols-2">
          <input type="hidden" name="_action" value="save" />
          {editBank && <input type="hidden" name="id" value={editBank.id} />}
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Bank Name *</label>
            <input type="text" name="bankName" required value={editBank?.bankName || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" placeholder="e.g. State Bank of India" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Account Holder Name *</label>
            <input type="text" name="accountHolderName" required value={editBank?.accountHolderName || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Account Number *</label>
            <input type="text" name="accountNumber" required value={editBank?.accountNumber || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">IFSC Code *</label>
            <input type="text" name="ifscCode" required value={editBank?.ifscCode || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Branch Name *</label>
            <input type="text" name="branchName" required value={editBank?.branchName || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">UPI QR Code</label>
            <input type="hidden" id="upiQrCode" name="upiQrCode" value={editBank?.upiQrCode || ''} />
            <div id="upi-preview" class="mb-2"></div>
            <div class="relative border border-dashed border-neutral-300 rounded p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer text-center">
              <input type="file" id="upi-file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
              <p class="text-xs font-semibold text-neutral-600">Choose UPI QR</p>
            </div>
            <div id="upi-upload-progress" class="hidden mt-2 space-y-1">
              <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
                <span>Uploading...</span>
                <span id="upi-upload-percent">0%</span>
              </div>
              <div class="w-full bg-neutral-200 rounded-full h-1 overflow-hidden">
                <div id="upi-upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
              </div>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Bank QR Code</label>
            <input type="hidden" id="bankQrCode" name="bankQrCode" value={editBank?.bankQrCode || ''} />
            <div id="bank-preview" class="mb-2"></div>
            <div class="relative border border-dashed border-neutral-300 rounded p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer text-center">
              <input type="file" id="bank-file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
              <p class="text-xs font-semibold text-neutral-600">Choose Bank QR</p>
            </div>
            <div id="bank-upload-progress" class="hidden mt-2 space-y-1">
              <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
                <span>Uploading...</span>
                <span id="bank-upload-percent">0%</span>
              </div>
              <div class="w-full bg-neutral-200 rounded-full h-1 overflow-hidden">
                <div id="bank-upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
              </div>
            </div>
          </div>
          <div class="sm:col-span-2 flex gap-2">
            <button type="submit" class="btn-primary text-xs">{editBank ? 'Update' : 'Add Bank Details'}</button>
            <a href="/admin/bank-details" class="btn-outline text-xs">Cancel</a>
          </div>
        </form>

        <script>
          import { buildCloudinaryUrl } from '../../lib/cloudinary';

          function setupUploader(inputId: string, filePickerId: string, previewId: string, progressContainerId: string, progressBarId: string, percentId: string) {
            const input = document.getElementById(inputId) as HTMLInputElement;
            const preview = document.getElementById(previewId);
            const picker = document.getElementById(filePickerId) as HTMLInputElement;
            const progressContainer = document.getElementById(progressContainerId);
            const progressBar = document.getElementById(progressBarId);
            const percent = document.getElementById(percentId);

            function render() {
              if (!preview) return;
              preview.innerHTML = '';
              const val = input.value.trim();
              if (!val) return;

              const displayUrl = buildCloudinaryUrl(val, { width: 200, height: 200 });

              const div = document.createElement('div');
              div.className = 'relative group w-24 h-24 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
              div.innerHTML = `
                <img src="${displayUrl}" class="w-full h-full object-cover" />
                <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
              `;

              div.querySelector('button')?.addEventListener('click', async () => {
                const oldVal = input.value.trim();
                if (oldVal) {
                  await deleteAssetClient(oldVal, 'image');
                }
                input.value = '';
                render();
              });

              preview.appendChild(div);
            }

            async function deleteAssetClient(publicId: string, resourceType: 'image' | 'video' = 'image') {
              if (!publicId || publicId.startsWith('http') || publicId.startsWith('/')) return;
              try {
                await fetch('/api/admin/delete-asset', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ publicId, resourceType })
                });
              } catch (e) {
                console.error('[Client delete error]', e);
              }
            }

            picker?.addEventListener('change', async () => {
              const files = picker.files;
              if (!files || files.length === 0) return;

              const file = files[0];
              progressContainer?.classList.remove('hidden');

              try {
                const resVal = await new Promise<string>((resolve, reject) => {
                  const xhr = new XMLHttpRequest();
                  xhr.open('POST', '/api/upload', true);
                  
                  xhr.upload.onprogress = (e) => {
                    if (e.lengthComputable) {
                      const pct = Math.round((e.loaded / e.total) * 100);
                      progressBar!.style.width = `${pct}%`;
                      percent!.textContent = `${pct}%`;
                    }
                  };

                  xhr.onload = () => {
                    if (xhr.status === 200) {
                      try {
                        const res = JSON.parse(xhr.responseText);
                        resolve(res.public_id || res.url);
                      } catch(e) {
                        reject('Invalid response');
                      }
                    } else {
                      reject('Server returned status ' + xhr.status);
                    }
                  };

                  xhr.onerror = () => reject('Network error');

                  const formData = new FormData();
                  formData.append('file', file);
                  xhr.send(formData);
                });

                if (resVal) {
                  const oldVal = input.value.trim();
                  if (oldVal && oldVal !== resVal) {
                    await deleteAssetClient(oldVal, 'image');
                  }
                  input.value = resVal;
                  render();
                }
              } catch (err) {
                alert('Upload failed: ' + err);
              } finally {
                progressContainer?.classList.add('hidden');
                picker.value = '';
              }
            });

            render();
          }

          // Setup both uploaders
          setupUploader('upiQrCode', 'upi-file-picker', 'upi-preview', 'upi-upload-progress', 'upi-upload-progress-bar', 'upi-upload-percent');
          setupUploader('bankQrCode', 'bank-file-picker', 'bank-preview', 'bank-upload-progress', 'bank-upload-progress-bar', 'bank-upload-percent');
        </script>
      </div>
    )}

    {!showForm && <div class="flex justify-end mb-4"><a href="/admin/bank-details?action=add" class="btn-primary text-xs">+ Add Bank Details</a></div>}

    <div class="space-y-4">
      {allBankDetails.map(bank => (
        <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm">
          <div class="flex justify-between items-start mb-3">
            <div>
              <h3 class="font-bold text-neutral-900">{bank.bankName}</h3>
              <p class="text-xs text-neutral-500">{bank.branchName}</p>
            </div>
            <div class="flex items-center gap-3">
              <a href={`/admin/bank-details?edit=${bank.id}`} class="text-xs font-semibold text-primary hover:underline">Edit</a>
              <form method="post" class="inline-flex items-center m-0">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={bank.id} />
                <button type="button" onclick="confirmDelete(this, 'Delete Bank Details', 'Are you sure?')" class="text-xs font-semibold text-red-500 hover:underline cursor-pointer bg-transparent border-none p-0">Delete</button>
              </form>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div><span class="text-neutral-400 font-semibold">Holder:</span> <span class="text-neutral-700">{bank.accountHolderName}</span></div>
            <div><span class="text-neutral-400 font-semibold">A/C:</span> <span class="text-neutral-700 font-mono">{bank.accountNumber}</span></div>
            <div><span class="text-neutral-400 font-semibold">IFSC:</span> <span class="text-neutral-700 font-mono">{bank.ifscCode}</span></div>
            <div><span class="text-neutral-400 font-semibold">QR:</span> <span class="text-neutral-700">{bank.upiQrCode ? 'UPI ✅' : '—'} {bank.bankQrCode ? 'Bank ✅' : ''}</span></div>
          </div>
        </div>
      ))}
      {allBankDetails.length === 0 && <div class="text-center py-8 text-neutral-500">No bank details added yet.</div>}
    </div>
</AdminLayout>
