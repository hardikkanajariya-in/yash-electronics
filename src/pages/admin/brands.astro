---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { brands } from '../../db/schema';
import { eq, and, or, ilike, sql, asc, desc } from 'drizzle-orm';
import { getSessionUser, generateId } from '../../lib/auth';
import { clearCmsCache } from '../../services/cms';

export const prerender = false;

// Authenticate
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

const action = Astro.url.searchParams.get('action') || 'list';
const brandId = Astro.url.searchParams.get('id') || '';

let error = Astro.url.searchParams.get('error') || '';
let success = Astro.url.searchParams.get('success') || '';
let redirectUrl = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('formAction')?.toString() || '';

    if (formAction === 'delete') {
      const idToDelete = formData.get('id')?.toString() || '';
      const [existing] = await db.select().from(brands).where(eq(brands.id, idToDelete));
      if (existing?.logo) {
        const { deleteCloudinaryAsset } = await import('../../lib/cloudinary');
        await deleteCloudinaryAsset(existing.logo);
      }
      await db.delete(brands).where(eq(brands.id, idToDelete));
      clearCmsCache();
      redirectUrl = '/admin/brands?success=' + encodeURIComponent('Brand deleted successfully!');
    } else if (formAction === 'save') {
      const name = formData.get('name')?.toString().trim() || '';
      const nameGu = formData.get('nameGu')?.toString().trim() || null;
      const slug = (formData.get('slug')?.toString() || '').trim().toLowerCase();

      const slugRegex = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
      if (!slugRegex.test(slug)) {
        throw new Error('Slug must only contain lowercase alphanumeric characters and hyphens, and cannot start or end with a hyphen.');
      }
      const logo = formData.get('logo')?.toString().trim() || null;
      const sortOrder = Number(formData.get('sortOrder') || 0);
      const isActive = formData.get('isActive') === 'on';

      if (!name || !slug) {
        throw new Error('Name and Slug are required.');
      }

      // Check if a brand with the same slug already exists
      const existingBrand = await db.select({ id: brands.id }).from(brands).where(eq(brands.slug, slug));
      if (existingBrand.length > 0 && (!brandId || existingBrand[0].id !== brandId)) {
        throw new Error(`A brand with the slug "${slug}" already exists. Please choose a different, unique slug.`);
      }

      if (brandId) {
        // Edit existing brand
        const [existing] = await db.select().from(brands).where(eq(brands.id, brandId));
        if (existing?.logo && existing.logo !== logo) {
          const { deleteCloudinaryAsset } = await import('../../lib/cloudinary');
          await deleteCloudinaryAsset(existing.logo);
        }
        // Edit existing brand
        await db.update(brands).set({
          name,
          nameGu,
          slug,
          logo,
          sortOrder,
          isActive,
        }).where(eq(brands.id, brandId));
        clearCmsCache();
        redirectUrl = '/admin/brands?success=' + encodeURIComponent('Brand updated successfully!');
      } else {
        // Create new brand
        const newId = generateId();
        await db.insert(brands).values({
          id: newId,
          name,
          nameGu,
          slug,
          logo,
          sortOrder,
          isActive,
        });
        clearCmsCache();
        redirectUrl = '/admin/brands?success=' + encodeURIComponent('Brand added successfully!');
      }
    }
  } catch (e: any) {
    const errMsg = e.message || '';
    if (errMsg.includes('unique constraint') || errMsg.includes('brands_slug_unique') || errMsg.includes('duplicate key')) {
      error = 'A brand with this slug already exists. Please choose a different, unique slug.';
    } else {
      error = errMsg || 'Failed to save brand.';
    }
  }
}

if (redirectUrl) {
  return Astro.redirect(redirectUrl);
}

// Fetch single brand if in edit mode
let editBrand: any = null;
if (action === 'edit' && brandId) {
  const [found] = await db.select().from(brands).where(eq(brands.id, brandId));
  editBrand = found;
}


const search = Astro.url.searchParams.get('search')?.trim() || '';
const statusFilter = Astro.url.searchParams.get('status') || 'all'; // all, active, inactive
const sort = Astro.url.searchParams.get('sort') || 'sort-asc';
const page = Number(Astro.url.searchParams.get('page') || '1');
const limit = 10;
const offset = (page - 1) * limit;

const conditions = [];

if (statusFilter === 'active') {
  conditions.push(eq(brands.isActive, true));
} else if (statusFilter === 'inactive') {
  conditions.push(eq(brands.isActive, false));
}

if (search) {
  conditions.push(
    or(
      ilike(brands.name, `%${search}%`),
      ilike(brands.nameGu, `%${search}%`),
      ilike(brands.slug, `%${search}%`)
    )
  );
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

let orderByClause = [asc(brands.sortOrder)];
if (sort === 'sort-desc') {
  orderByClause = [desc(brands.sortOrder)];
} else if (sort === 'name-asc') {
  orderByClause = [asc(brands.name)];
} else if (sort === 'name-desc') {
  orderByClause = [desc(brands.name)];
}

let allBrands: any[] = [];
let totalCount = 0;

try {
  allBrands = await db.select().from(brands)
    .where(whereClause)
    .orderBy(...orderByClause)
    .limit(limit)
    .offset(offset);

  const [countRes] = await db
    .select({ count: sql`count(*)` })
    .from(brands)
    .where(whereClause);
  totalCount = Number(countRes?.count || 0);
} catch (e) {
  console.error('[Admin Brands] Failed to fetch brands:', e);
}

const totalPages = Math.ceil(totalCount / limit);
---

<AdminLayout title="Manage Brands" activeTab="brands" subtitle="Manage authorized brand partnerships dynamically">
  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
      {error}
    </div>
  )}
  {success && (
    <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
      {success}
    </div>
  )}

  <!-- LIST VIEW -->
  {action === 'list' && (
    <div class="space-y-4">
      {/* Search, Sort, Filter Controls */}
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 bg-white border border-neutral-200 rounded-lg p-4 shadow-sm">
        <form method="get" class="flex flex-col sm:flex-row flex-wrap gap-3 items-stretch sm:items-center w-full md:w-auto">
          <div class="relative w-full sm:w-64">
            <input
              type="text"
              name="search"
              value={search}
              placeholder="Search brands..."
              class="w-full rounded border border-neutral-300 pl-8 pr-3 py-1.5 text-xs focus:border-primary focus:outline-none"
            />
            <span class="absolute left-2.5 top-2.5 text-neutral-400 text-xs">🔍</span>
          </div>
          
          <select name="status" class="w-full sm:w-auto rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer">
            <option value="all" selected={statusFilter === 'all'}>All Status</option>
            <option value="active" selected={statusFilter === 'active'}>Active Only</option>
            <option value="inactive" selected={statusFilter === 'inactive'}>Inactive Only</option>
          </select>

          <select name="sort" class="w-full sm:w-auto rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer">
            <option value="sort-asc" selected={sort === 'sort-asc'}>Sort Order (Asc)</option>
            <option value="sort-desc" selected={sort === 'sort-desc'}>Sort Order (Desc)</option>
            <option value="name-asc" selected={sort === 'name-asc'}>Name (A-Z)</option>
            <option value="name-desc" selected={sort === 'name-desc'}>Name (Z-A)</option>
          </select>

          <div class="flex items-center gap-2 w-full sm:w-auto">
            <button type="submit" class="flex-1 sm:flex-initial bg-neutral-800 text-white rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-900 transition-colors cursor-pointer text-center">
              Filter
            </button>

            {(search || statusFilter !== 'all' || sort !== 'sort-asc') && (
              <a href="/admin/brands" class="flex-1 sm:flex-initial bg-neutral-100 text-neutral-700 rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-200 transition-colors text-center justify-center flex items-center">
                Clear
              </a>
            )}
          </div>
        </form>
        <a href="/admin/brands?action=add" class="w-full md:w-auto text-center text-xs font-semibold text-white bg-primary hover:bg-primary/95 rounded-md px-3.5 py-2 transition-colors">
          + Add Brand
        </a>
      </div>

      {/* Desktop Table View */}
      <div class="hidden md:block bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm text-neutral-700 border-collapse">
            <thead>
              <tr class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900">
                <th class="p-3 w-16">Logo</th>
                <th class="p-3">Brand Name</th>
                <th class="p-3">Slug</th>
                <th class="p-3">Sort Order</th>
                <th class="p-3">Status</th>
                <th class="p-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              {allBrands.map((b) => {
                const editUrl = "/admin/brands?action=edit&id=" + b.id;

                const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dyjsrdrxa';
                let displayUrl = b.logo || '/images/placeholder-product.svg';
                if (b.logo && !b.logo.startsWith('http') && !b.logo.startsWith('/')) {
                  displayUrl = `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/w_100,h_100,c_fill,f_auto,q_auto/${b.logo}`;
                }

                return (
                  <tr class="border-b border-neutral-100 hover:bg-neutral-50/50">
                    <td class="p-3">
                      <img src={displayUrl} class="w-10 h-10 object-contain rounded border border-neutral-200 shadow-sm bg-neutral-50" alt={b.name} />
                    </td>
                    <td class="p-3">
                      <div class="font-medium text-neutral-900">{b.name}</div>
                      {b.nameGu && <div class="text-[11px] text-neutral-400">{b.nameGu}</div>}
                    </td>
                    <td class="p-3 text-xs text-neutral-500 font-mono">{b.slug}</td>
                    <td class="p-3 text-xs font-semibold text-neutral-600">{b.sortOrder}</td>
                    <td class="p-3">
                      <span class={`inline-block w-2.5 h-2.5 rounded-full ${b.isActive ? 'bg-green-500' : 'bg-red-500'}`} title={b.isActive ? 'Active' : 'Inactive'}></span>
                    </td>
                    <td class="p-3 text-right flex justify-end gap-2 items-center h-16">
                      <a href={editUrl} class="text-xs font-semibold text-primary hover:underline">
                        Edit
                      </a>
                      <form method="post" class="inline m-0">
                        <input type="hidden" name="formAction" value="delete" />
                        <input type="hidden" name="id" value={b.id} />
                        <button 
                          type="button" 
                          onclick="window.confirmDelete(this, 'Delete Brand', 'Are you sure you want to delete this brand?')"
                          class="text-xs font-semibold text-red-600 hover:underline bg-none border-none cursor-pointer focus:outline-none"
                        >
                          Delete
                        </button>
                      </form>
                    </td>
                  </tr>
                );
              })}
              {allBrands.length === 0 && (
                <tr>
                  <td colspan="6" class="p-8 text-center text-neutral-500">No brands found.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

      {/* Mobile Flat List View */}
      <div class="md:hidden bg-white border border-neutral-200 rounded-lg shadow-sm divide-y divide-neutral-100">
        {allBrands.map((b) => {
          const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dyjsrdrxa';
          let displayUrl = b.logo || '/images/placeholder-product.svg';
          if (b.logo && !b.logo.startsWith('http') && !b.logo.startsWith('/')) {
            displayUrl = `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/w_100,h_100,c_fill,f_auto,q_auto/${b.logo}`;
          }

          return (
            <div class="p-4 flex gap-3 items-center relative pr-20 min-h-[5.5rem]">
              <img src={displayUrl} class="w-12 h-12 object-contain rounded border border-neutral-200 shadow-sm bg-neutral-50 shrink-0" alt={b.name} />
              <div class="min-w-0 flex-1">
                <div class="font-bold text-sm text-neutral-900 truncate pr-2">{b.name}</div>
                {b.nameGu && <div class="text-[10px] text-neutral-400 truncate pr-2">{b.nameGu}</div>}
                <div class="text-[10px] text-neutral-500 mt-1 flex flex-wrap gap-x-2 gap-y-0.5 items-center">
                  <span>Order: {b.sortOrder}</span>
                  <span>•</span>
                  <span class={`inline-block w-2 h-2 rounded-full ${b.isActive ? 'bg-green-500' : 'bg-red-500'}`} title={b.isActive ? 'Active' : 'Inactive'}></span>
                </div>
              </div>

              <!-- Corner Actions -->
              <div class="absolute top-4 right-4 flex items-center gap-2">
                <a 
                  href={"/admin/brands?action=edit&id=" + b.id} 
                  class="w-8 h-8 rounded-full border border-neutral-200 hover:border-primary/30 hover:bg-primary/5 flex items-center justify-center text-xs text-neutral-600 hover:text-primary transition-colors cursor-pointer"
                  title="Edit"
                >
                  ✏️
                </a>
                <form method="post" class="inline m-0">
                  <input type="hidden" name="formAction" value="delete" />
                  <input type="hidden" name="id" value={b.id} />
                  <button 
                    type="button" 
                    onclick="window.confirmDelete(this, 'Delete Brand', 'Are you sure you want to delete this brand?')"
                    class="w-8 h-8 rounded-full border border-red-100 bg-red-50 hover:bg-red-100 flex items-center justify-center text-xs text-red-600 transition-colors cursor-pointer"
                    title="Delete"
                  >
                    🗑️
                  </button>
                </form>
              </div>
            </div>
          );
        })}
        {allBrands.length === 0 && (
          <div class="p-8 text-center text-neutral-500 text-sm">No brands found.</div>
        )}
      </div>

      {/* Pagination Controls */}
      {totalPages > 1 && (
        <div class="flex items-center justify-between border-t border-neutral-200 bg-white px-4 py-3 sm:px-6 rounded-lg shadow-sm">
          <div class="flex flex-1 justify-between sm:hidden">
            <a
              href={page > 1 ? `?page=${page - 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
              class={`relative inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
            >
              Previous
            </a>
            <a
              href={page < totalPages ? `?page=${page + 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
              class={`relative ml-3 inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
            >
              Next
            </a>
          </div>
          <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
              <p class="text-xs text-neutral-700">
                Showing
                <span class="font-semibold">{Math.min(offset + 1, totalCount)}</span>
                to
                <span class="font-semibold">{Math.min(offset + limit, totalCount)}</span>
                of
                <span class="font-semibold">{totalCount}</span>
                results
              </p>
            </div>
            <div>
              <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                <a
                  href={page > 1 ? `?page=${page - 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
                  class={`relative inline-flex items-center rounded-l-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
                >
                  <span class="sr-only">Previous</span>
                  <span>◀</span>
                </a>
                {Array.from({ length: totalPages }).map((_, idx) => {
                  const pNum = idx + 1;
                  const isCurrent = pNum === page;
                  return (
                    <a
                      href={`?page=${pNum}&search=${search}&status=${statusFilter}&sort=${sort}`}
                      aria-current={isCurrent ? "page" : undefined}
                      class={`relative inline-flex items-center px-3 py-2 text-xs font-semibold ${isCurrent ? 'z-10 bg-primary text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary' : 'text-neutral-900 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0'}`}
                    >
                      {pNum}
                    </a>
                  );
                })}
                <a
                  href={page < totalPages ? `?page=${page + 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
                  class={`relative inline-flex items-center rounded-r-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
                >
                  <span class="sr-only">Next</span>
                  <span>▶</span>
                </a>
              </nav>
            </div>
          </div>
        </div>
      )}
    </div>
  )}

  <!-- FORM VIEW -->
  {(action === 'add' || action === 'edit') && (
    <div class="bg-white border border-neutral-200 rounded-lg p-6 shadow-sm max-w-2xl mx-auto">
      <h2 class="text-lg font-bold text-neutral-900 mb-6">{action === 'edit' ? 'Edit Brand' : 'Add New Brand'}</h2>
      
      <form method="post" class="space-y-4">
        <input type="hidden" name="formAction" value="save" />

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-semibold text-neutral-700 mb-1">Brand Name (English) *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={editBrand?.name || ''}
              placeholder="e.g. Luminous"
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
            />
          </div>
          <div>
            <label for="nameGu" class="block text-sm font-semibold text-neutral-700 mb-1">Brand Name (Gujarati)</label>
            <input
              type="text"
              id="nameGu"
              name="nameGu"
              value={editBrand?.nameGu || ''}
              placeholder="દા.ત. લ્યુમિનસ"
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="slug" class="block text-sm font-semibold text-neutral-700 mb-1">Slug (URL parameter) *</label>
            <input
              type="text"
              id="slug"
              name="slug"
              required
              pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$"
              title="Slug must only contain lowercase letters, numbers, and hyphens, and cannot start or end with a hyphen."
              value={editBrand?.slug || ''}
              placeholder="e.g. luminous"
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
            />
          </div>
          <div>
            <label for="sortOrder" class="block text-sm font-semibold text-neutral-700 mb-1">Sort Order</label>
            <input
              type="number"
              id="sortOrder"
              name="sortOrder"
              value={editBrand?.sortOrder || 0}
              placeholder="0"
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-neutral-700 mb-2">Brand Logo Image *</label>
          <input type="hidden" id="logo" name="logo" value={editBrand?.logo || ''} />
          
          <div id="logo-preview" class="mb-3"></div>

          <div class="relative border-2 border-dashed border-neutral-300 rounded-lg p-6 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer group text-center" id="upload-dropzone">
            <input type="file" id="file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
            <div class="space-y-1">
              <span class="text-2xl text-neutral-400 group-hover:text-primary transition-colors">📷</span>
              <p class="text-xs font-semibold text-neutral-600">Choose logo image file</p>
              <p class="text-[10px] text-neutral-400">Supports SVG, PNG, JPG, WEBP</p>
            </div>
          </div>

          <div id="upload-progress-container" class="hidden mt-3 space-y-1.5">
            <div class="flex justify-between text-[11px] font-semibold text-neutral-500">
              <span id="upload-status">Uploading...</span>
              <span id="upload-percent">0%</span>
            </div>
            <div class="w-full bg-neutral-200 rounded-full h-1.5 overflow-hidden">
              <div id="upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
            </div>
          </div>
        </div>

        <div class="py-2">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="isActive" checked={editBrand ? editBrand.isActive : true} class="rounded border-neutral-300 text-primary focus:ring-primary" />
            <span class="text-sm font-semibold text-neutral-700">Brand Active</span>
          </label>
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t border-neutral-200">
          <a href="/admin/brands" class="btn-outline px-4 py-2 text-sm">
            Cancel
          </a>
          <button type="submit" class="btn-primary px-6 py-2 text-sm font-medium">
            Save Brand
          </button>
        </div>
      </form>

      <script>
        // Automatic Slug Generator
        const nameInput = document.getElementById('name') as HTMLInputElement;
        const slugInput = document.getElementById('slug') as HTMLInputElement;

        nameInput?.addEventListener('input', () => {
          if (slugInput && (!slugInput.value || slugInput.value === slugify(nameInput.value.slice(0, -1)))) {
            slugInput.value = slugify(nameInput.value);
          }
        });

        if (slugInput) {
          slugInput.addEventListener('input', () => {
            let val = slugInput.value;
            val = val.replace(/[\s_]+/g, '-');
            val = val.toLowerCase().replace(/[^a-z0-9-]/g, '');
            val = val.replace(/-+/g, '-');
            slugInput.value = val;
          });
        }

        function slugify(text: string): string {
          return text
            .toString()
            .toLowerCase()
            .trim()
            .replace(/\s+/g, '-')
            .replace(/[^\w\-]+/g, '')
            .replace(/\-\-+/g, '-');
        }

        // Image Picker Logic
        const logoInput = document.getElementById('logo') as HTMLInputElement;
        const previewContainer = document.getElementById('logo-preview');
        const filePicker = document.getElementById('file-picker') as HTMLInputElement;
        const progressContainer = document.getElementById('upload-progress-container');
        const progressBar = document.getElementById('upload-progress-bar');
        const progressPercent = document.getElementById('upload-percent');

        const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dyjsrdrxa';

        function renderPreview() {
          if (!previewContainer) return;
          previewContainer.innerHTML = '';
          const imgVal = logoInput.value.trim();
          if (!imgVal) return;

          let displayUrl = imgVal;
          if (!imgVal.startsWith('http') && !imgVal.startsWith('/')) {
            displayUrl = `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/w_200,h_200,c_fill,f_auto,q_auto/${imgVal}`;
          }

          const div = document.createElement('div');
          div.className = 'relative group w-24 h-24 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
          div.innerHTML = `
            <img src="${displayUrl}" class="w-full h-full object-contain p-1" />
            <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
          `;

          div.querySelector('button')?.addEventListener('click', async () => {
            const oldVal = logoInput.value.trim();
            if (oldVal) {
              await deleteAssetClient(oldVal, 'image');
            }
            logoInput.value = '';
            renderPreview();
          });

          previewContainer.appendChild(div);
        }

        async function deleteAssetClient(publicId: string, resourceType: 'image' | 'video' = 'image') {
          if (!publicId || publicId.startsWith('http') || publicId.startsWith('/')) return;
          try {
            await fetch('/api/admin/delete-asset', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ publicId, resourceType })
            });
          } catch (e) {
            console.error('[Client delete error]', e);
          }
        }

        filePicker?.addEventListener('change', async () => {
          const files = filePicker.files;
          if (!files || files.length === 0) return;

          const file = files[0];
          progressContainer?.classList.remove('hidden');

          try {
            const resVal = await new Promise<string>((resolve, reject) => {
              const xhr = new XMLHttpRequest();
              xhr.open('POST', '/api/upload', true);
              
              xhr.upload.onprogress = (e) => {
                if (e.lengthComputable) {
                  const pct = Math.round((e.loaded / e.total) * 100);
                  progressBar!.style.width = `${pct}%`;
                  progressPercent!.textContent = `${pct}%`;
                }
              };

              xhr.onload = () => {
                if (xhr.status === 200) {
                  try {
                    const res = JSON.parse(xhr.responseText);
                    resolve(res.public_id || res.url);
                  } catch(e) {
                    reject('Invalid response');
                  }
                } else {
                  reject('Server returned status ' + xhr.status);
                }
              };

              xhr.onerror = () => reject('Network error');

              const formData = new FormData();
              formData.append('file', file);
              xhr.send(formData);
            });

            if (resVal) {
              const oldVal = logoInput.value.trim();
              if (oldVal && oldVal !== resVal) {
                await deleteAssetClient(oldVal, 'image');
              }
              logoInput.value = resVal;
              renderPreview();
            }
          } catch (err) {
            alert('Upload failed: ' + err);
          } finally {
            progressContainer?.classList.add('hidden');
            filePicker.value = '';
          }
        });

        renderPreview();
      </script>
    </div>
  )}
</AdminLayout>
