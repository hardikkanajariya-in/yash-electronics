---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { bundleRules } from '../../db/schema';
import { eq, and, or, sql, asc, desc } from 'drizzle-orm';
import { getSessionUser, generateId } from '../../lib/auth';
import { clearCmsCache } from '../../services/cms';

export const prerender = false;
export const isr = false;

// Authenticate Admin
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

const action = Astro.url.searchParams.get('action') || 'list';
const ruleId = Astro.url.searchParams.get('id') || '';

let error = Astro.url.searchParams.get('error') || '';
let success = Astro.url.searchParams.get('success') || '';
let redirectUrl = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('formAction')?.toString() || '';

    if (formAction === 'delete') {
      const idToDelete = formData.get('id')?.toString() || '';
      await db.delete(bundleRules).where(eq(bundleRules.id, idToDelete));
      clearCmsCache();
      redirectUrl = '/admin/bundle-rules?success=' + encodeURIComponent('Bundle rule deleted successfully!');
    } else if (formAction === 'toggle_status') {
      const idToToggle = formData.get('id')?.toString() || '';
      const currentValue = formData.get('currentValue')?.toString() === 'true';
      await db.update(bundleRules).set({
        isActive: !currentValue,
        updatedAt: new Date().toISOString()
      }).where(eq(bundleRules.id, idToToggle));
      clearCmsCache();
      redirectUrl = '/admin/bundle-rules?success=' + encodeURIComponent('Status updated successfully!');
    } else if (formAction === 'save') {
      const name = formData.get('name')?.toString() || '';
      const nameGu = formData.get('nameGu')?.toString().trim() || null;
      const minQuantity = parseInt(formData.get('minQuantity')?.toString() || '3', 10);
      const rewardType = formData.get('rewardType')?.toString() as any || 'free_gift';
      const rewardValue = parseInt(formData.get('rewardValue')?.toString() || '0', 10);
      const rewardDescription = formData.get('rewardDescription')?.toString() || '';
      const rewardDescriptionGu = formData.get('rewardDescriptionGu')?.toString().trim() || null;
      const isActive = formData.get('isActive') === 'on';

      if (!name || minQuantity < 1 || !rewardDescription) {
        throw new Error('Please fill in all required fields correctly.');
      }

      const now = new Date().toISOString();

      if (ruleId) {
        // Edit existing rule
        await db.update(bundleRules).set({
          name,
          nameGu,
          minQuantity,
          rewardType,
          rewardValue: isNaN(rewardValue) ? 0 : rewardValue,
          rewardDescription,
          rewardDescriptionGu,
          isActive,
          updatedAt: now,
        }).where(eq(bundleRules.id, ruleId));
        clearCmsCache();
        redirectUrl = '/admin/bundle-rules?success=' + encodeURIComponent('Bundle rule updated successfully!');
      } else {
        // Create new rule
        const newId = generateId();
        await db.insert(bundleRules).values({
          id: newId,
          name,
          nameGu,
          minQuantity,
          rewardType,
          rewardValue: isNaN(rewardValue) ? 0 : rewardValue,
          rewardDescription,
          rewardDescriptionGu,
          isActive,
          createdAt: now,
          updatedAt: now,
        });
        clearCmsCache();
        redirectUrl = '/admin/bundle-rules?success=' + encodeURIComponent('Bundle rule created successfully!');
      }
    }
  } catch (e: any) {
    error = e.message || 'Failed to save bundle rule.';
  }
}

if (redirectUrl) {
  return Astro.redirect(redirectUrl);
}

// Fetch single rule if in edit mode
let editRule: any = null;
if (action === 'edit' && ruleId) {
  const [found] = await db.select().from(bundleRules).where(eq(bundleRules.id, ruleId));
  editRule = found;
}

// Fetch all rules
let allRules: any[] = [];
try {
  allRules = await db.select().from(bundleRules).orderBy(asc(bundleRules.minQuantity));
} catch (e) {
  console.error('[Bundle Rules] Failed to fetch rules:', e);
}
---

<AdminLayout title="Bundle Rules" activeTab="bundle-rules" subtitle="Configure order discount rules for custom product bundles">
  <div class="max-w-6xl mx-auto py-2">
    <!-- Header row -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-b border-neutral-200 pb-5 mb-6">
      <div>
        <h2 class="text-xl font-bold text-neutral-900 animate-fade-in">Purchase Order Bundle Rules</h2>
        <p class="text-xs text-neutral-500 mt-1">Customers building custom bundles will unlock these rewards during checkout based on rules below.</p>
      </div>
      
      {action === 'list' && (
        <a href="/admin/bundle-rules?action=add" class="btn-primary flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-md shadow transition-all cursor-pointer">
          <span>+</span> Add Bundle Rule
        </a>
      )}
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-6">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-6">
        {success}
      </div>
    )}

    <!-- LIST VIEW -->
    {action === 'list' && (
      <div>
        <div class="bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm text-neutral-700 border-collapse">
              <thead>
                <tr class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900">
                  <th class="p-4">Rule Name</th>
                  <th class="p-4">Min Quantity</th>
                  <th class="p-4">Reward Type</th>
                  <th class="p-4">Reward Value / Description</th>
                  <th class="p-4">Status</th>
                  <th class="p-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100">
                {allRules.map((rule) => (
                  <tr class="hover:bg-neutral-50/50">
                    <td class="p-4">
                      <div class="font-bold text-neutral-900">{rule.name}</div>
                      {rule.nameGu && <div class="text-xs text-neutral-400 mt-0.5">{rule.nameGu}</div>}
                    </td>
                    <td class="p-4 font-mono font-bold text-neutral-900">{rule.minQuantity} products</td>
                    <td class="p-4 text-xs font-semibold uppercase">
                      {rule.rewardType === 'free_gift' && <span class="bg-purple-50 text-purple-700 border border-purple-200 rounded px-2 py-0.5">🎁 Free Gift</span>}
                      {rule.rewardType === 'store_voucher' && <span class="bg-blue-50 text-blue-700 border border-blue-200 rounded px-2 py-0.5">🎫 Store Voucher</span>}
                      {rule.rewardType === 'percentage_discount' && <span class="bg-green-50 text-green-700 border border-green-200 rounded px-2 py-0.5">🏷️ % Discount</span>}
                      {rule.rewardType === 'flat_discount' && <span class="bg-emerald-50 text-emerald-700 border border-emerald-200 rounded px-2 py-0.5">₹ Flat Discount</span>}
                    </td>
                    <td class="p-4">
                      <div class="text-neutral-800 font-semibold">{rule.rewardDescription}</div>
                      {rule.rewardType.includes('discount') && (
                        <div class="text-[11px] text-neutral-500 font-mono mt-0.5">Value: {rule.rewardType === 'percentage_discount' ? `${rule.rewardValue}%` : `₹${rule.rewardValue.toLocaleString('en-IN')}`}</div>
                      )}
                      {rule.rewardDescriptionGu && <div class="text-xs text-neutral-400 mt-0.5">{rule.rewardDescriptionGu}</div>}
                    </td>
                    <td class="p-4">
                      <form method="post" class="inline m-0">
                        <input type="hidden" name="formAction" value="toggle_status" />
                        <input type="hidden" name="id" value={rule.id} />
                        <input type="hidden" name="currentValue" value={rule.isActive ? 'true' : 'false'} />
                        <button
                          type="submit"
                          class={`relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none ${
                            rule.isActive ? 'bg-secondary' : 'bg-neutral-200'
                          }`}
                          title={rule.isActive ? 'Active (Click to disable)' : 'Inactive (Click to enable)'}
                        >
                          <span
                            class={`pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out ${
                              rule.isActive ? 'translate-x-4' : 'translate-x-0'
                            }`}
                          />
                        </button>
                      </form>
                    </td>
                    <td class="p-4 text-right flex justify-end gap-3 items-center min-h-[4rem]">
                      <a href={`/admin/bundle-rules?action=edit&id=${rule.id}`} class="text-xs font-semibold text-primary hover:underline">
                        Edit
                      </a>
                      <form method="post" class="inline m-0">
                        <input type="hidden" name="formAction" value="delete" />
                        <input type="hidden" name="id" value={rule.id} />
                        <button
                          type="button"
                          onclick="window.confirmDelete(this, 'Delete Rule', 'Are you sure you want to delete this bundle rule?')"
                          class="text-xs font-semibold text-red-600 hover:underline bg-none border-none cursor-pointer focus:outline-none"
                        >
                          Delete
                        </button>
                      </form>
                    </td>
                  </tr>
                ))}
                {allRules.length === 0 && (
                  <tr>
                    <td colspan="6" class="p-8 text-center text-neutral-500">No bundle rules configured. Add a rule to start offering order discounts!</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}

    <!-- FORM VIEW -->
    {(action === 'add' || action === 'edit') && (
      <div class="bg-white border border-neutral-200 rounded-lg p-6 shadow-sm max-w-2xl mx-auto">
        <h2 class="text-base font-bold text-neutral-900 border-b border-neutral-100 pb-3 mb-6">
          {action === 'edit' ? 'Edit Bundle Rule' : 'Create New Bundle Rule'}
        </h2>
        
        <form method="post" class="space-y-4">
          <input type="hidden" name="formAction" value="save" />

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-xs font-bold text-neutral-600 uppercase mb-1">Rule Name (English) *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                value={editRule?.name || ''}
                placeholder="e.g. 3 Products Special Gift"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
            <div>
              <label for="nameGu" class="block text-xs font-bold text-neutral-600 uppercase mb-1">Rule Name (Gujarati)</label>
              <input
                type="text"
                id="nameGu"
                name="nameGu"
                value={editRule?.nameGu || ''}
                placeholder="દા.ત. ૩ પ્રોડક્ટ્સ સ્પેશિયલ ગિફ્ટ"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="minQuantity" class="block text-xs font-bold text-neutral-600 uppercase mb-1">Minimum Quantity of Products *</label>
              <input
                type="number"
                id="minQuantity"
                name="minQuantity"
                required
                min="1"
                value={editRule?.minQuantity || 3}
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none font-mono"
              />
            </div>
            <div>
              <label for="rewardType" class="block text-xs font-bold text-neutral-600 uppercase mb-1">Reward Type *</label>
              <select
                id="rewardType"
                name="rewardType"
                required
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none bg-white"
                onchange="toggleRewardValueField(this.value)"
              >
                <option value="free_gift" selected={editRule?.rewardType === 'free_gift'}>🎁 Free Gift</option>
                <option value="percentage_discount" selected={editRule?.rewardType === 'percentage_discount'}>🏷️ Percentage Discount (Applied at Checkout)</option>
                <option value="flat_discount" selected={editRule?.rewardType === 'flat_discount'}>₹ Flat Discount (Applied at Checkout)</option>
                <option value="store_voucher" selected={editRule?.rewardType === 'store_voucher'}>🎫 Cash Coupon / Voucher at Store</option>
              </select>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div id="reward-value-container" class={editRule?.rewardType?.includes('discount') ? '' : 'hidden'}>
              <label for="rewardValue" class="block text-xs font-bold text-neutral-600 uppercase mb-1" id="reward-value-label">
                {editRule?.rewardType === 'percentage_discount' ? 'Discount Percentage (%) *' : 'Discount Value (₹) *'}
              </label>
              <input
                type="number"
                id="rewardValue"
                name="rewardValue"
                min="0"
                value={editRule?.rewardValue || 0}
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none font-mono"
              />
            </div>
            
            <div class={editRule?.rewardType?.includes('discount') ? 'col-span-1' : 'col-span-2'} id="desc-container-parent">
              <label for="rewardDescription" class="block text-xs font-bold text-neutral-600 uppercase mb-1">Reward Description (English) *</label>
              <input
                type="text"
                id="rewardDescription"
                name="rewardDescription"
                required
                value={editRule?.rewardDescription || ''}
                placeholder="e.g. Free Noise Bluetooth Soundbar"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label for="rewardDescriptionGu" class="block text-xs font-bold text-neutral-600 uppercase mb-1">Reward Description (Gujarati)</label>
            <input
              type="text"
              id="rewardDescriptionGu"
              name="rewardDescriptionGu"
              value={editRule?.rewardDescriptionGu || ''}
              placeholder="દા.ત. મફત નોઈઝ બ્લૂટૂથ સાઉન્ડબાર"
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
            />
          </div>

          <div class="py-2">
            <label class="flex items-center gap-2 cursor-pointer select-none">
              <input type="checkbox" name="isActive" checked={editRule ? editRule.isActive : true} class="rounded border-neutral-300 text-primary focus:ring-primary" />
              <span class="text-sm font-semibold text-neutral-700">Rule Active</span>
            </label>
          </div>

          <div class="flex justify-end gap-3 pt-4 border-t border-neutral-100">
            <a href="/admin/bundle-rules" class="btn-outline px-4 py-2 text-sm">
              Cancel
            </a>
            <button type="submit" class="btn-primary px-6 py-2 text-sm font-semibold">
              Save Rule
            </button>
          </div>
        </form>

        <script is:inline>
          function toggleRewardValueField(val) {
            const container = document.getElementById('reward-value-container');
            const label = document.getElementById('reward-value-label');
            const descParent = document.getElementById('desc-container-parent');
            
            if (val === 'percentage_discount' || val === 'flat_discount') {
              container.classList.remove('hidden');
              descParent.className = 'col-span-1';
              if (val === 'percentage_discount') {
                label.textContent = 'Discount Percentage (%) *';
              } else {
                label.textContent = 'Discount Value (₹) *';
              }
            } else {
              container.classList.add('hidden');
              descParent.className = 'col-span-2';
            }
          }
          
          // Initial trigger on form load to set initial state correctly
          document.addEventListener('DOMContentLoaded', () => {
            const selectEl = document.getElementById('rewardType');
            if (selectEl) {
              toggleRewardValueField(selectEl.value);
            }
          });
        </script>
      </div>
    )}
  </div>
</AdminLayout>

<script is:inline>
  // Confirm Delete Custom Dialog Modal Hook
  window.confirmDelete = function (button, title, message) {
    if (window.showConfirm) {
      window.showConfirm(title, message, () => {
        button.form.submit();
      });
    } else if (confirm(message)) {
      button.form.submit();
    }
  };
</script>
