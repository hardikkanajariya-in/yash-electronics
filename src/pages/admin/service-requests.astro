---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { serviceRequests } from '../../db/schema';
import { eq, desc, and, or, ilike, sql } from 'drizzle-orm';
import { getSessionUser } from '../../lib/auth';

export const prerender = false;

// Authenticate Admin
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/admin/login');
}

let error = Astro.url.searchParams.get('error') || '';
let success = Astro.url.searchParams.get('success') || '';

// Handle POST actions: update status or tracking info
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('formAction')?.toString() || '';
    const srId = formData.get('srId')?.toString() || '';

    if (srId) {
      if (action === 'update_status') {
        const newStatus = formData.get('status')?.toString() as any;
        if (['pending', 'in_progress', 'resolved', 'cancelled'].includes(newStatus)) {
          await db.update(serviceRequests)
            .set({ status: newStatus, updatedAt: new Date().toISOString() })
            .where(eq(serviceRequests.id, srId));
          return Astro.redirect(Astro.url.pathname + '?success=' + encodeURIComponent('Service Request status updated successfully!'));
        }
      } else if (action === 'update_tracking') {
        const trackingInfo = formData.get('trackingInfo')?.toString().trim() || '';
        await db.update(serviceRequests)
          .set({ trackingInfo, updatedAt: new Date().toISOString() })
          .where(eq(serviceRequests.id, srId));
        return Astro.redirect(Astro.url.pathname + '?success=' + encodeURIComponent('Tracking information updated successfully!'));
      } else if (action === 'delete') {
        await db.delete(serviceRequests).where(eq(serviceRequests.id, srId));
        return Astro.redirect(Astro.url.pathname + '?success=' + encodeURIComponent('Service Request deleted successfully!'));
      }
    }
  } catch (e: any) {
    error = e.message || 'Failed to perform request action.';
  }
}

const search = Astro.url.searchParams.get('search')?.trim() || '';
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const page = Number(Astro.url.searchParams.get('page') || '1');
const limit = 10;
const offset = (page - 1) * limit;

// Build search and filter conditions
const conditions = [];

if (statusFilter !== 'all') {
  conditions.push(eq(serviceRequests.status, statusFilter as any));
}

if (search) {
  conditions.push(
    or(
      ilike(serviceRequests.customerName, `%${search}%`),
      ilike(serviceRequests.customerPhone, `%${search}%`),
      ilike(serviceRequests.village, `%${search}%`),
      ilike(serviceRequests.brandName, `%${search}%`),
      ilike(serviceRequests.productCategory, `%${search}%`),
      ilike(serviceRequests.fault, `%${search}%`),
      ilike(serviceRequests.productName, `%${search}%`),
      ilike(serviceRequests.complaintDetails, `%${search}%`)
    )
  );
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

let allRequests: any[] = [];
let totalCount = 0;

try {
  allRequests = await db.query.serviceRequests.findMany({
    where: whereClause,
    orderBy: [desc(serviceRequests.createdAt)],
    limit,
    offset,
    with: {
      user: true,
    },
  });

  const [countRes] = await db
    .select({ count: sql`count(*)` })
    .from(serviceRequests)
    .where(whereClause);
  totalCount = Number(countRes?.count || 0);
} catch (e) {
  console.error('[Admin SRs] Failed to fetch service requests:', e);
}

const totalPages = Math.ceil(totalCount / limit);

// Fetch overall counts for status badges
let statsCounts = { all: 0, pending: 0, in_progress: 0, resolved: 0, cancelled: 0 };
try {
  const allCounts = await db
    .select({ status: serviceRequests.status, count: sql<number>`count(*)` })
    .from(serviceRequests)
    .groupBy(serviceRequests.status);

  allCounts.forEach((c) => {
    if (c.status === 'pending') statsCounts.pending = Number(c.count);
    else if (c.status === 'in_progress') statsCounts.in_progress = Number(c.count);
    else if (c.status === 'resolved') statsCounts.resolved = Number(c.count);
    else if (c.status === 'cancelled') statsCounts.cancelled = Number(c.count);
  });
  statsCounts.all = statsCounts.pending + statsCounts.in_progress + statsCounts.resolved + statsCounts.cancelled;
} catch (e) {
  console.error('[Admin SRs] Failed to fetch counts:', e);
}
---

<AdminLayout title="Service Requests" activeTab="service-requests" subtitle="Track, process and provide updates on customer product complaints">

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    {/* Search & Filter Bar */}
    <div class="bg-white border border-neutral-200 rounded-lg p-4 shadow-sm mb-6">
      <form method="get" class="flex flex-wrap gap-3 items-center justify-between w-full">
        <input type="hidden" name="status" value={statusFilter} />
        <div class="relative flex-1 max-w-md w-full">
          <input
            type="text"
            name="search"
            value={search}
            placeholder="Search customer, phone, village, fault..."
            class="w-full rounded border border-neutral-300 pl-8 pr-3 py-1.5 text-xs focus:border-primary focus:outline-none"
          />
          <span class="absolute left-2.5 top-2.5 text-neutral-400 text-xs">🔍</span>
        </div>
        <div class="flex gap-2">
          <button type="submit" class="bg-neutral-800 text-white rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-900 transition-colors cursor-pointer">
            Search
          </button>
          {search && (
            <a href={`?status=${statusFilter}`} class="bg-neutral-100 text-neutral-700 rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-200 transition-colors text-center flex items-center">
              Clear
            </a>
          )}
        </div>
      </form>
    </div>

    <!-- Navigation Tabs / Filters -->
    <nav class="flex border-b border-neutral-200 gap-2 mb-6 overflow-x-auto text-xs font-medium pb-2 select-none whitespace-nowrap">
      <a href={`?status=all&search=${search}`} class={`px-3 py-2 font-bold focus:outline-none border-b-2 ${statusFilter === 'all' ? 'border-primary text-primary' : 'border-transparent text-neutral-600 hover:text-primary'}`}>
        All ({statsCounts.all})
      </a>
      <a href={`?status=pending&search=${search}`} class={`px-3 py-2 font-bold focus:outline-none border-b-2 ${statusFilter === 'pending' ? 'border-primary text-primary' : 'border-transparent text-neutral-600 hover:text-primary'}`}>
        Pending ({statsCounts.pending})
      </a>
      <a href={`?status=in_progress&search=${search}`} class={`px-3 py-2 font-bold focus:outline-none border-b-2 ${statusFilter === 'in_progress' ? 'border-primary text-primary' : 'border-transparent text-neutral-600 hover:text-primary'}`}>
        In Progress ({statsCounts.in_progress})
      </a>
      <a href={`?status=resolved&search=${search}`} class={`px-3 py-2 font-bold focus:outline-none border-b-2 ${statusFilter === 'resolved' ? 'border-primary text-primary' : 'border-transparent text-neutral-600 hover:text-primary'}`}>
        Resolved ({statsCounts.resolved})
      </a>
      <a href={`?status=cancelled&search=${search}`} class={`px-3 py-2 font-bold focus:outline-none border-b-2 ${statusFilter === 'cancelled' ? 'border-primary text-primary' : 'border-transparent text-neutral-600 hover:text-primary'}`}>
        Cancelled ({statsCounts.cancelled})
      </a>
    </nav>

    <!-- Service Requests List -->
    <div class="space-y-6" id="srs-container">
      {allRequests.map((sr) => {
        const dateStr = new Date(sr.createdAt).toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });

        return (
          <div data-status={sr.status} class="sr-card bg-white border border-neutral-200 rounded-lg shadow-sm p-4 sm:p-5 hover:shadow-md transition-shadow">
            <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-100 pb-3 mb-3">
              <div>
                <span class="text-[10px] text-neutral-400 font-bold uppercase">Customer</span>
                <h3 class="text-sm font-bold text-neutral-800">{sr.user?.name || sr.customerName || 'Guest Customer'}</h3>
                <span class="text-[10px] text-neutral-400">{dateStr}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class={`inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase border ${
                  sr.status === 'pending' ? 'bg-amber-50 text-amber-700 border-amber-200 font-bold' :
                  sr.status === 'in_progress' ? 'bg-blue-50 text-blue-700 border-blue-200' :
                  sr.status === 'resolved' ? 'bg-green-50 text-green-700 border-green-200' :
                  'bg-neutral-50 text-neutral-700 border-neutral-200'
                }`}>
                  {sr.status.replace('_', ' ')}
                </span>
              </div>
            </div>

            <div class="space-y-4">
              {/* Customer Contact Details */}
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-neutral-600">
                <span>
                  📞 Phone: <a href={`tel:${sr.user?.phone || sr.customerPhone}`} class="text-primary hover:underline font-medium">{sr.user?.phone || sr.customerPhone}</a>
                </span>
                {sr.village && (
                  <span>
                    📍 Village / City: <span class="font-semibold text-neutral-800">{sr.village}</span>
                  </span>
                )}
                {sr.pincode && (
                  <span>
                    📮 Pincode: <span class="font-semibold text-neutral-800 font-mono">{sr.pincode}</span>
                  </span>
                )}
              </div>

              {/* Product Info & Complaint Description */}
              <div class="grid md:grid-cols-3 gap-4">
                <div class="border border-neutral-100 rounded-md p-3 bg-neutral-50/50">
                  <h4 class="text-xs font-bold text-neutral-500 uppercase mb-1">Product Details</h4>
                  <div class="space-y-0.5 text-xs text-neutral-700">
                    <div><span class="font-semibold text-neutral-400">Category:</span> {sr.productCategory || '—'}</div>
                    <div><span class="font-semibold text-neutral-400">Brand:</span> {sr.brandName || '—'}</div>
                    <div><span class="font-semibold text-neutral-400">Model No:</span> {sr.modelNumber || '—'}</div>
                  </div>
                </div>
                <div class="border border-neutral-100 rounded-md p-3 bg-neutral-50/50">
                  <h4 class="text-xs font-bold text-neutral-500 uppercase mb-1">Fault / Issue</h4>
                  <p class="text-xs text-neutral-700 whitespace-pre-wrap leading-relaxed">{sr.fault || sr.complaintDetails}</p>
                </div>
                <div class="border border-neutral-100 rounded-md p-3 bg-neutral-50/50">
                  <h4 class="text-xs font-bold text-neutral-500 uppercase mb-1">Address</h4>
                  <p class="text-xs text-neutral-700 whitespace-pre-wrap leading-relaxed">{sr.address || '—'}</p>
                </div>
              </div>

              {/* Tracking Info Form & Update */}
              <div class="border-t border-neutral-100 pt-4 mt-3">
                <form method="post" class="grid sm:grid-cols-3 gap-3 items-end">
                  <input type="hidden" name="formAction" value="update_tracking" />
                  <input type="hidden" name="srId" value={sr.id} />
                  
                  <div class="sm:col-span-2">
                    <label class="block text-[10px] font-bold text-neutral-400 uppercase mb-1">
                      Tracking Info / Complaint Updates (Customer will see this)
                    </label>
                    <textarea
                      name="trackingInfo"
                      placeholder="e.g. Technician Ramesh assigned. Scheduled for Tuesday 10 AM."
                      rows="2"
                      class="w-full text-xs rounded border border-neutral-300 px-3 py-1.5 focus:border-primary focus:outline-none"
                    >{sr.trackingInfo || ''}</textarea>
                  </div>
                  
                  <div>
                    <button type="submit" class="w-full text-xs font-semibold bg-neutral-800 text-white hover:bg-neutral-900 rounded px-3 py-2 transition-colors cursor-pointer">
                      Update Info
                    </button>
                  </div>
                </form>
              </div>

              {/* Actions Footer */}
              <div class="flex items-center justify-between border-t border-neutral-100 pt-3 mt-3">
                <form method="post" class="inline">
                  <input type="hidden" name="formAction" value="delete" />
                  <input type="hidden" name="srId" value={sr.id} />
                  <button 
                    type="button" 
                    onclick="window.confirmDelete(this, 'Delete Request', 'Are you sure you want to delete this service request?')"
                    class="text-xs text-red-600 font-semibold hover:underline bg-none border-none cursor-pointer focus:outline-none"
                  >
                    Delete Request
                  </button>
                </form>

                <form method="post" class="flex items-center gap-2">
                  <input type="hidden" name="formAction" value="update_status" />
                  <input type="hidden" name="srId" value={sr.id} />
                  <span class="text-[11px] text-neutral-400">Change Status:</span>
                  <select
                    name="status"
                    class="rounded border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none cursor-pointer"
                    onchange="this.form.submit()"
                  >
                    <option value="pending" selected={sr.status === 'pending'}>Pending</option>
                    <option value="in_progress" selected={sr.status === 'in_progress'}>In Progress</option>
                    <option value="resolved" selected={sr.status === 'resolved'}>Resolved</option>
                    <option value="cancelled" selected={sr.status === 'cancelled'}>Cancelled</option>
                  </select>
                </form>
              </div>
            </div>
          </div>
        );
      })}

      {allRequests.length === 0 && (
        <div class="bg-white border border-neutral-200 rounded-lg p-12 text-center text-neutral-500 shadow-sm">
          No service requests found.
        </div>
      )}
    </div>

    {/* Pagination Controls */}
    {totalPages > 1 && (
      <div class="flex items-center justify-between border-t border-neutral-200 bg-white px-4 py-3 sm:px-6 rounded-lg shadow-sm mt-6">
        <div class="flex flex-1 justify-between sm:hidden">
          <a
            href={page > 1 ? `?page=${page - 1}&status=${statusFilter}&search=${search}` : '#'}
            class={`relative inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
          >
            Previous
          </a>
          <a
            href={page < totalPages ? `?page=${page + 1}&status=${statusFilter}&search=${search}` : '#'}
            class={`relative ml-3 inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
          >
            Next
          </a>
        </div>
        <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
          <div>
            <p class="text-xs text-neutral-700">
              Showing
              <span class="font-semibold">{Math.min(offset + 1, totalCount)}</span>
              to
              <span class="font-semibold">{Math.min(offset + limit, totalCount)}</span>
              of
              <span class="font-semibold">{totalCount}</span>
              results
            </p>
          </div>
          <div>
            <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
              <a
                href={page > 1 ? `?page=${page - 1}&status=${statusFilter}&search=${search}` : '#'}
                class={`relative inline-flex items-center rounded-l-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
              >
                <span class="sr-only">Previous</span>
                <span>◀</span>
              </a>
              {Array.from({ length: totalPages }).map((_, idx) => {
                const pNum = idx + 1;
                const isCurrent = pNum === page;
                return (
                  <a
                    href={`?page=${pNum}&status=${statusFilter}&search=${search}`}
                    aria-current={isCurrent ? "page" : undefined}
                    class={`relative inline-flex items-center px-3 py-2 text-xs font-semibold ${isCurrent ? 'z-10 bg-primary text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary' : 'text-neutral-900 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0'}`}
                  >
                    {pNum}
                  </a>
                );
              })}
              <a
                href={page < totalPages ? `?page=${page + 1}&status=${statusFilter}&search=${search}` : '#'}
                class={`relative inline-flex items-center rounded-r-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
              >
                <span class="sr-only">Next</span>
                <span>▶</span>
              </a>
            </nav>
          </div>
        </div>
      </div>
    )}
</AdminLayout>
