---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { serviceRequests } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getSessionUser } from '../../lib/auth';

export const prerender = false;

// Authenticate Admin
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/admin/login');
}

let error = '';
let success = '';

// Handle POST actions: update status or tracking info
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('formAction')?.toString() || '';
    const srId = formData.get('srId')?.toString() || '';

    if (srId) {
      if (action === 'update_status') {
        const newStatus = formData.get('status')?.toString() as any;
        if (['pending', 'in_progress', 'resolved', 'cancelled'].includes(newStatus)) {
          await db.update(serviceRequests)
            .set({ status: newStatus, updatedAt: new Date().toISOString() })
            .where(eq(serviceRequests.id, srId));
          success = 'Service Request status updated successfully!';
        }
      } else if (action === 'update_tracking') {
        const trackingInfo = formData.get('trackingInfo')?.toString().trim() || '';
        await db.update(serviceRequests)
          .set({ trackingInfo, updatedAt: new Date().toISOString() })
          .where(eq(serviceRequests.id, srId));
        success = 'Tracking information updated successfully!';
      } else if (action === 'delete') {
        await db.delete(serviceRequests).where(eq(serviceRequests.id, srId));
        success = 'Service Request deleted successfully!';
      }
    }
  } catch (e: any) {
    error = e.message || 'Failed to perform request action.';
  }
}

// Fetch all service requests with customer details
let allRequests: any[] = [];
try {
  allRequests = await db.query.serviceRequests.findMany({
    orderBy: [desc(serviceRequests.createdAt)],
    with: {
      user: true,
    },
  });
} catch (e) {
  console.error('[Admin SRs] Failed to fetch service requests:', e);
}

// Stats for counts
const counts = {
  all: allRequests.length,
  pending: allRequests.filter(r => r.status === 'pending').length,
  in_progress: allRequests.filter(r => r.status === 'in_progress').length,
  resolved: allRequests.filter(r => r.status === 'resolved').length,
  cancelled: allRequests.filter(r => r.status === 'cancelled').length,
};
---

<AdminLayout title="Service Requests" activeTab="service-requests" subtitle="Track, process and provide updates on customer product complaints">


    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    <!-- Navigation Tabs / Filters -->
    <nav class="flex border-b border-neutral-200 gap-2 mb-6 overflow-x-auto text-xs font-medium pb-2 select-none whitespace-nowrap">
      <button onclick="filterSR('all')" id="tab-all" class="border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none">
        All ({counts.all})
      </button>
      <button onclick="filterSR('pending')" id="tab-pending" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Pending ({counts.pending})
      </button>
      <button onclick="filterSR('in_progress')" id="tab-in_progress" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        In Progress ({counts.in_progress})
      </button>
      <button onclick="filterSR('resolved')" id="tab-resolved" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Resolved ({counts.resolved})
      </button>
      <button onclick="filterSR('cancelled')" id="tab-cancelled" class="text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none">
        Cancelled ({counts.cancelled})
      </button>
    </nav>

    <!-- Service Requests List -->
    <div class="space-y-6" id="srs-container">
      {allRequests.map((sr) => {
        const dateStr = new Date(sr.createdAt).toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });

        return (
          <div data-status={sr.status} class="sr-card bg-white border border-neutral-200 rounded-lg shadow-sm p-5 hover:shadow-md transition-shadow">
            <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-100 pb-3 mb-3">
              <div>
                <span class="text-[10px] text-neutral-400 font-bold uppercase">Customer</span>
                <h3 class="text-sm font-bold text-neutral-800">{sr.user?.name || sr.customerName || 'Guest Customer'}</h3>
                <span class="text-[10px] text-neutral-400">{dateStr}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class={`inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase border ${
                  sr.status === 'pending' ? 'bg-amber-50 text-amber-700 border-amber-200 font-bold' :
                  sr.status === 'in_progress' ? 'bg-blue-50 text-blue-700 border-blue-200' :
                  sr.status === 'resolved' ? 'bg-green-50 text-green-700 border-green-200' :
                  'bg-neutral-50 text-neutral-700 border-neutral-200'
                }`}>
                  {sr.status}
                </span>
              </div>
            </div>

            <div class="space-y-4">
              {/* Customer Contact Details */}
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-neutral-600">
                <span>
                  📞 Phone: <a href={`tel:${sr.user?.phone || sr.customerPhone}`} class="text-primary hover:underline font-medium">{sr.user?.phone || sr.customerPhone}</a>
                </span>
              </div>

              {/* Product Info & Complaint Description */}
              <div class="grid md:grid-cols-2 gap-4">
                <div class="border border-neutral-100 rounded-md p-3 bg-neutral-50/50">
                  <h4 class="text-xs font-bold text-neutral-500 uppercase mb-1">Product</h4>
                  <p class="text-sm font-semibold text-neutral-800">{sr.productName}</p>
                </div>
                <div class="border border-neutral-100 rounded-md p-3 bg-neutral-50/50">
                  <h4 class="text-xs font-bold text-neutral-500 uppercase mb-1">Complaint Details</h4>
                  <p class="text-xs text-neutral-700 whitespace-pre-wrap leading-relaxed">{sr.complaintDetails}</p>
                </div>
              </div>

              {/* Tracking Info Form & Update */}
              <div class="border-t border-neutral-100 pt-4 mt-3">
                <form method="post" class="grid sm:grid-cols-3 gap-3 items-end">
                  <input type="hidden" name="formAction" value="update_tracking" />
                  <input type="hidden" name="srId" value={sr.id} />
                  
                  <div class="sm:col-span-2">
                    <label class="block text-[10px] font-bold text-neutral-400 uppercase mb-1">
                      Tracking Info / Complaint Updates (Customer will see this)
                    </label>
                    <textarea
                      name="trackingInfo"
                      placeholder="e.g. Technician Ramesh assigned. Scheduled for Tuesday 10 AM."
                      rows="2"
                      class="w-full text-xs rounded border border-neutral-300 px-3 py-1.5 focus:border-primary focus:outline-none"
                    >{sr.trackingInfo || ''}</textarea>
                  </div>
                  
                  <div>
                    <button type="submit" class="w-full text-xs font-semibold bg-neutral-800 text-white hover:bg-neutral-900 rounded px-3 py-2 transition-colors">
                      Update Info
                    </button>
                  </div>
                </form>
              </div>

              {/* Actions Footer */}
              <div class="flex items-center justify-between border-t border-neutral-100 pt-3 mt-3">
                <form method="post" class="inline">
                  <input type="hidden" name="formAction" value="delete" />
                  <input type="hidden" name="srId" value={sr.id} />
                  <button 
                    type="button" 
                    onclick="window.confirmDelete(this, 'Delete Request', 'Are you sure you want to delete this service request?')"
                    class="text-xs text-red-600 font-semibold hover:underline bg-none border-none cursor-pointer focus:outline-none"
                  >
                    Delete Request
                  </button>
                </form>

                <form method="post" class="flex items-center gap-2">
                  <input type="hidden" name="formAction" value="update_status" />
                  <input type="hidden" name="srId" value={sr.id} />
                  <span class="text-[11px] text-neutral-400">Change Status:</span>
                  <select
                    name="status"
                    class="rounded border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none"
                    onchange="this.form.submit()"
                  >
                    <option value="pending" selected={sr.status === 'pending'}>Pending</option>
                    <option value="in_progress" selected={sr.status === 'in_progress'}>In Progress</option>
                    <option value="resolved" selected={sr.status === 'resolved'}>Resolved</option>
                    <option value="cancelled" selected={sr.status === 'cancelled'}>Cancelled</option>
                  </select>
                </form>
              </div>
            </div>
          </div>
        );
      })}

      {allRequests.length === 0 && (
        <div class="bg-white border border-neutral-200 rounded-lg p-12 text-center text-neutral-500 shadow-sm">
          No service requests found.
        </div>
      )}
    </div>
</AdminLayout>

<script is:inline>
  function filterSR(status) {
    const tabs = ['all', 'pending', 'in_progress', 'resolved', 'cancelled'];
    tabs.forEach(t => {
      const el = document.getElementById(`tab-${t}`);
      if (el) {
        if (t === status) {
          el.className = "border-b-2 border-primary text-primary px-3 py-2 font-bold focus:outline-none";
        } else {
          el.className = "text-neutral-600 hover:text-primary px-3 py-2 focus:outline-none";
        }
      }
    });

    const cards = document.querySelectorAll('.sr-card');
    cards.forEach(card => {
      const cardStatus = card.getAttribute('data-status');
      if (status === 'all' || cardStatus === status) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>
