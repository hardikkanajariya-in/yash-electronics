---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { services } from '../../db/schema';
import { getSessionUser, generateId } from '../../lib/auth';
import { eq } from 'drizzle-orm';
import { deleteCloudinaryAsset } from '../../lib/cloudinary-server';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));

let message = Astro.url.searchParams.get('message') || '';
let error = Astro.url.searchParams.get('error') || '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('_action')?.toString();

    if (formAction === 'delete') {
      const deleteId = formData.get('id')?.toString();
      if (deleteId) {
        const [existing] = await db.select().from(services).where(eq(services.id, deleteId));
        if (existing?.image) {
          await deleteCloudinaryAsset(existing.image);
        }
        await db.delete(services).where(eq(services.id, deleteId));
        return Astro.redirect('/admin/services?message=' + encodeURIComponent('Service deleted.'));
      }
    } else if (formAction === 'save') {
      const id = formData.get('id')?.toString();
      const title = formData.get('title')?.toString().trim() || '';
      const description = formData.get('description')?.toString().trim() || null;
      const icon = formData.get('icon')?.toString().trim() || null;
      const image = formData.get('image')?.toString().trim() || null;
      const sortOrder = Number(formData.get('sortOrder') || '0');
      const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

      if (!title) {
        error = 'Title is required.';
      } else if (id) {
        const [existing] = await db.select().from(services).where(eq(services.id, id));
        if (existing?.image && existing.image !== image) {
          await deleteCloudinaryAsset(existing.image);
        }
        await db.update(services).set({ title, slug, description, icon, image, sortOrder }).where(eq(services.id, id));
        return Astro.redirect('/admin/services?message=' + encodeURIComponent('Service updated.'));
      } else {
        await db.insert(services).values({ id: generateId(), title, slug, description, icon, image, sortOrder, isActive: true });
        return Astro.redirect('/admin/services?message=' + encodeURIComponent('Service added.'));
      }
    }
  } catch (e: any) {
    error = 'Operation failed: ' + (e.message || 'Unknown error');
  }
}

let allServices: any[] = [];
try { allServices = await db.select().from(services).orderBy(services.sortOrder); } catch (e) { }

const editId = Astro.url.searchParams.get('edit');
const isAdding = Astro.url.searchParams.get('action') === 'add';
const editService = editId ? allServices.find(s => s.id === editId) : null;
const showForm = isAdding || editService;

const iconOptions = [
  { value: 'inverter', label: '🔌 Inverter' },
  { value: 'battery', label: '🔋 Battery' },
  { value: 'sound', label: '🔊 Sound' },
  { value: 'dj', label: '🎵 DJ' },
  { value: 'repair', label: '🔧 Repair' },
  { value: 'amc', label: '📋 AMC' },
  { value: 'installation', label: '⚙️ Installation' },
  { value: 'support', label: '🤝 Support' },
];
---

<AdminLayout title="Services Management" activeTab="services" subtitle={`${allServices.length} services configured`}>

    {message && <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">{message}</div>}
    {error && <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">{error}</div>}

    {showForm && (
      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm mb-6">
        <h2 class="text-base font-bold text-neutral-900 mb-4">{editService ? 'Edit Service' : 'Add Service'}</h2>
        <form id="service-form" method="post" class="grid gap-4 sm:grid-cols-2">
          <input type="hidden" name="_action" value="save" />
          {editService && <input type="hidden" name="id" value={editService.id} />}
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Title *</label>
            <input type="text" name="title" required value={editService?.title || ''} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" placeholder="e.g. Inverter Installation" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Description</label>
            <textarea name="description" rows="3" class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none">{editService?.description || ''}</textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Icon</label>
            <select name="icon" class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none">
              <option value="">None</option>
              {iconOptions.map(opt => (
                <option value={opt.value} selected={editService?.icon === opt.value}>{opt.label}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Sort Order</label>
            <input type="number" name="sortOrder" value={editService?.sortOrder ?? 0} class="w-full rounded border border-neutral-300 px-3 py-1.5 text-sm focus:border-primary focus:outline-none" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-neutral-700 mb-1">Service Image</label>
            <input type="hidden" id="image" name="image" value={editService?.image || ''} />
            
            <div id="image-preview" class="mb-2"></div>
            
            <div class="relative border border-dashed border-neutral-300 rounded p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer group text-center" id="upload-dropzone">
              <input type="file" id="file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
              <div class="space-y-1">
                <p class="text-xs font-semibold text-neutral-600">Choose Image</p>
              </div>
            </div>

            <div id="upload-progress-container" class="hidden mt-2 space-y-1">
              <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
                <span id="upload-status">Uploading...</span>
                <span id="upload-percent">0%</span>
              </div>
              <div class="w-full bg-neutral-200 rounded-full h-1 overflow-hidden">
                <div id="upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
              </div>
            </div>
          </div>
          <div class="sm:col-span-2 flex gap-2">
            <button type="submit" class="btn-primary text-xs">{editService ? 'Update' : 'Add Service'}</button>
            <a href="/admin/services" class="btn-outline text-xs">Cancel</a>
          </div>
        </form>

        <script>
          import { fileManager } from '../../lib/file-manager';
          import { buildCloudinaryUrl } from '../../lib/cloudinary';

          const serviceForm = document.getElementById('service-form') as HTMLFormElement;
          const imageInput = document.getElementById('image') as HTMLInputElement;
          const previewContainer = document.getElementById('image-preview');
          const filePicker = document.getElementById('file-picker') as HTMLInputElement;
          const progressContainer = document.getElementById('upload-progress-container');
          const progressBar = document.getElementById('upload-progress-bar');
          const progressPercent = document.getElementById('upload-percent');
          const progressStatus = document.getElementById('upload-status');

          let selectedFile: File | null = null;
          let removedPublicIds: string[] = [];

          function renderPreview() {
            if (!previewContainer) return;
            previewContainer.innerHTML = '';
            
            let displayUrl = '';
            if (selectedFile) {
              displayUrl = URL.createObjectURL(selectedFile);
            } else {
              const imgVal = imageInput.value.trim();
              if (!imgVal) return;
              displayUrl = buildCloudinaryUrl(imgVal, { width: 200, height: 200 });
            }

            const div = document.createElement('div');
            div.className = 'relative group w-24 h-24 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
            div.innerHTML = `
              <img src="${displayUrl}" class="w-full h-full object-cover" />
              <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
            `;

            div.querySelector('button')?.addEventListener('click', () => {
              if (selectedFile) {
                selectedFile = null;
                filePicker.value = '';
              } else {
                const oldVal = imageInput.value.trim();
                if (oldVal) {
                  removedPublicIds.push(oldVal);
                }
                imageInput.value = '';
              }
              renderPreview();
            });

            previewContainer.appendChild(div);
          }

          filePicker?.addEventListener('change', async () => {
            const files = filePicker.files;
            if (!files || files.length === 0) return;

            let file = files[0];
            if (file.type.startsWith('image/')) {
              const cropped = await (window as any).cropImage(file, { aspectRatio: 1, title: 'Crop Service Image' });
              if (cropped === null) {
                filePicker.value = '';
                return;
              }
              file = cropped;
            }

            selectedFile = file;
            renderPreview();
          });

          serviceForm?.addEventListener('submit', async (e) => {
            if (!selectedFile && removedPublicIds.length === 0) {
              return; // Normal submit
            }

            e.preventDefault();

            if (progressContainer) {
              progressContainer.classList.remove('hidden');
              if (progressStatus) progressStatus.textContent = 'Saving service...';
              if (progressBar) progressBar.style.width = '20%';
              if (progressPercent) progressPercent.textContent = '20%';
            }

            try {
              // 1. Upload new image if selected
              if (selectedFile) {
                if (progressStatus) progressStatus.textContent = 'Uploading image...';
                if (progressBar) progressBar.style.width = '50%';
                if (progressPercent) progressPercent.textContent = '50%';
                
                const uploadedId = await fileManager.upload(selectedFile, 'yash-electronics/services');
                imageInput.value = uploadedId;
              }

              // 2. Delete removed images
              if (removedPublicIds.length > 0) {
                if (progressStatus) progressStatus.textContent = 'Removing old image...';
                if (progressBar) progressBar.style.width = '80%';
                if (progressPercent) progressPercent.textContent = '80%';
                
                await Promise.all(removedPublicIds.map(id => fileManager.remove(id)));
                removedPublicIds = [];
              }

              if (progressBar) progressBar.style.width = '100%';
              if (progressPercent) progressPercent.textContent = '100%';

              // Submit form
              serviceForm.submit();
            } catch (err: any) {
              alert('Error saving service image: ' + err.message);
              if (progressContainer) progressContainer.classList.add('hidden');
            }
          });

          renderPreview();
        </script>
      </div>
    )}

    {!showForm && (
      <div class="flex justify-end mb-4 w-full">
        <a href="/admin/services?action=add" class="w-full sm:w-auto text-center btn-primary text-xs">+ Add Service</a>
      </div>
    )}

    {/* Desktop Table View */}
    <div class="hidden md:block bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-neutral-50 border-b border-neutral-200">
          <tr>
            <th class="text-left px-4 py-3 text-xs font-semibold text-neutral-500 uppercase">Title</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-neutral-500 uppercase hidden sm:table-cell">Icon</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-neutral-500 uppercase hidden md:table-cell">Status</th>
            <th class="text-right px-4 py-3 text-xs font-semibold text-neutral-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
          {allServices.map(service => (
            <tr class="hover:bg-neutral-50 transition-colors">
              <td class="px-4 py-3">
                <p class="font-medium text-neutral-900">{service.title}</p>
                {service.description && <p class="text-xs text-neutral-500 mt-0.5 truncate max-w-xs">{service.description}</p>}
              </td>
              <td class="px-4 py-3 hidden sm:table-cell">{service.icon || '—'}</td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-semibold border ${service.isActive ? 'bg-green-50 text-green-700 border-green-200' : 'bg-neutral-50 text-neutral-600 border-neutral-200'}`}>{service.isActive ? 'Active' : 'Inactive'}</span>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href={`/admin/services?edit=${service.id}`} class="text-xs font-semibold text-primary hover:underline">Edit</a>
                  <form method="post" class="inline">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="id" value={service.id} />
                    <button type="button" onclick="confirmDelete(this, 'Delete Service', 'Are you sure?')" class="text-xs font-semibold text-red-500 hover:underline cursor-pointer">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
          {allServices.length === 0 && <tr><td colspan="4" class="px-4 py-8 text-center text-neutral-500">No services yet.</td></tr>}
        </tbody>
      </table>
    </div>

    {/* Mobile Card List View */}
    <div class="md:hidden space-y-4">
      {allServices.map(service => {
        const matchingIcon = iconOptions.find(opt => opt.value === service.icon);
        const displayIcon = matchingIcon ? matchingIcon.label : '💼';
        return (
          <div class="bg-white border border-neutral-200 rounded-lg p-4 shadow-sm relative pr-20">
            <div class="flex items-center gap-2">
              <span class="text-xl shrink-0">{displayIcon}</span>
              <div class="min-w-0 flex-1">
                <h3 class="font-bold text-sm text-neutral-900 truncate">{service.title}</h3>
                <span class={`inline-block rounded mt-1 px-1.5 py-0.5 text-[9px] font-bold border ${service.isActive ? 'bg-green-50 text-green-700 border-green-200' : 'bg-neutral-50 text-neutral-600 border-neutral-200'}`}>
                  {service.isActive ? 'Active' : 'Inactive'}
                </span>
              </div>
            </div>
            
            {service.description && (
              <p class="text-xs text-neutral-500 mt-2 leading-relaxed whitespace-pre-wrap">{service.description}</p>
            )}

            {/* Corner Actions */}
            <div class="absolute top-4 right-4 flex items-center gap-2">
              <a 
                href={`/admin/services?edit=${service.id}`} 
                class="w-8 h-8 rounded-full border border-neutral-200 hover:border-primary/30 hover:bg-primary/5 flex items-center justify-center text-xs text-neutral-600 hover:text-primary transition-colors cursor-pointer"
                title="Edit"
              >
                ✏️
              </a>
              <form method="post" class="inline m-0">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={service.id} />
                <button 
                  type="button" 
                  onclick="confirmDelete(this, 'Delete Service', 'Are you sure?')"
                  class="w-8 h-8 rounded-full border border-red-100 bg-red-50 hover:bg-red-100 flex items-center justify-center text-xs text-red-600 transition-colors cursor-pointer"
                  title="Delete"
                >
                  🗑️
                </button>
              </form>
            </div>
          </div>
        );
      })}
      {allServices.length === 0 && (
        <div class="bg-white border border-neutral-200 rounded-lg p-8 text-center text-neutral-500 text-sm">
          No services yet.
        </div>
      )}
    </div>
</AdminLayout>
