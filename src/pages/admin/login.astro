---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { db } from '../../db';
import { users } from '../../db/schema';
import { eq, and } from 'drizzle-orm';
import { hashPassword, setSessionUser, getSessionUser } from '../../lib/auth';

export const prerender = false;

// If already logged in as admin, redirect
const currentUser = await getSessionUser(Astro.cookies);
if (currentUser && currentUser.role === 'admin') {
  Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
  return Astro.redirect('/admin');
}

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const phone = formData.get('phone')?.toString() || '';
    const password = formData.get('password')?.toString() || '';

    const hashedPassword = hashPassword(password);
    
    const [user] = await db
      .select()
      .from(users)
      .where(
        and(
          eq(users.phone, phone),
          eq(users.password, hashedPassword),
          eq(users.role, 'admin')
        )
      );

    if (user) {
      Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
      setSessionUser(Astro.cookies, user.id, Astro.url);
      return new Response(null, {
        status: 303,
        headers: {
          Location: '/admin',
          'Cache-Control': 'no-cache, no-store, must-revalidate',
        },
      });
    } else {
      error = 'Invalid credentials or access denied.';
    }
  } catch (e) {
    error = 'An error occurred. Please try again.';
  }
}
---

<BaseLayout title="Admin Login" noindex={true}>
  <Container class="py-16 max-w-md">
    <div class="bg-white border border-neutral-200 rounded-lg p-6 shadow-md">
      <div class="text-center mb-6">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-md bg-primary text-xl font-bold text-white mb-2">
          YE
        </div>
        <h1 class="text-xl font-bold text-neutral-900">Admin Control Panel</h1>
        <p class="text-xs text-neutral-500 mt-1">Yash Electronics</p>
      </div>

      {error && (
        <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
          {error}
        </div>
      )}

      <form method="post" class="space-y-4">
        <div>
          <label for="phone" class="block text-sm font-semibold text-neutral-700 mb-1">Phone Number</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            placeholder="e.g. 9999999999"
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold text-neutral-700 mb-1">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            placeholder="••••••••"
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>

        <button type="submit" class="w-full btn-primary py-2 text-sm font-medium">
          Sign In
        </button>
      </form>
    </div>
  </Container>
</BaseLayout>
