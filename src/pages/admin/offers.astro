---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { offers } from '../../db/schema';
import { eq, and, or, ilike, sql, asc, desc } from 'drizzle-orm';
import { getSessionUser, generateId } from '../../lib/auth';
import { clearCmsCache } from '../../services/cms';
import { buildCloudinaryUrl } from '../../lib/cloudinary';
import { deleteCloudinaryAsset } from '../../lib/cloudinary-server';

export const prerender = false;

// Authenticate
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser || currentUser.role !== 'admin') {
  return Astro.redirect('/account/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

const action = Astro.url.searchParams.get('action') || 'list';
const offerId = Astro.url.searchParams.get('id') || '';

let error = Astro.url.searchParams.get('error') || '';
let success = Astro.url.searchParams.get('success') || '';
let redirectUrl = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const formAction = formData.get('formAction')?.toString() || '';

    if (formAction === 'delete') {
      const idToDelete = formData.get('id')?.toString() || '';
      const [existing] = await db.select().from(offers).where(eq(offers.id, idToDelete));
      if (existing?.image) {
        await deleteCloudinaryAsset(existing.image);
      }
      if (existing?.detailImage) {
        await deleteCloudinaryAsset(existing.detailImage);
      }
      await db.delete(offers).where(eq(offers.id, idToDelete));
      clearCmsCache();
      redirectUrl = '/admin/offers?success=' + encodeURIComponent('Offer deleted successfully!');
    } else if (formAction === 'save') {
      const title = formData.get('title')?.toString() || '';
      const titleGu = formData.get('titleGu')?.toString().trim() || null;
      const slug = (formData.get('slug')?.toString() || '').trim().toLowerCase();

      const slugRegex = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
      if (!slugRegex.test(slug)) {
        throw new Error('Slug must only contain lowercase alphanumeric characters and hyphens, and cannot start or end with a hyphen.');
      }
      const type = formData.get('type')?.toString() as any || 'combo';
      const description = formData.get('description')?.toString() || '';
      const descriptionGu = formData.get('descriptionGu')?.toString().trim() || null;
      const image = formData.get('image')?.toString() || '';
      const detailImage = formData.get('detailImage')?.toString() || '';
      const detailDescription = formData.get('detailDescription')?.toString() || '';
      const detailDescriptionGu = formData.get('detailDescriptionGu')?.toString().trim() || null;
      const discountText = formData.get('discountText')?.toString() || '';
      const discountTextGu = formData.get('discountTextGu')?.toString().trim() || null;
      const validUntil = formData.get('validUntil')?.toString() || '';
      const isActive = formData.get('isActive') === 'on';
      const sortOrder = Number(formData.get('sortOrder') || 0);
      const couponCode = formData.get('couponCode')?.toString().trim().toUpperCase() || null;
      const discountType = formData.get('discountType')?.toString() || 'flat';
      const discountValue = parseInt(formData.get('discountValue')?.toString() || '0', 10);
      const minOrderValue = parseInt(formData.get('minOrderValue')?.toString() || '0', 10);
      const discountCap = formData.get('discountCap')?.toString().trim() ? parseInt(formData.get('discountCap')?.toString() || '0', 10) : null;

      // Check if an offer with the same slug already exists
      const existingOffer = await db.select({ id: offers.id }).from(offers).where(eq(offers.slug, slug));
      if (existingOffer.length > 0 && (!offerId || existingOffer[0].id !== offerId)) {
        throw new Error(`An offer with the slug "${slug}" already exists. Please choose a different, unique slug.`);
      }

      if (offerId) {
        // Edit existing
        const [existing] = await db.select().from(offers).where(eq(offers.id, offerId));
        if (existing?.image && existing.image !== image) {
          await deleteCloudinaryAsset(existing.image);
        }
        if (existing?.detailImage && existing.detailImage !== detailImage) {
          await deleteCloudinaryAsset(existing.detailImage);
        }
        await db.update(offers).set({
          title,
          titleGu,
          slug,
          type,
          description,
          descriptionGu,
          image,
          detailImage,
          detailDescription,
          detailDescriptionGu,
          discountText,
          discountTextGu,
          validUntil,
          isActive,
          sortOrder,
          couponCode,
          discountType: discountType as any,
          discountValue: isNaN(discountValue) ? 0 : discountValue,
          minOrderValue: isNaN(minOrderValue) ? 0 : minOrderValue,
          discountCap: isNaN(discountCap as any) || discountCap === null ? null : discountCap,
        }).where(eq(offers.id, offerId));
        clearCmsCache();
        redirectUrl = '/admin/offers?success=' + encodeURIComponent('Offer updated successfully!');
      } else {
        // Create new
        const newId = generateId();
        await db.insert(offers).values({
          id: newId,
          title,
          titleGu,
          slug,
          type,
          description,
          descriptionGu,
          image,
          detailImage,
          detailDescription,
          detailDescriptionGu,
          discountText,
          discountTextGu,
          validUntil,
          isActive,
          sortOrder,
          couponCode,
          discountType: discountType as any,
          discountValue: isNaN(discountValue) ? 0 : discountValue,
          minOrderValue: isNaN(minOrderValue) ? 0 : minOrderValue,
          discountCap: isNaN(discountCap as any) || discountCap === null ? null : discountCap,
        });
        clearCmsCache();
        redirectUrl = '/admin/offers?success=' + encodeURIComponent('Offer added successfully!');
      }
    }
  } catch (e: any) {
    const errMsg = e.message || '';
    if (errMsg.includes('unique constraint') || errMsg.includes('offers_slug_unique') || errMsg.includes('duplicate key')) {
      error = 'An offer with this slug already exists. Please choose a different, unique slug.';
    } else {
      error = errMsg || 'Failed to save offer.';
    }
  }
}

if (redirectUrl) {
  return Astro.redirect(redirectUrl);
}

// Fetch single offer if editing
let editOffer: any = null;
if (action === 'edit' && offerId) {
  const [found] = await db.select().from(offers).where(eq(offers.id, offerId));
  editOffer = found;
}

const search = Astro.url.searchParams.get('search')?.trim() || '';
const statusFilter = Astro.url.searchParams.get('status') || 'all'; // all, active, inactive
const sort = Astro.url.searchParams.get('sort') || 'sort-asc';
const page = Number(Astro.url.searchParams.get('page') || '1');
const limit = 10;
const offset = (page - 1) * limit;

const conditions = [];

if (statusFilter === 'active') {
  conditions.push(eq(offers.isActive, true));
} else if (statusFilter === 'inactive') {
  conditions.push(eq(offers.isActive, false));
}

if (search) {
  conditions.push(
    or(
      ilike(offers.title, `%${search}%`),
      ilike(offers.titleGu, `%${search}%`),
      ilike(offers.slug, `%${search}%`),
      ilike(offers.couponCode, `%${search}%`),
      ilike(offers.description, `%${search}%`),
      ilike(offers.descriptionGu, `%${search}%`)
    )
  );
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

let orderByClause = [asc(offers.sortOrder)];
if (sort === 'sort-desc') {
  orderByClause = [desc(offers.sortOrder)];
} else if (sort === 'name-asc') {
  orderByClause = [asc(offers.title)];
} else if (sort === 'name-desc') {
  orderByClause = [desc(offers.title)];
}

let allOffers: any[] = [];
let totalCount = 0;

try {
  allOffers = await db.select().from(offers)
    .where(whereClause)
    .orderBy(...orderByClause)
    .limit(limit)
    .offset(offset);

  const [countRes] = await db
    .select({ count: sql`count(*)` })
    .from(offers)
    .where(whereClause);
  totalCount = Number(countRes?.count || 0);
} catch (e) {
  console.error('[Admin Offers] Failed to fetch offers:', e);
}

const totalPages = Math.ceil(totalCount / limit);

function getOfferImageUrl(img: string) {
  return buildCloudinaryUrl(img, { width: 100, height: 100 });
}
---

<AdminLayout title="Manage Offers" activeTab="offers" subtitle="Create or edit special deals & promotions">
    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-4">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-md p-3 mb-4">
        {success}
      </div>
    )}

    <!-- LIST VIEW -->
    {action === 'list' && (
      <div class="space-y-4">
        {/* Search, Sort, Filter Controls */}
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 bg-white border border-neutral-200 rounded-lg p-4 shadow-sm">
          <form method="get" class="flex flex-col sm:flex-row flex-wrap gap-3 items-stretch sm:items-center w-full md:w-auto">
            <div class="relative w-full sm:w-64">
              <input
                type="text"
                name="search"
                value={search}
                placeholder="Search offers..."
                class="w-full rounded border border-neutral-300 pl-8 pr-3 py-1.5 text-xs focus:border-primary focus:outline-none"
              />
              <span class="absolute left-2.5 top-2.5 text-neutral-400 text-xs">🔍</span>
            </div>
            
            <select name="status" class="w-full sm:w-auto rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer">
              <option value="all" selected={statusFilter === 'all'}>All Status</option>
              <option value="active" selected={statusFilter === 'active'}>Active Only</option>
              <option value="inactive" selected={statusFilter === 'inactive'}>Inactive Only</option>
            </select>

            <select name="sort" class="w-full sm:w-auto rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none cursor-pointer">
              <option value="sort-asc" selected={sort === 'sort-asc'}>Sort Order (Asc)</option>
              <option value="sort-desc" selected={sort === 'sort-desc'}>Sort Order (Desc)</option>
              <option value="name-asc" selected={sort === 'name-asc'}>Title (A-Z)</option>
              <option value="name-desc" selected={sort === 'name-desc'}>Title (Z-A)</option>
            </select>

            <div class="flex items-center gap-2 w-full sm:w-auto">
              <button type="submit" class="flex-1 sm:flex-initial bg-neutral-800 text-white rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-900 transition-colors cursor-pointer text-center">
                Filter
              </button>

              {(search || statusFilter !== 'all' || sort !== 'sort-asc') && (
                <a href="/admin/offers" class="flex-1 sm:flex-initial bg-neutral-100 text-neutral-700 rounded px-4 py-1.5 text-xs font-semibold hover:bg-neutral-200 transition-colors text-center justify-center flex items-center">
                  Clear
                </a>
              )}
            </div>
          </form>
          <a href="/admin/offers?action=add" class="w-full md:w-auto text-center text-xs font-semibold text-white bg-primary hover:bg-primary/95 rounded-md px-3.5 py-2 transition-colors">
            + Create Offer
          </a>
        </div>

        {/* Desktop Table View */}
        <div class="hidden md:block bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm text-neutral-700 border-collapse">
              <thead>
                <tr class="bg-neutral-50 border-b border-neutral-200 font-semibold text-neutral-900">
                  <th class="p-3 w-16">Image</th>
                  <th class="p-3">Offer Title</th>
                  <th class="p-3">Type</th>
                  <th class="p-3">Coupon Code</th>
                  <th class="p-3">Discount Text</th>
                  <th class="p-3">Valid Until</th>
                  <th class="p-3">Status</th>
                  <th class="p-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody>
                {allOffers.map((off) => {
                  const editUrl = "/admin/offers?action=edit&id=" + off.id;

                  return (
                    <tr class="border-b border-neutral-100 hover:bg-neutral-50/50">
                      <td class="p-3">
                        <img src={getOfferImageUrl(off.image)} class="w-10 h-10 object-cover rounded border border-neutral-200 shadow-sm bg-neutral-50" alt={off.title} />
                      </td>
                      <td class="p-3">
                        <div class="font-medium text-neutral-900">{off.title}</div>
                        {off.titleGu && <div class="text-[11px] text-neutral-400">{off.titleGu}</div>}
                      </td>
                      <td class="p-3 text-xs capitalize text-neutral-500">{off.type}</td>
                      <td class="p-3 text-xs text-neutral-800">
                        {off.couponCode ? (
                          <div>
                            <span class="font-mono font-bold">{off.couponCode}</span>
                            <span class="text-neutral-500"> ({off.discountType === 'percentage' ? `${off.discountValue}%` : `₹${off.discountValue}`})</span>
                            {off.minOrderValue! > 0 && <div class="text-[10px] text-neutral-500 font-sans mt-0.5">Min Order: ₹{off.minOrderValue}</div>}
                            {off.discountType === 'percentage' && off.discountCap && <div class="text-[10px] text-neutral-500 font-sans mt-0.5">Max Discount: ₹{off.discountCap}</div>}
                          </div>
                        ) : '-'}
                      </td>
                      <td class="p-3">
                        <div class="font-semibold text-accent">{off.discountText || '-'}</div>
                        {off.discountTextGu && <div class="text-[11px] text-neutral-400">{off.discountTextGu}</div>}
                      </td>
                      <td class="p-3 text-xs text-neutral-500">{off.validUntil || '-'}</td>
                      <td class="p-3">
                        <span class={`inline-block w-2.5 h-2.5 rounded-full ${off.isActive ? 'bg-green-500' : 'bg-red-500'}`} title={off.isActive ? 'Active' : 'Inactive'}></span>
                      </td>
                      <td class="p-3 text-right flex justify-end gap-2 items-center">
                        <a href={editUrl} class="text-xs font-semibold text-primary hover:underline">
                          Edit
                        </a>
                        <form method="post" class="inline m-0">
                          <input type="hidden" name="formAction" value="delete" />
                          <input type="hidden" name="id" value={off.id} />
                          <button 
                            type="button" 
                            onclick="window.confirmDelete(this, 'Delete Offer', 'Are you sure you want to delete this offer?')"
                            class="text-xs font-semibold text-red-600 hover:underline bg-none border-none cursor-pointer focus:outline-none"
                          >
                            Delete
                          </button>
                        </form>
                      </td>
                    </tr>
                  );
                })}
                {allOffers.length === 0 && (
                  <tr>
                    <td colspan="8" class="p-8 text-center text-neutral-500">No offers found.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

        {/* Mobile Flat List View */}
        <div class="md:hidden bg-white border border-neutral-200 rounded-lg shadow-sm divide-y divide-neutral-100">
          {allOffers.map((off) => {
            return (
              <div class="p-4 flex gap-3 items-center relative pr-20 min-h-[5.5rem]">
                <!-- Thumbnail -->
                <img 
                  src={getOfferImageUrl(off.image)} 
                  class="w-16 h-16 object-cover rounded border border-neutral-200 shadow-sm bg-neutral-50 shrink-0" 
                  alt={off.title} 
                />
                
                <div class="flex-1 min-w-0">
                  <div class="font-bold text-sm text-neutral-900 truncate pr-2">{off.title}</div>
                  {off.titleGu && <div class="text-[10px] text-neutral-400 truncate pr-2">{off.titleGu}</div>}
                  
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-xs font-semibold text-accent">{off.discountText || '-'}</span>
                    {off.discountTextGu && (
                      <span class="text-[10px] text-neutral-400">({off.discountTextGu})</span>
                    )}
                  </div>

                  <div class="text-[10px] text-neutral-500 mt-1 flex flex-wrap gap-x-2 gap-y-0.5 items-center">
                    <span class="capitalize bg-neutral-100 px-1.5 py-0.5 rounded">{off.type}</span>
                    <span>•</span>
                    <span>Valid: {off.validUntil || 'N/A'}</span>
                    <span>•</span>
                    <span class={`inline-block w-2 h-2 rounded-full ${off.isActive ? 'bg-green-500' : 'bg-red-500'}`} title={off.isActive ? 'Active' : 'Inactive'}></span>
                  </div>

                  {off.couponCode && (
                    <div class="bg-neutral-50 rounded p-1.5 text-[9px] text-neutral-700 font-mono flex items-center justify-between border border-neutral-100 mt-1">
                      <div>
                        Code: <span class="font-bold">{off.couponCode}</span>
                        <span class="text-neutral-500 font-sans"> ({off.discountType === 'percentage' ? `${off.discountValue}%` : `₹${off.discountValue}`})</span>
                      </div>
                      {off.minOrderValue! > 0 && <div class="text-neutral-500 font-sans text-[8px]">Min: ₹{off.minOrderValue}</div>}
                    </div>
                  )}
                </div>

                <!-- Corner Actions -->
                <div class="absolute top-4 right-4 flex items-center gap-2">
                  <a 
                    href={"/admin/offers?action=edit&id=" + off.id} 
                    class="w-8 h-8 rounded-full border border-neutral-200 hover:border-primary/30 hover:bg-primary/5 flex items-center justify-center text-xs text-neutral-600 hover:text-primary transition-colors cursor-pointer"
                    title="Edit"
                  >
                    ✏️
                  </a>
                  <form method="post" class="inline m-0">
                    <input type="hidden" name="formAction" value="delete" />
                    <input type="hidden" name="id" value={off.id} />
                    <button 
                      type="button" 
                      onclick="window.confirmDelete(this, 'Delete Offer', 'Are you sure you want to delete this offer?')"
                      class="w-8 h-8 rounded-full border border-red-100 bg-red-50 hover:bg-red-100 flex items-center justify-center text-xs text-red-600 transition-colors cursor-pointer"
                      title="Delete"
                    >
                      🗑️
                    </button>
                  </form>
                </div>
              </div>
            );
          })}
          {allOffers.length === 0 && (
            <div class="p-8 text-center text-neutral-500 text-sm">No offers found.</div>
          )}
        </div>

        {/* Pagination Controls */}
        {totalPages > 1 && (
          <div class="flex items-center justify-between border-t border-neutral-200 bg-white px-4 py-3 sm:px-6 rounded-lg shadow-sm">
            <div class="flex flex-1 justify-between sm:hidden">
              <a
                href={page > 1 ? `?page=${page - 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
                class={`relative inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
              >
                Previous
              </a>
              <a
                href={page < totalPages ? `?page=${page + 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
                class={`relative ml-3 inline-flex items-center rounded-md border border-neutral-300 bg-white px-4 py-2 text-xs font-medium text-neutral-700 hover:bg-neutral-50 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
              >
                Next
              </a>
            </div>
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
              <div>
                <p class="text-xs text-neutral-700">
                  Showing
                  <span class="font-semibold">{Math.min(offset + 1, totalCount)}</span>
                  to
                  <span class="font-semibold">{Math.min(offset + limit, totalCount)}</span>
                  of
                  <span class="font-semibold">{totalCount}</span>
                  results
                </p>
              </div>
              <div>
                <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                  <a
                    href={page > 1 ? `?page=${page - 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
                    class={`relative inline-flex items-center rounded-l-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page <= 1 ? 'pointer-events-none opacity-50' : ''}`}
                  >
                    <span class="sr-only">Previous</span>
                    <span>◀</span>
                  </a>
                  {Array.from({ length: totalPages }).map((_, idx) => {
                    const pNum = idx + 1;
                    const isCurrent = pNum === page;
                    return (
                      <a
                        href={`?page=${pNum}&search=${search}&status=${statusFilter}&sort=${sort}`}
                        aria-current={isCurrent ? "page" : undefined}
                        class={`relative inline-flex items-center px-3 py-2 text-xs font-semibold ${isCurrent ? 'z-10 bg-primary text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary' : 'text-neutral-900 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0'}`}
                      >
                        {pNum}
                      </a>
                    );
                  })}
                  <a
                    href={page < totalPages ? `?page=${page + 1}&search=${search}&status=${statusFilter}&sort=${sort}` : '#'}
                    class={`relative inline-flex items-center rounded-r-md px-2 py-2 text-neutral-400 ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50 focus:z-20 focus:outline-offset-0 ${page >= totalPages ? 'pointer-events-none opacity-50' : ''}`}
                  >
                    <span class="sr-only">Next</span>
                    <span>▶</span>
                  </a>
                </nav>
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- FORM VIEW -->
    {(action === 'add' || action === 'edit') && (
      <div class="bg-white border border-neutral-200 rounded-lg p-6 shadow-sm max-w-2xl mx-auto">
        <h2 class="text-lg font-bold text-neutral-900 mb-6">{action === 'edit' ? 'Edit Offer' : 'Create Offer'}</h2>
        
        <form id="offer-form" method="post" class="space-y-4">
          <input type="hidden" name="formAction" value="save" />

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="title" class="block text-sm font-semibold text-neutral-700 mb-1">Offer Title (English) *</label>
              <input
                type="text"
                id="title"
                name="title"
                required
                value={editOffer?.title || ''}
                placeholder="e.g. TV + Soundbar Combo"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
            <div>
              <label for="titleGu" class="block text-sm font-semibold text-neutral-700 mb-1">Offer Title (Gujarati)</label>
              <input
                type="text"
                id="titleGu"
                name="titleGu"
                value={editOffer?.titleGu || ''}
                placeholder="દા.ત. ટીવી + સાઉન્ડબાર કોમ્બો"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="slug" class="block text-sm font-semibold text-neutral-700 mb-1">Slug *</label>
              <input
                type="text"
                id="slug"
                name="slug"
                required
                pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$"
                title="Slug must only contain lowercase letters, numbers, and hyphens, and cannot start or end with a hyphen."
                value={editOffer?.slug || ''}
                placeholder="e.g. tv-soundbar-combo"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
            <div>
              <label for="type" class="block text-sm font-semibold text-neutral-700 mb-1">Offer Type *</label>
              <select
                id="type"
                name="type"
                required
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >
                <option value="combo" selected={editOffer?.type === 'combo'}>Combo Offer</option>
                <option value="bundle" selected={editOffer?.type === 'bundle'}>Build Your Bundle</option>
                <option value="weekly" selected={editOffer?.type === 'weekly'}>Offer Of The Week</option>
                <option value="festival" selected={editOffer?.type === 'festival'}>Festival Offer</option>
              </select>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="discountText" class="block text-sm font-semibold text-neutral-700 mb-1">Discount Text (English)</label>
              <input
                type="text"
                id="discountText"
                name="discountText"
                value={editOffer?.discountText || ''}
                placeholder="e.g. Save up to ₹8,000"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
            <div>
              <label for="discountTextGu" class="block text-sm font-semibold text-neutral-700 mb-1">Discount Text (Gujarati)</label>
              <input
                type="text"
                id="discountTextGu"
                name="discountTextGu"
                value={editOffer?.discountTextGu || ''}
                placeholder="દા.ત. ₹૮,૦૦૦ સુધીની બચત"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="validUntil" class="block text-sm font-semibold text-neutral-700 mb-1">Valid Until (Expiry Date)</label>
              <input
                type="text"
                id="validUntil"
                name="validUntil"
                value={editOffer?.validUntil || ''}
                placeholder="e.g. 2026-06-30"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
            <div>
              <label for="sortOrder" class="block text-sm font-semibold text-neutral-700 mb-1">Sort Order</label>
              <input
                type="number"
                id="sortOrder"
                name="sortOrder"
                value={editOffer?.sortOrder || 0}
                placeholder="0"
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-sm font-semibold text-neutral-700 mb-1">Cover Image *</label>
              <input type="hidden" id="image" name="image" value={editOffer?.image || ''} />
              
              <div id="image-preview" class="mb-2"></div>
              
              <div class="relative border border-dashed border-neutral-300 rounded p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer group text-center" id="upload-dropzone">
                <input type="file" id="file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
                <div class="space-y-1">
                  <p class="text-xs font-semibold text-neutral-600">Choose Cover Image</p>
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-neutral-700 mb-1">Detail Image (shows in pop-up)</label>
              <input type="hidden" id="detailImage" name="detailImage" value={editOffer?.detailImage || ''} />
              
              <div id="detail-image-preview" class="mb-2"></div>
              
              <div class="relative border border-dashed border-neutral-300 rounded p-4 hover:border-primary hover:bg-neutral-50/50 transition-colors cursor-pointer group text-center" id="detail-upload-dropzone">
                <input type="file" id="detail-file-picker" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" />
                <div class="space-y-1">
                  <p class="text-xs font-semibold text-neutral-600">Choose Detail Image</p>
                </div>
              </div>
            </div>
          </div>

          <div id="upload-progress-container" class="hidden mt-2 space-y-1">
            <div class="flex justify-between text-[10px] font-semibold text-neutral-500">
              <span id="upload-status">Uploading...</span>
              <span id="upload-percent">0%</span>
            </div>
            <div class="w-full bg-neutral-200 rounded-full h-1 overflow-hidden">
              <div id="upload-progress-bar" class="bg-primary h-full w-0 transition-all duration-150"></div>
            </div>
          </div>

          <!-- Coupon Configuration -->
          <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 space-y-4">
            <h3 class="text-xs font-bold uppercase text-neutral-500 tracking-wider">Coupon Configuration (Optional)</h3>
            <div class="grid gap-4 sm:grid-cols-3">
              <div>
                <label for="couponCode" class="block text-xs font-semibold text-neutral-700 mb-1">Coupon Code</label>
                <input
                  type="text"
                  id="couponCode"
                  name="couponCode"
                  value={editOffer?.couponCode || ''}
                  placeholder="e.g. SAVE20"
                  class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none uppercase"
                />
              </div>
              <div>
                <label for="discountType" class="block text-xs font-semibold text-neutral-700 mb-1">Discount Type</label>
                <select
                  id="discountType"
                  name="discountType"
                  class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none"
                >
                  <option value="flat" selected={editOffer?.discountType === 'flat'}>Flat Discount (₹)</option>
                  <option value="percentage" selected={editOffer?.discountType === 'percentage'}>Percentage Discount (%)</option>
                </select>
              </div>
              <div>
                <label for="discountValue" class="block text-xs font-semibold text-neutral-700 mb-1">Discount Value</label>
                <input
                  type="number"
                  id="discountValue"
                  name="discountValue"
                  min="0"
                  value={editOffer?.discountValue || 0}
                  placeholder="e.g. 200 or 15"
                  class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none"
                />
              </div>
            </div>
            
            <div class="grid gap-4 sm:grid-cols-2 pt-2 border-t border-neutral-200/60">
              <div>
                <label for="minOrderValue" class="block text-xs font-semibold text-neutral-700 mb-1">Minimum Order Value (₹)</label>
                <input
                  type="number"
                  id="minOrderValue"
                  name="minOrderValue"
                  min="0"
                  value={editOffer?.minOrderValue || 0}
                  placeholder="e.g. 1000"
                  class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none"
                />
              </div>
              <div>
                <label for="discountCap" class="block text-xs font-semibold text-neutral-700 mb-1">Discount Cap (Upto ₹, for % type)</label>
                <input
                  type="number"
                  id="discountCap"
                  name="discountCap"
                  min="0"
                  value={editOffer?.discountCap || ''}
                  placeholder="e.g. 500"
                  class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none"
                />
              </div>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="description" class="block text-sm font-semibold text-neutral-700 mb-1">Brief Description (English)</label>
              <textarea
                id="description"
                name="description"
                rows="2"
                placeholder="Enter brief offer details..."
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >{editOffer?.description || ''}</textarea>
            </div>
            <div>
              <label for="descriptionGu" class="block text-sm font-semibold text-neutral-700 mb-1">Brief Description (Gujarati)</label>
              <textarea
                id="descriptionGu"
                name="descriptionGu"
                rows="2"
                placeholder="ઓફરની ગુજરાતીમાં ટૂંકી વિગતો..."
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >{editOffer?.descriptionGu || ''}</textarea>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="detailDescription" class="block text-sm font-semibold text-neutral-700 mb-1">Detailed Description (English - shows in pop-up)</label>
              <textarea
                id="detailDescription"
                name="detailDescription"
                rows="3"
                placeholder="Enter detailed description for popup..."
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >{editOffer?.detailDescription || ''}</textarea>
            </div>
            <div>
              <label for="detailDescriptionGu" class="block text-sm font-semibold text-neutral-700 mb-1">Detailed Description (Gujarati - shows in pop-up)</label>
              <textarea
                id="detailDescriptionGu"
                name="detailDescriptionGu"
                rows="3"
                placeholder="ઓફરની ગુજરાતીમાં વિગતવાર વિગતો..."
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none"
              >{editOffer?.detailDescriptionGu || ''}</textarea>
            </div>
          </div>

          <div class="py-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="isActive" checked={editOffer ? editOffer.isActive : true} class="rounded border-neutral-300 text-primary focus:ring-primary" />
              <span class="text-sm font-semibold text-neutral-700">Offer Active</span>
            </label>
          </div>

          <div class="flex justify-end gap-3 pt-4 border-t border-neutral-200">
            <a href="/admin/offers" class="btn-outline px-4 py-2 text-sm">
              Cancel
            </a>
            <button type="submit" class="btn-primary px-6 py-2 text-sm font-medium">
              Save Offer
            </button>
          </div>
        </form>

        <script>
          import { fileManager } from '../../lib/file-manager';
          import { buildCloudinaryUrl } from '../../lib/cloudinary';

          const slugInput = document.getElementById('slug') as HTMLInputElement;
          if (slugInput) {
            slugInput.addEventListener('input', () => {
              let val = slugInput.value;
              val = val.replace(/[\s_]+/g, '-');
              val = val.toLowerCase().replace(/[^a-z0-9-]/g, '');
              val = val.replace(/-+/g, '-');
              slugInput.value = val;
            });
          }

          const offerForm = document.getElementById('offer-form') as HTMLFormElement;
          const imageInput = document.getElementById('image') as HTMLInputElement;
          const previewContainer = document.getElementById('image-preview');
          const filePicker = document.getElementById('file-picker') as HTMLInputElement;

          const detailImageInput = document.getElementById('detailImage') as HTMLInputElement;
          const detailPreviewContainer = document.getElementById('detail-image-preview');
          const detailFilePicker = document.getElementById('detail-file-picker') as HTMLInputElement;

          const progressContainer = document.getElementById('upload-progress-container');
          const progressBar = document.getElementById('upload-progress-bar');
          const progressPercent = document.getElementById('upload-percent');
          const progressStatus = document.getElementById('upload-status');

          let selectedFile: File | null = null;
          let detailSelectedFile: File | null = null;
          let removedPublicIds: string[] = [];

          function renderPreview() {
            if (!previewContainer) return;
            previewContainer.innerHTML = '';
            
            let displayUrl = '';
            if (selectedFile) {
              displayUrl = URL.createObjectURL(selectedFile);
            } else {
              const imgVal = imageInput.value.trim();
              if (!imgVal) return;
              displayUrl = buildCloudinaryUrl(imgVal, { width: 100, height: 100 });
            }

            const div = document.createElement('div');
            div.className = 'relative group w-24 h-24 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
            div.innerHTML = `
              <img src="${displayUrl}" class="w-full h-full object-cover" />
              <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
            `;

            div.querySelector('button')?.addEventListener('click', () => {
              if (selectedFile) {
                selectedFile = null;
                filePicker.value = '';
              } else {
                const oldVal = imageInput.value.trim();
                if (oldVal) {
                  removedPublicIds.push(oldVal);
                }
                imageInput.value = '';
              }
              renderPreview();
            });

            previewContainer.appendChild(div);
          }

          function renderDetailPreview() {
            if (!detailPreviewContainer) return;
            detailPreviewContainer.innerHTML = '';
            
            let displayUrl = '';
            if (detailSelectedFile) {
              displayUrl = URL.createObjectURL(detailSelectedFile);
            } else {
              const imgVal = detailImageInput.value.trim();
              if (!imgVal) return;
              displayUrl = buildCloudinaryUrl(imgVal, { width: 100, height: 100 });
            }

            const div = document.createElement('div');
            div.className = 'relative group w-24 h-24 border border-neutral-200 rounded-md overflow-hidden bg-neutral-50 shadow-sm';
            div.innerHTML = `
              <img src="${displayUrl}" class="w-full h-full object-cover" />
              <button type="button" class="absolute inset-0 bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold font-mono">Remove</button>
            `;

            div.querySelector('button')?.addEventListener('click', () => {
              if (detailSelectedFile) {
                detailSelectedFile = null;
                detailFilePicker.value = '';
              } else {
                const oldVal = detailImageInput.value.trim();
                if (oldVal) {
                  removedPublicIds.push(oldVal);
                }
                detailImageInput.value = '';
              }
              renderDetailPreview();
            });

            detailPreviewContainer.appendChild(div);
          }

          filePicker?.addEventListener('change', async () => {
            const files = filePicker.files;
            if (!files || files.length === 0) return;

            let file = files[0];
            if (file.type.startsWith('image/')) {
              // Free cropping aspect ratio for offers since they can vary
              const cropped = await (window as any).cropImage(file, { aspectRatio: NaN, title: 'Crop Cover Image' });
              if (cropped === null) {
                filePicker.value = '';
                return;
              }
              file = cropped;
            }

            selectedFile = file;
            renderPreview();
          });

          detailFilePicker?.addEventListener('change', async () => {
            const files = detailFilePicker.files;
            if (!files || files.length === 0) return;

            let file = files[0];
            if (file.type.startsWith('image/')) {
              // Free cropping aspect ratio for offers since they can vary
              const cropped = await (window as any).cropImage(file, { aspectRatio: NaN, title: 'Crop Detail Image' });
              if (cropped === null) {
                detailFilePicker.value = '';
                return;
              }
              file = cropped;
            }

            detailSelectedFile = file;
            renderDetailPreview();
          });

          offerForm?.addEventListener('submit', async (e) => {
            if (!selectedFile && !detailSelectedFile && removedPublicIds.length === 0) {
              return; // Normal submit
            }

            e.preventDefault();

            if (progressContainer) {
              progressContainer.classList.remove('hidden');
              if (progressStatus) progressStatus.textContent = 'Saving offer...';
              if (progressBar) progressBar.style.width = '10%';
              if (progressPercent) progressPercent.textContent = '10%';
            }

            try {
              // 1. Upload new cover image if selected
              if (selectedFile) {
                if (progressStatus) progressStatus.textContent = 'Uploading cover image...';
                if (progressBar) progressBar.style.width = '40%';
                if (progressPercent) progressPercent.textContent = '40%';
                
                const uploadedId = await fileManager.upload(selectedFile, 'yash-electronics/offers');
                imageInput.value = uploadedId;
              }

              // 2. Upload new detail image if selected
              if (detailSelectedFile) {
                if (progressStatus) progressStatus.textContent = 'Uploading detail image...';
                if (progressBar) progressBar.style.width = '70%';
                if (progressPercent) progressPercent.textContent = '70%';
                
                const uploadedId = await fileManager.upload(detailSelectedFile, 'yash-electronics/offers');
                detailImageInput.value = uploadedId;
              }

              // 3. Delete removed images
              if (removedPublicIds.length > 0) {
                if (progressStatus) progressStatus.textContent = 'Removing old images...';
                if (progressBar) progressBar.style.width = '90%';
                if (progressPercent) progressPercent.textContent = '90%';
                
                await Promise.all(removedPublicIds.map(id => fileManager.remove(id)));
                removedPublicIds = [];
              }

              if (progressBar) progressBar.style.width = '100%';
              if (progressPercent) progressPercent.textContent = '100%';

              // Submit form
              offerForm.submit();
            } catch (err: any) {
              alert('Error saving offer images: ' + err.message);
              if (progressContainer) progressContainer.classList.add('hidden');
            }
          });

          renderPreview();
          renderDetailPreview();
        </script>
      </div>
    )}
</AdminLayout>
