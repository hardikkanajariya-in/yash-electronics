---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { getAboutInfo, getSettings, getTeamMembers } from '../services/cms';
import { translateObject, t } from '../lib/translations';
import CloudinaryImage from '../components/common/CloudinaryImage.astro';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const locale = Astro.currentLocale || 'gu';
const rawSettings = await getSettings();
const settings = translateObject(rawSettings, locale);

let aboutPeople: any[] = [];
try {
  aboutPeople = await getAboutInfo();
} catch (e) {
  console.error('[About] Failed to load about info:', e);
}

const founder = aboutPeople.find(p => p.role === 'founder');
const owner = aboutPeople.find(p => p.role === 'owner');
const nextGen = aboutPeople.find(p => p.role === 'next_gen');

let allMembers: any[] = [];
try {
  allMembers = await getTeamMembers();
} catch (e) {
  console.error('[About] Failed to load team members:', e);
}

const salesHead = allMembers.find(m => m.role === 'sales_head');
const salesStaff = allMembers.filter(m => m.role === 'sales_staff');
const serviceHead = allMembers.find(m => m.role === 'service_head');
const serviceStaff = allMembers.filter(m => m.role === 'service_staff');
---

<BaseLayout
  title={`${t('about.title', locale)} - ${settings.businessName}`}
  description={locale === 'gu' ? `${settings.businessName} - પેઢીઓથી વિશ્વાસપાત્ર ઇલેક્ટ્રોનિક્સ અને પાવર સોલ્યુશન્સ` : `${settings.businessName} - Trusted electronics & power solutions across generations`}
  canonicalUrl="/about"
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-neutral-950 via-slate-900 to-neutral-950 text-white overflow-hidden py-20 md:py-28 border-b border-primary-950">
    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-40">
      <!-- Decorative radial gradient glow -->
      <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-primary/20 rounded-full blur-[140px] animate-pulse"></div>
      <div class="absolute top-1/3 right-1/4 -translate-y-1/2 w-[400px] h-[400px] bg-secondary/15 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
      <!-- Subtle Grid Pattern -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
    </div>
    <Container class="relative z-10 text-center">
      <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-widest text-primary-300 mb-4 backdrop-blur-sm">
        ✨ {t('about.ourStory', locale)}
      </div>
      <h1 class="font-display text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white tracking-tight drop-shadow-md">
        {t('about.title', locale)}
      </h1>
      <div class="w-24 h-1 bg-gradient-to-r from-primary to-secondary mx-auto mb-8 rounded-full shadow-sm"></div>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed font-light">
        {t('about.subtitle', locale)}
      </p>
    </Container>
  </section>

  <!-- Our Legacy & Core Values Section (Two-Column Redesign) -->
  <section class="py-16 md:py-24 bg-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-neutral-50 rounded-full blur-3xl opacity-60 -z-10"></div>
    <Container>
      <div class="grid gap-12 lg:grid-cols-12 items-start">
        
        <!-- Left Column: Legacy Story & Stats -->
        <div class="lg:col-span-6 space-y-8">
          <div class="space-y-4">
            <span class="text-primary font-bold text-xs uppercase tracking-[0.2em] block">
              {locale === 'gu' ? 'અમારો ઇતિહાસ' : 'Our Legacy'}
            </span>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 leading-tight">
              {locale === 'gu' ? 'પરિવાર દ્વારા ચાલતો વ્યવસાય, વિશ્વાસ પર બનેલો' : 'A Family-Run Business, Built on Trust'}
            </h2>
            <p class="text-neutral-600 leading-relaxed text-base">
              {locale === 'gu'
                ? `${settings.businessName} ${settings.city}, ${settings.state}માં એક કૌટુંબિક વ્યવસાય છે. અમે ઇન્વર્ટર, બેટરી, સાઉન્ડ સિસ્ટમ અને DJ સ્પીકર સિસ્ટમમાં અસલી પ્રોડક્ટ્સ અને વ્યાવસાયિક સેવા પ્રદાન કરીએ છીએ.`
                : `${settings.businessName} is a family-owned business in ${settings.city}, ${settings.state}. We provide genuine products and professional service in Home Inverters, Batteries, Sound Systems, and DJ Speaker Systems.`}
            </p>
            <p class="text-neutral-600 leading-relaxed text-base font-light">
              {locale === 'gu'
                ? 'અમારું લક્ષ્ય હંમેશા ગ્રાહકોને વ્યાજબી કિંમતે શ્રેષ્ઠ ગુણવત્તાવાળી પ્રોડક્ટ્સ અને ઝડપી ઘરબેઠા સર્વિસ પૂરી પાડવાનું રહ્યું છે. પેઢીઓથી ચાલતા આ વિશ્વાસને અમે આજે પણ જાળવી રાખ્યો છે.'
                : 'Our goal has always been to provide customers with the best quality products at fair prices and fast doorstep service. We continue to uphold this trust built across generations.'}
            </p>
          </div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-3 gap-4 pt-4">
            <div class="bg-neutral-50 rounded-xl p-4 border border-neutral-100 text-center shadow-sm">
              <span class="block text-2xl md:text-3xl font-bold text-primary">15+</span>
              <span class="text-[10px] md:text-xs font-semibold text-neutral-500 uppercase tracking-wider block mt-1">
                {locale === 'gu' ? 'વર્ષોનો અનુભવ' : 'Years of Trust'}
              </span>
            </div>
            <div class="bg-neutral-50 rounded-xl p-4 border border-neutral-100 text-center shadow-sm">
              <span class="block text-2xl md:text-3xl font-bold text-secondary">10k+</span>
              <span class="text-[10px] md:text-xs font-semibold text-neutral-500 uppercase tracking-wider block mt-1">
                {locale === 'gu' ? 'ખુશ ગ્રાહકો' : 'Happy Customers'}
              </span>
            </div>
            <div class="bg-neutral-50 rounded-xl p-4 border border-neutral-100 text-center shadow-sm">
              <span class="block text-2xl md:text-3xl font-bold text-accent">100%</span>
              <span class="text-[10px] md:text-xs font-semibold text-neutral-500 uppercase tracking-wider block mt-1">
                {locale === 'gu' ? 'અસલી બ્રાન્ડ્સ' : 'Genuine Brands'}
              </span>
            </div>
          </div>
        </div>

        <!-- Right Column: Core Values Cards Grid -->
        <div class="lg:col-span-6 grid gap-4 sm:grid-cols-2">
          
          <!-- Value Card 1 -->
          <div class="bg-gradient-to-br from-primary-50/40 to-white border border-primary-100/70 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              🏪
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'સ્થાનિક દુકાન' : 'Local Store'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{settings.address}</p>
            <span class="text-xs text-primary font-semibold tracking-wider uppercase">{locale === 'gu' ? 'મુલાકાત લો' : 'Visit Us'} →</span>
          </div>

          <!-- Value Card 2 -->
          <div class="bg-gradient-to-br from-secondary-50/40 to-white border border-secondary-100/70 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-secondary-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              🔧
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'વ્યાવસાયિક સેવા' : 'Expert Service'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{locale === 'gu' ? 'ઇન્સ્ટોલેશન, રિપેર અને AMC વાર્ષિક કોન્ટ્રાક્ટ્સ' : 'Expert Installation, Repairs & AMC Maintenance Contracts'}</p>
            <span class="text-xs text-secondary font-semibold tracking-wider uppercase">{locale === 'gu' ? 'ઝડપી ઉકેલ' : 'Fast Support'} →</span>
          </div>

          <!-- Value Card 3 -->
          <div class="bg-gradient-to-br from-accent-50/40 to-white border border-accent-100/70 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-accent-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              ✅
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'અસલી પ્રોડક્ટ્સ' : 'Genuine Products'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{locale === 'gu' ? 'તમામ પ્રોડક્ટ્સ સીધી કંપનીમાંથી ઓરિજિનલ ગેરંટી સાથે' : 'Original merchandise directly from top brands with brand warranty'}</p>
            <span class="text-xs text-accent font-semibold tracking-wider uppercase">{locale === 'gu' ? '૧૦૦% ઓરિજિનલ' : '100% Genuine'} →</span>
          </div>

          <!-- Value Card 4 -->
          <div class="bg-gradient-to-br from-neutral-50 to-white border border-neutral-200/80 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-neutral-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              🤝
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'લાંબા ગાળાનો સાથ' : 'Customer Support'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{locale === 'gu' ? 'વેચાણ પછીની સર્વિસ એ જ અમારી ખરી તાકાત અને મૂડી છે' : 'Dedicated post-sales services that maintain clients for a lifetime'}</p>
            <span class="text-xs text-neutral-500 font-semibold tracking-wider uppercase">{locale === 'gu' ? 'વિશ્વાસપાત્ર સાથ' : 'Trusted Support'} →</span>
          </div>

        </div>

      </div>
    </Container>
  </section>

  <!-- Leadership Section -->
  <section class="py-20 bg-neutral-50 relative">
    <Container class="max-w-6xl">
      <div class="text-center mb-16">
        <span class="text-secondary text-xs font-bold uppercase tracking-[0.2em] block mb-2">{t('about.leadershipTitle', locale)}</span>
        <h2 class="font-display text-3xl md:text-4xl font-extrabold text-neutral-900 tracking-tight">
          {locale === 'gu' ? 'અમારા નેતાઓ' : 'Meet Our Leadership'}
        </h2>
        <div class="w-12 h-1 bg-secondary mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 justify-center">
        <!-- Founder -->
        {founder && (
          <div class="bg-white rounded-2xl border border-neutral-200/80 shadow-md hover:shadow-xl hover:border-primary/30 transition-all duration-300 flex flex-col overflow-hidden group">
            <div class="relative aspect-[3/4] bg-neutral-50 overflow-hidden border-b border-neutral-100 flex items-center justify-center">
              {founder.photo ? (
                <CloudinaryImage
                  src={founder.photo}
                  alt={founder.name}
                  width={400}
                  height={533}
                  crop="limit"
                  class="h-full w-full object-contain p-2 group-hover:scale-102 transition-transform duration-500"
                />
              ) : (
                <span class="text-7xl opacity-20">👤</span>
              )}
              <div class="absolute top-4 left-4 z-10">
                <span class="bg-gradient-to-r from-primary to-primary-700 text-white text-[10px] font-bold uppercase tracking-wider px-3.5 py-1.5 rounded-full shadow-sm">
                  {t('about.founder', locale)}
                </span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="font-display text-xl font-bold text-neutral-900 tracking-tight group-hover:text-primary transition-colors">{founder.name}</h3>
              <div class="w-10 h-0.5 bg-primary/30 my-3 rounded-full"></div>
              {founder.description && (
                <p class="text-sm text-neutral-600 leading-relaxed font-normal flex-grow">{founder.description}</p>
              )}
            </div>
          </div>
        )}

        <!-- Owner -->
        {owner && (
          <div class="bg-white rounded-2xl border border-neutral-200/80 shadow-md hover:shadow-xl hover:border-secondary/30 transition-all duration-300 flex flex-col overflow-hidden group">
            <div class="relative aspect-[3/4] bg-neutral-50 overflow-hidden border-b border-neutral-100 flex items-center justify-center">
              {owner.photo ? (
                <CloudinaryImage
                  src={owner.photo}
                  alt={owner.name}
                  width={400}
                  height={533}
                  crop="limit"
                  class="h-full w-full object-contain p-2 group-hover:scale-102 transition-transform duration-500"
                />
              ) : (
                <span class="text-7xl opacity-20">👤</span>
              )}
              <div class="absolute top-4 left-4 z-10">
                <span class="bg-gradient-to-r from-secondary to-secondary-700 text-white text-[10px] font-bold uppercase tracking-wider px-3.5 py-1.5 rounded-full shadow-sm">
                  {t('about.owner', locale)}
                </span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="font-display text-xl font-bold text-neutral-900 tracking-tight group-hover:text-secondary transition-colors">{owner.name}</h3>
              <div class="w-10 h-0.5 bg-secondary/30 my-3 rounded-full"></div>
              {owner.description && (
                <p class="text-sm text-neutral-600 leading-relaxed font-normal flex-grow">{owner.description}</p>
              )}
            </div>
          </div>
        )}

        <!-- Next Gen -->
        {nextGen && (
          <div class="bg-white rounded-2xl border border-neutral-200/80 shadow-md hover:shadow-xl hover:border-accent/30 transition-all duration-300 flex flex-col overflow-hidden group">
            <div class="relative aspect-[3/4] bg-neutral-50 overflow-hidden border-b border-neutral-100 flex items-center justify-center">
              {nextGen.photo ? (
                <CloudinaryImage
                  src={nextGen.photo}
                  alt={nextGen.name}
                  width={400}
                  height={533}
                  crop="limit"
                  class="h-full w-full object-contain p-2 group-hover:scale-102 transition-transform duration-500"
                />
              ) : (
                <span class="text-7xl opacity-20">👤</span>
              )}
              <div class="absolute top-4 left-4 z-10">
                <span class="bg-gradient-to-r from-accent to-accent-700 text-white text-[10px] font-bold uppercase tracking-wider px-3.5 py-1.5 rounded-full shadow-sm">
                  {t('about.nextGen', locale)}
                </span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="font-display text-xl font-bold text-neutral-900 tracking-tight group-hover:text-accent transition-colors">{nextGen.name}</h3>
              <div class="w-10 h-0.5 bg-accent/30 my-3 rounded-full"></div>
              {nextGen.description && (
                <p class="text-sm text-neutral-600 leading-relaxed font-normal flex-grow">{nextGen.description}</p>
              )}
            </div>
          </div>
        )}
      </div>

      {aboutPeople.length === 0 && (
        <div class="text-center py-12 text-neutral-500">
          <p class="text-sm">{locale === 'gu' ? 'નેતૃત્વ માહિતી ટૂંક સમયમાં ઉમેરવામાં આવશે.' : 'Leadership information will be added soon.'}</p>
        </div>
      )}
    </Container>
  </section>

  <!-- Sales Team -->
  {(salesHead || salesStaff.length > 0) && (
    <section class="py-16 bg-white border-t border-neutral-200">
      <Container class="max-w-5xl">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 text-primary px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-3">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            {t('team.salesTeam', locale)}
          </div>
          <h2 class="font-display text-2xl md:text-3xl font-extrabold text-neutral-900 tracking-tight">{t('team.salesTeam', locale)}</h2>
          <div class="w-10 h-1 bg-primary mx-auto mt-3 rounded-full"></div>
        </div>

        <div class="flex flex-col items-center gap-10">
          {/* Sales Head — Highlighted */}
          {salesHead && (
            <div class="bg-gradient-to-br from-primary-50/55 to-white border border-primary-200/80 rounded-2xl p-6 text-center max-w-sm w-full shadow-md hover:shadow-lg transition-all duration-300 group hover:-translate-y-0.5">
              <div class="h-28 w-28 rounded-full bg-primary-50 border-2 border-primary/20 mx-auto mb-4 overflow-hidden flex items-center justify-center p-0.5">
                {salesHead.photo ? (
                  <CloudinaryImage src={salesHead.photo} alt={salesHead.name} crop="limit" class="h-full w-full object-contain rounded-full bg-white" width={200} height={200} />
                ) : (
                  <span class="text-4xl opacity-30">👤</span>
                )}
              </div>
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-3 shadow-sm">{t('team.salesHead', locale)}</span>
              <h3 class="font-display text-xl font-bold text-neutral-900">{salesHead.name}</h3>
              {salesHead.phone && (
                <div class="mt-4 flex justify-center">
                  <a href={`tel:${salesHead.phone}`} class="inline-flex items-center gap-1.5 bg-primary text-white text-xs font-semibold px-4 py-2 rounded-lg hover:bg-primary-600 transition-colors shadow-sm">
                    📞 {salesHead.phone}
                  </a>
                </div>
              )}
            </div>
          )}

          {/* Sales Staff Grid */}
          {salesStaff.length > 0 && (
            <div class="grid gap-6 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 w-full">
              {salesStaff.map(member => (
                <div class="bg-white border border-neutral-200 rounded-xl p-5 text-center shadow-sm hover:shadow-md hover:border-primary/20 transition-all duration-300 flex flex-col justify-between">
                  <div>
                    <div class="h-16 w-16 rounded-full bg-neutral-50 border border-neutral-200/80 mx-auto mb-3 overflow-hidden flex items-center justify-center p-0.5">
                      {member.photo ? (
                        <CloudinaryImage src={member.photo} alt={member.name} crop="limit" class="h-full w-full object-contain rounded-full bg-white" width={120} height={120} />
                      ) : (
                        <span class="text-2xl opacity-30">👤</span>
                      )}
                    </div>
                    <h4 class="font-bold text-sm text-neutral-900 leading-snug">{member.name}</h4>
                  </div>
                  {member.phone && (
                    <div class="mt-3 pt-2 border-t border-neutral-100">
                      <a href={`tel:${member.phone}`} class="text-xs text-primary font-medium hover:underline inline-flex items-center gap-1">
                        📞 {member.phone}
                      </a>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </Container>
    </section>
  )}

  <!-- Service Team -->
  {(serviceHead || serviceStaff.length > 0) && (
    <section class="py-16 bg-neutral-50 border-t border-neutral-200">
      <Container class="max-w-5xl">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 bg-accent/10 border border-accent/20 text-accent px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-3">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            {t('team.serviceTeam', locale)}
          </div>
          <h2 class="font-display text-2xl md:text-3xl font-extrabold text-neutral-900 tracking-tight">{t('team.serviceTeam', locale)}</h2>
          <div class="w-10 h-1 bg-accent mx-auto mt-3 rounded-full"></div>
        </div>

        <div class="flex flex-col items-center gap-10">
          {/* Service Head — Highlighted */}
          {serviceHead && (
            <div class="bg-gradient-to-br from-accent-50/55 to-white border border-accent-200/80 rounded-2xl p-6 text-center max-w-sm w-full shadow-md hover:shadow-lg transition-all duration-300 group hover:-translate-y-0.5">
              <div class="h-28 w-28 rounded-full bg-accent-50 border-2 border-accent/20 mx-auto mb-4 overflow-hidden flex items-center justify-center p-0.5">
                {serviceHead.photo ? (
                  <CloudinaryImage src={serviceHead.photo} alt={serviceHead.name} crop="limit" class="h-full w-full object-contain rounded-full bg-white" width={200} height={200} />
                ) : (
                  <span class="text-4xl opacity-30">👤</span>
                )}
              </div>
              <span class="inline-block bg-accent text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-3 shadow-sm">{t('team.serviceHead', locale)}</span>
              <h3 class="font-display text-xl font-bold text-neutral-900">{serviceHead.name}</h3>
              {serviceHead.phone && (
                <div class="mt-4 flex justify-center">
                  <a href={`tel:${serviceHead.phone}`} class="inline-flex items-center gap-1.5 bg-accent text-white text-xs font-semibold px-4 py-2 rounded-lg hover:bg-accent-600 transition-colors shadow-sm">
                    📞 {serviceHead.phone}
                  </a>
                </div>
              )}
            </div>
          )}

          {/* Service Staff Grid */}
          {serviceStaff.length > 0 && (
            <div class="grid gap-6 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 w-full">
              {serviceStaff.map(member => (
                <div class="bg-white border border-neutral-200 rounded-xl p-5 text-center shadow-sm hover:shadow-md hover:border-accent/20 transition-all duration-300 flex flex-col justify-between">
                  <div>
                    <div class="h-16 w-16 rounded-full bg-neutral-50 border border-neutral-200/80 mx-auto mb-3 overflow-hidden flex items-center justify-center p-0.5">
                      {member.photo ? (
                        <CloudinaryImage src={member.photo} alt={member.name} crop="limit" class="h-full w-full object-contain rounded-full bg-white" width={120} height={120} />
                      ) : (
                        <span class="text-2xl opacity-30">👤</span>
                      )}
                    </div>
                    <h4 class="font-bold text-sm text-neutral-900 leading-snug">{member.name}</h4>
                  </div>
                  {member.phone && (
                    <div class="mt-3 pt-2 border-t border-neutral-100">
                      <a href={`tel:${member.phone}`} class="text-xs text-accent font-medium hover:underline inline-flex items-center gap-1">
                        📞 {member.phone}
                      </a>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </Container>
    </section>
  )}

  <!-- CTA Section -->
  <section class="relative bg-gradient-to-br from-primary-950 via-primary-900 to-primary-950 text-white py-20 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-20">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-secondary rounded-full blur-[160px] animate-pulse"></div>
    </div>
    <Container class="text-center max-w-3xl relative z-10 space-y-6">
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight">
        {locale === 'gu' ? 'અમારી દુકાનની મુલાકાત લો' : 'Visit Our Store'}
      </h2>
      <p class="text-slate-200 max-w-xl mx-auto leading-relaxed text-sm md:text-base font-light">
        {locale === 'gu' ? 'ઇન્વર્ટર, બેટરી, સાઉન્ડ સિસ્ટમ અને DJ સ્પીકર સિસ્ટમ માટે અમારો સંપર્ક કરો.' : 'Contact us for Home Inverters, Batteries, Sound Systems and DJ Speaker Systems.'}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
        <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="inline-flex items-center justify-center gap-2 bg-white text-primary hover:bg-neutral-100 font-bold px-6 py-3.5 rounded-xl shadow-md hover:shadow-lg transition-all text-sm md:text-base">
          📞 {t('contact.callNow', locale)}
        </a>
        <a href={`https://wa.me/${settings.whatsapp}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-emerald-600 text-white hover:bg-emerald-500 font-bold px-6 py-3.5 rounded-xl shadow-md hover:shadow-lg transition-all text-sm md:text-base">
          💬 {t('contact.chatWhatsApp', locale)}
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
