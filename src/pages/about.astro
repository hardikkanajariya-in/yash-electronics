---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { getAboutInfo, getSettings, getTeamMembers } from '../services/cms';
import { translateObject, t } from '../lib/translations';
import CloudinaryImage from '../components/common/CloudinaryImage.astro';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const locale = Astro.currentLocale || 'gu';
const rawSettings = await getSettings();
const settings = translateObject(rawSettings, locale);

let aboutPeople: any[] = [];
try {
  aboutPeople = await getAboutInfo();
} catch (e) {
  console.error('[About] Failed to load about info:', e);
}

const founder = aboutPeople.find(p => p.role === 'founder');
const owner = aboutPeople.find(p => p.role === 'owner');
const nextGen = aboutPeople.find(p => p.role === 'next_gen');

let allMembers: any[] = [];
try {
  allMembers = await getTeamMembers();
} catch (e) {
  console.error('[About] Failed to load team members:', e);
}

const salesHead = allMembers.find(m => m.role === 'sales_head');
const salesStaff = allMembers.filter(m => m.role === 'sales_staff');
const serviceHead = allMembers.find(m => m.role === 'service_head');
const serviceStaff = allMembers.filter(m => m.role === 'service_staff');
---

<BaseLayout
  title={`${t('about.title', locale)} - ${settings.businessName}`}
  description={locale === 'gu' ? 'યશ ઇલેક્ટ્રોનિક્સ - પેઢીઓથી વિશ્વાસપાત્ર ઇલેક્ટ્રોનિક્સ અને પાવર સોલ્યુશન્સ' : 'Yash Electronics - Trusted electronics & power solutions across generations'}
  canonicalUrl="/about"
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-neutral-950 via-primary-950 to-neutral-950 text-white overflow-hidden py-16 md:py-24 border-b border-primary-900/30">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-96 h-96 bg-primary/20 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute top-1/3 right-1/4 -translate-y-1/2 w-96 h-96 bg-secondary/15 rounded-full blur-[100px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>
    <Container class="relative text-center z-10">
      <p class="text-secondary font-bold text-xs uppercase tracking-[0.25em] mb-3 drop-shadow-sm">
        {t('about.ourStory', locale)}
      </p>
      <h1 class="font-display text-4xl md:text-6xl font-black mb-4 leading-tight text-white tracking-tight drop-shadow-md">
        {t('about.title', locale)}
      </h1>
      <div class="w-16 h-1 bg-gradient-to-r from-primary to-secondary mx-auto mb-6 rounded-full"></div>
      <p class="text-base md:text-lg text-neutral-300 max-w-2xl mx-auto leading-relaxed font-medium">
        {t('about.subtitle', locale)}
      </p>
    </Container>
  </section>

  <!-- Our Story Section -->
  <section class="section-padding bg-white">
    <Container class="max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-neutral-900 mb-4">
          {locale === 'gu' ? 'પરિવાર દ્વારા ચાલતો વ્યવસાય, વિશ્વાસ પર બનેલો' : 'A Family-Run Business, Built on Trust'}
        </h2>
        <p class="text-neutral-600 leading-relaxed max-w-2xl mx-auto">
          {locale === 'gu'
            ? 'યશ ઇલેક્ટ્રોનિક્સ ખંભાળિયા, ગુજરાતમાં એક કૌટુંબિક વ્યવસાય છે. અમે ઇન્વર્ટર, બેટરી, સાઉન્ડ સિસ્ટમ અને DJ સ્પીકર સિસ્ટમમાં અસલી પ્રોડક્ટ્સ અને વ્યાવસાયિક સેવા પ્રદાન કરીએ છીએ.'
            : 'Yash Electronics is a family-owned business in Khambhalia, Gujarat. We provide genuine products and professional service in Home Inverters, Batteries, Sound Systems, and DJ Speaker Systems.'}
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <div class="bg-gradient-to-br from-primary-50 to-white border border-primary-100 rounded-xl p-6 text-center">
          <span class="text-3xl mb-3 block">🏪</span>
          <h3 class="font-display text-lg font-bold text-primary mb-1">{locale === 'gu' ? 'સ્થાનિક દુકાન' : 'Local Store'}</h3>
          <p class="text-sm text-neutral-600">{locale === 'gu' ? 'ખંભાળિયામાં જોધપુર ગેટ નજીક' : 'Near Jodhpur Gate, Khambhalia'}</p>
        </div>
        <div class="bg-gradient-to-br from-secondary-50 to-white border border-secondary-100 rounded-xl p-6 text-center">
          <span class="text-3xl mb-3 block">🔧</span>
          <h3 class="font-display text-lg font-bold text-secondary mb-1">{locale === 'gu' ? 'વ્યાવસાયિક સેવા' : 'Expert Service'}</h3>
          <p class="text-sm text-neutral-600">{locale === 'gu' ? 'ઇન્સ્ટોલેશન, રિપેર અને AMC' : 'Installation, Repair & AMC'}</p>
        </div>
        <div class="bg-gradient-to-br from-accent-50 to-white border border-accent-100 rounded-xl p-6 text-center">
          <span class="text-3xl mb-3 block">✅</span>
          <h3 class="font-display text-lg font-bold text-accent mb-1">{locale === 'gu' ? 'અસલી પ્રોડક્ટ્સ' : 'Genuine Products'}</h3>
          <p class="text-sm text-neutral-600">{locale === 'gu' ? 'ઉત્પાદક વોરંટી સાથે' : 'With Manufacturer Warranty'}</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Leadership Section -->
  <section class="section-padding bg-neutral-50">
    <Container class="max-w-5xl">
      <div class="text-center mb-12">
        <p class="text-secondary text-xs font-bold uppercase tracking-[0.15em] mb-2">{t('about.leadershipTitle', locale)}</p>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-neutral-900">
          {locale === 'gu' ? 'અમારા નેતાઓ' : 'Meet Our Leadership'}
        </h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Founder -->
        {founder && (
          <div class="bg-white rounded-2xl border border-neutral-200 shadow-card overflow-hidden text-center group hover:shadow-card-hover transition-shadow duration-300">
            <div class="relative h-56 bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center overflow-hidden">
              {founder.photo ? (
                <CloudinaryImage
                  src={founder.photo}
                  alt={founder.name}
                  class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width={400}
                  height={300}
                />
              ) : (
                <span class="text-6xl opacity-30">👤</span>
              )}
              <div class="absolute top-3 left-3">
                <span class="bg-primary text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full">{t('about.founder', locale)}</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-display text-xl font-bold text-neutral-900">{founder.name}</h3>
              {founder.description && (
                <p class="text-sm text-neutral-600 mt-2 leading-relaxed">{founder.description}</p>
              )}
            </div>
          </div>
        )}

        <!-- Owner -->
        {owner && (
          <div class="bg-white rounded-2xl border border-neutral-200 shadow-card overflow-hidden text-center group hover:shadow-card-hover transition-shadow duration-300">
            <div class="relative h-56 bg-gradient-to-br from-secondary-100 to-secondary-50 flex items-center justify-center overflow-hidden">
              {owner.photo ? (
                <CloudinaryImage
                  src={owner.photo}
                  alt={owner.name}
                  class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width={400}
                  height={300}
                />
              ) : (
                <span class="text-6xl opacity-30">👤</span>
              )}
              <div class="absolute top-3 left-3">
                <span class="bg-secondary text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full">{t('about.owner', locale)}</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-display text-xl font-bold text-neutral-900">{owner.name}</h3>
              {owner.description && (
                <p class="text-sm text-neutral-600 mt-2 leading-relaxed">{owner.description}</p>
              )}
            </div>
          </div>
        )}

        <!-- Next Gen -->
        {nextGen && (
          <div class="bg-white rounded-2xl border border-neutral-200 shadow-card overflow-hidden text-center group hover:shadow-card-hover transition-shadow duration-300">
            <div class="relative h-56 bg-gradient-to-br from-accent-100 to-accent-50 flex items-center justify-center overflow-hidden">
              {nextGen.photo ? (
                <CloudinaryImage
                  src={nextGen.photo}
                  alt={nextGen.name}
                  class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width={400}
                  height={300}
                />
              ) : (
                <span class="text-6xl opacity-30">👤</span>
              )}
              <div class="absolute top-3 left-3">
                <span class="bg-accent text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full">{t('about.nextGen', locale)}</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-display text-xl font-bold text-neutral-900">{nextGen.name}</h3>
              {nextGen.description && (
                <p class="text-sm text-neutral-600 mt-2 leading-relaxed">{nextGen.description}</p>
              )}
            </div>
          </div>
        )}
      </div>

      {aboutPeople.length === 0 && (
        <div class="text-center py-12 text-neutral-500">
          <p class="text-sm">{locale === 'gu' ? 'નેતૃત્વ માહિતી ટૂંક સમયમાં ઉમેરવામાં આવશે.' : 'Leadership information will be added soon.'}</p>
        </div>
      )}
    </Container>
  </section>

  <!-- Sales Team -->
  {(salesHead || salesStaff.length > 0) && (
    <section class="section-padding bg-white border-t border-neutral-200">
      <Container class="max-w-5xl">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 bg-primary-50 text-primary px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-3">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            {t('team.salesTeam', locale)}
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900">{t('team.salesTeam', locale)}</h2>
        </div>

        <div class="flex flex-col items-center gap-8">
          {/* Sales Head — Highlighted */}
          {salesHead && (
            <div class="bg-gradient-to-br from-primary-50 to-white border-2 border-primary-200 rounded-2xl p-6 text-center max-w-xs w-full shadow-card">
              <div class="h-28 w-28 rounded-full bg-primary-100 mx-auto mb-4 overflow-hidden flex items-center justify-center">
                {salesHead.photo ? (
                  <CloudinaryImage src={salesHead.photo} alt={salesHead.name} class="h-full w-full object-cover" width={200} height={200} />
                ) : (
                  <span class="text-4xl opacity-30">👤</span>
                )}
              </div>
              <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">{t('team.salesHead', locale)}</span>
              <h3 class="font-display text-xl font-bold text-neutral-900">{salesHead.name}</h3>
              {salesHead.phone && (
                <a href={`tel:${salesHead.phone}`} class="text-sm text-primary font-medium hover:underline mt-1 block">📞 {salesHead.phone}</a>
              )}
            </div>
          )}

          {/* Sales Staff Grid */}
          {salesStaff.length > 0 && (
            <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 w-full">
              {salesStaff.map(member => (
                <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center shadow-card hover:shadow-card-hover transition-shadow duration-300">
                  <div class="h-16 w-16 rounded-full bg-neutral-100 mx-auto mb-3 overflow-hidden flex items-center justify-center">
                    {member.photo ? (
                      <CloudinaryImage src={member.photo} alt={member.name} class="h-full w-full object-cover" width={120} height={120} />
                    ) : (
                      <span class="text-2xl opacity-30">👤</span>
                    )}
                  </div>
                  <h4 class="font-semibold text-sm text-neutral-900">{member.name}</h4>
                  {member.phone && (
                    <a href={`tel:${member.phone}`} class="text-xs text-neutral-500 hover:text-primary mt-0.5 block">📞 {member.phone}</a>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </Container>
    </section>
  )}

  <!-- Service Team -->
  {(serviceHead || serviceStaff.length > 0) && (
    <section class="section-padding bg-neutral-50 border-t border-neutral-200">
      <Container class="max-w-5xl">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 bg-accent-50 text-accent px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-3">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            {t('team.serviceTeam', locale)}
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900">{t('team.serviceTeam', locale)}</h2>
        </div>

        <div class="flex flex-col items-center gap-8">
          {/* Service Head — Highlighted */}
          {serviceHead && (
            <div class="bg-gradient-to-br from-accent-50 to-white border-2 border-accent-200 rounded-2xl p-6 text-center max-w-xs w-full shadow-card">
              <div class="h-28 w-28 rounded-full bg-accent-100 mx-auto mb-4 overflow-hidden flex items-center justify-center">
                {serviceHead.photo ? (
                  <CloudinaryImage src={serviceHead.photo} alt={serviceHead.name} class="h-full w-full object-cover" width={200} height={200} />
                ) : (
                  <span class="text-4xl opacity-30">👤</span>
                )}
              </div>
              <span class="inline-block bg-accent text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">{t('team.serviceHead', locale)}</span>
              <h3 class="font-display text-xl font-bold text-neutral-900">{serviceHead.name}</h3>
              {serviceHead.phone && (
                <a href={`tel:${serviceHead.phone}`} class="text-sm text-accent font-medium hover:underline mt-1 block">📞 {serviceHead.phone}</a>
              )}
            </div>
          )}

          {/* Service Staff Grid */}
          {serviceStaff.length > 0 && (
            <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 w-full">
              {serviceStaff.map(member => (
                <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center shadow-card hover:shadow-card-hover transition-shadow duration-300">
                  <div class="h-16 w-16 rounded-full bg-neutral-100 mx-auto mb-3 overflow-hidden flex items-center justify-center">
                    {member.photo ? (
                      <CloudinaryImage src={member.photo} alt={member.name} class="h-full w-full object-cover" width={120} height={120} />
                    ) : (
                      <span class="text-2xl opacity-30">👤</span>
                    )}
                  </div>
                  <h4 class="font-semibold text-sm text-neutral-900">{member.name}</h4>
                  {member.phone && (
                    <a href={`tel:${member.phone}`} class="text-xs text-neutral-500 hover:text-accent mt-0.5 block">📞 {member.phone}</a>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </Container>
    </section>
  )}

  <!-- CTA Section -->
  <section class="bg-gradient-to-r from-primary to-primary-700 text-white section-padding">
    <Container class="text-center max-w-2xl">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">
        {locale === 'gu' ? 'અમારી દુકાનની મુલાકાત લો' : 'Visit Our Store'}
      </h2>
      <p class="text-white/80 mb-6">
        {locale === 'gu' ? 'ઇન્વર્ટર, બેટરી, સાઉન્ડ સિસ્ટમ અને DJ સ્પીકર સિસ્ટમ માટે અમારો સંપર્ક કરો.' : 'Contact us for Home Inverters, Batteries, Sound Systems and DJ Speaker Systems.'}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="btn bg-white text-primary hover:bg-neutral-100 font-bold">
          📞 {t('contact.callNow', locale)}
        </a>
        <a href={`https://wa.me/${settings.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp font-bold">
          💬 {t('contact.chatWhatsApp', locale)}
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
