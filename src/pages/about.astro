---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { getAboutInfo, getSettings, getTeamMembers } from '../services/cms';
import { translateObject, t } from '../lib/translations';
import CloudinaryImage from '../components/common/CloudinaryImage.astro';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');

const locale = Astro.currentLocale || 'gu';
const rawSettings = await getSettings();
const settings = translateObject(rawSettings, locale);

let aboutPeople: any[] = [];
try {
  aboutPeople = await getAboutInfo();
} catch (e) {
  console.error('[About] Failed to load about info:', e);
}

const founder = aboutPeople.find(p => p.role === 'founder');
const owner = aboutPeople.find(p => p.role === 'owner');
const nextGen = aboutPeople.find(p => p.role === 'next_gen');

let allMembers: any[] = [];
try {
  allMembers = await getTeamMembers();
} catch (e) {
  console.error('[About] Failed to load team members:', e);
}

const salesHead = allMembers.find(m => m.role === 'sales_head');
const salesStaff = allMembers.filter(m => m.role === 'sales_staff');
const serviceHead = allMembers.find(m => m.role === 'service_head');
const serviceStaff = allMembers.filter(m => m.role === 'service_staff');
---

<BaseLayout
  title={`${t('about.title', locale)} - ${settings.businessName}`}
  description={locale === 'gu' ? `${settings.businessName} - પેઢીઓથી વિશ્વાસપાત્ર ઇલેક્ટ્રોનિક્સ અને પાવર સોલ્યુશન્સ` : `${settings.businessName} - Trusted electronics & power solutions across generations`}
  canonicalUrl="/about"
>
  <!-- Hero Section -->
  <section class="relative bg-[#0E1012] bg-gradient-to-br from-[#0E1012] via-[#0f172a] to-[#0E1012] text-white overflow-hidden py-20 md:py-28 border-b border-[#060F1E]">
    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-40">
      <!-- Decorative radial gradient glow -->
      <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-primary/20 rounded-full blur-[140px] animate-pulse"></div>
      <div class="absolute top-1/3 right-1/4 -translate-y-1/2 w-[400px] h-[400px] bg-secondary/15 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
      <!-- Subtle Grid Pattern -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
    </div>
    <Container class="relative z-10 text-center">
      <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-widest text-primary-300 mb-4 backdrop-blur-sm">
        ✨ {t('about.ourStory', locale)}
      </div>
      <h1 class="font-display text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white tracking-tight drop-shadow-md">
        {t('about.title', locale)}
      </h1>
      <div class="w-24 h-1 bg-gradient-to-r from-primary to-secondary mx-auto mb-8 rounded-full shadow-sm"></div>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed font-light">
        {t('about.subtitle', locale)}
      </p>
    </Container>
  </section>

  <!-- Our Legacy & Core Values Section (Two-Column Redesign) -->
  <section class="py-16 md:py-24 bg-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-neutral-50 rounded-full blur-3xl opacity-60 -z-10"></div>
    <Container>
      <div class="grid gap-12 lg:grid-cols-12 items-start">
        
        <!-- Left Column: Legacy Story & Stats -->
        <div class="lg:col-span-6 space-y-8">
          <div class="space-y-4">
            <span class="text-primary font-bold text-xs uppercase tracking-[0.2em] block">
              {locale === 'gu' ? 'અમારો ઇતિહાસ' : 'Our Legacy'}
            </span>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 leading-tight">
              {locale === 'gu' ? 'પરિવાર દ્વારા ચાલતો વ્યવસાય, વિશ્વાસ પર બનેલો' : 'A Family-Run Business, Built on Trust'}
            </h2>
            <p class="text-neutral-600 leading-relaxed text-base">
              {locale === 'gu'
                ? `${settings.businessName} ${settings.city}, ${settings.state}માં એક કૌટુંબિક વ્યવસાય છે. અમે ઇન્વર્ટર, બેટરી, સાઉન્ડ સિસ્ટમ અને DJ સ્પીકર સિસ્ટમમાં અસલી પ્રોડક્ટ્સ અને વ્યાવસાયિક સેવા પ્રદાન કરીએ છીએ.`
                : `${settings.businessName} is a family-owned business in ${settings.city}, ${settings.state}. We provide genuine products and professional service in Home Inverters, Batteries, Sound Systems, and DJ Speaker Systems.`}
            </p>
            <p class="text-neutral-600 leading-relaxed text-base font-light">
              {locale === 'gu'
                ? 'અમારું લક્ષ્ય હંમેશા ગ્રાહકોને વ્યાજબી કિંમતે શ્રેષ્ઠ ગુણવત્તાવાળી પ્રોડક્ટ્સ અને ઝડપી ઘરબેઠા સર્વિસ પૂરી પાડવાનું રહ્યું છે. પેઢીઓથી ચાલતા આ વિશ્વાસને અમે આજે પણ જાળવી રાખ્યો છે.'
                : 'Our goal has always been to provide customers with the best quality products at fair prices and fast doorstep service. We continue to uphold this trust built across generations.'}
            </p>
          </div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-3 gap-4 pt-4">
            <div class="bg-neutral-50 rounded-xl p-4 border border-neutral-100 text-center shadow-sm">
              <span class="block text-2xl md:text-3xl font-bold text-primary">15+</span>
              <span class="text-[10px] md:text-xs font-semibold text-neutral-500 uppercase tracking-wider block mt-1">
                {locale === 'gu' ? 'વર્ષોનો અનુભવ' : 'Years of Trust'}
              </span>
            </div>
            <div class="bg-neutral-50 rounded-xl p-4 border border-neutral-100 text-center shadow-sm">
              <span class="block text-2xl md:text-3xl font-bold text-secondary">10k+</span>
              <span class="text-[10px] md:text-xs font-semibold text-neutral-500 uppercase tracking-wider block mt-1">
                {locale === 'gu' ? 'ખુશ ગ્રાહકો' : 'Happy Customers'}
              </span>
            </div>
            <div class="bg-neutral-50 rounded-xl p-4 border border-neutral-100 text-center shadow-sm">
              <span class="block text-2xl md:text-3xl font-bold text-accent">100%</span>
              <span class="text-[10px] md:text-xs font-semibold text-neutral-500 uppercase tracking-wider block mt-1">
                {locale === 'gu' ? 'અસલી બ્રાન્ડ્સ' : 'Genuine Brands'}
              </span>
            </div>
          </div>
        </div>

        <!-- Right Column: Core Values Cards Grid -->
        <div class="lg:col-span-6 grid gap-4 sm:grid-cols-2">
          
          <!-- Value Card 1 -->
          <div class="bg-gradient-to-br from-primary-50/40 to-white border border-primary-100/70 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              🏪
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'સ્થાનિક દુકાન' : 'Local Store'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{settings.address}</p>
            <span class="text-xs text-primary font-semibold tracking-wider uppercase">{locale === 'gu' ? 'મુલાકાત લો' : 'Visit Us'} →</span>
          </div>

          <!-- Value Card 2 -->
          <div class="bg-gradient-to-br from-secondary-50/40 to-white border border-secondary-100/70 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-secondary-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              🔧
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'વ્યાવસાયિક સેવા' : 'Expert Service'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{locale === 'gu' ? 'ઇન્સ્ટોલેશન, રિપેર અને AMC વાર્ષિક કોન્ટ્રાક્ટ્સ' : 'Expert Installation, Repairs & AMC Maintenance Contracts'}</p>
            <span class="text-xs text-secondary font-semibold tracking-wider uppercase">{locale === 'gu' ? 'ઝડપી ઉકેલ' : 'Fast Support'} →</span>
          </div>

          <!-- Value Card 3 -->
          <div class="bg-gradient-to-br from-accent-50/40 to-white border border-accent-100/70 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-accent-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              ✅
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'અસલી પ્રોડક્ટ્સ' : 'Genuine Products'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{locale === 'gu' ? 'તમામ પ્રોડક્ટ્સ સીધી કંપનીમાંથી ઓરિજિનલ ગેરંટી સાથે' : 'Original merchandise directly from top brands with brand warranty'}</p>
            <span class="text-xs text-accent font-semibold tracking-wider uppercase">{locale === 'gu' ? '૧૦૦% ઓરિજિનલ' : '100% Genuine'} →</span>
          </div>

          <!-- Value Card 4 -->
          <div class="bg-gradient-to-br from-neutral-50 to-white border border-neutral-200/80 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-neutral-100 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              🤝
            </div>
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">{locale === 'gu' ? 'લાંબા ગાળાનો સાથ' : 'Customer Support'}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{locale === 'gu' ? 'વેચાણ પછીની સર્વિસ એ જ અમારી ખરી તાકાત અને મૂડી છે' : 'Dedicated post-sales services that maintain clients for a lifetime'}</p>
            <span class="text-xs text-neutral-500 font-semibold tracking-wider uppercase">{locale === 'gu' ? 'વિશ્વાસપાત્ર સાથ' : 'Trusted Support'} →</span>
          </div>

        </div>

      </div>
    </Container>
  </section>

  <!-- Leadership Section -->
  <section class="py-24 bg-[#0E1012] bg-gradient-to-b from-[#0E1012] via-[#0f172a] to-[#0E1012] text-white relative overflow-hidden border-b border-white/[0.05]">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-40">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[140px] animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-secondary/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2.5s;"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
    </div>
    <Container class="max-w-6xl relative z-10">
      <div class="text-center mb-16">
        <span class="text-secondary-400 text-xs font-bold uppercase tracking-[0.25em] block mb-3 drop-shadow-sm">{t('about.leadershipTitle', locale)}</span>
        <h2 class="font-display text-3xl md:text-5xl font-black text-white tracking-tight drop-shadow-md">
          {locale === 'gu' ? 'અમારા નેતાઓ' : 'Meet Our Leadership'}
        </h2>
        <div class="w-16 h-1 bg-gradient-to-r from-primary to-secondary mx-auto mt-5 rounded-full shadow-sm"></div>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 justify-center">
        {(() => {
          // Sort aboutPeople by sortOrder
          const sortedPeople = [...aboutPeople].sort((a, b) => (a.sortOrder || 0) - (b.sortOrder || 0));
          return sortedPeople.map((person) => {
            let roleLabel = '';
            let roleColorClass = '';
            if (person.role === 'founder') {
              roleLabel = t('about.founder', locale);
              roleColorClass = 'from-primary-500 to-primary-700';
            } else if (person.role === 'owner') {
              roleLabel = t('about.owner', locale);
              roleColorClass = 'from-secondary-500 to-secondary-700';
            } else {
              roleLabel = t('about.nextGen', locale);
              roleColorClass = 'from-accent-500 to-accent-700';
            }

            return (
              <div class="bg-gradient-to-b from-white/[0.03] to-white/[0.01] backdrop-blur-lg rounded-3xl border border-white/[0.08] hover:border-white/[0.18] shadow-2xl hover:shadow-[0_30px_60px_rgba(0,0,0,0.4),0_0_40px_rgba(27,58,107,0.15)] hover:-translate-y-3 transition-all duration-500 flex flex-col overflow-hidden group">
                <div class="relative aspect-[4/5] bg-neutral-950/20 overflow-hidden flex items-center justify-center p-3">
                  <div class="w-full h-full rounded-2xl overflow-hidden relative group-hover:shadow-lg transition-all duration-500">
                    {person.photo ? (
                      <CloudinaryImage
                        src={person.photo}
                        alt={person.name}
                        width={400}
                        height={500}
                        crop="fill"
                        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                      />
                    ) : (
                      <div class="w-full h-full bg-neutral-900/60 flex items-center justify-center">
                        <span class="text-7xl opacity-20">👤</span>
                      </div>
                    )}
                    <!-- Ambient overlay on image -->
                    <div class="absolute inset-0 bg-gradient-to-t from-neutral-950/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500"></div>
                    
                    <div class="absolute top-3 left-3 z-10">
                      <span class={`bg-gradient-to-r ${roleColorClass} text-white text-[9px] font-extrabold uppercase tracking-widest px-3.5 py-1.5 rounded-full shadow-lg backdrop-blur-md`}>
                        {roleLabel}
                      </span>
                    </div>
                  </div>
                </div>
                <div class="p-6 pt-2 flex-1 flex flex-col relative">
                  <!-- Subtle glow separator -->
                  <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
                  
                  <div class="space-y-1 mt-4">
                    <h3 class="font-display text-xl font-extrabold text-white tracking-tight group-hover:text-primary-300 transition-colors duration-300">
                      {person.name}
                    </h3>
                  </div>
                  <div class="w-12 h-0.5 bg-gradient-to-r from-primary to-secondary my-4 rounded-full"></div>
                  {person.description && (
                    <p class="text-sm text-neutral-300 leading-relaxed font-light flex-grow">
                      {person.description}
                    </p>
                  )}
                </div>
              </div>
            );
          });
        })()}
      </div>

      {aboutPeople.length === 0 && (
        <div class="text-center py-12 text-neutral-400">
          <p class="text-sm">{locale === 'gu' ? 'નેતૃત્વ માહિતી ટૂંક સમયમાં ઉમેરવામાં આવશે.' : 'Leadership information will be added soon.'}</p>
        </div>
      )}
    </Container>
  </section>

  <!-- Sales Team Section -->
  {(salesHead || salesStaff.length > 0) && (
    <section class="py-20 bg-white border-t border-neutral-100 relative overflow-hidden">
      <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary-50 rounded-full blur-3xl opacity-50 -z-10"></div>
      <Container class="max-w-6xl">
        <div class="text-center mb-16">
          <span class="text-primary text-xs font-bold uppercase tracking-[0.2em] block mb-2">Sales Department</span>
          <h2 class="font-display text-3xl md:text-4xl font-extrabold text-neutral-900 tracking-tight">
            {locale === 'gu' ? 'અમારી સેલ્સ ટીમ' : 'Our Sales Experts'}
          </h2>
          <div class="w-12 h-1 bg-primary mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="grid gap-10 lg:grid-cols-12 items-start">
          <!-- Department Head (Left Column / Highlighted) -->
          {salesHead ? (
            <div class="lg:col-span-5 bg-gradient-to-br from-primary-50/60 via-white to-white border border-primary-100/80 rounded-3xl p-8 text-center shadow-lg hover:shadow-primary-500/5 hover:-translate-y-1.5 transition-all duration-500 relative group">
              <div class="absolute top-4 right-4 bg-primary/10 text-primary text-[9px] font-extrabold uppercase tracking-widest px-3 py-1.5 rounded-full border border-primary-200/50">
                {t('team.salesHead', locale)}
              </div>
              <div class="h-32 w-32 rounded-full bg-primary-50 border-2 border-primary-100 shadow-md mx-auto mb-6 overflow-hidden flex items-center justify-center p-1 group-hover:border-primary-300 transition-colors duration-300">
                {salesHead.photo ? (
                  <CloudinaryImage src={salesHead.photo} alt={salesHead.name} crop="fill" class="h-full w-full object-cover rounded-full bg-white group-hover:scale-105 transition-transform duration-500" width={240} height={240} />
                ) : (
                  <span class="text-5xl opacity-30">👤</span>
                )}
              </div>
              <h3 class="font-display text-2xl font-black text-neutral-900 group-hover:text-primary transition-colors duration-300">{salesHead.name}</h3>
              <p class="text-neutral-500 text-xs mt-1 uppercase tracking-wider font-semibold">{locale === 'gu' ? 'સેલ્સ હેડ' : 'Department Lead'}</p>
              
              <p class="text-neutral-600 text-sm mt-4 leading-relaxed font-light">
                {locale === 'gu'
                  ? 'સેલ્સ અને બલ્ક ઓર્ડર પૂછપરછ માટે અમારા હેડ સાથે સીધો સંપર્ક કરો.'
                  : 'Contact our lead directly for bulk sales queries, commercial orders, and corporate partnerships.'}
              </p>

              {salesHead.phone && (
                <div class="mt-6 flex flex-col sm:flex-row gap-2 justify-center">
                  <a href={`tel:${salesHead.phone}`} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-700 text-white text-xs font-bold px-5 py-3 rounded-xl transition-colors shadow-md">
                    📞 Call: {salesHead.phone}
                  </a>
                  <a href={`https://wa.me/${salesHead.phone}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold px-5 py-3 rounded-xl transition-colors shadow-md">
                    💬 WhatsApp
                  </a>
                </div>
              )}
            </div>
          ) : null}

          <!-- Staff Members (Right Column Grid) -->
          <div class={`${salesHead ? 'lg:col-span-7' : 'lg:col-span-12'} space-y-6`}>
            {salesStaff.length > 0 ? (
              <div>
                <h4 class="text-xs font-bold text-neutral-400 uppercase tracking-widest mb-4">Sales Executives</h4>
                <div class="grid gap-4 sm:grid-cols-2">
                  {salesStaff.map(member => (
                    <div class="bg-white border border-neutral-200/80 hover:border-primary-200 rounded-2xl p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-500 flex items-center gap-4 group">
                      <div class="h-16 w-16 rounded-full bg-neutral-50 border border-neutral-200/80 overflow-hidden flex items-center justify-center p-0.5 shrink-0 group-hover:border-primary-200 transition-colors duration-300">
                        {member.photo ? (
                          <CloudinaryImage src={member.photo} alt={member.name} crop="fill" class="h-full w-full object-cover rounded-full bg-white group-hover:scale-105 transition-transform duration-500" width={120} height={120} />
                        ) : (
                          <span class="text-2xl opacity-30">👤</span>
                        )}
                      </div>
                      <div class="flex-1 min-w-0">
                        <h4 class="font-bold text-sm text-neutral-900 truncate leading-snug group-hover:text-primary transition-colors">{member.name}</h4>
                        <span class="text-[10px] text-neutral-400 uppercase font-semibold block mt-0.5">{locale === 'gu' ? 'સેલ્સ એક્ઝિક્યુટિવ' : 'Sales Executive'}</span>
                        
                        {member.phone && (
                          <div class="mt-2 flex gap-2">
                            <a href={`tel:${member.phone}`} class="text-xs text-primary font-bold hover:underline inline-flex items-center gap-1">
                              📞 Call
                            </a>
                            <a href={`https://wa.me/${member.phone}`} target="_blank" rel="noopener noreferrer" class="text-xs text-emerald-600 font-bold hover:underline inline-flex items-center gap-1">
                              💬 Chat
                            </a>
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ) : (
              <div class="bg-neutral-50 rounded-2xl p-8 border border-neutral-100 text-center text-neutral-400 text-xs">
                No other sales staff registered.
              </div>
            )}
          </div>
        </div>
      </Container>
    </section>
  )}

  <!-- Service Team Section -->
  {(serviceHead || serviceStaff.length > 0) && (
    <section class="py-20 bg-neutral-50 border-t border-neutral-200 relative overflow-hidden">
      <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-accent-50 rounded-full blur-3xl opacity-40 -z-10"></div>
      <Container class="max-w-6xl">
        <div class="text-center mb-16">
          <span class="text-accent text-xs font-bold uppercase tracking-[0.2em] block mb-2">Service Department</span>
          <h2 class="font-display text-3xl md:text-4xl font-extrabold text-neutral-900 tracking-tight">
            {locale === 'gu' ? 'અમારી સર્વિસ ટીમ' : 'Our Service Engineers'}
          </h2>
          <div class="w-12 h-1 bg-accent mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="grid gap-10 lg:grid-cols-12 items-start">
          <!-- Department Head (Left Column / Highlighted) -->
          {serviceHead ? (
            <div class="lg:col-span-5 bg-gradient-to-br from-accent-50/60 via-white to-white border border-accent-100/80 rounded-3xl p-8 text-center shadow-lg hover:shadow-accent-500/5 hover:-translate-y-1.5 transition-all duration-500 relative group">
              <div class="absolute top-4 right-4 bg-accent/10 text-accent text-[9px] font-extrabold uppercase tracking-widest px-3 py-1.5 rounded-full border border-accent-200/50">
                {t('team.serviceHead', locale)}
              </div>
              <div class="h-32 w-32 rounded-full bg-accent-50 border-2 border-accent-100 shadow-md mx-auto mb-6 overflow-hidden flex items-center justify-center p-1 group-hover:border-accent-300 transition-colors duration-300">
                {serviceHead.photo ? (
                  <CloudinaryImage src={serviceHead.photo} alt={serviceHead.name} crop="fill" class="h-full w-full object-cover rounded-full bg-white group-hover:scale-105 transition-transform duration-500" width={240} height={240} />
                ) : (
                  <span class="text-5xl opacity-30">👤</span>
                )}
              </div>
              <h3 class="font-display text-2xl font-black text-neutral-900 group-hover:text-accent transition-colors duration-300">{serviceHead.name}</h3>
              <p class="text-neutral-500 text-xs mt-1 uppercase tracking-wider font-semibold">{locale === 'gu' ? 'સર્વિસ હેડ' : 'Service Lead'}</p>
              
              <p class="text-neutral-600 text-sm mt-4 leading-relaxed font-light">
                {locale === 'gu'
                  ? 'સેવા અને વોરંટી ફરિયાદો માટે અમારા હેડ સાથે સંપર્ક કરો.'
                  : 'Contact our service lead directly for warranty escalations, technical support, and site inspection requests.'}
              </p>

              {serviceHead.phone && (
                <div class="mt-6 flex flex-col sm:flex-row gap-2 justify-center">
                  <a href={`tel:${serviceHead.phone}`} class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-700 text-white text-sm font-bold px-5 py-3 rounded-xl transition-colors shadow-md">
                    📞 Call: {serviceHead.phone}
                  </a>
                  <a href={`https://wa.me/${serviceHead.phone}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold px-5 py-3 rounded-xl transition-colors shadow-md">
                    💬 WhatsApp
                  </a>
                </div>
              )}
            </div>
          ) : null}

          <!-- Staff Members (Right Column Grid) -->
          <div class={`${serviceHead ? 'lg:col-span-7' : 'lg:col-span-12'} space-y-6`}>
            {serviceStaff.length > 0 ? (
              <div>
                <h4 class="text-xs font-bold text-neutral-400 uppercase tracking-widest mb-4">Technical Staff</h4>
                <div class="grid gap-4 sm:grid-cols-2">
                  {serviceStaff.map(member => (
                    <div class="bg-white border border-neutral-200 hover:border-accent-200 rounded-2xl p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-500 flex items-center gap-4 group">
                      <div class="h-16 w-16 rounded-full bg-neutral-50 border border-neutral-200/80 overflow-hidden flex items-center justify-center p-0.5 shrink-0 group-hover:border-accent-200 transition-colors duration-300">
                        {member.photo ? (
                          <CloudinaryImage src={member.photo} alt={member.name} crop="fill" class="h-full w-full object-cover rounded-full bg-white group-hover:scale-105 transition-transform duration-500" width={120} height={120} />
                        ) : (
                          <span class="text-2xl opacity-30">👤</span>
                        )}
                      </div>
                      <div class="flex-1 min-w-0">
                        <h4 class="font-bold text-sm text-neutral-900 truncate leading-snug group-hover:text-accent transition-colors">{member.name}</h4>
                        <span class="text-[10px] text-neutral-400 uppercase font-semibold block mt-0.5">{locale === 'gu' ? 'ટેકનિશિયન' : 'Service Engineer'}</span>
                        
                        {member.phone && (
                          <div class="mt-2 flex gap-2">
                            <a href={`tel:${member.phone}`} class="text-xs text-accent font-bold hover:underline inline-flex items-center gap-1">
                              📞 Call
                            </a>
                            <a href={`https://wa.me/${member.phone}`} target="_blank" rel="noopener noreferrer" class="text-xs text-emerald-600 font-bold hover:underline inline-flex items-center gap-1">
                              💬 Chat
                            </a>
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ) : (
              <div class="bg-white border border-neutral-200/80 rounded-2xl p-8 text-center text-neutral-400 text-xs shadow-sm">
                No service technical staff registered.
              </div>
            )}
          </div>
        </div>
      </Container>
    </section>
  )}

  <!-- CTA Section -->
  <section class="relative bg-[#060F1E] bg-gradient-to-br from-[#060F1E] via-[#0C1A30] to-[#060F1E] text-white py-24 overflow-hidden border-t border-white/[0.05]">
    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-30">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-secondary/20 rounded-full blur-[140px] animate-pulse"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-35"></div>
    </div>
    <Container class="text-center max-w-3xl relative z-10 space-y-6">
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-widest text-primary-200 mb-2 backdrop-blur-sm">
        📍 {locale === 'gu' ? 'મુલાકાત લો' : 'Visit Us'}
      </div>
      <h2 class="font-display text-3xl md:text-5xl font-black tracking-tight text-white drop-shadow-sm">
        {locale === 'gu' ? 'અમારી દુકાનની મુલાકાત લો' : 'Visit Our Store'}
      </h2>
      <p class="text-slate-200 max-w-xl mx-auto leading-relaxed text-sm md:text-base font-light">
        {locale === 'gu' ? 'ઇન્વર્ટર, બેટરી, સાઉન્ડ સિસ્ટમ અને DJ સ્પીકર સિસ્ટમ માટે અમારો સંપર્ક કરો.' : 'Contact us for Home Inverters, Batteries, Sound Systems and DJ Speaker Systems.'}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
        <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="inline-flex items-center justify-center gap-2.5 bg-white text-primary hover:bg-neutral-100 font-bold px-7 py-4 rounded-xl shadow-lg hover:shadow-white/10 hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 text-sm md:text-base group">
          <span class="group-hover:scale-110 transition-transform">📞</span> {t('contact.callNow', locale)}
        </a>
        <a href={`https://wa.me/${settings.whatsapp}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2.5 bg-emerald-600 text-white hover:bg-emerald-500 font-bold px-7 py-4 rounded-xl shadow-lg hover:shadow-emerald-500/20 hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 text-sm md:text-base group">
          <span class="group-hover:scale-110 transition-transform">💬</span> {t('contact.chatWhatsApp', locale)}
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
