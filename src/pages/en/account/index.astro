---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import { db } from '../../../db';
import { orders, serviceRequests } from '../../../db/schema';
import { eq, desc, or } from 'drizzle-orm';
import { getSessionUser, clearSessionUser } from '../../../lib/auth';
import { getLocalizedPath } from '../../../lib/translations';
import { getSettings } from '../../../services/cms';
import { translateObject } from '../../../lib/translations';

export const prerender = false;

const locale = 'en';
const rawSettings = await getSettings();
const settings = translateObject(rawSettings, locale);

// Authenticate user
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (currentUser && currentUser.role === 'admin') {
  return Astro.redirect('/admin');
}
if (!currentUser || currentUser.role !== 'customer') {
  return Astro.redirect(getLocalizedPath('/account/login', locale));
}

// Handle logout
if (Astro.url.searchParams.get('action') === 'logout') {
  clearSessionUser(Astro.cookies, Astro.url);
  return Astro.redirect(getLocalizedPath('/account/login', locale));
}

// Fetch user orders with items
let userOrders: any[] = [];
try {
  userOrders = await db.query.orders.findMany({
    where: eq(orders.userId, currentUser.id),
    orderBy: [desc(orders.createdAt)],
    with: {
      items: {
        with: {
          product: true,
        },
      },
    },
  });
} catch (e) {
  console.error('[User Account] Failed to fetch user orders:', e);
}

// Fetch user service requests
let userServiceRequests: any[] = [];
try {
  userServiceRequests = await db
    .select()
    .from(serviceRequests)
    .where(
      or(
        eq(serviceRequests.userId, currentUser.id),
        eq(serviceRequests.customerPhone, currentUser.phone)
      )
    )
    .orderBy(desc(serviceRequests.createdAt));
} catch (e) {
  console.error('[User Account] Failed to fetch user service requests:', e);
}

// English translations
const t = {
  title: `My Account - ${settings.businessName}`,
  welcome: 'Welcome, {name}',
  logout: 'Sign Out',
  creditsTitle: 'Your Store Credits',
  creditsSubtitle: 'Use these credits at checkout to receive additional discounts on your order.',
  referTitle: 'Refer Friends & Earn Credits!',
  referDesc: 'When someone signs up using your code, they get ₹50 credits instantly and you receive ₹100 credits!',
  yourCode: 'Your Referral Code:',
  copyBtn: 'Copy Link',
  copiedMsg: 'Link copied to clipboard!',
  shareWa: 'Share on WhatsApp',
  waText: `Sign up at ${settings.businessName} and get ₹50 off on your first order! My referral code: {code}. Sign up here: {link}`,
  historyTitle: 'Order History',
  noOrders: 'You have not placed any orders yet.',
  orderId: 'Order ID',
  total: 'Total',
  discount: 'Credits Discount',
  status: 'Status',
  date: 'Date',
  srTitle: 'Service Requests (Complaints)',
  newSrBtn: 'Raise New Complaint',
  noSrs: 'You have not raised any complaints yet.',
  srProduct: 'Product',
  srStatus: 'Status',
  srDetails: 'Complaint Details',
  srTracking: 'Tracking Info / Updates',
  srDate: 'Date',
};

// Construct absolute referral URL
const host = Astro.url.host;
const protocol = Astro.url.protocol;
const refLink = `${protocol}//${host}${getLocalizedPath('/account/login', locale)}?ref=${currentUser.referralCode}`;
const waShareUrl = `https://wa.me/?text=${encodeURIComponent(
  t.waText.replace('{code}', currentUser.referralCode).replace('{link}', refLink)
)}`;
---

<BaseLayout title={t.title} noindex={true}>
  <Container class="py-8 max-w-4xl">
    {/* Welcome Header */}
    <div class="flex flex-wrap items-center justify-between gap-4 border-b border-neutral-200 pb-5 mb-6">
      <div>
        <h1 class="text-2xl font-bold text-neutral-900">{t.welcome.replace('{name}', currentUser.name)}</h1>
        <p class="text-xs text-neutral-500">📞 {currentUser.phone}</p>
      </div>
      <a href="?action=logout" class="text-xs font-semibold text-red-600 border border-red-200 bg-red-50 hover:bg-red-100 rounded-md px-3 py-1.5 transition-colors">
        {t.logout}
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-3 mb-8">
      {/* Credits Card */}
      <div class="bg-gradient-to-br from-primary to-primary/90 rounded-lg p-5 text-white shadow-md flex flex-col justify-between md:col-span-1">
        <div>
          <h2 class="text-xs font-bold uppercase tracking-wider text-white/80">{t.creditsTitle}</h2>
          <p class="text-4xl font-extrabold mt-2">₹{currentUser.credits.toLocaleString('en-IN')}</p>
        </div>
        <p class="text-[11px] text-white/95 leading-relaxed mt-4">
          {t.creditsSubtitle}
        </p>
      </div>

      {/* Referral Program Card */}
      <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm md:col-span-2 flex flex-col justify-between">
        <div>
          <h2 class="text-base font-bold text-neutral-900">{t.referTitle}</h2>
          <p class="text-xs text-neutral-500 mt-1 leading-relaxed">
            {t.referDesc}
          </p>

          <div class="mt-4 flex flex-wrap items-center gap-3">
            <div class="bg-neutral-50 border border-neutral-200 rounded px-3 py-1.5 font-mono text-sm font-bold text-primary">
              {currentUser.referralCode}
            </div>
            
            <button 
              id="copy-ref-btn"
              onclick={`navigator.clipboard.writeText('${refLink}'); window.showToast('${t.copiedMsg}')`}
              class="text-xs font-semibold text-neutral-700 bg-neutral-100 hover:bg-neutral-200 rounded px-3 py-2 transition-colors focus:outline-none"
            >
              📋 {t.copyBtn}
            </button>
          </div>
        </div>

        <div class="mt-4 pt-4 border-t border-neutral-100">
          <a 
            href={waShareUrl} 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white text-xs font-bold py-2 px-4 rounded-md transition-colors"
          >
            <span>💬</span> {t.shareWa}
          </a>
        </div>
      </div>
    </div>

    {/* Order History */}
    <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm">
      <h2 class="text-lg font-bold text-neutral-900 border-b border-neutral-100 pb-3 mb-4">{t.historyTitle}</h2>
      
      <div class="space-y-4">
        {userOrders.map((order) => {
          const dateStr = new Date(order.createdAt).toLocaleDateString('en-US', {
            day: '2-digit',
            month: 'short',
            year: 'numeric',
          });

          return (
            <div class="border border-neutral-150 rounded-md p-4 bg-neutral-50/20">
              <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-100 pb-2 mb-3">
                <div>
                  <span class="text-[10px] font-bold text-neutral-400 uppercase">{t.orderId}</span>
                  <p class="text-xs font-mono font-bold text-neutral-700">#{order.id.slice(0, 8)}</p>
                </div>
                
                <div class="text-right">
                  <span class="text-[10px] text-neutral-400 block">{t.date}</span>
                  <span class="text-xs text-neutral-600 font-medium">{dateStr}</span>
                </div>

                <div>
                  <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-semibold uppercase border ${
                    order.status === 'pending' ? 'bg-amber-50 text-amber-700 border-amber-200' :
                    order.status === 'processing' ? 'bg-blue-50 text-blue-700 border-blue-200' :
                    order.status === 'delivered' ? 'bg-green-50 text-green-700 border-green-200' :
                    'bg-neutral-50 text-neutral-700 border-neutral-200'
                  }`}>
                    {order.status}
                  </span>
                </div>
              </div>

              {/* Items List */}
              <div class="divide-y divide-neutral-100 mb-3">
                {order.items?.map((item: any) => (
                  <div class="py-1.5 flex justify-between text-xs gap-4">
                    <span class="font-medium text-neutral-800 flex-1">{item.product?.name || 'Product'}</span>
                    <span class="text-neutral-500 shrink-0">₹{item.price.toLocaleString('en-IN')} x {item.quantity}</span>
                  </div>
                ))}
              </div>

              {/* Totals */}
              <div class="flex flex-col items-end border-t border-neutral-100 pt-2 gap-0.5 text-xs">
                {order.creditsUsed > 0 && (
                  <span class="text-green-600 font-medium">
                    {t.discount}: -₹{order.creditsUsed.toLocaleString('en-IN')}
                  </span>
                )}
                <span class="font-semibold text-neutral-800">
                  {t.total}: <span class="text-sm font-bold text-primary">₹{order.totalAmount.toLocaleString('en-IN')}</span>
                </span>
              </div>
            </div>
          );
        })}

        {userOrders.length === 0 && (
          <p class="text-sm text-neutral-500 py-4 text-center">
            {t.noOrders}
          </p>
        )}
      </div>
    </div>

    {/* Service Requests Section */}
    <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm mt-6">
      <div class="flex flex-wrap items-center justify-between gap-4 border-b border-neutral-100 pb-3 mb-4">
        <h2 class="text-lg font-bold text-neutral-900">{t.srTitle}</h2>
        <a href={getLocalizedPath('/service-request', locale)} class="text-xs font-bold bg-primary text-white hover:bg-primary/95 px-3 py-1.5 rounded-md transition-colors">
          + {t.newSrBtn}
        </a>
      </div>
      
      <div class="space-y-4">
        {userServiceRequests.map((sr) => {
          const dateStr = new Date(sr.createdAt).toLocaleDateString(locale === 'en' ? 'en-US' : 'en-IN', {
            day: '2-digit',
            month: 'short',
            year: 'numeric',
          });

          return (
            <div class="border border-neutral-150 rounded-md p-4 bg-neutral-50/20">
              <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-100 pb-2 mb-3">
                <div>
                  <span class="text-[10px] font-bold text-neutral-400 uppercase">{t.srDate}</span>
                  <p class="text-xs font-medium text-neutral-600">{dateStr}</p>
                </div>
                
                <div>
                  <span class={`inline-block rounded px-2 py-0.5 text-[10px] font-semibold uppercase border ${
                    sr.status === 'pending' ? 'bg-amber-50 text-amber-700 border-amber-200' :
                    sr.status === 'in_progress' ? 'bg-blue-50 text-blue-700 border-blue-200' :
                    sr.status === 'resolved' ? 'bg-green-50 text-green-700 border-green-200' :
                    'bg-neutral-50 text-neutral-700 border-neutral-200'
                  }`}>
                    {sr.status}
                  </span>
                </div>
              </div>

              <div class="space-y-2.5">
                <div>
                  <h3 class="text-xs font-bold text-neutral-400 uppercase">{t.srProduct}</h3>
                  <p class="text-sm font-semibold text-neutral-800">{sr.productName}</p>
                </div>

                <div>
                  <h3 class="text-xs font-bold text-neutral-400 uppercase">{t.srDetails}</h3>
                  <p class="text-xs text-neutral-600 whitespace-pre-line leading-relaxed">{sr.complaintDetails}</p>
                </div>

                {sr.trackingInfo && (
                  <div class="bg-neutral-100/60 rounded p-3 border border-neutral-200/50">
                    <h3 class="text-xs font-bold text-primary uppercase mb-1">{t.srTracking}</h3>
                    <p class="text-xs text-neutral-700 whitespace-pre-line leading-relaxed">{sr.trackingInfo}</p>
                  </div>
                )}
              </div>
            </div>
          );
        })}

        {userServiceRequests.length === 0 && (
          <p class="text-sm text-neutral-500 py-4 text-center">
            {t.noSrs}
          </p>
        )}
      </div>
    </div>
  </Container>
</BaseLayout>
