---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { db } from '../../db';
import { products, orders, orderItems, users, offers, bundleRules } from '../../db/schema';
import { eq, inArray, and, asc, desc } from 'drizzle-orm';
import { getSessionUser, generateId } from '../../lib/auth';
import { getLocalizedPath } from '../../lib/translations';
import { getSettings } from '../../services/cms';
import { translateObject } from '../../lib/translations';
import { cloudinaryConfig } from '../../config/cloudinary';

export const prerender = false;

const locale = 'en';
const rawSettings = await getSettings();
const settings = translateObject(rawSettings, locale);

const rawBundleRules = await db
  .select()
  .from(bundleRules)
  .where(eq(bundleRules.isActive, true))
  .orderBy(asc(bundleRules.minQuantity));
const bundleRulesList = translateObject(rawBundleRules, locale);

const rawBundleProducts = await db
  .select()
  .from(products)
  .where(and(eq(products.isActive, true), eq(products.eligibleForBundle, true)))
  .orderBy(desc(products.createdAt));
const bundleProductsList = translateObject(rawBundleProducts, locale);




// Authenticate user. Redirect to login if not logged in.
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);
if (!currentUser) {
  return Astro.redirect(`/en/account/login?redirect=${encodeURIComponent('/en/cart')}`);
}

let error = Astro.url.searchParams.get('error') || '';
let successOrderId = Astro.url.searchParams.get('successOrderId') || '';

// Handle Checkout Form Submission
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const customerName = formData.get('name')?.toString().trim() || '';
    const customerPhone = formData.get('phone')?.toString().trim() || '';
    const shippingAddress = formData.get('address')?.toString().trim() || '';
    const cartItemsRaw = formData.get('cartItems')?.toString() || '[]';
    const couponCode = formData.get('couponCode')?.toString().trim().toUpperCase() || '';
    const redeemPointsStr = formData.get('redeemPoints')?.toString().trim() || '0';

    let redeemPoints = parseInt(redeemPointsStr, 10);
    if (isNaN(redeemPoints) || redeemPoints < 0) redeemPoints = 0;

    const cart = JSON.parse(cartItemsRaw);

    if (!customerName || !customerPhone || !shippingAddress || cart.length === 0) {
      error = 'Please fill in all details and add items to cart.';
    } else {
      // 1. Gather product IDs and verify prices from DB
      const productIds = cart.map((item: any) => item.id);
      const dbProducts = await db.select().from(products).where(inArray(products.id, productIds));
      
      let subtotal = 0;
      let eligibleQty = 0;
      const orderLines: { productId: string; quantity: number; price: number }[] = [];
 
      cart.forEach((cartItem: any) => {
        const dbProduct = dbProducts.find((p: any) => p.id === cartItem.id);
        if (dbProduct) {
          const price = dbProduct.offerPrice > 0 ? dbProduct.offerPrice : dbProduct.mrp;
          subtotal += price * cartItem.quantity;
          orderLines.push({
            productId: dbProduct.id,
            quantity: cartItem.quantity,
            price,
          });
          if (dbProduct.eligibleForBundle) {
            eligibleQty += cartItem.quantity;
          }
        }
      });
 
      if (orderLines.length === 0) {
        error = 'Cart contains invalid products.';
      } else {
        // 2. Resolve Coupon discount
        let couponDiscount = 0;
        let appliedCoupon: string | null = null;

        if (couponCode) {
          const [offer] = await db
            .select()
            .from(offers)
            .where(
              and(
                eq(offers.couponCode, couponCode),
                eq(offers.isActive, true)
              )
            );

          if (offer) {
            let isValid = true;
            if (offer.validUntil) {
              const expiry = new Date(offer.validUntil);
              const today = new Date();
              today.setHours(0, 0, 0, 0);
              if (expiry.getTime() < today.getTime()) {
                isValid = false;
              }
            }
            if (offer.minOrderValue && subtotal < offer.minOrderValue) {
              isValid = false;
            }

            if (isValid) {
              appliedCoupon = offer.couponCode;
              const discountVal = offer.discountValue ?? 0;
              if (offer.discountType === 'percentage') {
                let calcDiscount = Math.round(subtotal * (discountVal / 100));
                if (offer.discountCap && calcDiscount > offer.discountCap) {
                  calcDiscount = offer.discountCap;
                }
                couponDiscount = calcDiscount;
              } else {
                couponDiscount = discountVal;
              }
              couponDiscount = Math.min(couponDiscount, subtotal);
            }
          }
        }

        // 2.5 Resolve Bundle rule discount/rewards on the server
        let bundleDiscount = 0;
        let appliedBundleRuleId: string | null = null;
        let appliedBundleRewardGiven: string | null = null;

        if (eligibleQty > 0) {
          const activeRules = await db
            .select()
            .from(bundleRules)
            .where(eq(bundleRules.isActive, true))
            .orderBy(desc(bundleRules.minQuantity));
          
          const matchedRule = activeRules.find((r: any) => eligibleQty >= r.minQuantity);
          if (matchedRule) {
            appliedBundleRuleId = matchedRule.id;
            const localizedRule = translateObject(matchedRule, locale);
            if (matchedRule.rewardType === 'percentage_discount') {
              bundleDiscount = Math.round(subtotal * (matchedRule.rewardValue / 100));
            } else if (matchedRule.rewardType === 'flat_discount') {
              bundleDiscount = matchedRule.rewardValue;
            } else {
              appliedBundleRewardGiven = localizedRule.rewardDescription;
            }
            bundleDiscount = Math.min(bundleDiscount, subtotal - couponDiscount);
          }
        }

        // 3. Resolve store credits/points usage
        let creditsToUse = 0;
        if (redeemPoints > 0) {
          // Re-fetch user to get fresh credits balance
          const [userRecord] = await db.select().from(users).where(eq(users.id, currentUser.id));
          if (userRecord && userRecord.credits > 0) {
            const maxUsableCredits = Math.min(userRecord.credits, subtotal - couponDiscount - bundleDiscount);
            creditsToUse = Math.min(redeemPoints, maxUsableCredits);
          }
        }

        const totalAmount = subtotal - couponDiscount - bundleDiscount - creditsToUse;
        const newOrderId = generateId();

        // 4. Insert into orders table
        await db.insert(orders).values({
          id: newOrderId,
          userId: currentUser.id,
          customerName,
          customerPhone,
          shippingAddress,
          creditsUsed: creditsToUse,
          totalAmount,
          status: 'pending',
          createdAt: new Date().toISOString(),
          couponCode: appliedCoupon,
          discountApplied: couponDiscount,
          bundleRuleId: appliedBundleRuleId,
          bundleDiscountApplied: bundleDiscount,
          bundleRewardGiven: appliedBundleRewardGiven,
        });

        // 5. Insert order items
        for (const line of orderLines) {
          await db.insert(orderItems).values({
            id: generateId(),
            orderId: newOrderId,
            productId: line.productId,
            quantity: line.quantity,
            price: line.price,
          });
        }

        // 6. Deduct credits if used
        if (creditsToUse > 0) {
          await db
            .update(users)
            .set({ credits: currentUser.credits - creditsToUse })
            .where(eq(users.id, currentUser.id));
        }

        return Astro.redirect(Astro.url.pathname + '?successOrderId=' + encodeURIComponent(newOrderId));
      }
    }
  } catch (e) {
    console.error('[Checkout Error]:', e);
    error = 'Checkout failed. Please try again.';
  }
}

// Inline English translations
const t = {
  title: `My Cart - ${settings.businessName}`,
  header: 'Shopping Cart',
  emptyCart: 'Your cart is empty.',
  browseBtn: 'Browse Products',
  summaryTitle: 'Order Summary',
  subtotal: 'Subtotal',
  creditsAvailable: 'Available: {amount} Pts',
  useCredits: 'Apply Store Credits Discount',
  total: 'Total Payable Amount',
  detailsTitle: 'Delivery Details',
  nameLabel: 'Full Name',
  phoneLabel: 'Phone Number',
  addressLabel: 'Full Shipping Address',
  placeOrderBtn: 'Place Order (Cash on Delivery)',
  successTitle: 'Order Placed Successfully!',
  successDesc: `Thank you for shopping at ${settings.businessName}. Your order has been registered.`,
  orderIdText: 'Order ID:',
  orderNote: 'Our team will contact you shortly to confirm the delivery details.',
  backShopBtn: 'Continue Shopping',
  accDashboard: 'Track Order Status',
  quantity: 'Quantity',
  remove: 'Remove',
  couponLabel: 'Apply Discount Code',
  applyBtn: 'Apply',
  pointsLabel: 'Redeem Points',
  pointsHelper: '1 Point = ₹1. Up to subtotal after coupon discount.',
  redeemMax: 'Redeem Max',
  couponApplied: 'Coupon Discount',
  pointsApplied: 'Points Redeemed',
};
---

<BaseLayout title={t.title} noindex={true}>
  <Container class="py-8 max-w-5xl">
    {successOrderId ? (
      /* Success View */
      <div class="bg-white border border-neutral-200 rounded-lg p-8 max-w-xl mx-auto text-center shadow-md">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-green-100 text-green-600 text-3xl mb-4">
          ✓
        </div>
        <h1 class="text-2xl font-bold text-neutral-900 mb-2">{t.successTitle}</h1>
        <p class="text-sm text-neutral-600 mb-6">{t.successDesc}</p>
        
        <div class="bg-neutral-50 rounded-md border border-neutral-100 p-4 mb-6 font-mono text-xs text-neutral-700">
          <span class="font-sans font-bold text-neutral-500 uppercase tracking-wider block mb-1">{t.orderIdText}</span>
          <span class="text-sm font-bold text-neutral-900">{successOrderId}</span>
        </div>
        
        <p class="text-xs text-neutral-500 mb-6 leading-relaxed">
          {t.orderNote}
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={getLocalizedPath('/products', locale)} class="btn-primary px-6 py-2.5 text-sm font-semibold">
            {t.backShopBtn}
          </a>
          <a href={getLocalizedPath('/account', locale)} class="btn-outline px-6 py-2.5 text-sm">
            {t.accDashboard}
          </a>
        </div>
      </div>
    ) : (
      /* Main Cart View */
      <div>
        <h1 class="text-2xl font-bold text-neutral-900 border-b border-neutral-200 pb-4 mb-6">
          {t.header}
        </h1>

        {error && (
          <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-md p-3 mb-6">
            {error}
          </div>
        )}

        <div class="grid gap-8 lg:grid-cols-3">
          {/* Cart Items Column */}
          <div class="lg:col-span-2 space-y-4">
            <div id="cart-loading" class="text-center py-12 text-neutral-500">
              Loading cart items...
            </div>
            
            <div id="cart-empty" class="hidden bg-white border border-neutral-200 rounded-lg p-12 text-center shadow-sm">
              <span class="text-4xl mb-4 block">🛒</span>
              <p class="text-sm text-neutral-500 mb-6">{t.emptyCart}</p>
              <a href={getLocalizedPath('/products', locale)} class="btn-primary px-6 py-2.5 text-sm font-semibold inline-block">
                {t.browseBtn}
              </a>
            </div>

            <div id="cart-items-container" class="space-y-3">
              {/* Dynanically populated by JS */}
            </div>

            <!-- Bundle Organizer View -->
            <div id="bundle-organizer-container" class="hidden mt-6 bg-white border border-neutral-200 rounded-xl p-5 shadow-sm space-y-4">
              <!-- Dynamically populated by JS -->
            </div>
          </div>

          {/* Checkout & Summary Form Column */}
          <div class="lg:col-span-1">
            <div class="bg-white border border-neutral-200 rounded-lg p-5 shadow-sm sticky top-24">
              <h2 class="text-base font-bold text-neutral-900 border-b border-neutral-100 pb-3 mb-4">
                {t.summaryTitle}
              </h2>

              <div class="space-y-3 text-sm pb-4 border-b border-neutral-100">
                <div class="flex justify-between text-neutral-600">
                  <span>{t.subtotal}</span>
                  <span class="font-bold text-neutral-900" id="cart-subtotal">₹0</span>
                </div>

                <!-- Dynamic Coupon Row -->
                <div class="flex justify-between text-green-600 hidden" id="coupon-discount-row">
                  <span>{t.couponApplied} (<span id="applied-coupon-label"></span>)</span>
                  <span class="font-bold font-mono" id="coupon-discount-value">-₹0</span>
                </div>

                <!-- Dynamic Bundle Row -->
                <div class="flex flex-col border border-dashed border-secondary/35 rounded-md p-2.5 bg-secondary/5 hidden" id="bundle-discount-row">
                  <div class="flex justify-between text-secondary font-bold">
                    <span id="applied-bundle-label">Bundle Deal</span>
                    <span class="font-bold font-mono" id="bundle-discount-value">-₹0</span>
                  </div>
                  <p class="text-[10px] text-neutral-500 mt-0.5" id="bundle-reward-desc"></p>
                </div>

                <!-- Dynamic Points Row -->
                <div class="flex justify-between text-green-600 hidden" id="points-discount-row">
                  <span>{t.pointsApplied}</span>
                  <span class="font-bold font-mono" id="points-discount-value">-₹0</span>
                </div>

                <!-- Apply Discount Code Field -->
                <div class="border border-neutral-200 rounded-md p-3 bg-neutral-50/50">
                  <label for="coupon-code-field" class="block text-[11px] font-bold text-neutral-600 uppercase mb-1">{t.couponLabel}</label>
                  <div class="flex gap-1.5">
                    <input 
                      type="text" 
                      id="coupon-code-field" 
                      placeholder="e.g. SAVE20" 
                      class="flex-1 rounded border border-neutral-300 px-2.5 py-1 text-xs focus:border-primary focus:outline-none uppercase font-mono font-bold"
                    />
                    <button 
                      type="button" 
                      id="apply-coupon-btn" 
                      onclick="applyCouponCode()"
                      class="bg-neutral-800 text-white text-xs font-semibold px-3 py-1 rounded hover:bg-neutral-900 transition-colors focus:outline-none cursor-pointer"
                    >
                      {t.applyBtn}
                    </button>
                  </div>
                  <p class="text-[10px] mt-1 font-semibold text-red-600 hidden" id="coupon-error"></p>
                  <p class="text-[10px] mt-1 font-semibold text-green-600 hidden" id="coupon-success"></p>
                </div>

                <!-- Redeem Points Field -->
                <div class="border border-neutral-200 rounded-md p-3 bg-neutral-50/50">
                  <div class="flex justify-between items-center mb-1">
                    <label for="points-redeem-field" class="block text-[11px] font-bold text-neutral-600 uppercase">{t.pointsLabel}</label>
                    <span class="text-[10px] font-bold text-green-700">{t.creditsAvailable.replace('{amount}', currentUser.credits.toString())}</span>
                  </div>
                  <div class="flex gap-1.5 items-center">
                    <input 
                      type="number" 
                      id="points-redeem-field" 
                      value="0"
                      min="0"
                      max={currentUser.credits}
                      oninput="recalculateTotals()"
                      class="w-24 rounded border border-neutral-300 px-2 py-1 text-xs focus:border-primary focus:outline-none font-mono font-bold"
                    />
                    <button 
                      type="button" 
                      onclick={`document.getElementById('points-redeem-field').value = ${currentUser.credits}; recalculateTotals()`}
                      class="text-[10px] font-bold text-primary hover:underline cursor-pointer focus:outline-none"
                    >
                      {t.redeemMax}
                    </button>
                  </div>
                  <p class="text-[9px] text-neutral-400 mt-1 leading-tight">{t.pointsHelper}</p>
                </div>

                <div class="flex justify-between text-neutral-900 font-bold border-t border-neutral-100 pt-3">
                  <span>{t.total}</span>
                  <span class="text-lg text-primary" id="cart-final-total">₹0</span>
                </div>
              </div>

              {/* Checkout Form */}
              <form method="post" id="checkout-form" class="mt-4 space-y-4">
                <input type="hidden" name="cartItems" id="cart-items-input" />
                <input type="hidden" name="couponCode" id="coupon-code-input" />
                <input type="hidden" name="redeemPoints" id="redeem-points-input" value="0" />
                <input type="hidden" name="bundleRuleId" id="bundle-rule-input" />
                <input type="hidden" name="bundleDiscountApplied" id="bundle-discount-input" value="0" />
                <input type="hidden" name="bundleRewardGiven" id="bundle-reward-input" />

                <h3 class="text-xs font-bold uppercase text-neutral-400 mt-2">
                  {t.detailsTitle}
                </h3>

                <div>
                  <label for="checkout-name" class="block text-xs font-semibold text-neutral-700 mb-1">{t.nameLabel} *</label>
                  <input
                    type="text"
                    id="checkout-name"
                    name="name"
                    required
                    value={currentUser?.name || ''}
                    placeholder="e.g. Hardik Patel"
                    class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none"
                  />
                </div>

                <div>
                  <label for="checkout-phone" class="block text-xs font-semibold text-neutral-700 mb-1">{t.phoneLabel} *</label>
                  <input
                    type="tel"
                    id="checkout-phone"
                    name="phone"
                    required
                    value={currentUser?.phone || ''}
                    placeholder="e.g. 9876543210"
                    class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none"
                  />
                </div>

                <div>
                  <label for="checkout-address" class="block text-xs font-semibold text-neutral-700 mb-1">{t.addressLabel} *</label>
                  <textarea
                    id="checkout-address"
                    name="address"
                    required
                    rows="3"
                    placeholder="House No., Street Name, Area, City"
                    class="w-full rounded border border-neutral-300 px-3 py-1.5 text-xs focus:border-primary focus:outline-none"
                  ></textarea>
                </div>

                <button 
                  type="submit" 
                  id="checkout-submit-btn"
                  class="w-full btn-primary py-2.5 text-xs font-semibold focus:outline-none cursor-pointer"
                >
                  {t.placeOrderBtn}
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    )}
  </Container>
</BaseLayout>

<script is:inline define:vars={{ userCredits: currentUser?.credits || 0, successOrderId, locale, cloudName: cloudinaryConfig.cloudName, bundleRulesList, bundleProductsList }}>
  // Manage client side cart
  const CART_KEY = 'ye_cart';
  let activeCoupon = null; // Holds { code, discountType, discountValue }

  function getCart() {
    try {
      return JSON.parse(localStorage.getItem(CART_KEY) || '[]');
    } catch (e) {
      return [];
    }
  }

  function saveCart(cart) {
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart-updated'));
  }

  function renderCart() {
    const loadingEl = document.getElementById('cart-loading');
    const emptyEl = document.getElementById('cart-empty');
    const containerEl = document.getElementById('cart-items-container');
    const checkoutForm = document.getElementById('checkout-form');
    
    if (loadingEl) loadingEl.style.display = 'none';

    const cart = getCart();

    if (cart.length === 0) {
      if (emptyEl) emptyEl.classList.remove('hidden');
      if (containerEl) containerEl.innerHTML = '';
      const organizerContainer = document.getElementById('bundle-organizer-container');
      if (organizerContainer) organizerContainer.classList.add('hidden');
      if (checkoutForm) {
        const submitBtn = document.getElementById('checkout-submit-btn');
        if (submitBtn) submitBtn.disabled = true;
      }
      return;
    }

    if (emptyEl) emptyEl.classList.add('hidden');
    if (!containerEl) return;

    function buildImageUrl(imagePath) {
      if (!imagePath) return '/images/placeholder-product.svg';
      if (imagePath.startsWith('/') || imagePath.startsWith('http')) return imagePath;
      return `https://res.cloudinary.com/${cloudName}/image/upload/${imagePath}`;
    }

    // Render items
    containerEl.innerHTML = cart.map((item) => `
      <div class="bg-white border border-neutral-200 rounded-lg p-4 flex flex-col sm:flex-row gap-4 items-start sm:items-center animate-fade-in w-full">
        <div class="flex gap-3 w-full sm:w-auto items-center sm:items-start">
          <!-- Thumbnail -->
          <div class="h-16 w-16 bg-neutral-100 rounded border border-neutral-200 flex items-center justify-center text-xl shrink-0">
            ${item.image ? `<img src="${buildImageUrl(item.image)}" alt="${item.name}" class="h-full w-full object-cover rounded" />` : '📺'}
          </div>
          
          <!-- Info -->
          <div class="flex-1 min-w-0">
            <h3 class="text-sm font-bold text-neutral-900 break-words">${item.name}</h3>
            <p class="text-xs text-primary font-bold mt-0.5 font-mono">₹${item.price.toLocaleString('en-IN')}</p>
          </div>
        </div>

        <!-- Controls Row -->
        <div class="flex items-center justify-between sm:justify-start gap-4 w-full sm:w-auto sm:ml-auto pt-2 sm:pt-0 border-t sm:border-t-0 border-neutral-100">
          <!-- Quantity Controls -->
          <div class="flex items-center gap-1 border border-neutral-200 rounded bg-neutral-50 px-1">
            <button type="button" onclick="updateQty('${item.id}', -1)" class="h-6 w-6 font-bold text-neutral-600 hover:text-primary focus:outline-none cursor-pointer">-</button>
            <span class="text-xs font-bold w-6 text-center font-mono">${item.quantity}</span>
            <button type="button" onclick="updateQty('${item.id}', 1)" class="h-6 w-6 font-bold text-neutral-600 hover:text-primary focus:outline-none cursor-pointer">+</button>
          </div>

          <!-- Remove -->
          <button type="button" onclick="removeItem('${item.id}')" class="text-xs font-semibold text-red-500 hover:text-red-700 hover:underline cursor-pointer">
            ${locale === 'en' ? 'Remove' : 'કાઢી નાખો'}
          </button>
        </div>
      </div>
    `).join('');

    recalculateTotals();
  }

  window.updateQty = function (productId, delta) {
    let cart = getCart();
    const item = cart.find(i => i.id === productId);
    if (item) {
      item.quantity = Math.max(1, item.quantity + delta);
      saveCart(cart);
      renderCart();
    }
  };

  window.removeItem = function (productId) {
    let cart = getCart();
    cart = cart.filter(i => i.id !== productId);
    saveCart(cart);
    renderCart();
  };

  window.applyCouponCode = async function () {
    const field = document.getElementById('coupon-code-field');
    const errEl = document.getElementById('coupon-error');
    const succEl = document.getElementById('coupon-success');
    
    if (!field || !errEl || !succEl) return;

    const code = field.value.trim().toUpperCase();
    errEl.classList.add('hidden');
    succEl.classList.add('hidden');

    if (!code) {
      activeCoupon = null;
      recalculateTotals();
      return;
    }

    try {
      const res = await fetch(`/api/validate-coupon?code=${encodeURIComponent(code)}`);
      const data = await res.json();

      if (data.valid) {
        const subtotal = getCart().reduce((sum, item) => sum + item.price * item.quantity, 0);
        if (data.minOrderValue && subtotal < data.minOrderValue) {
          activeCoupon = null;
          errEl.textContent = locale === 'en' 
            ? `Minimum order value of ₹${data.minOrderValue} required for this coupon.`
            : `આ કૂપન માટે ન્યૂનતમ ₹${data.minOrderValue} નો ઓર્ડર જરૂરી છે.`;
          errEl.classList.remove('hidden');
        } else {
          activeCoupon = data;
          succEl.textContent = locale === 'en' 
            ? `Coupon ${data.code} applied successfully!` 
            : `કૂપન ${data.code} સફળતાપૂર્વક લાગુ થઈ!`;
          succEl.classList.remove('hidden');
        }
      } else {
        activeCoupon = null;
        errEl.textContent = data.message || (locale === 'en' ? 'Invalid coupon code.' : 'અમાન્ય કૂપન કોડ.');
        errEl.classList.remove('hidden');
      }
    } catch (e) {
      activeCoupon = null;
      errEl.textContent = locale === 'en' ? 'Failed to validate coupon.' : 'કૂપન તપાસવામાં ભૂલ આવી.';
      errEl.classList.remove('hidden');
    }

    recalculateTotals();
  };

  window.addEligibleProductToCart = function (productId) {
    const product = bundleProductsList.find(p => p.id === productId);
    if (!product) return;

    let cart = getCart();
    const existing = cart.find(item => item.id === productId);
    const price = product.offerPrice > 0 ? product.offerPrice : product.mrp;
    
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push({
        id: product.id,
        name: product.name,
        price: price,
        image: product.images?.[0] || '',
        eligibleForBundle: true,
        quantity: 1
      });
    }
    
    saveCart(cart);
    renderCart();
    
    if (window.showToast) {
      window.showToast(locale === 'en' ? 'Product added to cart!' : 'પ્રોડક્ટ કાર્ટમાં ઉમેરવામાં આવી!');
    }
  };

  function renderBundleOrganizer(cart, eligibleQty, subtotal) {
    const organizerContainer = document.getElementById('bundle-organizer-container');
    if (!organizerContainer) return;

    if (cart.length === 0 || !bundleRulesList || bundleRulesList.length === 0) {
      organizerContainer.classList.add('hidden');
      return;
    }

    organizerContainer.classList.remove('hidden');

    // Sort rules ascending by minQuantity
    const sortedRules = [...bundleRulesList].sort((a, b) => a.minQuantity - b.minQuantity);
    const maxRuleQty = sortedRules.length > 0 ? sortedRules[sortedRules.length - 1].minQuantity : 1;

    // Progress bar percentage
    const progressPercentage = Math.min(100, (eligibleQty / maxRuleQty) * 100);

    // Determine next locked rule or highest unlocked rule message
    let progressTip = '';
    const nextLockedRule = sortedRules.find(r => eligibleQty < r.minQuantity);
    const highestUnlockedRule = [...sortedRules].reverse().find(r => eligibleQty >= r.minQuantity);

    if (nextLockedRule) {
      const diff = nextLockedRule.minQuantity - eligibleQty;
      progressTip = locale === 'en'
        ? `Add <strong class="text-secondary">${diff}</strong> more eligible item${diff > 1 ? 's' : ''} to unlock: <strong class="text-primary">${nextLockedRule.rewardDescription}</strong>`
        : `મેળવવા માટે વધુ <strong class="text-secondary">${diff}</strong> લાયક પ્રોડક્ટ ઉમેરો: <strong class="text-primary">${nextLockedRule.rewardDescription}</strong>`;
    } else if (highestUnlockedRule) {
      progressTip = locale === 'en'
        ? `<span class="text-green-600 font-bold">Congratulations! You have unlocked the best bundle deal: <strong>${highestUnlockedRule.rewardDescription}</strong> 🌟</span>`
        : `<span class="text-green-600 font-bold">અભિનંદન! તમે શ્રેષ્ઠ બંડલ ડીલ અનલોક કરી દીધી છે: <strong>${highestUnlockedRule.rewardDescription}</strong> 🌟</span>`;
    } else {
      progressTip = locale === 'en'
        ? `Add bundle-eligible products to start unlocking discounts!`
        : `બંડલ ડિસ્કાઉન્ટ મેળવવા માટે લાયક પ્રોડક્ટ્સ ઉમેરો!`;
    }

    // Render milestones / rules list
    const rulesListHtml = sortedRules.map(r => {
      const isUnlocked = eligibleQty >= r.minQuantity;
      return `
        <div class="flex items-center justify-between p-3 rounded-lg border ${isUnlocked ? 'border-green-200 bg-green-50/40 text-green-800' : 'border-neutral-200 bg-neutral-50 text-neutral-600'} transition-all">
          <div class="flex items-center gap-2.5">
            <span class="text-sm shrink-0">${isUnlocked ? '✅' : '🔒'}</span>
            <div class="min-w-0">
              <span class="text-xs font-bold font-sans block truncate">${r.name}</span>
              <p class="text-[10px] text-neutral-500 mt-0.5 leading-tight">${r.rewardDescription}</p>
            </div>
          </div>
          <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-white border ${isUnlocked ? 'border-green-300 text-green-700' : 'border-neutral-300 text-neutral-500'} font-mono shrink-0 select-none ml-2">
            Min Qty: ${r.minQuantity}
          </span>
        </div>
      `;
    }).join('');

    // Filter products to show: bundle eligible and NOT already in cart
    const cartIds = new Set(cart.map(item => item.id));
    let itemsToShow = bundleProductsList.filter(p => !cartIds.has(p.id)).slice(0, 3);
    if (itemsToShow.length === 0) {
      itemsToShow = bundleProductsList.slice(0, 3);
    }

    const productsHtml = itemsToShow.map(p => {
      const price = p.offerPrice > 0 ? p.offerPrice : p.mrp;
      const imageUrl = p.images && p.images[0]
        ? (p.images[0].startsWith('/') || p.images[0].startsWith('http') ? p.images[0] : `https://res.cloudinary.com/${cloudName}/image/upload/w_150,h_150,c_fill,f_auto,q_auto/${p.images[0]}`)
        : '/images/placeholder-product.svg';
      
      return `
        <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-3 flex flex-col justify-between hover:shadow-sm transition-all group">
          <div class="flex gap-2.5 items-start">
            <div class="w-12 h-12 bg-white rounded border border-neutral-100 overflow-hidden shrink-0 flex items-center justify-center">
              <img src="${imageUrl}" alt="${p.name}" class="object-cover h-full w-full" />
            </div>
            <div class="flex-1 min-w-0">
              <span class="text-[9px] uppercase font-bold text-neutral-400 font-sans tracking-wide block truncate">${p.brand}</span>
              <h4 class="font-bold text-neutral-850 text-xs truncate mt-0.5" title="${p.name}">${p.name}</h4>
              <div class="flex items-center gap-1.5 mt-0.5">
                <span class="text-primary font-bold text-xs font-mono">₹${price.toLocaleString('en-IN')}</span>
                ${p.mrp > price ? `<span class="text-[9px] text-neutral-400 line-through font-mono">₹${p.mrp.toLocaleString('en-IN')}</span>` : ''}
              </div>
            </div>
          </div>
          <button 
            type="button" 
            onclick="addEligibleProductToCart('${p.id}')"
            class="mt-2.5 w-full bg-white border border-neutral-200 hover:border-secondary hover:bg-secondary/5 text-neutral-700 hover:text-secondary text-[10px] font-bold py-1.5 px-2 rounded transition-all cursor-pointer text-center"
          >
            ${locale === 'en' ? '+ Add to Cart' : '+ કાર્ટમાં ઉમેરો'}
          </button>
        </div>
      `;
    }).join('');

    const relevantProductsSectionHtml = productsHtml.length > 0 
      ? `
        <div class="border-t border-neutral-100 pt-4">
          <h4 class="text-xs font-bold text-neutral-850 mb-3 flex items-center gap-1.5">
            <span>📦</span> ${locale === 'en' ? 'Eligible Products You Can Add Directly' : 'લાયક પ્રોડક્ટ્સ જે તમે ઉમેરી શકો છો'}
          </h4>
          <div class="grid gap-3 sm:grid-cols-3">
            ${productsHtml}
          </div>
        </div>
      `
      : '';

    organizerContainer.innerHTML = `
      <div class="flex items-center justify-between border-b border-neutral-100 pb-3 mb-1">
        <h3 class="text-sm font-bold text-neutral-900 flex items-center gap-1.5">
          <span>🎁</span> ${locale === 'en' ? 'Bundle Deal Organizer' : 'બંડલ ડીલ ઓર્ગેનાઇઝર'}
        </h3>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-secondary/10 text-secondary border border-secondary/20 font-mono">
          ${locale === 'en' ? `Eligible Items: ${eligibleQty}` : `લાયક આઇટમ્સ: ${eligibleQty}`}
        </span>
      </div>

      <!-- Progress Tip -->
      <p class="text-xs text-neutral-600 font-medium leading-relaxed">
        ${progressTip}
      </p>

      <!-- Progress Bar -->
      <div class="relative w-full h-3 bg-neutral-100 rounded-full overflow-hidden border border-neutral-200">
        <div class="h-full bg-gradient-to-r from-secondary to-primary transition-all duration-500" style="width: ${progressPercentage}%"></div>
      </div>

      <!-- Milestones list -->
      <div class="space-y-2 pt-2">
        ${rulesListHtml}
      </div>

      <!-- Relevant Products Section -->
      ${relevantProductsSectionHtml}
    `;
  }

  window.recalculateTotals = function () {
    const cart = getCart();
    const subtotal = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
    
    // 1. Calculate coupon discount
    let couponDiscount = 0;
    const couponRow = document.getElementById('coupon-discount-row');
    const couponLabel = document.getElementById('applied-coupon-label');
    const couponVal = document.getElementById('coupon-discount-value');
    const couponHiddenInput = document.getElementById('coupon-code-input');

    if (activeCoupon) {
      if (activeCoupon.minOrderValue && subtotal < activeCoupon.minOrderValue) {
        const errEl = document.getElementById('coupon-error');
        const succEl = document.getElementById('coupon-success');
        if (errEl) {
          errEl.textContent = locale === 'en'
            ? `Minimum order value of ₹${activeCoupon.minOrderValue} required for this coupon.`
            : `આ કૂપન માટે ન્યૂનતમ ₹${activeCoupon.minOrderValue} નો ઓર્ડર જરૂરી છે.`;
          errEl.classList.remove('hidden');
        }
        if (succEl) succEl.classList.add('hidden');
        couponDiscount = 0;
        if (couponRow) couponRow.classList.add('hidden');
        if (couponHiddenInput) couponHiddenInput.value = '';
      } else {
        const errEl = document.getElementById('coupon-error');
        const succEl = document.getElementById('coupon-success');
        if (errEl && errEl.textContent.includes(locale === 'en' ? 'Minimum order' : 'ન્યૂનતમ')) {
          errEl.classList.add('hidden');
        }
        if (succEl && activeCoupon.code) {
          succEl.textContent = locale === 'en' 
            ? `Coupon ${activeCoupon.code} applied successfully!` 
            : `કૂપન ${activeCoupon.code} સફળતાપૂર્વક લાગુ થઈ!`;
          succEl.classList.remove('hidden');
        }

        if (activeCoupon.discountType === 'percentage') {
          couponDiscount = Math.round(subtotal * (activeCoupon.discountValue / 100));
          if (activeCoupon.discountCap && couponDiscount > activeCoupon.discountCap) {
            couponDiscount = activeCoupon.discountCap;
          }
        } else {
          couponDiscount = activeCoupon.discountValue;
        }
        couponDiscount = Math.min(couponDiscount, subtotal);
        
        if (couponLabel) couponLabel.textContent = activeCoupon.code;
        if (couponVal) couponVal.textContent = `-₹` + couponDiscount.toLocaleString('en-IN');
        if (couponRow) couponRow.classList.remove('hidden');
        if (couponHiddenInput) couponHiddenInput.value = activeCoupon.code;
      }
    } else {
      if (couponRow) couponRow.classList.add('hidden');
      if (couponHiddenInput) couponHiddenInput.value = '';
    }

    // 2. Calculate bundle discount
    let bundleDiscount = 0;
    let appliedBundleRuleId = '';
    let appliedBundleRewardGiven = '';
    
    let eligibleQty = 0;
    cart.forEach(item => {
      if (item.eligibleForBundle) {
        eligibleQty += item.quantity;
      }
    });

    const bundleRow = document.getElementById('bundle-discount-row');
    const bundleLabel = document.getElementById('applied-bundle-label');
    const bundleVal = document.getElementById('bundle-discount-value');
    const bundleDesc = document.getElementById('bundle-reward-desc');
    const bundleRuleInput = document.getElementById('bundle-rule-input');
    const bundleDiscountInput = document.getElementById('bundle-discount-input');
    const bundleRewardInput = document.getElementById('bundle-reward-input');

    if (eligibleQty > 0 && bundleRulesList && bundleRulesList.length > 0) {
      const sortedRules = [...bundleRulesList].sort((a, b) => b.minQuantity - a.minQuantity);
      const matchedRule = sortedRules.find(r => eligibleQty >= r.minQuantity);
      
      if (matchedRule) {
        appliedBundleRuleId = matchedRule.id;
        
        if (matchedRule.rewardType === 'percentage_discount') {
          bundleDiscount = Math.round(subtotal * (matchedRule.rewardValue / 100));
        } else if (matchedRule.rewardType === 'flat_discount') {
          bundleDiscount = matchedRule.rewardValue;
        } else {
          appliedBundleRewardGiven = matchedRule.rewardDescription;
        }
        
        bundleDiscount = Math.min(bundleDiscount, subtotal - couponDiscount);
        
        if (bundleLabel) bundleLabel.textContent = matchedRule.name;
        if (bundleVal) {
          bundleVal.textContent = bundleDiscount > 0 ? `-₹${bundleDiscount.toLocaleString('en-IN')}` : 'FREE';
        }
        if (bundleDesc) bundleDesc.textContent = matchedRule.rewardDescription;
        if (bundleRow) bundleRow.classList.remove('hidden');
      } else {
        if (bundleRow) bundleRow.classList.add('hidden');
      }
    } else {
      if (bundleRow) bundleRow.classList.add('hidden');
    }

    if (bundleRuleInput) bundleRuleInput.value = appliedBundleRuleId;
    if (bundleDiscountInput) bundleDiscountInput.value = bundleDiscount.toString();
    if (bundleRewardInput) bundleRewardInput.value = appliedBundleRewardGiven;

    // 3. Calculate points discount
    const pointsField = document.getElementById('points-redeem-field');
    let pointsToRedeem = pointsField ? parseInt(pointsField.value, 10) : 0;
    if (isNaN(pointsToRedeem) || pointsToRedeem < 0) pointsToRedeem = 0;

    const maxUsablePoints = Math.min(userCredits, subtotal - couponDiscount - bundleDiscount);
    if (pointsToRedeem > maxUsablePoints) {
      pointsToRedeem = maxUsablePoints;
      if (pointsField) pointsField.value = pointsToRedeem;
    }

    const pointsRow = document.getElementById('points-discount-row');
    const pointsVal = document.getElementById('points-discount-value');
    const pointsHiddenInput = document.getElementById('redeem-points-input');

    if (pointsToRedeem > 0) {
      if (pointsVal) pointsVal.textContent = `-₹` + pointsToRedeem.toLocaleString('en-IN');
      if (pointsRow) pointsRow.classList.remove('hidden');
      if (pointsHiddenInput) pointsHiddenInput.value = pointsToRedeem.toString();
    } else {
      if (pointsRow) pointsRow.classList.add('hidden');
      if (pointsHiddenInput) pointsHiddenInput.value = '0';
    }

    const finalTotal = subtotal - couponDiscount - bundleDiscount - pointsToRedeem;

    // Update UI elements
    const subtotalEl = document.getElementById('cart-subtotal');
    const totalEl = document.getElementById('cart-final-total');
    
    if (subtotalEl) subtotalEl.textContent = '₹' + subtotal.toLocaleString('en-IN');
    if (totalEl) totalEl.textContent = '₹' + finalTotal.toLocaleString('en-IN');

    // Populate checkout form hidden value for items
    const itemsInput = document.getElementById('cart-items-input');
    if (itemsInput) itemsInput.value = JSON.stringify(cart);

    // Render bundle deal organizer progress and product recommendations
    renderBundleOrganizer(cart, eligibleQty, subtotal);
  };

  // Render on mount
  renderCart();

  // Clear cart if checkout succeeded
  if (successOrderId) {
    localStorage.removeItem(CART_KEY);
    window.dispatchEvent(new CustomEvent('cart-updated'));
  }
</script>
