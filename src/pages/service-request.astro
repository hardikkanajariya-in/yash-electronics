---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { getSessionUser } from '../lib/auth';
import { getLocalizedPath } from '../lib/translations';
import { db } from '../db';
import { serviceRequests } from '../db/schema';
import { generateId } from '../lib/auth';

export const prerender = false;

const locale = Astro.currentLocale || 'gu';

// Authenticate user (optional)
Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
const currentUser = await getSessionUser(Astro.cookies);

let success = Astro.url.searchParams.get('success') === 'true';
let error = Astro.url.searchParams.get('error') || '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const customerName = currentUser ? currentUser.name : (formData.get('customerName')?.toString().trim() || '');
    const customerPhone = currentUser ? currentUser.phone : (formData.get('customerPhone')?.toString().trim() || '');
    const address = formData.get('address')?.toString().trim() || '';
    const pincode = formData.get('pincode')?.toString().trim() || '';
    const village = formData.get('village')?.toString().trim() || '';
    const productCategory = formData.get('productCategory')?.toString().trim() || '';
    const brandName = formData.get('brandName')?.toString().trim() || '';
    const modelNumber = formData.get('modelNumber')?.toString().trim() || '';
    const fault = formData.get('fault')?.toString().trim() || '';

    if (!customerName || !customerPhone || !address || !pincode || !village || !productCategory || !brandName || !fault) {
      error = locale === 'en' ? 'All required fields must be filled.' : 'બધી ફરજિયાત વિગતો ભરવી જરૂરી છે.';
    } else {
      const productName = `${brandName} ${modelNumber}`.trim();
      const complaintDetails = fault;

      await db.insert(serviceRequests).values({
        id: generateId(),
        userId: currentUser?.id || null,
        customerName,
        customerPhone,
        productName,
        complaintDetails,
        address,
        pincode,
        village,
        productCategory,
        brandName,
        modelNumber: modelNumber || null,
        fault,
        status: 'pending',
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString(),
      });
      return Astro.redirect(Astro.url.pathname + '?success=true');
    }
  } catch (e) {
    console.error('[Service Request Submit Error]:', e);
    error = locale === 'en' ? 'Something went wrong. Please try again.' : 'કંઈક ખોટું થયું. કૃપા કરીને ફરી પ્રયાસ કરો.';
  }
}

// Translations for page elements
const translations = {
  gu: {
    title: 'નવી સર્વિસ રિક્વેસ્ટ (SR)',
    subtitle: 'તમારી પ્રોડક્ટ સંબંધિત ફરિયાદ અહીં નોંધાવો. અમારી ટીમ ટૂંક સમયમાં તમારો સંપર્ક કરશે.',
    customerName: 'ગ્રાહકનું નામ *',
    customerPhone: 'મોબાઇલ નંબર *',
    namePlaceholder: 'તમારું પૂરું નામ લખો',
    phonePlaceholder: '૧૦ અંકનો મોબાઇલ નંબર લખો',
    address: 'સરનામું *',
    addressPlaceholder: 'તમારું પૂરું સરનામું લખો',
    pincode: 'પિનકોડ *',
    pincodePlaceholder: '૬ અંકનો પિનકોડ લખો',
    village: 'ગામ/શહેર *',
    villagePlaceholder: 'તમારા ગામ અથવા શહેરનું નામ લખો',
    productCategory: 'પ્રોડક્ટ કેટેગરી *',
    productCategoryPlaceholder: 'દા.ત. ઇન્વર્ટર, બેટરી, સોલાર',
    brandName: 'બ્રાન્ડનું નામ *',
    brandNamePlaceholder: 'દા.ત. લ્યુમિનસ, એકસાઇડ, માઇક્રોટેક',
    modelNumber: 'મોડલ નંબર (વૈકલ્પિક)',
    modelNumberPlaceholder: 'દા.ત. Zelio+ 1100',
    fault: 'સમસ્યા / ખામી (Fault) *',
    faultPlaceholder: 'કૃપા કરીને સમસ્યા વિશે વિગતવાર લખો (દા.ત. બેકઅપ નથી આપતું)',
    submit: 'ફરિયાદ નોંધાવો',
    backToAccount: '← મારા ખાતા પર પાછા જાઓ',
    successMsg: 'તમારી ફરિયાદ સફળતાપૂર્વક નોંધાઈ ગઈ છે! તમે તમારા ખાતાના પેજ પર આને ટ્રેક કરી શકો છો.',
  },
  en: {
    title: 'New Service Request (SR)',
    subtitle: 'File a complaint regarding your product here. Our team will contact you shortly.',
    customerName: 'Customer Name *',
    customerPhone: 'Mobile Number *',
    namePlaceholder: 'Enter your full name',
    phonePlaceholder: 'Enter 10-digit mobile number',
    address: 'Address *',
    addressPlaceholder: 'Enter your full shipping address',
    pincode: 'Pincode *',
    pincodePlaceholder: 'Enter 6-digit pincode',
    village: 'Village / City *',
    villagePlaceholder: 'Enter village or city name',
    productCategory: 'Product Category *',
    productCategoryPlaceholder: 'e.g. Inverter, Battery, Solar',
    brandName: 'Brand Name *',
    brandNamePlaceholder: 'e.g. Luminous, Exide, Microtek',
    modelNumber: 'Model Number (Optional)',
    modelNumberPlaceholder: 'e.g. Zelio+ 1100',
    fault: 'Fault / Issue *',
    faultPlaceholder: 'Please describe the issue in detail (e.g. no backup, making noise)',
    submit: 'Submit Request',
    backToAccount: '← Back to My Account',
    successMsg: 'Your service request has been successfully submitted! You can track it in your account panel.',
  }
};

const pageT = translations[locale === 'en' ? 'en' : 'gu'];
---

<BaseLayout title={pageT.title} noindex={true}>
  <Container class="py-12 max-w-xl">
    <div class="mb-6">
      <a href={currentUser ? getLocalizedPath('/account', locale) : getLocalizedPath('/', locale)} class="text-sm text-primary hover:underline font-semibold">
        {currentUser ? pageT.backToAccount : (locale === 'en' ? '← Back to Home' : '← હોમ પેજ પર પાછા જાઓ')}
      </a>
    </div>

    <div class="bg-white border border-neutral-200 rounded-xl p-6 md:p-8 shadow-md">
      <div class="border-b border-neutral-100 pb-4 mb-6">
        <h1 class="text-2xl font-bold text-neutral-900">{pageT.title}</h1>
        <p class="text-xs text-neutral-500 mt-1">{pageT.subtitle}</p>
      </div>

      {success && (
        <div class="bg-green-50 border border-green-200 text-green-800 text-sm rounded-lg p-4 mb-6 flex items-start gap-2">
          <span class="text-lg">✓</span>
          <div>
            <p class="font-semibold">{locale === 'en' ? 'Success' : 'સફળતા'}</p>
            <p class="text-xs mt-0.5">{pageT.successMsg}</p>
            {currentUser && (
              <a href={getLocalizedPath('/account', locale)} class="mt-2 inline-block text-xs font-bold underline text-green-900 hover:text-green-950">
                {locale === 'en' ? 'View status in My Account' : 'મારા ખાતામાં સ્થિતિ જુઓ'} →
              </a>
            )}
          </div>
        </div>
      )}

      {error && (
        <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg p-4 mb-6 flex items-start gap-2">
          <span class="text-lg">⚠</span>
          <div>
            <p class="font-semibold">{locale === 'en' ? 'Error' : 'ભૂલ'}</p>
            <p class="text-xs mt-0.5">{error}</p>
          </div>
        </div>
      )}

      {!success && (
        <form method="post" class="space-y-5">
          {!currentUser && (
            <>
              <div>
                <label for="customerName" class="block text-sm font-semibold text-neutral-700 mb-1">
                  {pageT.customerName}
                </label>
                <input
                  type="text"
                  id="customerName"
                  name="customerName"
                  required
                  placeholder={pageT.namePlaceholder}
                  class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
                />
              </div>

              <div>
                <label for="customerPhone" class="block text-sm font-semibold text-neutral-700 mb-1">
                  {pageT.customerPhone}
                </label>
                <input
                  type="tel"
                  id="customerPhone"
                  name="customerPhone"
                  required
                  pattern="[0-9]{10}"
                  placeholder={pageT.phonePlaceholder}
                  class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
                />
              </div>
            </>
          )}

          <div>
            <label for="address" class="block text-sm font-semibold text-neutral-700 mb-1">
              {pageT.address}
            </label>
            <textarea
              id="address"
              name="address"
              required
              rows="2"
              placeholder={pageT.addressPlaceholder}
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
            ></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="village" class="block text-sm font-semibold text-neutral-700 mb-1">
                {pageT.village}
              </label>
              <input
                type="text"
                id="village"
                name="village"
                required
                placeholder={pageT.villagePlaceholder}
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
              />
            </div>
            <div>
              <label for="pincode" class="block text-sm font-semibold text-neutral-700 mb-1">
                {pageT.pincode}
              </label>
              <input
                type="text"
                id="pincode"
                name="pincode"
                required
                pattern="[0-9]{6}"
                placeholder={pageT.pincodePlaceholder}
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
              />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="productCategory" class="block text-sm font-semibold text-neutral-700 mb-1">
                {pageT.productCategory}
              </label>
              <input
                type="text"
                id="productCategory"
                name="productCategory"
                required
                placeholder={pageT.productCategoryPlaceholder}
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
              />
            </div>
            <div>
              <label for="brandName" class="block text-sm font-semibold text-neutral-700 mb-1">
                {pageT.brandName}
              </label>
              <input
                type="text"
                id="brandName"
                name="brandName"
                required
                placeholder={pageT.brandNamePlaceholder}
                class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
              />
            </div>
          </div>

          <div>
            <label for="modelNumber" class="block text-sm font-semibold text-neutral-700 mb-1">
              {pageT.modelNumber}
            </label>
            <input
              type="text"
              id="modelNumber"
              name="modelNumber"
              placeholder={pageT.modelNumberPlaceholder}
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
            />
          </div>

          <div>
            <label for="fault" class="block text-sm font-semibold text-neutral-700 mb-1">
              {pageT.fault}
            </label>
            <textarea
              id="fault"
              name="fault"
              required
              rows="4"
              placeholder={pageT.faultPlaceholder}
              class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-shadow"
            ></textarea>
          </div>

          <button type="submit" class="w-full btn-primary py-3 text-sm font-semibold shadow-sm transition-all hover:shadow">
            {pageT.submit}
          </button>
        </form>
      )}
    </div>
  </Container>
</BaseLayout>
