---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/home/ContactSection.astro';
import Container from '../components/ui/Container.astro';
import { getSettings } from '../services/cms';
import { translateObject, t } from '../lib/translations';
import { db } from '../db';
import { contactQueries, notifications } from '../db/schema';
import { generateId } from '../lib/auth';
import { triggerPushNotification } from '../services/push';

export const prerender = false;

const locale = Astro.currentLocale || 'gu';
const rawSettings = await getSettings();
const settings = translateObject(rawSettings, locale);

let success = Astro.url.searchParams.get('success') === 'true';
let error = Astro.url.searchParams.get('error') || '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const name = formData.get('name')?.toString().trim() || '';
    const phone = formData.get('phone')?.toString().trim() || '';
    const email = formData.get('email')?.toString().trim() || '';
    const message = formData.get('message')?.toString().trim() || '';

    if (!name || !phone || !message) {
      error = locale === 'en' ? 'Please fill in all required fields.' : 'કૃપા કરીને બધી જરૂરી વિગતો ભરો.';
    } else {
      const queryId = generateId();
      await db.insert(contactQueries).values({
        id: queryId,
        name,
        phone,
        email: email || null,
        message,
        status: 'unread',
        createdAt: new Date().toISOString(),
      });

      // Track notification and dispatch web push
      try {
        await db.insert(notifications).values({
          id: generateId(),
          type: 'contact',
          title: 'New Contact Request',
          message: `Inquiry from ${name} (${phone})`,
          referenceId: queryId,
          isRead: false,
          createdAt: new Date().toISOString(),
        });
        triggerPushNotification(
          'New Contact Request',
          `Inquiry from ${name} (${phone})`,
          '/admin/queries'
        );
      } catch (notifErr) {
        console.error('[Contact Notification Error]:', notifErr);
      }

      return Astro.redirect(Astro.url.pathname + '?success=true');
    }
  } catch (e) {
    console.error('[Contact Submit Error]:', e);
    error = locale === 'en' ? 'Failed to submit inquiry. Please try again.' : 'સંદેશો મોકલવામાં નિષ્ફળતા. કૃપા કરીને ફરી પ્રયાસ કરો.';
  }
}
---

<BaseLayout
  title={t('contact.contactUs', locale)}
  description={`Contact ${settings.businessName} for product enquiries, pricing and store directions.`}
  canonicalUrl="/contact"
>
  <ContactSection settings={settings} success={success} error={error} />
  
  <div class="pb-16 bg-neutral-50">
    <Container>
      <div class="overflow-hidden rounded-2xl border border-neutral-200 shadow-sm relative h-[400px] w-full bg-white p-2">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2909.917727789059!2d69.6535241!3d22.2054469!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3956fd744aa61b5f%3A0x43393887f7fc9b14!2sYash%20Electronics%20-%20Samsung%2520Exclusive!5e1!3m2!1sen!2sin!4v1782389161261!5m2!1sen!2sin" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="strict-origin-when-cross-origin" 
          class="rounded-xl w-full h-full shadow-inner"
        ></iframe>
      </div>
    </Container>
  </div>
</BaseLayout>
