---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import { getSettings } from "../../services/cms";
import { translateObject } from "../../lib/translations";

export const prerender = false;

const locale = Astro.currentLocale || "gu";

const rawSettings = await getSettings();
const settingsObj = translateObject(rawSettings, locale);

const phone = settingsObj.phone || "";
const whatsapp = settingsObj.whatsapp || "";
const businessName = settingsObj.businessName || "Yash Electronics";

const translations = {
  gu: {
    title: "પાસવર્ડ ભૂલી ગયા છો?",
    subtitle: "પાસવર્ડ રીસેટ માટે સહાય",
    desc: "સુરક્ષા કારણોસર, પાસવર્ડ રીસેટ અમારા એડમિનિસ્ટ્રેટર દ્વારા મેન્યુઅલી કરવામાં આવે છે. કૃપા કરીને નીચે તમારો ફોન નંબર દાખલ કરી એડમિનને વિનંતી મોકલો.",
    phoneLabel: "તમારો રજીસ્ટર્ડ ફોન નંબર",
    phonePlaceholder: "દા.ત. 9999999999",
    whatsappBtn: "વોટ્સએપ દ્વારા વિનંતી મોકલો",
    callBtn: "એડમિનને ડાયરેક્ટ કોલ કરો",
    orText: "અથવા",
    backToLogin: "લોગિન પેજ પર પાછા જાઓ",
    phoneError: "કૃપા કરીને તમારો રજીસ્ટર કરેલ ફોન નંબર દાખલ કરો.",
  },
  en: {
    title: "Forgot Password?",
    subtitle: "Password Reset Guide",
    desc: "For security purposes, password resets are processed manually by the store administrator. Please enter your registered phone number below to send a request.",
    phoneLabel: "Registered Phone Number",
    phonePlaceholder: "e.g. 9999999999",
    whatsappBtn: "Request via WhatsApp",
    callBtn: "Call Administrator",
    orText: "or",
    backToLogin: "Back to Login",
    phoneError: "Please enter your registered phone number.",
  },
};

const t = translations[locale === "en" ? "en" : "gu"];
---

<BaseLayout title={`${businessName} - ${t.title}`} noindex={true}>
  <Container class="py-16 max-w-md">
    <div
      class="bg-white border border-neutral-200 rounded-2xl p-8 shadow-lg space-y-6 relative overflow-hidden"
    >
      <!-- Top Decorative Accent -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-primary to-emerald-500"
      >
      </div>

      <!-- Icon & Heading -->
      <div class="text-center space-y-2">
        <div
          class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto text-primary text-2xl animate-pulse"
        >
          🔑
        </div>
        <h2 class="text-xl font-extrabold text-neutral-900 tracking-tight">
          {t.title}
        </h2>
        <p
          class="text-xs text-neutral-400 font-semibold uppercase tracking-wider"
        >
          {t.subtitle}
        </p>
      </div>

      <!-- Instruction Text -->
      <p
        class="text-neutral-600 text-xs leading-relaxed text-center bg-neutral-50 rounded-xl p-4 border border-neutral-100"
      >
        {t.desc}
      </p>

      <!-- Input and CTA Buttons -->
      <div class="space-y-4">
        <div>
          <label
            for="forgot-phone"
            class="block text-xs font-bold text-neutral-700 mb-1.5"
            >{t.phoneLabel} *</label
          >
          <input
            type="tel"
            id="forgot-phone"
            required
            placeholder={t.phonePlaceholder}
            class="w-full rounded-lg border border-neutral-300 px-4 py-2.5 text-sm font-mono focus:border-primary focus:outline-none transition-shadow focus:ring-2 focus:ring-primary/20"
          />
        </div>

        <div class="space-y-2.5 pt-2">
          <!-- WhatsApp Request Button -->
          <button
            id="whatsapp-btn"
            data-whatsapp={whatsapp}
            data-storename={businessName}
            class="flex items-center justify-center gap-2.5 w-full bg-[#25D366] hover:bg-[#20ba5a] text-white text-sm font-extrabold rounded-lg px-4 py-3 transition-all duration-150 active:scale-[0.98] shadow-md shadow-emerald-500/10 cursor-pointer text-center select-none"
          >
            <svg class="h-5 w-5 fill-current shrink-0" viewBox="0 0 24 24">
              <path
                d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.394 9.806-9.799.002-2.618-1.01-5.078-2.856-6.927C16.378 2.03 13.932.997 12.002.997c-5.408 0-9.813 4.394-9.816 9.801-.001 1.87.526 3.69 1.523 5.253L2.7 20.8l4.037-1.059.043-.027-.133-.56zm11.233-5.062c-.295-.148-1.746-.862-2.019-.962-.272-.1-.471-.148-.669.148-.198.295-.767.962-.94 1.16-.173.199-.347.223-.642.074-.295-.148-1.246-.459-2.373-1.464-.877-.782-1.47-1.747-1.642-2.043-.173-.295-.018-.454.13-.601.134-.133.295-.347.444-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.74-.71 1.988-1.396.248-.687.248-1.277.173-1.396-.074-.12-.272-.198-.57-.347z"
              ></path>
            </svg>
            <span>{t.whatsappBtn}</span>
          </button>

          <!-- Divider -->
          <div
            class="flex items-center justify-center gap-3 py-1.5 text-xs text-neutral-400 font-bold uppercase select-none"
          >
            <span class="h-px bg-neutral-200 flex-1"></span>
            <span>{t.orText}</span>
            <span class="h-px bg-neutral-200 flex-1"></span>
          </div>

          <!-- Phone Call Button -->
          <a
            href={`tel:${phone}`}
            class="flex items-center justify-center gap-2.5 w-full border border-neutral-300 hover:bg-neutral-50 text-neutral-800 text-sm font-extrabold rounded-lg px-4 py-3 transition-colors active:scale-[0.98] cursor-pointer text-center select-none"
          >
            <span>📞</span>
            <span>{t.callBtn}</span>
          </a>
        </div>
      </div>

      <!-- Navigation Footer -->
      <div class="text-center pt-4 border-t border-neutral-100">
        <a
          href={locale === "en" ? "/en/account/login" : "/account/login"}
          class="text-xs text-primary hover:underline font-bold transition-all"
        >
          ← {t.backToLogin}
        </a>
      </div>
    </div>
  </Container>
</BaseLayout>

<script is:inline define:vars={{ errorText: t.phoneError }}>
  document
    .getElementById("whatsapp-btn")
    ?.addEventListener("click", function (e) {
      const phoneInput = document.getElementById("forgot-phone");
      const userPhone = phoneInput ? phoneInput.value.trim() : "";
      if (!userPhone) {
        alert(errorText);
        e.preventDefault();
        return;
      }
      const adminWhatsapp = this.dataset.whatsapp;
      const storeName = this.dataset.storename;
      const isEn = document.documentElement.lang === "en";
      const textMsg = isEn
        ? `Hello, I forgot my password for ${storeName}. Please reset my password.\nMy registered phone number is: ${userPhone}`
        : `નમસ્તે, હું ${storeName} માટે મારો પાસવર્ડ ભૂલી ગયો છું. કૃપા કરીને મારો પાસવર્ડ રીસેટ કરો.\nમારો રજીસ્ટર કરેલ ફોન નંબર છે: ${userPhone}`;

      window.open(
        `https://wa.me/${adminWhatsapp}?text=${encodeURIComponent(textMsg)}`,
        "_blank",
      );
    });
</script>
