# Site
PUBLIC_SITE_URL=https://yashelectronics.in

# Google Apps Script API (deploy Code.gs and paste the web app URL)
SHEETS_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
SHEETS_API_KEY=your-secret-api-key

# Set to true only for local preview without CMS connected
USE_MOCK_DATA=false

# Cloudinary
PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
